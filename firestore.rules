rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.type == "admin";
    }

    // Users: any authenticated user can read, owner can write (but cannot change own type), admin can do anything
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.type == "user";
      allow update: if request.auth != null
        && ((request.auth.uid == userId && request.resource.data.type == resource.data.get('type', 'user'))
            || isAdmin());
      allow delete: if isAdmin();
    }

    // Favorites: user can read/write own favorites subcollection
    match /users/{userId}/favorites/{boatId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Boats: published read, owner/admin read all, owner write, admin can update/delete any
    match /boats/{boatId} {
      allow read: if resource.data.status == "published"
        || (request.auth != null && request.auth.uid == resource.data.ownerId)
        || isAdmin();
      allow create: if request.auth != null
        && request.resource.data.status == "draft"
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null
        && (request.auth.uid == resource.data.ownerId || isAdmin());
    }

    // Destinations: public read, admin write
    match /destinations/{destId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // Reviews: public read, authenticated create with validation, author can edit/delete
    // S3: Validate rating 1-5, comment length, userId matches auth
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.comment is string
        && request.resource.data.comment.size() <= 2000
        && request.resource.data.boatId is string;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.userId
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.comment is string
        && request.resource.data.comment.size() <= 2000;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    // Articles: public read, admin write
    match /articles/{articleId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // Subscribers: validated create, admin read
    // M13: Require email field and limit document size to prevent spam
    match /subscribers/{subscriberId} {
      allow create: if request.resource.data.keys().hasOnly(["email", "createdAt"])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 5
        && request.resource.data.email.size() < 255;
      allow read: if request.auth != null && isAdmin();
    }

    // Orders: participants + admin; creator must be the renter
    // S2: Restrict update — participants can only change status, admin can change anything
    match /orders/{orderId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.renterId
            || request.auth.uid == resource.data.ownerId || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.renterId == request.auth.uid
        && request.resource.data.totalPrice > 0;
      allow update: if request.auth != null
        && (isAdmin()
            || ((request.auth.uid == resource.data.renterId
                 || request.auth.uid == resource.data.ownerId)
                && request.resource.data.diff(resource.data).affectedKeys()
                    .hasOnly(["status", "updatedAt"])));
      allow delete: if isAdmin();
    }

    // Settings: public charges readable by authenticated users, other settings admin-only
    // S7: Only expose the charges document publicly; internal settings are admin-only
    match /settings/charges {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
    match /settings/{settingId} {
      allow read: if request.auth != null && isAdmin();
      allow write: if request.auth != null && isAdmin();
    }

    // Conversations: participants only
    match /conversations/{conversationId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          && request.auth.uid == request.resource.data.senderId;
      }
    }
  }
}
