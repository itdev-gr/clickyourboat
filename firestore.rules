rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: owner read/write own doc, admin can read all
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
        && (!("type" in request.resource.data) || request.resource.data.type == resource.data.type);
      allow read: if request.auth != null && request.auth.token.admin == true;
    }

    // Boats: public read, owner write
    match /boats/{boatId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.ownerId;
    }

    // Destinations: public read, admin write
    match /destinations/{destId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.admin == true;
    }

    // Reviews: public read, authenticated write
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    // Articles: public read, admin write
    match /articles/{articleId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.admin == true;
    }

    // Subscribers: public write, admin read
    match /subscribers/{subscriberId} {
      allow create: if true;
      allow read: if request.auth != null
        && request.auth.token.admin == true;
    }
  }
}
