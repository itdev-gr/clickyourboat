rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.type == "admin";
    }

    // Users: any authenticated user can read, owner can write (but cannot change own type), admin can do anything
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.type == "user";
      allow update: if request.auth != null
        && ((request.auth.uid == userId && request.resource.data.type == resource.data.get('type', 'user'))
            || isAdmin());
      allow delete: if isAdmin();
    }

    // Favorites: user can read/write own favorites subcollection
    match /users/{userId}/favorites/{boatId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Boats: published read, owner/admin read all, owner write, admin can update/delete any
    match /boats/{boatId} {
      allow read: if resource.data.status == "published"
        || (request.auth != null && request.auth.uid == resource.data.ownerId)
        || isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && (request.auth.uid == resource.data.ownerId || isAdmin());
    }

    // Destinations: public read, admin write
    match /destinations/{destId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // Reviews: public read, authenticated write
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    // Articles: public read, admin write
    match /articles/{articleId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // Subscribers: public write, admin read
    match /subscribers/{subscriberId} {
      allow create: if true;
      allow read: if request.auth != null && isAdmin();
    }

    // Orders: participants + admin
    match /orders/{orderId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.renterId
            || request.auth.uid == resource.data.ownerId || isAdmin());
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.renterId
            || request.auth.uid == resource.data.ownerId
            || isAdmin());
      allow delete: if isAdmin();
    }

    // Settings: authenticated read, admin write
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // Conversations: participants only
    match /conversations/{conversationId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          && request.auth.uid == request.resource.data.senderId;
      }
    }
  }
}
