---
import Layout from "../../layouts/Layout.astro";
import { formatDate } from "../../lib/utils";
import { mockArticles } from "../../lib/mock-data";

// Try Firestore first, fall back to mock data
let articles = mockArticles;
try {
  const { getLatestArticles } = await import("../../lib/api");
  const firestoreArticles = await getLatestArticles(20);
  if (firestoreArticles.length > 0) {
    articles = firestoreArticles;
  }
} catch {
  // Firestore unavailable — use mock data
}

const title = "Blog — BoatHaven";
const description = "Tips, guides, and stories from the sea. Discover sailing destinations, boat rental advice, and maritime adventures.";
---

<Layout title={title} description={description}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-3xl sm:text-4xl font-extrabold text-text mb-3">From the Blog</h1>
      <p class="text-lg text-text-muted max-w-2xl mx-auto">
        Tips, guides, and stories from the sea
      </p>
    </div>

    <!-- Featured article (first) -->
    {articles.length > 0 && (
      <a href={`/blog/${articles[0].slug}`} class="group block mb-12">
        <article class="bg-white rounded-2xl overflow-hidden border border-gray-100 hover:shadow-lg transition-shadow lg:flex">
          <div class="lg:w-1/2 aspect-[16/9] lg:aspect-auto overflow-hidden">
            <img
              src={articles[0].image}
              alt={articles[0].title}
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="eager"
            />
          </div>
          <div class="lg:w-1/2 p-6 sm:p-8 lg:p-10 flex flex-col justify-center">
            <span class="inline-block px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-semibold mb-4 w-fit">Featured</span>
            <time class="text-sm text-text-muted font-medium" datetime={articles[0].createdAt?.toISOString?.() ?? ""}>
              {articles[0].createdAt ? formatDate(articles[0].createdAt) : ""}
            </time>
            <h2 class="mt-2 text-2xl sm:text-3xl font-bold text-text group-hover:text-primary transition-colors">
              {articles[0].title}
            </h2>
            <p class="mt-3 text-text-muted leading-relaxed">
              {articles[0].summary}
            </p>
            <div class="mt-6 flex items-center gap-1 text-sm font-semibold text-primary group-hover:gap-2 transition-all">
              Read article
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </div>
          </div>
        </article>
      </a>
    )}

    <!-- Article grid -->
    {articles.length > 1 && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {articles.slice(1).map((article) => (
          <a href={`/blog/${article.slug}`} class="group block">
            <article class="bg-white rounded-xl overflow-hidden border border-gray-100 hover:shadow-lg transition-shadow h-full flex flex-col">
              <div class="aspect-[16/9] overflow-hidden">
                <img
                  src={article.image}
                  alt={article.title}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <div class="p-5 flex flex-col flex-1">
                <time class="text-xs text-text-muted font-medium" datetime={article.createdAt?.toISOString?.() ?? ""}>
                  {article.createdAt ? formatDate(article.createdAt) : ""}
                </time>
                <h3 class="mt-2 text-lg font-bold text-text group-hover:text-primary transition-colors line-clamp-2">
                  {article.title}
                </h3>
                <p class="mt-2 text-sm text-text-muted line-clamp-2 flex-1">
                  {article.summary}
                </p>
                <div class="mt-4 flex items-center gap-1 text-sm font-semibold text-primary group-hover:gap-2 transition-all">
                  Read more
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
                </div>
              </div>
            </article>
          </a>
        ))}
      </div>
    )}

    {articles.length === 0 && (
      <div class="text-center py-16">
        <p class="text-text-muted text-lg">No articles yet. Check back soon!</p>
      </div>
    )}
  </div>
</Layout>
