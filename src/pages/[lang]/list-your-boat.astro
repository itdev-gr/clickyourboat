---
import { getLangs, localizeHref } from "../../lib/i18n-utils";
export function getStaticPaths() { return getLangs(); }
const { lang } = Astro.params;
import Layout from "../../layouts/Layout.astro";

const title = "List Your Boat — BoatHaven";
const description = "List your boat on BoatHaven and start earning. Reach thousands of renters in 600+ destinations worldwide.";
const l = (href: string) => localizeHref(href, lang);
---
<Layout lang={lang} title={title} description={description}>
  <!-- Loading state -->
  <div id="auth-loading" class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <div class="h-8 w-8 border-2 border-primary border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
      <p class="text-sm text-text-muted">Loading...</p>
    </div>
  </div>

  <!-- Not logged in: Login prompt -->
  <div id="auth-gate" class="hidden">
    <div class="min-h-[60vh] flex items-center justify-center px-4 py-16">
      <div class="max-w-md w-full text-center">
        <div class="mx-auto mb-6 h-16 w-16 rounded-full bg-primary/10 flex items-center justify-center">
          <svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
        </div>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-text mb-3">Log in to list your boat</h1>
        <p class="text-text-muted mb-8 max-w-sm mx-auto">
          You need to be logged in to list your boat on BoatHaven. Sign in or create an account to get started.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a
            href={l("/login?redirect=/list-your-boat")}
            class="inline-flex items-center px-6 py-3 rounded-xl bg-primary text-white text-sm font-bold hover:bg-primary-dark transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
          >
            Log in
          </a>
          <a
            href={l("/login?signup&redirect=/list-your-boat")}
            class="inline-flex items-center px-6 py-3 rounded-xl border border-gray-200 text-sm font-bold text-text hover:bg-gray-50 transition-colors"
          >
            Create account
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Logged in: User's existing listings -->
  <div id="my-listings" class="hidden">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-bold text-text">My Listings</h1>
        <button
          type="button"
          id="add-new-listing-btn"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-primary text-white text-sm font-bold hover:bg-primary-dark transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          Add New Listing
        </button>
      </div>

      <!-- Filter tabs -->
      <div id="listings-tabs" class="hidden flex gap-2 mb-6">
        <button type="button" data-tab="all" class="listings-tab px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-primary text-white">All <span class="tab-count">(0)</span></button>
        <button type="button" data-tab="published" class="listings-tab px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-white text-gray-600 border border-gray-300 hover:bg-gray-50">Published <span class="tab-count">(0)</span></button>
        <button type="button" data-tab="pending" class="listings-tab px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-white text-gray-600 border border-gray-300 hover:bg-gray-50">Pending <span class="tab-count">(0)</span></button>
        <button type="button" data-tab="drafts" class="listings-tab px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-white text-gray-600 border border-gray-300 hover:bg-gray-50">Drafts <span class="tab-count">(0)</span></button>
      </div>

      <!-- Loading spinner -->
      <div id="listings-loading" class="flex items-center justify-center py-16">
        <div class="text-center">
          <div class="h-8 w-8 border-2 border-primary border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
          <p class="text-sm text-text-muted">Loading your listings...</p>
        </div>
      </div>

      <!-- Error banner -->
      <div id="listings-error" class="hidden rounded-xl border border-red-200 bg-red-50 p-6 text-center">
        <p class="text-sm text-red-700 mb-3">Failed to load your listings. Please try again.</p>
        <button type="button" id="listings-retry-btn" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-red-600 text-white text-sm font-medium hover:bg-red-700 transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"/></svg>
          Retry
        </button>
      </div>

      <!-- Listings grid -->
      <div id="listings-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 hidden"></div>
    </div>
  </div>

  <!-- Logged in: Boat listing form (Wizard) -->
  <div id="listing-form" class="hidden">
    <div class="flex min-h-[calc(100vh-64px)]">
      <!-- Sidebar -->
      <aside id="wizard-sidebar" class="hidden lg:flex flex-col w-[280px] bg-white border-r border-gray-200 shrink-0">
        <div class="p-6 border-b border-gray-200">
          <h2 class="text-lg font-bold text-pink">Ahoy there Captain!</h2>
          <p class="text-sm text-text-muted mt-1">Complete all sections to publish your listing</p>
          <div class="mt-4 h-2 bg-gray-100 rounded-full overflow-hidden">
            <div id="wizard-progress" class="h-full bg-pink rounded-full transition-all" style="width:0%"></div>
          </div>
          <p id="wizard-progress-text" class="text-xs text-text-muted mt-1">0 of 11 sections completed</p>
        </div>
        <nav class="flex-1 overflow-y-auto py-2" id="wizard-nav"></nav>
        <div class="p-6 border-t border-gray-200">
          <p class="text-xs text-text-muted">Need some help?</p>
          <p class="text-sm font-semibold text-text mt-1">+30 210 1234567</p>
        </div>
      </aside>

      <!-- Mobile section selector -->
      <div id="mobile-section-nav" class="lg:hidden sticky top-0 z-20 bg-white border-b border-gray-200">
        <button type="button" id="mobile-nav-toggle" class="w-full flex items-center justify-between px-4 py-3 text-sm font-semibold text-text">
          <span id="mobile-nav-label">General</span>
          <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div id="mobile-nav-drawer" class="hidden border-t border-gray-100 bg-white max-h-[60vh] overflow-y-auto" id="mobile-nav-list"></div>
      </div>

      <!-- Main content -->
      <main class="flex-1 bg-gray-50 overflow-y-auto">
        <!-- Top bar -->
        <div class="sticky top-0 z-10 bg-white border-b border-gray-200 px-4 sm:px-6 py-3 flex items-center justify-between">
          <button type="button" id="wizard-back-btn" class="inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:text-primary-dark transition-colors">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/></svg>
            Back
          </button>
          <div class="flex items-center gap-2">
            <button type="button" id="wizard-preview-btn" class="px-4 py-2 rounded-lg bg-gray-800 text-white text-sm font-medium hover:bg-gray-700 transition-colors">Preview</button>
            <button type="button" id="wizard-publish-btn" class="px-4 py-2 rounded-lg bg-pink text-white text-sm font-medium hover:opacity-90 transition-opacity">Publish</button>
          </div>
        </div>

        <!-- Content area -->
        <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8">

          <!-- ===== Section 1: General ===== -->
          <div id="wizard-section-general" class="wizard-section">
            <h2 class="text-xl font-bold text-text mb-6">General Information</h2>
            <div class="mb-8">
              <label class="block text-sm font-semibold text-text mb-4">Type <span class="text-red-500">*</span></label>
              <div class="flex flex-wrap gap-3" id="boat-type-grid">
                <button type="button" data-type="motorboat" class="boat-type-btn flex flex-col items-center justify-center w-[120px] h-[110px] rounded-xl border border-gray-200 hover:border-primary hover:bg-primary/5 transition-colors cursor-pointer">
                  <svg class="h-10 w-10 text-gray-500 mb-2" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><path d="M6 30c0 0 6-6 18-6s18 6 18 6" stroke-linecap="round"/><path d="M14 24l8-10h8l-4 10" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span class="text-xs font-medium text-text">Motorboat</span>
                </button>
                <button type="button" data-type="sailboat" class="boat-type-btn flex flex-col items-center justify-center w-[120px] h-[110px] rounded-xl border border-gray-200 hover:border-primary hover:bg-primary/5 transition-colors cursor-pointer">
                  <svg class="h-10 w-10 text-gray-500 mb-2" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><path d="M24 8v24" stroke-linecap="round"/><path d="M24 8L14 30h20L24 8z" stroke-linejoin="round"/><path d="M8 34c0 0 6-4 16-4s16 4 16 4" stroke-linecap="round"/></svg>
                  <span class="text-xs font-medium text-text">Sailboat</span>
                </button>
                <button type="button" data-type="rib" class="boat-type-btn flex flex-col items-center justify-center w-[120px] h-[110px] rounded-xl border border-gray-200 hover:border-primary hover:bg-primary/5 transition-colors cursor-pointer">
                  <svg class="h-10 w-10 text-gray-500 mb-2" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><path d="M6 28c2-4 8-6 18-6s16 2 18 6" stroke-linecap="round"/><path d="M16 22l4-6h8l4 6" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 32h32" stroke-linecap="round"/></svg>
                  <span class="text-xs font-medium text-text">RIB</span>
                </button>
                <button type="button" data-type="catamaran" class="boat-type-btn flex flex-col items-center justify-center w-[120px] h-[110px] rounded-xl border border-gray-200 hover:border-primary hover:bg-primary/5 transition-colors cursor-pointer">
                  <svg class="h-10 w-10 text-gray-500 mb-2" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><path d="M10 32l4-14h6l-2 14" stroke-linecap="round" stroke-linejoin="round"/><path d="M30 32l4-14h6l-2 14" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 28h32" stroke-linecap="round"/><path d="M12 32h24" stroke-linecap="round"/></svg>
                  <span class="text-xs font-medium text-text">Catamaran</span>
                </button>
                <button type="button" data-type="houseboat" class="boat-type-btn flex flex-col items-center justify-center w-[120px] h-[110px] rounded-xl border border-gray-200 hover:border-primary hover:bg-primary/5 transition-colors cursor-pointer">
                  <svg class="h-10 w-10 text-gray-500 mb-2" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><rect x="10" y="18" width="28" height="12" rx="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 18v-6h20v6" stroke-linecap="round" stroke-linejoin="round"/><path d="M20 18v-6M28 18v-6" stroke-linecap="round"/><path d="M6 34c2-2 6-4 18-4s16 2 18 4" stroke-linecap="round"/></svg>
                  <span class="text-xs font-medium text-text">Houseboat</span>
                </button>
                <button type="button" data-type="jetski" class="boat-type-btn flex flex-col items-center justify-center w-[120px] h-[110px] rounded-xl border border-gray-200 hover:border-primary hover:bg-primary/5 transition-colors cursor-pointer">
                  <svg class="h-10 w-10 text-gray-500 mb-2" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><path d="M10 28c2-3 8-5 14-5" stroke-linecap="round"/><path d="M24 23l6-6 4 2-2 9" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 32c4-2 12-4 20-4s12 2 14 4" stroke-linecap="round"/></svg>
                  <span class="text-xs font-medium text-text">Jet ski</span>
                </button>
                <button type="button" data-type="gulet" class="boat-type-btn flex flex-col items-center justify-center w-[120px] h-[110px] rounded-xl border border-gray-200 hover:border-primary hover:bg-primary/5 transition-colors cursor-pointer">
                  <svg class="h-10 w-10 text-gray-500 mb-2" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><path d="M8 30c2-4 8-6 16-6s14 2 16 6" stroke-linecap="round"/><path d="M16 24v-10M24 24v-12M32 24v-10" stroke-linecap="round"/><path d="M16 14l8-2 8 2" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 34h28" stroke-linecap="round"/></svg>
                  <span class="text-xs font-medium text-text">Gulet</span>
                </button>
                <button type="button" data-type="without-licence" class="boat-type-btn flex flex-col items-center justify-center w-[120px] h-[110px] rounded-xl border border-gray-200 hover:border-primary hover:bg-primary/5 transition-colors cursor-pointer">
                  <svg class="h-10 w-10 text-gray-500 mb-2" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><path d="M8 30c2-4 8-6 16-6s14 2 16 6" stroke-linecap="round"/><path d="M18 24l4-8h4l4 8" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 34h28" stroke-linecap="round"/></svg>
                  <span class="text-xs font-medium text-text leading-tight text-center">Boat without<br/>licence</span>
                </button>
                <button type="button" data-type="yacht" class="boat-type-btn flex flex-col items-center justify-center w-[120px] h-[110px] rounded-xl border border-gray-200 hover:border-primary hover:bg-primary/5 transition-colors cursor-pointer">
                  <svg class="h-10 w-10 text-gray-500 mb-2" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><path d="M6 32c2-6 10-10 18-10s14 4 18 10" stroke-linecap="round"/><path d="M24 22V10" stroke-linecap="round"/><path d="M24 10l10 8H24" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 36h32" stroke-linecap="round"/></svg>
                  <span class="text-xs font-medium text-text">Yacht</span>
                </button>
              </div>
              <input type="hidden" name="boatType" id="boat-type-input" />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">
              <div>
                <label for="city" class="block text-sm font-semibold text-text mb-2">City</label>
                <input type="text" id="city" name="city" class="w-full rounded-xl border border-gray-200 px-4 py-3.5 text-sm text-text placeholder:text-text-muted/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
              </div>
              <div>
                <label for="harbour" class="block text-sm font-semibold text-text mb-2">Harbour <span class="text-red-500">*</span></label>
                <input type="text" id="harbour" name="harbour" placeholder="Enter harbour name" required class="w-full rounded-xl border border-gray-200 px-4 py-3.5 text-sm text-text placeholder:text-text-muted/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 items-start mb-6">
              <div>
                <label for="professional" class="block text-sm font-semibold text-text mb-2">Are you a professional?</label>
                <div class="relative">
                  <select id="professional" name="professional" class="w-full appearance-none rounded-xl border border-gray-200 px-4 py-3.5 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent bg-white pr-10">
                    <option value="yes">Yes</option><option value="no">No</option>
                  </select>
                  <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </div>
              </div>
              <div class="bg-amber-50 border border-amber-200/60 rounded-xl p-4">
                <p class="text-sm text-amber-900"><strong>Attention:</strong> Your status must be accurately indicated. Presenting yourself as a "non-professional" when that is not the case constitutes a misleading commercial practice.</p>
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">
              <div>
                <label for="manufacturer" class="block text-sm font-semibold text-text mb-2">Manufacturer <span class="text-red-500">*</span></label>
                <input type="text" id="manufacturer" name="manufacturer" placeholder="Manufacturer" required class="w-full rounded-xl border border-gray-200 px-4 py-3.5 text-sm text-text placeholder:text-text-muted/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
              </div>
              <div>
                <label for="model" class="block text-sm font-semibold text-text mb-2">Model <span class="text-red-500">*</span></label>
                <input type="text" id="model" name="model" placeholder="Model" required class="w-full rounded-xl border border-gray-200 px-4 py-3.5 text-sm text-text placeholder:text-text-muted/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
              </div>
            </div>
            <div class="mb-6">
              <label for="boatName" class="block text-sm font-semibold text-text mb-2">Boat name <span class="text-red-500">*</span></label>
              <input type="text" id="boatName" name="boatName" placeholder="Give your boat a name" required class="w-full rounded-xl border border-gray-200 px-4 py-3.5 text-sm text-text placeholder:text-text-muted/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent max-w-md" />
            </div>
            <div class="flex justify-end mt-8">
              <button type="button" class="section-save-btn px-8 py-3 rounded-full bg-pink text-white text-sm font-bold hover:opacity-90 transition-opacity" data-section="general">Save</button>
            </div>
          </div>

          <!-- ===== Section 2: Description ===== -->
          <div id="wizard-section-description" class="wizard-section hidden">
            <h2 class="text-xl font-bold text-text mb-6">Description</h2>
            <div class="mb-6">
              <label class="block text-sm font-semibold text-text mb-3">Languages of the listing <span class="text-red-500">*</span></label>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-2" id="language-grid">
                <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 cursor-pointer"><input type="checkbox" name="languages" value="en" class="lang-cb h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" checked /><span class="text-sm text-text">English</span></label>
                <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 cursor-pointer"><input type="checkbox" name="languages" value="el" class="lang-cb h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" /><span class="text-sm text-text">Greek</span></label>
                <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 cursor-pointer"><input type="checkbox" name="languages" value="fr" class="lang-cb h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" /><span class="text-sm text-text">French</span></label>
                <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 cursor-pointer"><input type="checkbox" name="languages" value="es" class="lang-cb h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" /><span class="text-sm text-text">Spanish</span></label>
                <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 cursor-pointer"><input type="checkbox" name="languages" value="it" class="lang-cb h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" /><span class="text-sm text-text">Italian</span></label>
                <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 cursor-pointer"><input type="checkbox" name="languages" value="de" class="lang-cb h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" /><span class="text-sm text-text">Deutsch</span></label>
                <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 cursor-pointer"><input type="checkbox" name="languages" value="nl" class="lang-cb h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" /><span class="text-sm text-text">Nederlands</span></label>
                <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 cursor-pointer"><input type="checkbox" name="languages" value="pl" class="lang-cb h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" /><span class="text-sm text-text">Polski</span></label>
                <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 cursor-pointer"><input type="checkbox" name="languages" value="ru" class="lang-cb h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" /><span class="text-sm text-text">Russian</span></label>
                <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 cursor-pointer"><input type="checkbox" name="languages" value="pt" class="lang-cb h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" /><span class="text-sm text-text">Portuguese</span></label>
                <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 cursor-pointer"><input type="checkbox" name="languages" value="sv" class="lang-cb h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" /><span class="text-sm text-text">Svenska</span></label>
              </div>
            </div>
            <div class="mb-6">
              <label for="listingTitle" class="block text-sm font-semibold text-text mb-2">Title of the listing <span class="text-red-500">*</span></label>
              <input type="text" id="listingTitle" name="listingTitle" placeholder="e.g. Beautiful sailing yacht in Athens" required class="w-full rounded-xl border border-gray-200 px-4 py-3.5 text-sm text-text placeholder:text-text-muted/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
              <div class="lg:col-span-2">
                <label for="description" class="block text-sm font-semibold text-text mb-2">Description <span class="text-red-500">*</span></label>
                <textarea id="description" name="description" rows="8" placeholder="Describe your boat, the experience you offer, what makes it special..." required class="w-full rounded-xl border border-gray-200 px-4 py-3.5 text-sm text-text placeholder:text-text-muted/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent resize-y"></textarea>
              </div>
