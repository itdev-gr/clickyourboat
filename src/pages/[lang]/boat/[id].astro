---
import { getLangs, localizeHref } from "../../../lib/i18n-utils";
import Layout from "../../../layouts/Layout.astro";

export async function getStaticPaths() {
  const paths: { params: { id: string; lang: string } }[] = [];
  const langs = ["en", "gr"];
  try {
    const { searchBoats } = await import("../../../lib/api");
    const firestoreBoats = await searchBoats({}, 100);
    firestoreBoats.forEach((b: any) => {
      langs.forEach((lang) => {
        paths.push({ params: { id: b.id, lang } });
      });
    });
  } catch {
    // Firestore unavailable at build time
  }
  return paths;
}

const { id, lang } = Astro.params;

let boat: any = null;
try {
  const { getBoatListing } = await import("../../../lib/api");
  boat = await getBoatListing(id!);
} catch {
  // Firestore unavailable
}

if (!boat) {
  return Astro.redirect(l("/404"));
}

const title = `${boat.title || boat.listingTitle || "Boat"} — BoatHaven`;
const description = boat.description || boat.title || "View boat details on BoatHaven";
const images = boat.images || [];
const price = boat.price || boat.pricePerDay || 0;
const priceUnit = boat.priceUnit || "/ day";
const l = (href: string) => localizeHref(href, lang);
---

<Layout lang={lang} title={title} description={description}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6">
    <!-- Breadcrumb -->
    <nav class="mb-4 text-sm text-text-muted" aria-label="Breadcrumb">
      <ol class="flex items-center gap-1.5">
        <li><a href={l("/")} class="hover:text-primary transition-colors">Home</a></li>
        <li>/</li>
        <li><a href={l("/boat-rental")} class="hover:text-primary transition-colors">Boat Rental</a></li>
        <li>/</li>
        <li class="text-text font-medium truncate max-w-[250px]">{boat.title || boat.listingTitle}</li>
      </ol>
    </nav>

    <!-- Image Gallery -->
    <div class="mb-8">
      {images.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-[1.2fr_1fr] gap-2 rounded-2xl overflow-hidden">
          <!-- Main image -->
          <div class="aspect-[4/3] md:aspect-auto overflow-hidden bg-gray-100">
            <img
              id="main-image"
              src={images[0]}
              alt={boat.title || boat.listingTitle}
              class="h-full w-full object-cover cursor-pointer hover:scale-105 transition-transform duration-300"
              loading="eager"
            />
          </div>
          <!-- Secondary images 2x2 grid -->
          <div class="hidden md:grid grid-cols-2 grid-rows-2 gap-2">
            {images.slice(1, 5).map((img: string, i: number) => (
              <div class="overflow-hidden bg-gray-100 relative">
                <img
                  src={img}
                  alt={`${boat.title || boat.listingTitle} - Photo ${i + 2}`}
                  class="h-full w-full object-cover cursor-pointer hover:scale-105 transition-transform duration-300 gallery-thumb"
                  loading="lazy"
                  data-src={img}
                />
                {i === images.slice(1, 5).length - 1 && images.length > 5 && (
                  <div class="absolute inset-0 bg-black/50 flex items-center justify-center cursor-pointer gallery-thumb">
                    <span class="text-white font-bold text-lg">+{images.length - 5} photos</span>
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      ) : (
        <div class="aspect-[16/9] rounded-2xl bg-gray-100 flex items-center justify-center">
          <p class="text-text-muted">No photos available</p>
        </div>
      )}

      <!-- Mobile image dots -->
      {images.length > 1 && (
        <div class="flex justify-center gap-1.5 mt-3 md:hidden">
          {images.map((_: string, i: number) => (
            <button
              class:list={["h-2 w-2 rounded-full mobile-dot", i === 0 ? "bg-primary" : "bg-gray-300"]}
              data-index={i}
              aria-label={`View photo ${i + 1}`}
            />
          ))}
        </div>
      )}
    </div>

    <!-- Two-column layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">
      <!-- Left: Details -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Title & Location -->
        <div>
          <div class="flex items-start justify-between gap-4">
            <div>
              <h1 class="text-2xl sm:text-3xl font-extrabold text-text">{boat.title || boat.listingTitle}</h1>
              <p class="text-text-muted mt-1 flex items-center gap-1.5">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                {boat.location || `${boat.city || ""} ${boat.harbour || ""}`.trim()}
              </p>
            </div>
            {boat.rating > 0 && (
              <div class="flex items-center gap-1.5 flex-shrink-0 bg-surface px-3 py-2 rounded-xl">
                <svg class="h-5 w-5 text-pink" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <span class="font-bold text-text">{boat.rating}</span>
                {boat.reviewCount > 0 && <span class="text-sm text-text-muted">({boat.reviewCount} reviews)</span>}
              </div>
            )}
          </div>

          <!-- Tags -->
          {boat.tags && boat.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {boat.tags.map((tag: any) => (
                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-gray-50 border border-gray-200 text-xs text-text-muted font-medium">
                  {tag.label}
                </span>
              ))}
            </div>
          )}

          <!-- Save to favorites -->
          <button
            id="detail-fav-btn"
            class="mt-4 inline-flex items-center gap-2 px-4 py-2 rounded-xl border border-gray-200 text-sm font-medium text-text hover:border-gray-400 transition-colors"
            data-boat-id={boat.id}
          >
            <svg id="detail-fav-icon" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
            <span id="detail-fav-text">Save to favorites</span>
          </button>
        </div>

        <!-- Badges -->
        <div class="flex flex-wrap gap-3">
          {boat.instantBooking && (
            <div class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-gray-50 border border-gray-100">
              <svg class="h-4 w-4 text-pink" fill="currentColor" viewBox="0 0 20 20"><path d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"/></svg>
              <span class="text-sm font-medium text-text">Instant booking</span>
            </div>
          )}
          {boat.superOwner && (
            <div class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-gray-50 border border-gray-100">
              <span class="text-pink">&#127800;</span>
              <span class="text-sm font-medium text-text">Super Owner</span>
            </div>
          )}
          {boat.discountOffer && (
            <div class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-pink/5 border border-pink/20">
              <span class="text-sm font-medium text-pink">Discount available</span>
            </div>
          )}
        </div>

        <!-- Description -->
        <div>
          <h2 class="text-lg font-bold text-text mb-3">About this boat</h2>
          <p class="text-text-muted leading-relaxed">
            {boat.description || `Experience the ${boat.type || boat.boatType || "boat"} in ${boat.location || boat.city || "a beautiful location"}. Perfect for groups of up to ${boat.capacity || "several"} people.`}
          </p>
        </div>

        <!-- Specifications -->
        <div>
          <h2 class="text-lg font-bold text-text mb-4">Specifications</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
            {boat.type && (
              <div class="bg-surface rounded-xl p-4 border border-gray-100">
                <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Type</p>
                <p class="text-sm font-semibold text-text capitalize">{boat.type || boat.boatType}</p>
              </div>
            )}
            {boat.capacity > 0 && (
              <div class="bg-surface rounded-xl p-4 border border-gray-100">
                <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Capacity</p>
                <p class="text-sm font-semibold text-text">{boat.capacity} people</p>
              </div>
            )}
            {boat.length > 0 && (
              <div class="bg-surface rounded-xl p-4 border border-gray-100">
                <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Length</p>
                <p class="text-sm font-semibold text-text">{boat.length}m</p>
              </div>
            )}
            {boat.cabins > 0 && (
              <div class="bg-surface rounded-xl p-4 border border-gray-100">
                <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Cabins</p>
                <p class="text-sm font-semibold text-text">{boat.cabins}</p>
              </div>
            )}
            {boat.berths > 0 && (
              <div class="bg-surface rounded-xl p-4 border border-gray-100">
                <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Berths</p>
                <p class="text-sm font-semibold text-text">{boat.berths}</p>
              </div>
            )}
            {boat.enginePower > 0 && (
              <div class="bg-surface rounded-xl p-4 border border-gray-100">
                <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Engine</p>
                <p class="text-sm font-semibold text-text">{boat.enginePower} HP</p>
              </div>
            )}
            {boat.year > 0 && (
              <div class="bg-surface rounded-xl p-4 border border-gray-100">
                <p class="text-xs text-text-muted uppercase tracking-wide mb-1">Year</p>
                <p class="text-sm font-semibold text-text">{boat.year}</p>
              </div>
            )}
          </div>
        </div>

        <!-- Perks -->
        {boat.perks && boat.perks.length > 0 && (
          <div>
            <h2 class="text-lg font-bold text-text mb-3">What's included</h2>
            <div class="space-y-2">
              {boat.perks.includes("fuel") && (
                <p class="text-sm text-green-600 flex items-center gap-2">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                  Fuel included
                </p>
              )}
              {boat.perks.includes("free-cancel") && (
                <p class="text-sm text-green-600 flex items-center gap-2">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                  Free cancellation
                </p>
              )}
              {boat.perks.includes("flexible-cancel") && (
                <p class="text-sm text-green-600 flex items-center gap-2">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                  Flexible cancellation
                </p>
              )}
            </div>
          </div>
        )}

        <!-- Equipment -->
        {boat.equipment && boat.equipment.length > 0 && (
          <div>
            <h2 class="text-lg font-bold text-text mb-3">Equipment</h2>
            <div class="flex flex-wrap gap-2">
              {boat.equipment.map((item: string) => (
                <span class="inline-flex items-center px-3 py-1.5 rounded-lg bg-surface border border-gray-100 text-sm text-text">
                  {item}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Ideal for -->
        {boat.idealFor && boat.idealFor.length > 0 && (
          <div>
            <h2 class="text-lg font-bold text-text mb-3">Ideal for</h2>
            <div class="flex flex-wrap gap-2">
              {boat.idealFor.map((item: string) => (
                <span class="inline-flex items-center px-3 py-1.5 rounded-lg bg-primary/5 border border-primary/10 text-sm text-primary font-medium">
                  {item}
                </span>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Reviews Section -->
      <div id="reviews-section">
        <h2 class="text-lg font-bold text-text mb-4">Reviews</h2>

        <!-- Loading -->
        <div id="reviews-loading" class="flex items-center justify-center py-8">
          <div class="h-6 w-6 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
        </div>

        <!-- Empty state -->
        <div id="reviews-empty" class="hidden text-center py-8">
          <svg class="mx-auto h-12 w-12 text-gray-300 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
          </svg>
          <p class="text-sm text-text-muted">No reviews yet</p>
          <p class="text-xs text-gray-400 mt-1">Be the first to review this boat</p>
        </div>

        <!-- Reviews list -->
        <div id="reviews-list" class="space-y-4"></div>

        <!-- Review form (hidden by default) -->
        <div id="review-form-wrap" class="hidden mt-6 bg-surface rounded-xl border border-gray-100 p-6">
          <h3 class="font-semibold text-text mb-4">Write a review</h3>

          <!-- Star selector -->
          <div class="flex items-center gap-1 mb-4" id="star-selector">
            <button type="button" data-star="1" class="star-btn text-gray-300 hover:text-yellow-400 transition-colors">
              <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            </button>
            <button type="button" data-star="2" class="star-btn text-gray-300 hover:text-yellow-400 transition-colors">
              <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            </button>
            <button type="button" data-star="3" class="star-btn text-gray-300 hover:text-yellow-400 transition-colors">
              <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            </button>
            <button type="button" data-star="4" class="star-btn text-gray-300 hover:text-yellow-400 transition-colors">
              <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            </button>
            <button type="button" data-star="5" class="star-btn text-gray-300 hover:text-yellow-400 transition-colors">
              <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            </button>
          </div>

          <textarea id="review-comment" rows="3" placeholder="Share your experience..." class="w-full rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent resize-none mb-4"></textarea>

          <div class="flex items-center justify-between">
            <p id="review-error" class="text-xs text-red-600 hidden"></p>
            <button id="submit-review-btn" class="ml-auto px-6 py-2.5 rounded-xl bg-primary text-white text-sm font-bold hover:bg-primary-dark transition-colors">
              Submit review
            </button>
          </div>
        </div>
      </div>
    </div>

      <!-- Right: Booking sidebar -->
      <div class="lg:col-span-1">
        <div class="sticky top-24 space-y-4">
          <!-- Price card -->
          <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
            <div class="flex items-baseline gap-1 mb-6">
              <span class="text-sm text-text-muted">From</span>
              <span class="text-3xl font-extrabold text-text">&euro;{price.toLocaleString()}</span>
              {priceUnit && <span class="text-text-muted">{priceUnit}</span>}
            </div>

            <!-- Date selection -->
            <div class="space-y-3 mb-4">
              <div>
                <label for="booking-start" class="block text-xs font-semibold text-text-muted uppercase tracking-wide mb-1">Start date</label>
                <input
                  type="date"
                  id="booking-start"
                  class="w-full rounded-xl border border-gray-200 bg-surface px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
                />
              </div>
              <div>
                <label for="booking-end" class="block text-xs font-semibold text-text-muted uppercase tracking-wide mb-1">End date</label>
                <input
                  type="date"
                  id="booking-end"
                  class="w-full rounded-xl border border-gray-200 bg-surface px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
                />
              </div>
            </div>

            <!-- Price summary -->
            <div id="price-summary" class="hidden mb-4 p-4 bg-surface rounded-xl border border-gray-100">
              <div class="flex justify-between text-sm mb-2">
                <span class="text-text-muted">&euro;{price.toLocaleString()} x <span id="booking-days">0</span> days</span>
                <span class="text-text font-medium" id="booking-subtotal">&euro;0</span>
              </div>
              <div class="border-t border-gray-200 pt-2 flex justify-between">
                <span class="text-sm font-bold text-text">Total</span>
                <span class="text-sm font-bold text-text" id="booking-total">&euro;0</span>
              </div>
            </div>

            <!-- Request booking -->
            <button
              id="request-booking-btn"
              class="w-full rounded-xl bg-primary px-6 py-3.5 text-sm font-bold text-white hover:bg-primary-dark transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 mb-3"
              data-boat-id={boat.id}
              data-owner-id={boat.ownerId || ""}
              data-price={price}
              data-boat-title={boat.title || boat.listingTitle || "Boat"}
              data-boat-image={images[0] || ""}
            >
              {boat.instantBooking ? "Book now" : "Continue Booking"}
            </button>

            <p class="text-xs text-text-muted text-center">You won't be charged yet</p>

            <!-- Booking messages -->
            <div id="booking-success" class="hidden mt-4 p-4 bg-green-50 border border-green-200 rounded-xl">
              <p class="text-sm text-green-800 font-medium">Booking request sent!</p>
              <p class="text-xs text-green-600 mt-1">The owner has been notified. <a href={l("/dashboard")} class="underline font-semibold">View your bookings</a></p>
            </div>
            <div id="booking-error" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded-xl">
              <p class="text-sm text-red-800 font-medium" id="booking-error-text">Something went wrong</p>
            </div>
          </div>

          <!-- Contact owner -->
          <div class="bg-white rounded-2xl border border-gray-200 p-6">
            <h3 class="font-semibold text-text mb-3">Have questions?</h3>
            <p class="text-sm text-text-muted mb-4">Contact the owner directly to ask about the boat or trip details.</p>
            <button
              id="contact-owner-btn"
              class="w-full rounded-xl border border-gray-200 px-6 py-3 text-sm font-semibold text-text hover:border-gray-400 transition-colors"
              data-owner-id={boat.ownerId || ""}
              data-boat-id={boat.id}
              data-boat-title={boat.title || boat.listingTitle || "Boat"}
            >
              Contact owner
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    // Gallery: click thumbnail to swap main image
    var mainImage = document.getElementById("main-image");
    document.querySelectorAll(".gallery-thumb").forEach(function (thumb) {
      thumb.addEventListener("click", function () {
        if (mainImage) {
          var newSrc = thumb.getAttribute("data-src");
          if (newSrc) mainImage.src = newSrc;
        }
      });
    });

    // Mobile dots: simple image swipe
    var dots = document.querySelectorAll(".mobile-dot");
    var allImages = [];
    document.querySelectorAll("[data-src]").forEach(function (el) {
      allImages.push(el.getAttribute("data-src"));
    });
    if (mainImage && mainImage.src) {
      allImages.unshift(mainImage.src);
    }

    dots.forEach(function (dot) {
      dot.addEventListener("click", function () {
        var idx = parseInt(dot.getAttribute("data-index") || "0");
        if (mainImage && allImages[idx]) {
          mainImage.src = allImages[idx];
        }
        dots.forEach(function (d) {
          d.classList.remove("bg-primary");
          d.classList.add("bg-gray-300");
        });
        dot.classList.remove("bg-gray-300");
        dot.classList.add("bg-primary");
      });
    });

    // Set min dates to today
    var today = new Date().toISOString().split("T")[0];
    var startInput = document.getElementById("booking-start");
    var endInput = document.getElementById("booking-end");
    if (startInput) startInput.setAttribute("min", today);
    if (endInput) endInput.setAttribute("min", today);

    // Price summary calculation
    var bookBtn = document.getElementById("request-booking-btn");
    var dailyRate = parseFloat(bookBtn ? bookBtn.getAttribute("data-price") || "0" : "0");

    function updatePriceSummary() {
      var start = startInput ? startInput.value : "";
      var end = endInput ? endInput.value : "";
      var summary = document.getElementById("price-summary");
      if (!start || !end || !summary) return;

      var startDate = new Date(start);
      var endDate = new Date(end);
      var diffMs = endDate.getTime() - startDate.getTime();
      var days = Math.ceil(diffMs / (1000 * 60 * 60 * 24));

      if (days <= 0) {
        summary.classList.add("hidden");
        return;
      }

      var total = days * dailyRate;
      document.getElementById("booking-days").textContent = String(days);
      document.getElementById("booking-subtotal").textContent = "\u20AC" + total.toLocaleString();
      document.getElementById("booking-total").textContent = "\u20AC" + total.toLocaleString();
      summary.classList.remove("hidden");
    }

    if (startInput) startInput.addEventListener("change", updatePriceSummary);
    if (endInput) endInput.addEventListener("change", updatePriceSummary);

    // Contact owner - redirect to messages with owner context
    var contactBtn = document.getElementById("contact-owner-btn");
    if (contactBtn) {
      contactBtn.addEventListener("click", function () {
        var ownerId = contactBtn.getAttribute("data-owner-id");
        var cBoatId = contactBtn.getAttribute("data-boat-id");
        var cBoatTitle = contactBtn.getAttribute("data-boat-title");
        if (ownerId) {
          var params = new URLSearchParams();
          params.set("with", ownerId);
          if (cBoatId) params.set("boatId", cBoatId);
          if (cBoatTitle) params.set("boatTitle", cBoatTitle);
          window.location.href = "/" + getLangPrefix() + "/messages?" + params.toString();
        } else {
          window.location.href = "/" + getLangPrefix() + "/messages";
        }
      });
    }
  });
</script>

<!-- Booking logic -->
<script>

  function getLangPrefix() {
    return document.documentElement.dataset.langPrefix || "en";
  }
  import { auth } from "../../../lib/firebase";
  import { onAuthStateChanged } from "firebase/auth";
  import { getBoatReviews, createReview, hasUserReviewedBoat, getUserOrders } from "../../../lib/api";

  const bookBtn = document.getElementById("request-booking-btn") as HTMLButtonElement;
  const startInput = document.getElementById("booking-start") as HTMLInputElement;
  const endInput = document.getElementById("booking-end") as HTMLInputElement;
  const successDiv = document.getElementById("booking-success");
  const errorDiv = document.getElementById("booking-error");
  const errorText = document.getElementById("booking-error-text");

  const boatId = bookBtn?.getAttribute("data-boat-id") || "";
  const ownerId = bookBtn?.getAttribute("data-owner-id") || "";
  const dailyRate = parseFloat(bookBtn?.getAttribute("data-price") || "0");
  const boatTitle = bookBtn?.getAttribute("data-boat-title") || "";
  const boatImage = bookBtn?.getAttribute("data-boat-image") || "";

  let currentUser: any = null;

  function showError(msg: string) {
    if (errorText) errorText.textContent = msg;
    errorDiv?.classList.remove("hidden");
    successDiv?.classList.add("hidden");
  }

  onAuthStateChanged(auth, async (user) => {
    currentUser = user;
    if (user) {
      loadReviews(user);
    } else {
      loadReviews(null);
    }
  });

  bookBtn?.addEventListener("click", async () => {
    // Hide previous messages
    successDiv?.classList.add("hidden");
    errorDiv?.classList.add("hidden");

    // Auth check
    if (!currentUser) {
      window.location.href = "/" + getLangPrefix() + "/login?redirect=" + encodeURIComponent(window.location.pathname);
      return;
    }

    // Prevent booking own boat
    if (ownerId && currentUser.uid === ownerId) {
      showError("You cannot book your own boat.");
      return;
    }

    // Prevent booking boats with no owner
    if (!ownerId) {
      showError("This boat is not available for booking.");
      return;
    }

    // Validate dates
    const startVal = startInput?.value;
    const endVal = endInput?.value;
    if (!startVal || !endVal) {
      showError("Please select both start and end dates.");
      return;
    }

    const startDate = new Date(startVal);
    const endDate = new Date(endVal);
    if (endDate <= startDate) {
      showError("End date must be after start date.");
      return;
    }

    // Redirect to confirm-booking page with all necessary params
    const params = new URLSearchParams({
      boatId,
      startDate: startVal,
      endDate: endVal,
    });
    window.location.href = "/" + getLangPrefix() + "/confirm-booking?" + params.toString();
  });

  // --- Reviews ---
  function escapeHtml(text: string): string {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }

  function renderStars(rating: number): string {
    let html = "";
    for (let i = 1; i <= 5; i++) {
      html += `<svg class="h-4 w-4 ${i <= rating ? "text-yellow-400" : "text-gray-200"}" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>`;
    }
    return html;
  }

  async function loadReviews(user: any) {
    const loadingEl = document.getElementById("reviews-loading");
    const emptyEl = document.getElementById("reviews-empty");
    const listEl = document.getElementById("reviews-list");
    const formWrap = document.getElementById("review-form-wrap");

    try {
      const reviews = await getBoatReviews(boatId);

      loadingEl?.classList.add("hidden");

      if (reviews.length === 0) {
        emptyEl?.classList.remove("hidden");
      } else {
        emptyEl?.classList.add("hidden");
        let html = "";
        for (const review of reviews) {
          const date = review.createdAt
            ? new Date(review.createdAt).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })
            : "";
          html += `
            <div class="bg-surface rounded-xl border border-gray-100 p-5">
              <div class="flex items-center justify-between mb-2">
                <div class="flex items-center gap-2">
                  <div class="flex items-center gap-0.5">${renderStars(review.rating)}</div>
                  <span class="text-sm font-semibold text-text">${escapeHtml(review.userName || "Anonymous")}</span>
                </div>
                <span class="text-xs text-gray-400">${date}</span>
              </div>
              <p class="text-sm text-text-muted">${escapeHtml(review.comment || "")}</p>
            </div>
          `;
        }
        if (listEl) listEl.innerHTML = html;
      }

      // Show review form if user is logged in, has a booking, and hasn't reviewed yet
      if (user && formWrap) {
        const [hasReviewed, userOrders] = await Promise.all([
          hasUserReviewedBoat(user.uid, boatId),
          getUserOrders(user.uid),
        ]);
        const hasBooking = userOrders.some(
          (o: any) => o.boatId === boatId && (o.status === "confirmed" || o.status === "completed")
        );
        if (hasBooking && !hasReviewed) {
          formWrap.classList.remove("hidden");
        }
      }
    } catch (err) {
      console.error("Error loading reviews:", err);
      loadingEl?.classList.add("hidden");
      emptyEl?.classList.remove("hidden");
    }
  }

  // Star selector interaction
  let selectedRating = 0;
  document.querySelectorAll(".star-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      selectedRating = parseInt(btn.getAttribute("data-star") || "0");
      document.querySelectorAll(".star-btn").forEach((b, i) => {
        if (i < selectedRating) {
          b.classList.remove("text-gray-300");
          b.classList.add("text-yellow-400");
        } else {
          b.classList.remove("text-yellow-400");
          b.classList.add("text-gray-300");
        }
      });
    });
  });

  // Submit review
  document.getElementById("submit-review-btn")?.addEventListener("click", async () => {
    const comment = (document.getElementById("review-comment") as HTMLTextAreaElement)?.value?.trim();
    const reviewError = document.getElementById("review-error");

    if (selectedRating === 0) {
      if (reviewError) { reviewError.textContent = "Please select a star rating."; reviewError.classList.remove("hidden"); }
      return;
    }
    if (!comment) {
      if (reviewError) { reviewError.textContent = "Please write a comment."; reviewError.classList.remove("hidden"); }
      return;
    }

    const submitBtn = document.getElementById("submit-review-btn") as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = "Submitting...";

    try {
      await createReview({
        boatId,
        userId: currentUser.uid,
        userName: currentUser.displayName || currentUser.email || "Anonymous",
        rating: selectedRating,
        comment,
      });

      // Refresh reviews
      await loadReviews(currentUser);

      // Hide form after successful submission
      document.getElementById("review-form-wrap")?.classList.add("hidden");
    } catch (err: any) {
      console.error("Error submitting review:", err);
      if (reviewError) { reviewError.textContent = "Failed to submit review."; reviewError.classList.remove("hidden"); }
      submitBtn.disabled = false;
      submitBtn.textContent = "Submit review";
    }
  });
</script>

<!-- Boat detail favorites: Firebase-backed -->
<script>
  import { auth, db } from "../../../lib/firebase";
  import { onAuthStateChanged } from "firebase/auth";
  import { doc, setDoc, deleteDoc, getDoc, serverTimestamp } from "firebase/firestore";

  const favBtn = document.getElementById("detail-fav-btn");
  const favIcon = document.getElementById("detail-fav-icon");
  const favText = document.getElementById("detail-fav-text");
  if (!favBtn) throw new Error("No fav btn");

  const boatId = favBtn.getAttribute("data-boat-id");
  let currentUser: any = null;
  let isFavorited = false;

  function updateFavUI(fav: boolean) {
    isFavorited = fav;
    if (favIcon) {
      favIcon.setAttribute("fill", fav ? "currentColor" : "none");
      favIcon.classList.toggle("text-pink", fav);
      favIcon.classList.toggle("text-gray-400", !fav);
    }
    if (favText) {
      favText.textContent = fav ? "Saved to favorites" : "Save to favorites";
    }
    if (favBtn) {
      favBtn.classList.toggle("border-pink/30", fav);
      favBtn.classList.toggle("bg-pink/5", fav);
      favBtn.classList.toggle("border-gray-200", !fav);
    }
  }

  onAuthStateChanged(auth, async (user) => {
    currentUser = user;
    if (user && boatId) {
      try {
        const snap = await getDoc(doc(db, "users", user.uid, "favorites", boatId));
        updateFavUI(snap.exists());
      } catch {
        // ignore
      }
    }
  });

  favBtn?.addEventListener("click", async () => {
    if (!currentUser) {
      window.location.href = "/" + getLangPrefix() + "/login?redirect=" + encodeURIComponent(window.location.pathname);
      return;
    }
    if (!boatId) return;

    const favRef = doc(db, "users", currentUser.uid, "favorites", boatId);

    // Optimistic update
    updateFavUI(!isFavorited);

    try {
      if (isFavorited) {
        // We just set it to true above, so now we need to save
        // Get boat data from the page
        const title = document.querySelector("h1")?.textContent?.trim() || "";
        const location = document.querySelector("h1 + p")?.textContent?.trim() || "";
        const image = (document.getElementById("main-image") as HTMLImageElement)?.src || "";

        await setDoc(favRef, {
          boatId,
          title,
          image,
          location,
          price: 0,
          priceUnit: "/ day",
          type: "",
          rating: 0,
          reviewCount: 0,
          addedAt: serverTimestamp(),
        });
      } else {
        // We just set it to false, so remove
        await deleteDoc(favRef);
      }
    } catch (err) {
      console.error("[Favorites] Error toggling favorite:", err);
      // Revert
      updateFavUI(!isFavorited);
    }
  });
</script>
