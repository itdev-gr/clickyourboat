---
import { getLangs, localizeHref } from "../../lib/i18n-utils";
export function getStaticPaths() { return getLangs(); }
const { lang } = Astro.params;
import Layout from "../../layouts/Layout.astro";
import Sidebar from "../../components/boat-rental/Sidebar.astro";

const title = "Boat Rental — Find the Perfect Boat | TapYourBoat";
const description =
  "Rent a boat from over 50,000 listings in 600+ destinations. Motorboats, sailboats, catamarans, yachts — with or without skipper. Best prices guaranteed.";
const l = (href: string) => localizeHref(href, lang);
---
<Layout lang={lang} title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: "Boat Rental",
      description: description,
      url: "https://boathaven.com/boat-rental",
      publisher: {
        "@type": "Organization",
        name: "TapYourBoat",
        url: "https://boathaven.com",
      },
      breadcrumb: {
        "@type": "BreadcrumbList",
        itemListElement: [
          { "@type": "ListItem", position: 1, name: "Home", item: "https://boathaven.com" },
          { "@type": "ListItem", position: 2, name: "Boat Rental", item: "https://boathaven.com/boat-rental" },
        ],
      },
    })} />
  </Fragment>

  <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8 py-6">
    <!-- Breadcrumb -->
    <nav class="mb-4 text-xs text-text-muted" aria-label="Breadcrumb">
      <ol id="breadcrumb-list" class="flex items-center gap-1.5">
        <li><a href={l("/")} class="hover:text-primary transition-colors">TapYourBoat</a></li>
        <li>/</li>
        <li id="breadcrumb-current" class="text-text font-medium" data-i18n="rental.breadcrumb">Boat rental</li>
      </ol>
    </nav>

    <!-- Active filter chip (hidden by default, shown by JS when ?type= present) -->
    <div id="filter-chip" class="mb-4 flex items-center gap-2 hidden">
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-primary/10 text-primary text-sm font-medium">
        <span id="filter-chip-label"></span>
        <a href={l("/boat-rental")} class="hover:bg-primary/20 rounded-full p-0.5 transition-colors" aria-label="Clear filter">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </a>
      </span>
      <span id="filter-chip-count" class="text-sm text-text-muted"></span>
    </div>

    <!-- Two-column layout -->
    <div class="flex gap-10 lg:gap-14">
      <!-- Left sidebar (hidden on mobile, shown on lg+) -->
      <div class="hidden lg:block">
        <Sidebar />
      </div>

      <!-- Mobile filter toggle -->
      <button
        id="mobile-filter-btn"
        class="lg:hidden fixed bottom-6 left-1/2 -translate-x-1/2 z-[55] inline-flex items-center gap-2 px-5 py-3 rounded-full bg-text text-white text-sm font-semibold shadow-xl hover:bg-gray-800 transition-colors"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"/></svg>
        <span data-i18n="rental.filters_btn">Filters</span>
      </button>

      <!-- Mobile filter drawer -->
      <div
        id="mobile-filter-drawer"
        class="lg:hidden fixed inset-0 z-50 hidden"
        aria-hidden="true"
      >
        <div
          id="filter-drawer-backdrop"
          class="absolute inset-0 bg-black/40 opacity-0 transition-opacity duration-300"
        ></div>
        <div
          id="filter-drawer-panel"
          class="absolute bottom-0 left-0 right-0 max-h-[85vh] bg-white rounded-t-2xl shadow-2xl translate-y-full transition-transform duration-300 ease-out flex flex-col"
        >
          <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200 flex-shrink-0">
            <h2 class="text-lg font-bold text-text">Filters</h2>
            <button
              id="close-filter-drawer-btn"
              class="p-2 rounded-lg text-text-muted hover:bg-gray-100 transition-colors"
              aria-label="Close filters"
            >
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <div class="overflow-y-auto p-5">
            <Sidebar />
          </div>
        </div>
      </div>

      <!-- Main content area -->
      <div class="flex-1 min-w-0">
        <!-- Date prompt banner -->
        <div class="bg-amber-50 border border-amber-200/60 rounded-xl px-5 py-3.5 mb-6 flex items-center justify-between" id="date-banner">
          <div class="flex items-center gap-3">
            <svg class="h-5 w-5 text-amber-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
            <p class="text-sm text-amber-900">Add dates to find your ideal boat for the best price</p>
          </div>
          <button class="text-amber-600 hover:text-amber-800 transition-colors p-1" id="close-banner" aria-label="Dismiss">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <!-- No results (hidden by default) -->
        <div id="no-results" class="text-center py-16 hidden">
          <svg class="mx-auto h-16 w-16 text-text-muted/40 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <h2 class="text-xl font-bold text-text mb-2">No boats found</h2>
          <p id="no-results-text" class="text-text-muted mb-6">We couldn't find any boats matching your criteria.</p>
          <a href={l("/boat-rental")} class="inline-flex items-center px-6 py-3 rounded-xl bg-primary text-white text-sm font-semibold hover:bg-primary-dark transition-colors">
            View all boats
          </a>
        </div>

        <!-- Top trending section -->
        <section id="trending-section" class="mb-10" aria-labelledby="trending-heading">
          <div class="mb-4">
            <h2 id="trending-heading" class="text-xl font-bold text-text">Top trending boat</h2>
            <p class="text-xs text-text-muted flex items-center gap-1 mt-0.5">
              How we rank results
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4m0-4h.01"/></svg>
            </p>
          </div>
          <div id="trending-grid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
            <!-- Loading skeletons -->
            <div class="boat-skeleton bg-white rounded-xl border border-gray-200/80 overflow-hidden animate-pulse"><div class="aspect-[4/3] bg-gray-200"></div><div class="p-4 space-y-2"><div class="h-4 bg-gray-200 rounded w-3/4"></div><div class="h-3 bg-gray-200 rounded w-1/2"></div><div class="h-3 bg-gray-200 rounded w-2/3"></div></div></div>
            <div class="boat-skeleton bg-white rounded-xl border border-gray-200/80 overflow-hidden animate-pulse"><div class="aspect-[4/3] bg-gray-200"></div><div class="p-4 space-y-2"><div class="h-4 bg-gray-200 rounded w-3/4"></div><div class="h-3 bg-gray-200 rounded w-1/2"></div><div class="h-3 bg-gray-200 rounded w-2/3"></div></div></div>
            <div class="boat-skeleton bg-white rounded-xl border border-gray-200/80 overflow-hidden animate-pulse"><div class="aspect-[4/3] bg-gray-200"></div><div class="p-4 space-y-2"><div class="h-4 bg-gray-200 rounded w-3/4"></div><div class="h-3 bg-gray-200 rounded w-1/2"></div><div class="h-3 bg-gray-200 rounded w-2/3"></div></div></div>
          </div>
        </section>

        <!-- All boats section -->
        <section id="all-boats-section" aria-labelledby="all-boats-heading">
          <div class="mb-4">
            <h2 id="all-boats-heading" class="text-xl font-bold text-text">+100 boats available</h2>
            <p class="text-xs text-text-muted flex items-center gap-1 mt-0.5">
              How we rank results
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4m0-4h.01"/></svg>
            </p>
          </div>
          <div id="all-boats-grid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
            <!-- Loading skeletons -->
            <div class="boat-skeleton bg-white rounded-xl border border-gray-200/80 overflow-hidden animate-pulse"><div class="aspect-[4/3] bg-gray-200"></div><div class="p-4 space-y-2"><div class="h-4 bg-gray-200 rounded w-3/4"></div><div class="h-3 bg-gray-200 rounded w-1/2"></div><div class="h-3 bg-gray-200 rounded w-2/3"></div></div></div>
            <div class="boat-skeleton bg-white rounded-xl border border-gray-200/80 overflow-hidden animate-pulse"><div class="aspect-[4/3] bg-gray-200"></div><div class="p-4 space-y-2"><div class="h-4 bg-gray-200 rounded w-3/4"></div><div class="h-3 bg-gray-200 rounded w-1/2"></div><div class="h-3 bg-gray-200 rounded w-2/3"></div></div></div>
            <div class="boat-skeleton bg-white rounded-xl border border-gray-200/80 overflow-hidden animate-pulse"><div class="aspect-[4/3] bg-gray-200"></div><div class="p-4 space-y-2"><div class="h-4 bg-gray-200 rounded w-3/4"></div><div class="h-3 bg-gray-200 rounded w-1/2"></div><div class="h-3 bg-gray-200 rounded w-2/3"></div></div></div>
            <div class="boat-skeleton bg-white rounded-xl border border-gray-200/80 overflow-hidden animate-pulse"><div class="aspect-[4/3] bg-gray-200"></div><div class="p-4 space-y-2"><div class="h-4 bg-gray-200 rounded w-3/4"></div><div class="h-3 bg-gray-200 rounded w-1/2"></div><div class="h-3 bg-gray-200 rounded w-2/3"></div></div></div>
            <div class="boat-skeleton bg-white rounded-xl border border-gray-200/80 overflow-hidden animate-pulse"><div class="aspect-[4/3] bg-gray-200"></div><div class="p-4 space-y-2"><div class="h-4 bg-gray-200 rounded w-3/4"></div><div class="h-3 bg-gray-200 rounded w-1/2"></div><div class="h-3 bg-gray-200 rounded w-2/3"></div></div></div>
            <div class="boat-skeleton bg-white rounded-xl border border-gray-200/80 overflow-hidden animate-pulse"><div class="aspect-[4/3] bg-gray-200"></div><div class="p-4 space-y-2"><div class="h-4 bg-gray-200 rounded w-3/4"></div><div class="h-3 bg-gray-200 rounded w-1/2"></div><div class="h-3 bg-gray-200 rounded w-2/3"></div></div></div>
          </div>

          <!-- Load more -->
          <div id="load-more-wrap" class="mt-8 text-center">
            <button class="inline-flex items-center gap-2 px-8 py-3 rounded-xl border border-gray-200 text-sm font-semibold text-text hover:border-gray-400 transition-colors">
              Show more boats
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
          </div>
        </section>
      </div>
    </div>
  </div>
</Layout>

<!-- Client-side boat loading -->
<script>
  import { getFeaturedBoats, searchBoats, getOwnerBoats } from "../../lib/api";
  import { auth } from "../../lib/firebase";
  import { onAuthStateChanged } from "firebase/auth";

  function getLangPrefix(): string {
    return document.documentElement.dataset.langPrefix || "en";
  }

  function escAttr(s: string): string {
    return s.replace(/&/g,"&amp;").replace(/"/g,"&quot;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
  }
  function escHtml(s: string): string {
    return s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
  }

  interface MappedBoat {
    id: string; type: string; location: string; rating: number; reviewCount: number;
    title: string; images: string[]; tags: {icon:string;label:string}[]; specs: string;
    perks: string[]; price: number; priceUnit: string; instantBooking: boolean;
    discountOffer: boolean; isNew: boolean; capacity: number; cabins: number;
    berths: number; length: number; enginePower: number; year: number;
    superOwner: boolean; idealFor: string[]; equipment: string[]; ownerId: string;
  }

  function mapBoat(b: any): MappedBoat {
    return {
      id: b.id,
      type: b.type || b.boatType || "motor",
      location: typeof b.location === "object" ? `${b.location.city}, ${b.location.country}` : (b.location || b.city || ""),
      rating: b.rating || 0,
      reviewCount: b.reviewCount || 0,
      title: b.title || b.listingTitle || b.boatName || "Boat",
      images: b.images || [],
      tags: b.tags || [],
      specs: b.specs || "",
      perks: b.perks || [],
      price: b.price || b.pricePerDay || 0,
      priceUnit: b.priceUnit || "/ day",
      instantBooking: b.instantBooking || b.bookingMode === "instant" || false,
      discountOffer: b.discountOffer || false,
      isNew: b.isNew || false,
      capacity: b.capacity || 0,
      cabins: b.cabins || 0,
      berths: b.berths || 0,
      length: b.length || 0,
      enginePower: b.enginePower || b.horsepower || 0,
      year: b.year || b.yearOfConstruction || 0,
      superOwner: b.superOwner || false,
      idealFor: b.idealFor || [],
      equipment: b.equipment || [],
      ownerId: b.ownerId || "",
    };
  }

  const checkSvg = '<svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>';

  function renderBoatCard(boat: MappedBoat): string {
    const mainImage = boat.images && boat.images.length > 0 ? boat.images[0] : "";
    const hasSkipper = boat.tags.some(t => t.icon === "skipper");
    const noLicence = boat.tags.some(t => t.icon === "no-licence");
    const listingType = boat.priceUnit === "/ day" ? "rental" : "experience";

    let imageHtml = mainImage
      ? `<img src="${escAttr(mainImage)}" alt="${escAttr(boat.title)}" class="h-full w-full object-cover boat-card-img" loading="lazy" decoding="async" />`
      : `<div class="h-full w-full flex items-center justify-center text-gray-400"><svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z"/></svg></div>`;

    let dotsHtml = "";
    if (boat.images && boat.images.length > 1) {
      dotsHtml = `<div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5">${boat.images.map((img, i) =>
        `<button class="h-2 w-2 rounded-full carousel-dot cursor-pointer ${i === 0 ? "bg-white" : "bg-white/50"}" data-img="${escAttr(img)}" aria-label="Photo ${i + 1}"></button>`
      ).join("")}</div>`;
    }

    let badgesHtml = "";
    if (boat.discountOffer) badgesHtml += `<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-pink text-white text-xs font-semibold">Discount offer</span>`;
    if (boat.instantBooking) badgesHtml += `<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-gray-800 text-white text-xs font-semibold"><svg class="h-3 w-3 text-pink-light" fill="currentColor" viewBox="0 0 20 20"><path d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"/></svg> Instant booking</span>`;

    let ratingHtml = "";
    if (boat.rating > 0) {
      ratingHtml = `<div class="flex items-center gap-1 flex-shrink-0"><svg class="h-3.5 w-3.5 text-pink" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg><span class="text-xs font-semibold text-text">${boat.rating}</span><span class="text-xs text-text-muted">(${boat.reviewCount})</span></div>`;
    }

    let tagsHtml = boat.tags.map(tag => `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-gray-50 border border-gray-200 text-[11px] text-text-muted">${escHtml(tag.label)}</span>`).join("");

    let perksHtml = "";
    if (boat.perks.includes("fuel")) perksHtml += `<p class="text-xs text-green-600 flex items-center gap-1">${checkSvg} Fuel included</p>`;
    if (boat.perks.includes("free-cancel")) perksHtml += `<p class="text-xs text-green-600 flex items-center gap-1">${checkSvg} Free cancellation</p>`;
    if (boat.perks.includes("flexible-cancel")) perksHtml += `<p class="text-xs text-green-600 flex items-center gap-1">${checkSvg} Flexible cancellation</p>`;

    return `<a href="/${getLangPrefix()}/boat/${escAttr(boat.id)}" class="boat-card block bg-white rounded-xl border border-gray-200/80 overflow-hidden hover:shadow-lg transition-shadow duration-200 group"
      data-boat-id="${escAttr(boat.id)}"
      data-boat-type="${escAttr(boat.type)}"
      data-price="${boat.price}"
      data-capacity="${boat.capacity}"
      data-cabins="${boat.cabins}"
      data-berths="${boat.berths}"
      data-length="${boat.length}"
      data-engine-power="${boat.enginePower}"
      data-year="${boat.year}"
      data-rating="${boat.rating}"
      data-super-owner="${boat.superOwner}"
      data-instant-booking="${boat.instantBooking}"
      data-free-cancel="${boat.perks.includes("free-cancel")}"
      data-ideal-for="${escAttr(boat.idealFor.join(","))}"
      data-equipment="${escAttr(boat.equipment.join(","))}"
      data-location="${escAttr(boat.location.toLowerCase())}"
      data-has-skipper="${hasSkipper}"
      data-no-licence="${noLicence}"
      data-listing-type="${listingType}"
      data-owner-id="${escAttr(boat.ownerId)}"
    >
      <div class="relative aspect-[4/3] overflow-hidden bg-gray-100 boat-card-image-area">
        ${imageHtml}
        ${dotsHtml}
        <div class="absolute top-3 left-3 flex gap-1.5">${badgesHtml}</div>
        <button class="favorite-btn absolute top-3 right-3 h-8 w-8 rounded-full bg-white/80 backdrop-blur-sm flex items-center justify-center hover:bg-white transition-colors text-gray-600"
          aria-label="Save to favorites"
          data-boat-id="${escAttr(boat.id)}"
          data-boat-title="${escAttr(boat.title)}"
          data-boat-image="${escAttr(mainImage)}"
          data-boat-location="${escAttr(boat.location)}"
          data-boat-price="${boat.price}"
          data-boat-price-unit="${escAttr(boat.priceUnit)}"
          data-boat-type-val="${escAttr(boat.type)}"
          data-boat-rating="${boat.rating}"
          data-boat-review-count="${boat.reviewCount}"
        ><svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg></button>
      </div>
      <div class="p-4">
        <div class="flex items-start justify-between gap-2 mb-1">
          <h3 class="text-sm font-semibold text-text truncate">${escHtml(boat.location)}</h3>
          ${ratingHtml}
        </div>
        <p class="text-xs text-text-muted truncate mb-2.5">${escHtml(boat.title)}</p>
        <div class="flex flex-wrap gap-1.5 mb-2.5">${tagsHtml}</div>
        <p class="text-xs text-text-muted mb-3">${escHtml(boat.specs)}</p>
        <div class="flex items-end justify-between border-t border-gray-100 pt-3">
          <div class="space-y-0.5">${perksHtml}</div>
          <div class="text-right">
            <span class="text-[11px] text-text-muted">From</span>
            <span class="text-base font-bold text-text ml-1">&euro;${boat.price.toLocaleString()}</span>
            ${boat.priceUnit ? `<span class="text-xs text-text-muted"> ${escHtml(boat.priceUnit)}</span>` : ""}
          </div>
        </div>
      </div>
    </a>`;
  }

  async function loadBoats(ownerUid?: string) {
    const trendingGrid = document.getElementById("trending-grid");
    const allBoatsGrid = document.getElementById("all-boats-grid");
    const trendingSection = document.getElementById("trending-section");
    const allBoatsSection = document.getElementById("all-boats-section");
    const noResults = document.getElementById("no-results");

    try {
      const promises: [Promise<any[]>, Promise<any[]>, Promise<any[]>] = [
        getFeaturedBoats(3),
        searchBoats({}, 20),
        ownerUid ? getOwnerBoats(ownerUid) : Promise.resolve([]),
      ];
      const [featured, all, ownerBoats] = await Promise.all(promises);

      // Merge owner boats into the all-boats list, deduplicating by ID
      const seenIds = new Set(all.map((b: any) => b.id));
      const extraOwnerBoats = ownerBoats.filter((b: any) => !seenIds.has(b.id));
      const merged = [...extraOwnerBoats, ...all];

      const trendingBoats = featured.map(mapBoat);
      const allBoats = merged.map(mapBoat);

      // Clear skeletons and render cards
      if (trendingGrid) {
        if (trendingBoats.length > 0) {
          trendingGrid.innerHTML = trendingBoats.map(renderBoatCard).join("");
        } else {
          trendingGrid.innerHTML = "";
          if (trendingSection) trendingSection.style.display = "none";
        }
      }

      if (allBoatsGrid) {
        if (allBoats.length > 0) {
          allBoatsGrid.innerHTML = allBoats.map(renderBoatCard).join("");
        } else {
          allBoatsGrid.innerHTML = "";
          if (allBoatsSection) allBoatsSection.style.display = "none";
        }
      }

      if (trendingBoats.length === 0 && allBoats.length === 0 && noResults) {
        noResults.classList.remove("hidden");
      }

      // Dispatch event so filter engine and favorites can re-bind
      document.dispatchEvent(new CustomEvent("boats-loaded"));
    } catch (err) {
      console.error("Error loading boats:", err);
      // Clear skeletons
      if (trendingGrid) trendingGrid.innerHTML = "";
      if (allBoatsGrid) allBoatsGrid.innerHTML = "";
      if (trendingSection) trendingSection.style.display = "none";
      if (noResults) noResults.classList.remove("hidden");
    }
  }

  // Load published boats immediately, then reload with owner boats once auth resolves
  loadBoats();
  onAuthStateChanged(auth, (user) => {
    if (user) loadBoats(user.uid);
  });
</script>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    // Dismiss banner
    var closeBanner = document.getElementById("close-banner");
    if (closeBanner) closeBanner.addEventListener("click", function () {
      var banner = document.getElementById("date-banner");
      if (banner) banner.remove();
    });

    // Mobile filter drawer
    var filterBtn = document.getElementById("mobile-filter-btn");
    var filterDrawer = document.getElementById("mobile-filter-drawer");
    var filterBackdrop = document.getElementById("filter-drawer-backdrop");
    var filterPanel = document.getElementById("filter-drawer-panel");
    var closeFilterBtn = document.getElementById("close-filter-drawer-btn");

    function openFilterDrawer() {
      if (!filterDrawer || !filterBackdrop || !filterPanel) return;
      filterDrawer.classList.remove("hidden");
      filterDrawer.setAttribute("aria-hidden", "false");
      filterBackdrop.classList.remove("opacity-0");
      filterBackdrop.classList.add("opacity-100");
      filterPanel.classList.remove("translate-y-full");
      filterPanel.classList.add("translate-y-0");
      document.body.style.overflow = "hidden";
    }

    function closeFilterDrawer() {
      if (!filterDrawer || !filterBackdrop || !filterPanel) return;
      filterBackdrop.classList.remove("opacity-100");
      filterBackdrop.classList.add("opacity-0");
      filterPanel.classList.remove("translate-y-0");
      filterPanel.classList.add("translate-y-full");
      document.body.style.overflow = "";
      setTimeout(function () {
        filterDrawer.classList.add("hidden");
        filterDrawer.setAttribute("aria-hidden", "true");
      }, 300);
    }

    if (filterBtn) filterBtn.addEventListener("click", openFilterDrawer);
    if (closeFilterBtn) closeFilterBtn.addEventListener("click", closeFilterDrawer);
    if (filterBackdrop) filterBackdrop.addEventListener("click", closeFilterDrawer);
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeFilterDrawer();
    });

    // URL param pre-filter (e.g. ?type=motor)
    var params = new URLSearchParams(window.location.search);
    var rawType = params.get("type") || "";
    var slugAliases = { motorboat: "motor", sailboat: "sailing", rib: "motor", houseboat: "motor" };
    var typeParam = slugAliases[rawType] || rawType;
    var validTypes = ["sailing", "motor", "catamaran", "yacht", "luxury", "party"];

    // If URL has ?type=, pre-check the matching boat type checkbox and show chip
    if (validTypes.indexOf(typeParam) !== -1) {
      var typeLabels = {
        sailing: "Sailing", motor: "Motor", catamaran: "Catamaran",
        yacht: "Yacht", luxury: "Luxury", party: "Party"
      };
      document.querySelectorAll(".filter-boat-type").forEach(function (cb) {
        if (cb.getAttribute("data-filter-value") === typeParam) {
          cb.checked = true;
        }
      });
      // Update breadcrumb
      var breadcrumbCurrent = document.getElementById("breadcrumb-current");
      var breadcrumbList = document.getElementById("breadcrumb-list");
      if (breadcrumbCurrent && breadcrumbList) {
        var separator = document.createElement("li");
        separator.textContent = "/";
        var link = document.createElement("li");
        var a = document.createElement("a");
        a.href = "/" + getLangPrefix() + "/boat-rental";
        a.className = "hover:text-primary transition-colors";
        a.textContent = "Boat rental";
        link.appendChild(a);
        breadcrumbList.insertBefore(link, breadcrumbCurrent);
        breadcrumbList.insertBefore(separator, breadcrumbCurrent);
        breadcrumbCurrent.textContent = typeLabels[typeParam];
      }
      // Show filter chip
      var filterChip = document.getElementById("filter-chip");
      var chipLabel = document.getElementById("filter-chip-label");
      if (filterChip) filterChip.classList.remove("hidden");
      if (chipLabel) chipLabel.textContent = typeLabels[typeParam];
    }

    // ==========================================
    // MAIN FILTER ENGINE
    // ==========================================
    function getFilterState() {
      // Boat types (collect from ALL sidebars — desktop + mobile)
      var boatTypes = [];
      document.querySelectorAll(".filter-boat-type:checked").forEach(function (cb) {
        var val = cb.getAttribute("data-filter-value");
        if (val && boatTypes.indexOf(val) === -1) boatTypes.push(val);
      });

      // Location search
      var locationSearch = "";
      var locationInput = document.querySelector(".filter-location");
      if (locationInput) locationSearch = locationInput.value.trim().toLowerCase();

      // Dates
      var dateStart = "";
      var dateEnd = "";
      var dateStartInput = document.querySelector(".filter-date-start");
      var dateEndInput = document.querySelector(".filter-date-end");
      if (dateStartInput) dateStart = dateStartInput.value;
      if (dateEndInput) dateEnd = dateEndInput.value;

      // Rental type
      var rentalType = "all";
      document.querySelectorAll(".filter-rental-type:checked").forEach(function (r) {
        rentalType = r.value;
      });

      // Listing type tab (rentals vs experiences)
      var listingType = "rentals";
      var activeTab = document.querySelector('.sidebar-tab.border-pink');
      if (activeTab) listingType = activeTab.getAttribute("data-tab") || "rentals";

      // Price range — take first sidebar's values (desktop or mobile, whichever exists)
      var priceMin = 0;
      var priceMax = 1200;
      var minSlider = document.querySelector(".filter-price-min");
      var maxSlider = document.querySelector(".filter-price-max");
      if (minSlider) priceMin = parseInt(minSlider.value) || 0;
      if (maxSlider) priceMax = parseInt(maxSlider.value) || 1200;

      // Steppers — take max value from any sidebar
      function getStepperVal(name) {
        var max = 0;
        document.querySelectorAll('.stepper-value[data-stepper="' + name + '"]').forEach(function (el) {
          var v = parseInt(el.textContent) || 0;
          if (v > max) max = v;
        });
        return max;
      }
      var people = getStepperVal("people");
      var cabins = getStepperVal("cabins");
      var berths = getStepperVal("berths");

      // Range sliders
      var length = 15;
      var lengthSlider = document.querySelector(".filter-length");
      if (lengthSlider) length = parseInt(lengthSlider.value) || 15;

      var engine = 400;
      var engineSlider = document.querySelector(".filter-engine");
      if (engineSlider) engine = parseInt(engineSlider.value) || 400;

      var year = 2006;
      var yearSlider = document.querySelector(".filter-year");
      if (yearSlider) year = parseInt(yearSlider.value) || 2006;

      // Toggles — true if ANY sidebar has it checked
      function isToggleOn(name) {
        var on = false;
        document.querySelectorAll('.filter-toggle[data-filter-toggle="' + name + '"]').forEach(function (t) {
          if (t.getAttribute("aria-checked") === "true") on = true;
        });
        return on;
      }
      var superOwner = isToggleOn("superOwner");
      var instantBooking = isToggleOn("instantBooking");
      var freeCancel = isToggleOn("freeCancel");
      var bestRated = isToggleOn("bestRated");

      // Ideal for checkboxes
      var idealFor = [];
      document.querySelectorAll(".filter-ideal-for:checked").forEach(function (cb) {
        var val = cb.getAttribute("data-filter-value");
        if (val && idealFor.indexOf(val) === -1) idealFor.push(val);
      });

      // Equipment checkboxes
      var equipment = [];
      document.querySelectorAll(".filter-equipment:checked").forEach(function (cb) {
        var val = cb.getAttribute("data-filter-value");
        if (val && equipment.indexOf(val) === -1) equipment.push(val);
      });

      return {
        boatTypes: boatTypes,
        locationSearch: locationSearch,
        dateStart: dateStart,
        dateEnd: dateEnd,
        rentalType: rentalType,
        listingType: listingType,
        priceMin: priceMin,
        priceMax: priceMax,
        people: people,
        cabins: cabins,
        berths: berths,
        length: length,
        engine: engine,
        year: year,
        superOwner: superOwner,
        instantBooking: instantBooking,
        freeCancel: freeCancel,
        bestRated: bestRated,
        idealFor: idealFor,
        equipment: equipment,
      };
    }

    function cardMatchesFilters(card, filters) {
      var type = card.getAttribute("data-boat-type") || "";
      var price = parseFloat(card.getAttribute("data-price")) || 0;
      var capacity = parseInt(card.getAttribute("data-capacity")) || 0;
      var cardCabins = parseInt(card.getAttribute("data-cabins")) || 0;
      var cardBerths = parseInt(card.getAttribute("data-berths")) || 0;
      var cardLength = parseFloat(card.getAttribute("data-length")) || 0;
      var cardEngine = parseInt(card.getAttribute("data-engine-power")) || 0;
      var cardYear = parseInt(card.getAttribute("data-year")) || 0;
      var cardRating = parseFloat(card.getAttribute("data-rating")) || 0;
      var cardSuperOwner = card.getAttribute("data-super-owner") === "true";
      var cardInstantBooking = card.getAttribute("data-instant-booking") === "true";
      var cardFreeCancel = card.getAttribute("data-free-cancel") === "true";
      var cardIdealFor = (card.getAttribute("data-ideal-for") || "").split(",").filter(Boolean);
      var cardEquipment = (card.getAttribute("data-equipment") || "").split(",").filter(Boolean);
      var cardLocation = card.getAttribute("data-location") || "";
      var cardHasSkipper = card.getAttribute("data-has-skipper") === "true";
      var cardNoLicence = card.getAttribute("data-no-licence") === "true";
      var cardListingType = card.getAttribute("data-listing-type") || "rental";

      // Listing type tab filter (rentals vs experiences)
      if (filters.listingType === "rentals" && cardListingType !== "rental") return false;
      if (filters.listingType === "experiences" && cardListingType !== "experience") return false;

      // Location filter
      if (filters.locationSearch && cardLocation.indexOf(filters.locationSearch) === -1) return false;

      // Rental type filter
      if (filters.rentalType === "with-skipper" && !cardHasSkipper) return false;
      if (filters.rentalType === "without-skipper" && cardHasSkipper) return false;
      if (filters.rentalType === "no-licence" && !cardNoLicence) return false;

      // Boat type filter
      if (filters.boatTypes.length > 0 && filters.boatTypes.indexOf(type) === -1) return false;

      // Price range
      if (price < filters.priceMin || price > filters.priceMax) return false;

      // Capacity
      if (filters.people > 1 && capacity < filters.people) return false;

      // Cabins
      if (filters.cabins > 0 && cardCabins < filters.cabins) return false;

      // Berths
      if (filters.berths > 0 && cardBerths < filters.berths) return false;

      // Length (max filter — show boats up to this length)
      if (filters.length < 15 && cardLength > filters.length) return false;

      // Engine (max filter — skip for boats with unset engine)
      if (cardEngine > 0 && filters.engine < 400 && cardEngine > filters.engine) return false;

      // Year (min filter — skip for boats with unset year)
      if (cardYear > 0 && cardYear < filters.year) return false;

      // Toggles
      if (filters.superOwner && !cardSuperOwner) return false;
      if (filters.instantBooking && !cardInstantBooking) return false;
      if (filters.freeCancel && !cardFreeCancel) return false;
      if (filters.bestRated && cardRating < 4) return false;

      // Ideal for (all selected must be present)
      for (var i = 0; i < filters.idealFor.length; i++) {
        if (cardIdealFor.indexOf(filters.idealFor[i]) === -1) return false;
      }

      // Equipment (all selected must be present)
      for (var j = 0; j < filters.equipment.length; j++) {
        if (cardEquipment.indexOf(filters.equipment[j]) === -1) return false;
      }

      return true;
    }

    function applyFilters() {
      var filters = getFilterState();
      var allCards = document.querySelectorAll(".boat-card");
      var totalVisible = 0;
      var trendingVisible = 0;
      var allBoatsVisible = 0;

      allCards.forEach(function (card) {
        var matches = cardMatchesFilters(card, filters);
        card.style.display = matches ? "" : "none";
        if (matches) {
          totalVisible++;
          // Check which grid this card is in
          if (card.closest("#trending-grid")) trendingVisible++;
          else if (card.closest("#all-boats-grid")) allBoatsVisible++;
        }
      });

      // Update section visibility
      var trendingSection = document.getElementById("trending-section");
      var allSection = document.getElementById("all-boats-section");
      var noResults = document.getElementById("no-results");
      var noResultsText = document.getElementById("no-results-text");
      var allHeading = document.getElementById("all-boats-heading");

      if (trendingSection) trendingSection.style.display = trendingVisible > 0 ? "" : "none";

      if (allSection) allSection.style.display = allBoatsVisible > 0 ? "" : "none";

      if (allHeading) {
        allHeading.textContent = allBoatsVisible + (allBoatsVisible === 1 ? " boat" : " boats") + " available";
      }

      if (noResults) {
        if (totalVisible === 0) {
          noResults.classList.remove("hidden");
          if (noResultsText) noResultsText.textContent = "We couldn't find any boats matching your filters. Try adjusting your criteria.";
        } else {
          noResults.classList.add("hidden");
        }
      }

      // Update mobile filter button count
      var activeCount = countActiveFilters(filters);
      var filterBtnEl = document.getElementById("mobile-filter-btn");
      if (filterBtnEl) {
        if (activeCount > 0) {
          filterBtnEl.innerHTML = '<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"/></svg> Filters (' + activeCount + ')';
        } else {
          filterBtnEl.innerHTML = '<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"/></svg> Filters';
        }
      }
    }

    function countActiveFilters(f) {
      var count = 0;
      if (f.locationSearch) count++;
      if (f.dateStart || f.dateEnd) count++;
      if (f.rentalType !== "all") count++;
      if (f.boatTypes.length > 0) count++;
      if (f.priceMin > 0 || f.priceMax < 1200) count++;
      if (f.people > 1) count++;
      if (f.cabins > 0) count++;
      if (f.berths > 0) count++;
      if (f.length < 15) count++;
      if (f.engine < 400) count++;
      if (f.year > 2006) count++;
      if (f.superOwner) count++;
      if (f.instantBooking) count++;
      if (f.freeCancel) count++;
      if (f.bestRated) count++;
      if (f.idealFor.length > 0) count++;
      if (f.equipment.length > 0) count++;
      return count;
    }

    // Dismiss date banner when dates are selected in sidebar filters
    // (Dates are informational only — no availability data to filter against yet)
    function updateDateBanner() {
      var filters = getFilterState();
      var banner = document.getElementById("date-banner");
      if (banner && (filters.dateStart || filters.dateEnd)) {
        banner.style.display = "none";
      }
    }

    // Listen for filter changes from sidebar
    document.addEventListener("filters-changed", function () {
      applyFilters();
      updateDateBanner();
    });

    // Run initial filter (handles ?type= URL param)
    applyFilters();

    // "Show more boats" button — reveal hidden cards
    var INITIAL_VISIBLE = 12;
    var loadMoreWrap = document.getElementById("load-more-wrap");
    var loadMoreBtn = loadMoreWrap ? loadMoreWrap.querySelector("button") : null;
    var showCount = INITIAL_VISIBLE;

    if (loadMoreBtn) {
      loadMoreBtn.addEventListener("click", function () {
        showCount += 12;
        var allBoatCards = document.querySelectorAll("#all-boats-grid .boat-card");
        allBoatCards.forEach(function (card) {
          if (card.style.display !== "none" || card.classList.contains("show-more-hidden")) {
            card.classList.remove("show-more-hidden");
            card.style.display = "";
          }
        });
        applyFilters();
      });
    }

    // ==========================================
    // BOAT CARD CAROUSEL + FAVORITES
    // ==========================================
    function initCarousels() {
      document.querySelectorAll(".boat-card").forEach(function (card) {
        if (card.getAttribute("data-carousel-init")) return;
        card.setAttribute("data-carousel-init", "1");

        var imgEl = card.querySelector(".boat-card-img");
        var dots = card.querySelectorAll(".carousel-dot");
        var images = [];
        dots.forEach(function (dot) {
          images.push(dot.getAttribute("data-img"));
        });
        if (images.length <= 1 || !imgEl) return;

        var currentIndex = 0;

        function showImage(idx) {
          currentIndex = idx;
          imgEl.src = images[idx];
          dots.forEach(function (d, i) {
            d.classList.toggle("bg-white", i === idx);
            d.classList.toggle("bg-white/50", i !== idx);
          });
        }

        dots.forEach(function (dot, i) {
          dot.addEventListener("click", function (e) {
            e.preventDefault();
            e.stopPropagation();
            showImage(i);
          });
        });

        // Swipe support
        var startX = 0;
        var imageArea = card.querySelector(".boat-card-image-area");
        if (imageArea) {
          imageArea.addEventListener("touchstart", function (e) {
            startX = e.touches[0].clientX;
          }, { passive: true });
          imageArea.addEventListener("touchend", function (e) {
            var diff = startX - e.changedTouches[0].clientX;
            if (Math.abs(diff) > 40) {
              if (diff > 0 && currentIndex < images.length - 1) showImage(currentIndex + 1);
              else if (diff < 0 && currentIndex > 0) showImage(currentIndex - 1);
            }
          }, { passive: true });
        }
      });
    }

    initCarousels();

    // Re-init when boats are loaded dynamically
    document.addEventListener("boats-loaded", function () {
      initCarousels();
      applyFilters();
    });

  });
</script>

<!-- Favorites: Firebase-backed toggle -->
<script>
  import { auth, db } from "../../lib/firebase";
  import { onAuthStateChanged } from "firebase/auth";
  import { doc, setDoc, deleteDoc, getDoc, collection, getDocs, serverTimestamp } from "firebase/firestore";

  let currentUser: any = null;
  // Set of favorited boat IDs for the current user
  const favoritedIds = new Set<string>();

  function setFavoriteVisual(btn: Element, isFav: boolean) {
    const svg = btn.querySelector("svg");
    if (!svg) return;
    if (isFav) {
      svg.setAttribute("fill", "currentColor");
      svg.setAttribute("stroke", "currentColor");
      btn.classList.remove("text-gray-600");
      btn.classList.add("text-pink");
    } else {
      svg.setAttribute("fill", "none");
      svg.setAttribute("stroke", "currentColor");
      btn.classList.remove("text-pink");
      btn.classList.add("text-gray-600");
    }
  }

  // Load user's favorites and mark hearts
  async function loadUserFavorites(uid: string) {
    try {
      const snap = await getDocs(collection(db, "users", uid, "favorites"));
      favoritedIds.clear();
      snap.docs.forEach((d) => favoritedIds.add(d.id));
      // Update all heart buttons
      document.querySelectorAll(".favorite-btn").forEach((btn) => {
        const boatId = btn.getAttribute("data-boat-id");
        if (boatId && favoritedIds.has(boatId)) {
          setFavoriteVisual(btn, true);
        }
      });
    } catch (err) {
      console.error("[Favorites] Error loading favorites:", err);
    }
  }

  // Hide/show own boats based on auth state
  function toggleOwnBoats(uid: string | null) {
    document.querySelectorAll(".boat-card").forEach((card) => {
      const ownerId = card.getAttribute("data-owner-id");
      if (ownerId && uid && ownerId === uid) {
        (card as HTMLElement).style.display = "none";
      } else {
        (card as HTMLElement).style.display = "";
      }
    });
  }

  onAuthStateChanged(auth, (user) => {
    currentUser = user;
    toggleOwnBoats(user?.uid || null);
    if (user) {
      loadUserFavorites(user.uid);
    } else {
      favoritedIds.clear();
      document.querySelectorAll(".favorite-btn").forEach((btn) => {
        setFavoriteVisual(btn, false);
      });
    }
  });

  // Attach click handlers to favorite buttons
  function bindFavoriteButtons() {
    document.querySelectorAll(".favorite-btn").forEach((btn) => {
      if (btn.getAttribute("data-fav-init")) return;
      btn.setAttribute("data-fav-init", "1");

      // Mark as favorited if already in set
      const boatId = btn.getAttribute("data-boat-id");
      if (boatId && favoritedIds.has(boatId)) {
        setFavoriteVisual(btn, true);
      }

      btn.addEventListener("click", async (e) => {
        e.preventDefault();
        e.stopPropagation();

        if (!currentUser) {
          window.location.href = "/" + getLangPrefix() + "/login?redirect=" + encodeURIComponent(window.location.pathname);
          return;
        }

        const boatId = btn.getAttribute("data-boat-id");
        if (!boatId) return;

        const isFav = favoritedIds.has(boatId);
        const favRef = doc(db, "users", currentUser.uid, "favorites", boatId);

        // Optimistic UI update
        if (isFav) {
          favoritedIds.delete(boatId);
          setFavoriteVisual(btn, false);
        } else {
          favoritedIds.add(boatId);
          setFavoriteVisual(btn, true);
        }

        try {
          if (isFav) {
            await deleteDoc(favRef);
          } else {
            await setDoc(favRef, {
              boatId,
              title: btn.getAttribute("data-boat-title") || "",
              image: btn.getAttribute("data-boat-image") || "",
              location: btn.getAttribute("data-boat-location") || "",
              price: parseFloat(btn.getAttribute("data-boat-price") || "0"),
              priceUnit: btn.getAttribute("data-boat-price-unit") || "/ day",
              type: btn.getAttribute("data-boat-type-val") || "",
              rating: parseFloat(btn.getAttribute("data-boat-rating") || "0"),
              reviewCount: parseInt(btn.getAttribute("data-boat-review-count") || "0"),
              addedAt: serverTimestamp(),
            });
          }
        } catch (err) {
          console.error("[Favorites] Error toggling favorite:", err);
          // Revert on error
          if (isFav) {
            favoritedIds.add(boatId);
            setFavoriteVisual(btn, true);
          } else {
            favoritedIds.delete(boatId);
            setFavoriteVisual(btn, false);
          }
        }
      });
    });
  }

  bindFavoriteButtons();

  // Re-bind when boats are loaded dynamically
  document.addEventListener("boats-loaded", () => {
    bindFavoriteButtons();
    toggleOwnBoats(currentUser?.uid || null);
  });
</script>
