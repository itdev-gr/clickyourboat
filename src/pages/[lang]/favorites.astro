---
import { getLangs, localizeHref } from "../../lib/i18n-utils";
export function getStaticPaths() { return getLangs(); }
const { lang } = Astro.params;
import Layout from "../../layouts/Layout.astro";

const title = "My Favorites — TapYourBoat";
const description = "View your saved favorite boats on TapYourBoat.";
const l = (href: string) => localizeHref(href, lang);
---
<Layout lang={lang} title={title} description={description}>
  <!-- Loading state -->
  <div id="auth-loading" class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <div class="h-8 w-8 border-2 border-primary border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
      <p class="text-sm text-text-muted">Loading...</p>
    </div>
  </div>

  <!-- Not logged in -->
  <div id="auth-gate" class="hidden">
    <div class="min-h-[60vh] flex items-center justify-center px-4 py-16">
      <div class="max-w-md w-full text-center">
        <div class="mx-auto mb-6 h-16 w-16 rounded-full bg-primary/10 flex items-center justify-center">
          <svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
          </svg>
        </div>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-text mb-3">Log in to view your favorites</h1>
        <p class="text-text-muted mb-8 max-w-sm mx-auto">Save boats you love and find them here anytime.</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href={l("/login?redirect=/favorites")} class="inline-flex items-center px-6 py-3 rounded-xl bg-primary text-white text-sm font-bold hover:bg-primary-dark transition-colors">Log in</a>
          <a href={l("/login?signup&redirect=/favorites")} class="inline-flex items-center px-6 py-3 rounded-xl border border-gray-200 text-sm font-semibold text-text hover:border-gray-400 transition-colors">Create account</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Favorites content -->
  <div id="favorites-content" class="hidden">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-2xl sm:text-3xl font-extrabold text-text">My Favorites</h1>
          <p id="favorites-count" class="text-text-muted mt-1"></p>
        </div>
        <a href={l("/boat-rental")} class="inline-flex items-center gap-2 px-4 py-2 rounded-xl border border-gray-200 text-sm font-semibold text-text hover:border-gray-400 transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
          Browse boats
        </a>
      </div>

      <!-- Loading favorites -->
      <div id="favorites-loading" class="flex items-center justify-center py-16">
        <div class="h-8 w-8 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
      </div>

      <!-- Empty state -->
      <div id="favorites-empty" class="hidden text-center py-16">
        <svg class="mx-auto h-20 w-20 text-gray-200 mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
        </svg>
        <h2 class="text-xl font-bold text-text mb-2">No favorites yet</h2>
        <p class="text-text-muted mb-6 max-w-sm mx-auto">Browse boats and tap the heart icon to save them here for later.</p>
        <a href={l("/boat-rental")} class="inline-flex items-center px-6 py-3 rounded-xl bg-primary text-white text-sm font-semibold hover:bg-primary-dark transition-colors">
          Browse boats
        </a>
      </div>

      <!-- Favorites grid -->
      <div id="favorites-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5"></div>
    </div>
  </div>
</Layout>

<script>
  import { auth, db } from "../../lib/firebase";
  import { onAuthStateChanged } from "firebase/auth";
  import { collection, query, orderBy, getDocs, deleteDoc, doc } from "firebase/firestore";

  const $ = (id: string) => document.getElementById(id);

  function escapeHtml(text: string): string {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }

  let fallbackTimer = setTimeout(() => {
    $("auth-loading")?.classList.add("hidden");
    $("auth-gate")?.classList.remove("hidden");
  }, 3000);

  onAuthStateChanged(auth, async (user) => {
    clearTimeout(fallbackTimer);

    if (!user) {
      $("auth-loading")?.classList.add("hidden");
      $("auth-gate")?.classList.remove("hidden");
      $("favorites-content")?.classList.add("hidden");
      return;
    }

    $("auth-loading")?.classList.add("hidden");
    $("auth-gate")?.classList.add("hidden");
    $("favorites-content")?.classList.remove("hidden");

    await loadFavorites(user.uid);
  });

  async function loadFavorites(uid: string) {
    const loadingEl = $("favorites-loading");
    const emptyEl = $("favorites-empty");
    const gridEl = $("favorites-grid");
    const countEl = $("favorites-count");

    try {
      const q = query(
        collection(db, "users", uid, "favorites"),
        orderBy("addedAt", "desc")
      );
      const snap = await getDocs(q);

      loadingEl?.classList.add("hidden");

      if (snap.empty) {
        emptyEl?.classList.remove("hidden");
        if (countEl) countEl.textContent = "0 saved boats";
        return;
      }

      if (countEl) {
        countEl.textContent = `${snap.size} saved boat${snap.size !== 1 ? "s" : ""}`;
      }

      let html = "";
      snap.docs.forEach((docSnap) => {
        const fav = docSnap.data();
        const boatId = docSnap.id;
        const title = fav.title || "Untitled boat";
        const image = fav.image || "";
        const location = fav.location || "";
        const price = fav.price || 0;
        const priceUnit = fav.priceUnit || "/ day";
        const type = fav.type || "";
        const rating = fav.rating || 0;
        const reviewCount = fav.reviewCount || 0;

        html += `
          <div class="favorite-card bg-white rounded-xl border border-gray-200/80 overflow-hidden hover:shadow-lg transition-shadow duration-200 group" data-boat-id="${escapeHtml(boatId)}">
            <a href={l("/boat/${escapeHtml(boatId)}")} class="block">
              <div class="relative aspect-[4/3] overflow-hidden bg-gray-100">
                ${image
                  ? `<img src="${escapeHtml(image)}" alt="${escapeHtml(title)}" class="h-full w-full object-cover" loading="lazy" />`
                  : `<div class="h-full w-full flex items-center justify-center text-gray-300"><svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a2.25 2.25 0 002.25-2.25V5.25a2.25 2.25 0 00-2.25-2.25H3.75a2.25 2.25 0 00-2.25 2.25v13.5a2.25 2.25 0 002.25 2.25z"/></svg></div>`}
                ${type ? `<span class="absolute top-3 left-3 px-2.5 py-1 rounded-full bg-gray-800 text-white text-xs font-semibold capitalize">${escapeHtml(type)}</span>` : ""}
              </div>
              <div class="p-4">
                <div class="flex items-start justify-between gap-2 mb-1">
                  <h3 class="text-sm font-semibold text-text truncate">${escapeHtml(location)}</h3>
                  ${rating > 0 ? `
                    <div class="flex items-center gap-1 flex-shrink-0">
                      <svg class="h-3.5 w-3.5 text-pink" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                      <span class="text-xs font-semibold text-text">${rating}</span>
                      ${reviewCount > 0 ? `<span class="text-xs text-text-muted">(${reviewCount})</span>` : ""}
                    </div>
                  ` : ""}
                </div>
                <p class="text-xs text-text-muted truncate mb-3">${escapeHtml(title)}</p>
                <div class="flex items-end justify-between border-t border-gray-100 pt-3">
                  <button class="remove-fav-btn text-xs text-red-500 hover:text-red-700 transition-colors flex items-center gap-1" data-boat-id="${escapeHtml(boatId)}">
                    <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
                    Remove
                  </button>
                  <div class="text-right">
                    <span class="text-[11px] text-text-muted">From</span>
                    <span class="text-base font-bold text-text ml-1">&euro;${price.toLocaleString()}</span>
                    ${priceUnit ? `<span class="text-xs text-text-muted"> ${escapeHtml(priceUnit)}</span>` : ""}
                  </div>
                </div>
              </div>
            </a>
          </div>
        `;
      });

      if (gridEl) gridEl.innerHTML = html;

      // Attach remove handlers
      document.querySelectorAll(".remove-fav-btn").forEach((btn) => {
        btn.addEventListener("click", async (e) => {
          e.preventDefault();
          e.stopPropagation();
          const boatId = (btn as HTMLElement).dataset.boatId;
          if (!boatId) return;

          const card = (btn as HTMLElement).closest(".favorite-card");
          if (card) {
            (card as HTMLElement).style.opacity = "0.5";
            (card as HTMLElement).style.pointerEvents = "none";
          }

          try {
            await deleteDoc(doc(db, "users", uid, "favorites", boatId));
            card?.remove();

            // Update count
            const remaining = document.querySelectorAll(".favorite-card").length;
            if (countEl) {
              countEl.textContent = `${remaining} saved boat${remaining !== 1 ? "s" : ""}`;
            }
            if (remaining === 0) {
              emptyEl?.classList.remove("hidden");
            }
          } catch (err) {
            console.error("[Favorites] Error removing favorite:", err);
            if (card) {
              (card as HTMLElement).style.opacity = "1";
              (card as HTMLElement).style.pointerEvents = "";
            }
          }
        });
      });
    } catch (err) {
      console.error("[Favorites] Error loading favorites:", err);
      loadingEl?.classList.add("hidden");
      emptyEl?.classList.remove("hidden");
    }
  }
</script>
