---
import { getLangs, localizeHref } from "../../lib/i18n-utils";
export function getStaticPaths() { return getLangs(); }
const { lang } = Astro.params;
import Layout from "../../layouts/Layout.astro";

const title = "Reset Password — BoatHaven";
const description = "Reset your BoatHaven account password.";
const l = (href: string) => localizeHref(href, lang);
---
<Layout lang={lang} title={title} description={description}>
  <div class="min-h-[calc(100vh-64px)] flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
      <!-- Logo -->
      <a href={l("/")} class="flex items-center mb-8">
        <img src="/tap-your-boat.svg" alt="Tap Your Boat" class="h-10" />
      </a>

      <h1 class="text-2xl sm:text-3xl font-extrabold text-text mb-2" data-i18n="auth.reset_title">Reset your password</h1>
      <p class="text-text-muted mb-6" data-i18n="auth.reset_desc">Enter your email address and we'll send you a link to reset your password.</p>

      <!-- Reset form -->
      <form id="reset-form" class="space-y-4">
        <div>
          <label for="reset-email" class="block text-sm font-medium text-text mb-1.5" data-i18n="auth.email">Email address</label>
          <input
            type="email"
            id="reset-email"
            name="email"
            required
            autocomplete="email"
            placeholder="you@example.com"
            data-i18n-placeholder="auth.placeholder_email"
            class="w-full rounded-xl border border-gray-200 bg-surface px-4 py-3 text-sm text-text placeholder:text-text-muted/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
          />
        </div>
        <p id="reset-error" class="text-sm text-red-500 hidden"></p>
        <p id="reset-success" class="text-sm text-green-600 hidden"></p>
        <button
          type="submit"
          id="reset-btn"
          class="w-full rounded-xl bg-primary px-4 py-3 text-sm font-bold text-white hover:bg-primary-dark transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
        >
          <span data-i18n="auth.reset_send">Send reset link</span>
        </button>
      </form>

      <p class="mt-6 text-center text-sm text-text-muted">
        <span data-i18n="auth.remember_password">Remember your password?</span>
        <a href={l("/login")} class="font-semibold text-primary hover:text-primary-dark transition-colors" data-i18n="auth.switch_login">Log in</a>
      </p>
    </div>
  </div>
</Layout>

<script>
  import { auth } from "../../lib/firebase";
  import { sendPasswordResetEmail } from "firebase/auth";

  function tr(key: string, fallback: string): string {
    const i18n = (window as any).__i18n;
    if (!i18n?.translations?.[key]) return fallback;
    const lang = i18n.getLang?.() || "en";
    return i18n.translations[key][lang] || fallback;
  }

  const form = document.getElementById("reset-form") as HTMLFormElement;
  const errorEl = document.getElementById("reset-error") as HTMLParagraphElement;
  const successEl = document.getElementById("reset-success") as HTMLParagraphElement;
  const submitBtn = document.getElementById("reset-btn") as HTMLButtonElement;
  const btnText = submitBtn?.querySelector("[data-i18n]") || submitBtn;
  const originalBtnText = btnText?.textContent || "";

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl.classList.add("hidden");
    successEl.classList.add("hidden");

    const email = (form.elements.namedItem("email") as HTMLInputElement).value;

    submitBtn.disabled = true;
    btnText.textContent = tr("auth.reset_sending", "Sending...");
    submitBtn.classList.add("opacity-70", "cursor-not-allowed");

    try {
      await sendPasswordResetEmail(auth, email);
      successEl.textContent = tr("auth.reset_success", "Password reset email sent! Check your inbox (and spam folder).");
      successEl.classList.remove("hidden");
      form.reset();
    } catch (err: any) {
      if (err.code === "auth/user-not-found") {
        successEl.textContent = tr("auth.reset_success_generic", "If an account exists with this email, you'll receive a reset link shortly.");
        successEl.classList.remove("hidden");
      } else if (err.code === "auth/invalid-email") {
        errorEl.textContent = tr("auth.err_invalid_email", "Please enter a valid email address.");
        errorEl.classList.remove("hidden");
      } else if (err.code === "auth/too-many-requests") {
        errorEl.textContent = tr("auth.reset_too_many", "Too many requests. Please try again later.");
        errorEl.classList.remove("hidden");
      } else {
        errorEl.textContent = tr("auth.err_generic", "Something went wrong. Please try again.");
        errorEl.classList.remove("hidden");
      }
    } finally {
      submitBtn.disabled = false;
      btnText.textContent = originalBtnText;
      submitBtn.classList.remove("opacity-70", "cursor-not-allowed");
    }
  });
</script>
