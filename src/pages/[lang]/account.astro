---
import { getLangs, localizeHref } from "../../lib/i18n-utils";
export function getStaticPaths() { return getLangs(); }
const { lang } = Astro.params;
import Layout from "../../layouts/Layout.astro";

const title = "Profile — TapYourBoat";
const description = "Manage your TapYourBoat profile, personal information, boating experience, payment methods, and account settings.";
const l = (href: string) => localizeHref(href, lang);
---
<Layout lang={lang} title={title} description={description}>
  <!-- Loading state -->
  <div id="auth-loading" class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <div class="h-8 w-8 border-2 border-primary border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
      <p class="text-sm text-text-muted" data-i18n="common.loading">Loading...</p>
    </div>
  </div>

  <!-- Not logged in -->
  <div id="auth-gate" class="hidden">
    <div class="min-h-[60vh] flex items-center justify-center px-4 py-16">
      <div class="max-w-md w-full text-center">
        <div class="mx-auto mb-6 h-16 w-16 rounded-full bg-primary/10 flex items-center justify-center">
          <svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
        </div>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-text mb-3">Log in to view your profile</h1>
        <p class="text-text-muted mb-8 max-w-sm mx-auto">You need to be logged in to manage your profile.</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href={l("/login?redirect=/account")} class="inline-flex items-center px-6 py-3 rounded-xl bg-primary text-white text-sm font-bold hover:bg-primary-dark transition-colors">Log in</a>
          <a href={l("/login?signup&redirect=/account")} class="inline-flex items-center px-6 py-3 rounded-xl border border-gray-200 text-sm font-semibold text-text hover:border-gray-400 transition-colors">Create account</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Profile content -->
  <div id="profile-content" class="hidden">
    <div class="flex min-h-[calc(100vh-64px)]">

      <!-- ===== Left Sidebar ===== -->
      <aside class="hidden lg:flex flex-col w-72 bg-gray-800 text-white flex-shrink-0">
        <div class="flex flex-col items-center pt-10 pb-6 px-6 border-b border-gray-700">
          <div id="sidebar-avatar" class="h-24 w-24 rounded-full bg-gray-600 flex items-center justify-center text-2xl font-bold text-white mb-4 overflow-hidden">
            <img id="sidebar-avatar-img" class="h-full w-full object-cover hidden" alt="" />
            <span id="sidebar-avatar-initials"></span>
          </div>
          <h2 id="sidebar-name" class="text-lg font-bold text-center"></h2>
        </div>
        <nav class="flex-1 py-4 px-3 space-y-0.5">
          <a href={l("/dashboard")} class="sidebar-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
            Dashboard
          </a>
          <a href={l("/account")} class="sidebar-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium bg-gray-700 text-white transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
            Profile
          </a>
          <a href={l("/messages")} class="sidebar-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            Messages
          </a>
          <a id="sidebar-my-offers" href={l("/my-offers")} class="sidebar-link hidden items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
            My Offers
          </a>
          <a href={l("/bookings")} class="sidebar-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
            Bookings
          </a>
          <a href={l("/list-your-boat")} class="sidebar-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
            Listings
          </a>
          <a id="sidebar-payment" href={l("/account")} class="sidebar-link hidden items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/></svg>
            Payment information
          </a>
          <a href={l("/favorites")} class="sidebar-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
            Favourites
          </a>
          <div class="pt-2 mt-2 border-t border-gray-700">
            <button id="sidebar-logout-btn" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-gray-400 hover:bg-gray-700 hover:text-white transition-colors w-full">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9"/></svg>
              Log out
            </button>
          </div>
        </nav>
      </aside>

      <!-- ===== Main Content ===== -->
      <main class="flex-1 bg-gray-50 overflow-y-auto">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

          <h1 class="text-2xl font-bold text-text mb-6">Complete your profile</h1>

          <!-- Tabs -->
          <div class="flex gap-6 border-b border-gray-200 mb-8 overflow-x-auto">
            <button class="profile-tab pb-3 text-sm font-medium border-b-2 border-text text-text whitespace-nowrap" data-section="information">Information</button>
            <button class="profile-tab pb-3 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-text whitespace-nowrap transition-colors" data-section="experience">Boating experience level</button>
            <button class="profile-tab pb-3 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-text whitespace-nowrap transition-colors" data-section="payment">Payment methods</button>
            <button class="profile-tab pb-3 text-sm font-medium border-b-2 border-transparent text-text-muted hover:text-text whitespace-nowrap transition-colors" data-section="password">Password</button>
          </div>

          <!-- ===== SECTION: Personal Information ===== -->
          <div id="section-information">
            <div class="bg-white rounded-xl border border-gray-200 p-6 sm:p-8 mb-8">
              <h2 class="text-lg font-bold text-text mb-6">Personal information</h2>

              <!-- Avatar -->
              <div class="flex flex-col items-center mb-8">
                <div id="profile-avatar-wrap" class="h-32 w-32 rounded-full bg-gray-100 flex items-center justify-center text-3xl font-bold text-gray-400 mb-3 overflow-hidden">
                  <img id="profile-avatar-img" class="h-full w-full object-cover hidden" alt="" />
                  <span id="profile-avatar-initials"></span>
                </div>
                <p class="text-sm font-medium text-text">Change your photo</p>
                <p class="text-xs text-text-muted">Minimum size: 260px x 260px</p>
                <label class="mt-3 w-full max-w-sm cursor-pointer">
                  <span class="block w-full text-center px-6 py-3 rounded-xl bg-pink text-white text-sm font-bold hover:bg-pink/90 transition-colors">Select an image</span>
                  <input type="file" accept="image/*" class="hidden" id="avatar-upload" />
                </label>
              </div>

              <!-- Form fields -->
              <form id="personal-info-form" class="space-y-5">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-text mb-1.5">First name</label>
                    <input type="text" name="firstName" id="pf-firstName" class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-text mb-1.5">Surname</label>
                    <input type="text" name="lastName" id="pf-lastName" class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
                  </div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-text mb-1.5">Email</label>
                    <input type="email" name="email" id="pf-email" class="w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-text-muted cursor-not-allowed" readonly />
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-text mb-1.5">Gender</label>
                    <select name="gender" id="pf-gender" class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent appearance-none bg-white">
                      <option value="">Select...</option>
                      <option value="male">Male</option>
                      <option value="female">Female</option>
                      <option value="other">Other</option>
                    </select>
                  </div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-text mb-1.5">Date of birth</label>
                    <div class="grid grid-cols-3 gap-2">
                      <select name="birthDay" id="pf-birthDay" class="rounded-xl border border-gray-200 px-3 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary appearance-none bg-white">
                        <option value="">Day</option>
                        {Array.from({length: 31}, (_, i) => i + 1).map(d => <option value={String(d)}>{d}</option>)}
                      </select>
                      <select name="birthMonth" id="pf-birthMonth" class="rounded-xl border border-gray-200 px-3 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary appearance-none bg-white">
                        <option value="">Month</option>
                        {["January","February","March","April","May","June","July","August","September","October","November","December"].map((m, i) => <option value={String(i + 1)}>{m}</option>)}
                      </select>
                      <select name="birthYear" id="pf-birthYear" class="rounded-xl border border-gray-200 px-3 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary appearance-none bg-white">
                        <option value="">Year</option>
                        {Array.from({length: 80}, (_, i) => 2008 - i).map(y => <option value={String(y)}>{y}</option>)}
                      </select>
                    </div>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-text mb-1.5">Language spoken</label>
                    <select name="language" id="pf-language" class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent appearance-none bg-white">
                      <option value="">Select...</option>
                      <option value="en">English</option>
                      <option value="el">Greek</option>
                      <option value="fr">French</option>
                      <option value="de">German</option>
                      <option value="it">Italian</option>
                      <option value="es">Spanish</option>
                      <option value="pt">Portuguese</option>
                      <option value="nl">Dutch</option>
                      <option value="tr">Turkish</option>
                      <option value="hr">Croatian</option>
                    </select>
                  </div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-text mb-1.5">Telephone</label>
                    <div class="grid grid-cols-5 gap-2">
                      <select name="phoneCountry" id="pf-phoneCountry" class="col-span-2 rounded-xl border border-gray-200 px-3 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary appearance-none bg-white">
                        <option value="+30">Greece +30</option>
                        <option value="+1">US +1</option>
                        <option value="+44">UK +44</option>
                        <option value="+33">France +33</option>
                        <option value="+49">Germany +49</option>
                        <option value="+39">Italy +39</option>
                        <option value="+34">Spain +34</option>
                        <option value="+90">Turkey +90</option>
                        <option value="+385">Croatia +385</option>
                      </select>
                      <input type="tel" name="phone" id="pf-phone" placeholder="Phone number" pattern="[0-9\s\-\+\(\)]{6,20}" title="Please enter a valid phone number (digits, spaces, dashes, or parentheses)" class="col-span-3 rounded-xl border border-gray-200 px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
                    </div>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-text mb-1.5">Address</label>
                    <input type="text" name="address" id="pf-address" class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
                  </div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-text mb-1.5">Postal code</label>
                    <input type="text" name="postalCode" id="pf-postalCode" class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-text mb-1.5">City</label>
                    <input type="text" name="city" id="pf-city" class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
                  </div>
                </div>

                <!-- Company divider -->
                <div class="relative py-4">
                  <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
                  <div class="relative flex justify-center"><span class="bg-white px-4 text-sm font-semibold text-text">Company</span></div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-text mb-1.5">Company</label>
                    <input type="text" name="company" id="pf-company" class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-text mb-1.5">Address</label>
                    <input type="text" name="companyAddress" id="pf-companyAddress" class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
                  </div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-text mb-1.5">SIRET</label>
                    <input type="text" name="siret" id="pf-siret" class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-text mb-1.5">Intracommunity VAT</label>
                    <input type="text" name="vatNumber" id="pf-vatNumber" class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
                  </div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-text mb-1.5">Website</label>
                    <input type="url" name="website" id="pf-website" class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-text mb-1.5">Booking Management System</label>
                    <input type="text" name="bookingSystem" id="pf-bookingSystem" class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
                  </div>
                </div>

                <div class="flex justify-end">
                  <button type="submit" class="px-8 py-3 rounded-xl bg-pink text-white text-sm font-bold hover:bg-pink/90 transition-colors">Save</button>
                </div>
                <p id="info-success" class="text-sm text-green-600 text-right hidden">Profile saved successfully.</p>
                <p id="info-error" class="text-sm text-red-500 text-right hidden"></p>
              </form>
            </div>
          </div>

          <!-- ===== SECTION: Boating Experience ===== -->
          <div id="section-experience" class="hidden">
            <div class="bg-white rounded-xl border border-gray-200 p-6 sm:p-8 mb-8">
              <h2 class="text-lg font-bold text-text mb-6">Your nautical level</h2>
              <form id="experience-form" class="space-y-5">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-text mb-1.5">Your level</label>
                    <select name="nauticalLevel" id="pf-nauticalLevel" class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary appearance-none bg-white">
                      <option value="">Select...</option>
                      <option value="beginner">Beginner</option>
                      <option value="intermediate">Intermediate</option>
                      <option value="advanced">Advanced</option>
                      <option value="pro">Pro</option>
                    </select>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-text mb-1.5">You prefer</label>
                    <select name="boatPreference" id="pf-boatPreference" class="w-full rounded-xl border border-gray-200 px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary appearance-none bg-white">
                      <option value="">Select...</option>
                      <option value="motorboat">Motorboat</option>
                      <option value="sailboat">Sailboat</option>
                      <option value="catamaran">Catamaran</option>
                      <option value="yacht">Yacht</option>
                      <option value="rib">RIB</option>
                    </select>
                  </div>
                </div>

                <!-- Licences & experience checkboxes -->
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                  <div>
                    <p class="text-sm font-medium text-text mb-3">Your boat licence</p>
                    <div class="space-y-2.5">
                      {["Coastal license", "Offshore license", "Inland license"].map(l => (
                        <label class="flex items-center gap-2.5 cursor-pointer">
                          <input type="checkbox" name="licences" value={l} class="h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" />
                          <span class="text-sm text-text">{l}</span>
                        </label>
                      ))}
                    </div>
                  </div>
                  <div>
                    <p class="text-sm font-medium text-text mb-3">Other</p>
                    <div class="space-y-2.5">
                      {["Radio operator's certificate", "Professional skipper licence"].map(l => (
