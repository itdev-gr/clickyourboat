<!-- Tab switching & auth gate -->
<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    // Tab switching
    var tabs = document.querySelectorAll(".profile-tab");
    var sections = ["information", "experience", "payment", "password"];

    function showSection(name) {
      sections.forEach(function (s) {
        var el = document.getElementById("section-" + s);
        if (el) el.classList.toggle("hidden", s !== name);
      });
      tabs.forEach(function (t) {
        var active = t.getAttribute("data-section") === name;
        t.classList.toggle("border-text", active);
        t.classList.toggle("text-text", active);
        t.classList.toggle("border-transparent", !active);
        t.classList.toggle("text-text-muted", !active);
      });
    }

    tabs.forEach(function (tab) {
      tab.addEventListener("click", function () {
        showSection(tab.getAttribute("data-section"));
      });
    });
  });
</script>

<!-- Firebase auth & Firestore -->
<script>
  function getLangPrefix() { return document.documentElement.dataset.langPrefix || "en"; }
  import { auth, db } from "../../lib/firebase";
  import { onAuthStateChanged, signOut, updatePassword, reauthenticateWithCredential, EmailAuthProvider } from "firebase/auth";
  import { doc, getDoc, setDoc, serverTimestamp } from "firebase/firestore";

  function getInitials(name: string | null): string {
    if (!name) return "?";
    return name.split(" ").map(w => w[0]).join("").toUpperCase().slice(0, 2);
  }

  // Auth gate
  let fallbackTimer = setTimeout(() => {
    document.getElementById("auth-loading")?.classList.add("hidden");
    document.getElementById("auth-gate")?.classList.remove("hidden");
  }, 3000);

  onAuthStateChanged(auth, async (user) => {
    clearTimeout(fallbackTimer);
    const loading = document.getElementById("auth-loading");
    const gate = document.getElementById("auth-gate");
    const content = document.getElementById("profile-content");

    if (!user) {
      loading?.classList.add("hidden");
      gate?.classList.remove("hidden");
      content?.classList.add("hidden");
      return;
    }

    // Show profile
    loading?.classList.add("hidden");
    gate?.classList.add("hidden");
    content?.classList.remove("hidden");

    // Set sidebar info
    const initials = getInitials(user.displayName);
    const displayName = user.displayName || user.email || "User";
    const sidebarName = document.getElementById("sidebar-name");
    const sidebarInitials = document.getElementById("sidebar-avatar-initials");
    const sidebarImg = document.getElementById("sidebar-avatar-img") as HTMLImageElement;
    const profileInitials = document.getElementById("profile-avatar-initials");
    const profileImg = document.getElementById("profile-avatar-img") as HTMLImageElement;

    if (sidebarName) sidebarName.textContent = displayName;
    if (sidebarInitials) sidebarInitials.textContent = initials;
    if (profileInitials) profileInitials.textContent = initials;

    if (user.photoURL) {
      if (sidebarImg) { sidebarImg.src = user.photoURL; sidebarImg.classList.remove("hidden"); }
      if (profileImg) { profileImg.src = user.photoURL; profileImg.classList.remove("hidden"); }
    }

    // Pre-fill email
    const emailField = document.getElementById("pf-email") as HTMLInputElement;
    if (emailField) emailField.value = user.email || "";

    // Pre-fill name
    const firstNameField = document.getElementById("pf-firstName") as HTMLInputElement;
    const lastNameField = document.getElementById("pf-lastName") as HTMLInputElement;
    if (user.displayName) {
      const parts = user.displayName.split(" ");
      if (firstNameField) firstNameField.value = parts[0] || "";
      if (lastNameField) lastNameField.value = parts.slice(1).join(" ") || "";
    }

    // Load Firestore profile data
    try {
      const userDoc = await getDoc(doc(db, "users", user.uid));
      if (userDoc.exists()) {
        const data = userDoc.data();
        // Show owner/admin sidebar items
        const userType = data.type || "user";
        if (userType === "owner" || userType === "admin") {
          document.getElementById("sidebar-my-offers")?.classList.remove("hidden");
          document.getElementById("sidebar-my-offers")?.classList.add("flex");
          document.getElementById("sidebar-payment")?.classList.remove("hidden");
          document.getElementById("sidebar-payment")?.classList.add("flex");
        }
        const fields: Record<string, string> = {
          "pf-firstName": data.firstName || "",
          "pf-lastName": data.lastName || "",
          "pf-gender": data.gender || "",
          "pf-birthDay": data.birthDay || "",
          "pf-birthMonth": data.birthMonth || "",
          "pf-birthYear": data.birthYear || "",
          "pf-language": data.language || "",
          "pf-phoneCountry": data.phoneCountry || "+30",
          "pf-phone": data.phone || "",
          "pf-address": data.address || "",
          "pf-postalCode": data.postalCode || "",
          "pf-city": data.city || "",
          "pf-company": data.company || "",
          "pf-companyAddress": data.companyAddress || "",
          "pf-siret": data.siret || "",
          "pf-vatNumber": data.vatNumber || "",
          "pf-website": data.website || "",
          "pf-bookingSystem": data.bookingSystem || "",
          "pf-nauticalLevel": data.nauticalLevel || "",
          "pf-boatPreference": data.boatPreference || "",
          "pf-description": data.description || "",
          "pf-paymentType": data.paymentType || "iban",
          "pf-bankHolder": data.bankHolder || "",
          "pf-iban": data.iban || "",
          "pf-bic": data.bic || "",
          "pf-downpayment": data.downpayment || "",
          "pf-balanceDays": data.balanceDays || "",
        };
        Object.entries(fields).forEach(([id, val]) => {
          const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;
          if (el && val) el.value = val;
        });
        // Checkboxes
        (data.licences || []).forEach((v: string) => {
          const cb = document.querySelector(`input[name="licences"][value="${v}"]`) as HTMLInputElement;
          if (cb) cb.checked = true;
        });
        (data.otherCerts || []).forEach((v: string) => {
          const cb = document.querySelector(`input[name="otherCerts"][value="${v}"]`) as HTMLInputElement;
          if (cb) cb.checked = true;
        });
        (data.sailingExp || []).forEach((v: string) => {
          const cb = document.querySelector(`input[name="sailingExp"][value="${v}"]`) as HTMLInputElement;
          if (cb) cb.checked = true;
        });
        if (data.smsNotifications) {
          const cb = document.getElementById("pf-smsNotifications") as HTMLInputElement;
          if (cb) cb.checked = true;
        }
      }
    } catch (err) {
      console.error("[Profile] Error loading user data:", err);
    }
  });

  // Save personal info
  document.getElementById("personal-info-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const user = auth.currentUser;
    if (!user) return;
    const form = e.target as HTMLFormElement;
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = "Saving...";
    try {
      const data: Record<string, any> = {};
      ["firstName","lastName","gender","birthDay","birthMonth","birthYear","language","phoneCountry","phone","address","postalCode","city","company","companyAddress","siret","vatNumber","website","bookingSystem"].forEach(name => {
        const el = form.elements.namedItem(name) as HTMLInputElement;
        if (el) data[name] = el.value;
      });
      data.displayName = `${data.firstName || ""} ${data.lastName || ""}`.trim();
      data.updatedAt = serverTimestamp();
      await setDoc(doc(db, "users", user.uid), data, { merge: true });
      document.getElementById("info-success")?.classList.remove("hidden");
      setTimeout(() => document.getElementById("info-success")?.classList.add("hidden"), 3000);
    } catch (err: any) {
      const errEl = document.getElementById("info-error");
      if (errEl) { errEl.textContent = "Failed to save your changes. Please try again."; errEl.classList.remove("hidden"); }
    }
    btn.disabled = false; btn.textContent = "Save";
  });

  // Save experience
  document.getElementById("experience-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const user = auth.currentUser;
    if (!user) return;
    const form = e.target as HTMLFormElement;
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = "Saving...";
    try {
      const getChecked = (name: string) => Array.from(form.querySelectorAll(`input[name="${name}"]:checked`)).map((c: any) => c.value);
      const data: Record<string, any> = {
        nauticalLevel: (form.elements.namedItem("nauticalLevel") as HTMLSelectElement).value,
        boatPreference: (form.elements.namedItem("boatPreference") as HTMLSelectElement).value,
        description: (form.elements.namedItem("description") as HTMLTextAreaElement).value,
        licences: getChecked("licences"),
        otherCerts: getChecked("otherCerts"),
        sailingExp: getChecked("sailingExp"),
        updatedAt: serverTimestamp(),
      };
      await setDoc(doc(db, "users", user.uid), data, { merge: true });
      document.getElementById("exp-success")?.classList.remove("hidden");
      setTimeout(() => document.getElementById("exp-success")?.classList.add("hidden"), 3000);
    } catch (err: any) {
      const errEl = document.getElementById("exp-error");
      if (errEl) { errEl.textContent = "Failed to save your changes. Please try again."; errEl.classList.remove("hidden"); }
    }
    btn.disabled = false; btn.textContent = "Save";
  });

  // Change password
  document.getElementById("password-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const user = auth.currentUser;
    if (!user || !user.email) return;
    const form = e.target as HTMLFormElement;
    const oldPw = (form.elements.namedItem("oldPassword") as HTMLInputElement).value;
    const newPw = (form.elements.namedItem("newPassword") as HTMLInputElement).value;
    const confirmPw = (form.elements.namedItem("confirmNewPassword") as HTMLInputElement).value;
    const errEl = document.getElementById("pw-error");
    const successEl = document.getElementById("pw-success");
    errEl?.classList.add("hidden"); successEl?.classList.add("hidden");

    if (newPw !== confirmPw) {
      if (errEl) { errEl.textContent = "New passwords do not match."; errEl.classList.remove("hidden"); }
      return;
    }
    if (newPw.length < 8) {
      if (errEl) { errEl.textContent = "Password must be at least 8 characters."; errEl.classList.remove("hidden"); }
      return;
    }

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = "Saving...";
    try {
      const credential = EmailAuthProvider.credential(user.email, oldPw);
      await reauthenticateWithCredential(user, credential);
      await updatePassword(user, newPw);
      successEl?.classList.remove("hidden");
      form.reset();
      setTimeout(() => successEl?.classList.add("hidden"), 3000);
    } catch (err: any) {
      if (errEl) {
        if (err.code === "auth/wrong-password" || err.code === "auth/invalid-credential") {
          errEl.textContent = "Old password is incorrect.";
        } else {
          errEl.textContent = err.code === "auth/weak-password"
            ? "New password is too weak. Use at least 6 characters."
            : err.code === "auth/requires-recent-login"
            ? "Please log out and log back in before changing your password."
            : "Something went wrong. Please try again.";
        }
        errEl.classList.remove("hidden");
      }
    }
    btn.disabled = false; btn.textContent = "Save";
  });

  // Save payment info (with IBAN confirmation validation)
  document.getElementById("payment-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const user = auth.currentUser;
    if (!user) return;
    const form = e.target as HTMLFormElement;
    const errEl = document.getElementById("payment-error");
    const successEl = document.getElementById("payment-success");
    errEl?.classList.add("hidden"); successEl?.classList.add("hidden");

    const iban = (form.elements.namedItem("iban") as HTMLInputElement).value.trim();
    const confirmIban = (form.elements.namedItem("confirmIban") as HTMLInputElement).value.trim();

    if (iban && iban !== confirmIban) {
      if (errEl) { errEl.textContent = "IBAN fields do not match."; errEl.classList.remove("hidden"); }
      return;
    }

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = "Saving...";
    try {
      const data: Record<string, any> = {};
      ["paymentType","bankHolder","iban","bic"].forEach(name => {
        const el = form.elements.namedItem(name) as HTMLInputElement;
        if (el) data[name] = el.value;
      });
      data.updatedAt = serverTimestamp();
      await setDoc(doc(db, "users", user.uid), data, { merge: true });
      successEl?.classList.remove("hidden");
      setTimeout(() => successEl?.classList.add("hidden"), 3000);
    } catch (err: any) {
      if (errEl) { errEl.textContent = "Failed to save your changes. Please try again."; errEl.classList.remove("hidden"); }
    }
    btn.disabled = false; btn.textContent = "Save";
  });

  // Sidebar logout
  document.getElementById("sidebar-logout-btn")?.addEventListener("click", async () => {
    await signOut(auth);
    window.location.href = "/" + getLangPrefix() + "/";
  });
</script>
