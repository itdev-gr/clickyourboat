---
import { getLangs, localizeHref } from "../../lib/i18n-utils";
export function getStaticPaths() { return getLangs(); }
const { lang } = Astro.params;
import Layout from "../../layouts/Layout.astro";

const title = "Charter Types — Choose Your Perfect Charter | BoatHaven";
const description =
  "Explore our charter types: Without Licence boats and Luxury Charters. Find the ideal charter experience for your next trip on the water.";

const charterTypes = [
  {
    name: "Without Licence",
    nameKey: "charter.without_licence",
    slug: "without-licence",
    headline: "No licence? No problem. Just hop on and go.",
    headlineKey: "charter.without_licence_headline",
    description:
      "Our without-licence boats are perfect for beginners and casual boaters who want to enjoy the water without the hassle of certifications. These easy-to-operate boats are available in many destinations and come with everything you need for a safe and fun day on the sea. Simply pick your boat, get a quick briefing, and set off on your own adventure.",
    descKey: "charter.without_licence_desc",
    features: ["No boating licence required", "Easy to operate", "Quick safety briefing included", "Perfect for beginners", "Available in 400+ locations", "Ideal for day trips & coastal exploring"],
    featureKeys: ["charter.feat_no_licence", "charter.feat_easy", "charter.feat_briefing", "charter.feat_beginners", "charter.feat_locations", "charter.feat_day_trips"],
    image: "/license_free.jpeg",
    specs: [
      { label: "Capacity", labelKey: "charter.capacity", value: "2–8 guests", valueKey: "charter.spec_guests_small" },
      { label: "Length", labelKey: "charter.boat_length", value: "4–7 m" },
      { label: "Speed", labelKey: "charter.spec_speed", value: "5–15 knots", valueKey: "charter.spec_knots" },
      { label: "Experience", labelKey: "charter.experience_needed", value: "No experience needed", valueKey: "charter.no_experience" },
    ],
    priceFrom: 80,
    browseCta: "Browse Without Licence Charters",
    browseKey: "charter.browse_without_licence",
  },
  {
    name: "Luxury Charter",
    nameKey: "charter.luxury",
    slug: "luxury-charter",
    headline: "The ultimate VIP experience on the water",
    headlineKey: "charter.luxury_headline",
    description:
      "Indulge in the finest boats, professional crews, and first-class service with our luxury charters. From sleek motor yachts to elegant sailing vessels, every detail is taken care of. Enjoy gourmet catering, premium amenities, and personalised itineraries. Whether it's a celebration, corporate event, or simply a desire for the extraordinary — luxury charters deliver an experience like no other.",
    descKey: "charter.luxury_desc",
    features: ["Professional crew & captain", "Gourmet catering available", "Premium amenities & comfort", "Personalised itineraries", "Perfect for celebrations & events", "Top-of-the-line vessels"],
    featureKeys: ["charter.feat_crew", "charter.feat_catering", "charter.feat_amenities", "charter.feat_itineraries", "charter.feat_events", "charter.feat_vessels"],
    image: "https://images.unsplash.com/photo-1567899378494-47b22a2ae96a?w=800&q=80&auto=format",
    specs: [
      { label: "Capacity", labelKey: "charter.capacity", value: "6–30 guests", valueKey: "charter.spec_guests_large" },
      { label: "Length", labelKey: "charter.boat_length", value: "12–40 m" },
      { label: "Duration", labelKey: "charter.duration", value: "Day trips to multi-week", valueKey: "charter.day_to_multi" },
      { label: "Experience", labelKey: "charter.experience_needed", value: "Crew handles everything", valueKey: "charter.crew_handles" },
    ],
    priceFrom: 1500,
    browseCta: "Browse Luxury Charters",
    browseKey: "charter.browse_luxury",
  },
];
const l = (href: string) => localizeHref(href, lang);
---
<Layout lang={lang} title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: "Charter Types",
      description,
      url: "https://boathaven.com/charter-types",
      publisher: { "@type": "Organization", name: "BoatHaven" },
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="relative h-[360px] sm:h-[420px] overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1500514966906-fe245eea9344?w=1920&q=80&auto=format"
      alt="Luxury charter on open water"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/35 to-black/65"></div>
    <div class="relative z-10 flex flex-col items-center justify-center h-full text-center px-4">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight mb-4" data-i18n="charter.page_title">
        Charter Types
      </h1>
      <p class="text-lg sm:text-xl text-white/85 max-w-2xl" data-i18n="charter.page_subtitle">
        From licence-free fun to luxury getaways — choose the charter that fits your style
      </p>
    </div>
  </section>

  <!-- Quick nav pills -->
  <div class="sticky top-16 z-30 bg-white border-b border-border">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="flex gap-2 py-3 overflow-x-auto scrollbar-hide" aria-label="Charter types">
        {charterTypes.map((ct) => (
          <a
            href={`#${ct.slug}`}
            class="flex-shrink-0 px-4 py-2 rounded-full border border-gray-200 text-sm font-medium text-text-muted hover:border-primary hover:text-primary transition-colors"
            data-i18n={ct.nameKey}
          >
            {ct.name}
          </a>
        ))}
      </nav>
    </div>
  </div>

  <!-- Charter type sections -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 space-y-24">
    {charterTypes.map((ct, i) => (
      <section id={ct.slug} class="scroll-mt-32" aria-labelledby={`${ct.slug}-heading`}>
        <div class:list={["grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center", i % 2 !== 0 && "lg:direction-rtl"]}>
          <!-- Image -->
          <div class:list={["relative rounded-2xl overflow-hidden aspect-[4/3]", i % 2 !== 0 && "lg:order-2"]}>
            <img
              src={ct.image}
              alt={ct.name}
              class="h-full w-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>

          <!-- Content -->
          <div class:list={[i % 2 !== 0 && "lg:order-1"]}>
            <h2 id={`${ct.slug}-heading`} class="text-3xl sm:text-4xl font-extrabold text-text mb-3" data-i18n={ct.nameKey}>
              {ct.name}
            </h2>
            <p class="text-lg text-primary font-medium mb-4" data-i18n={ct.headlineKey}>{ct.headline}</p>
            <p class="text-text-muted leading-relaxed mb-6" data-i18n={ct.descKey}>{ct.description}</p>

            <!-- Specs grid -->
            <div class="grid grid-cols-2 gap-3 mb-6">
              {ct.specs.map((spec) => (
                <div class="bg-surface rounded-xl p-3.5">
                  <p class="text-[11px] text-text-muted uppercase tracking-wider font-medium mb-0.5" data-i18n={spec.labelKey}>{spec.label}</p>
                  <p class="text-sm font-bold text-text" {...(spec.valueKey ? {"data-i18n": spec.valueKey} : {})}>{spec.value}</p>
                </div>
              ))}
            </div>

            <!-- Features -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-8">
              {ct.features.map((f, fi) => (
                <div class="flex items-center gap-2">
                  <svg class="h-4 w-4 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                  <span class="text-sm text-text-muted" data-i18n={ct.featureKeys[fi]}>{f}</span>
                </div>
              ))}
            </div>

            <!-- CTA -->
            <a
              href={l(`/boat-rental?charter=${ct.slug}`)}
              class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-primary text-white text-sm font-semibold hover:bg-primary-dark transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
            >
              <span data-i18n={ct.browseKey}>{ct.browseCta}</span>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </a>
          </div>
        </div>
      </section>
    ))}
  </div>

  <!-- Comparison table -->
  <section class="bg-surface py-16 sm:py-20" aria-labelledby="compare-charters-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 id="compare-charters-heading" class="text-2xl sm:text-3xl font-bold text-text" data-i18n="charter.compare_title">Compare charter types</h2>
        <p class="mt-2 text-text-muted" data-i18n="charter.compare_subtitle">See which charter experience is right for you</p>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full bg-white rounded-2xl border border-gray-200 overflow-hidden text-sm">
          <thead>
            <tr class="border-b border-gray-200 bg-gray-50">
              <th class="text-left px-5 py-4 font-semibold text-text-muted"></th>
              {charterTypes.map((ct) => (
                <th class="text-center px-6 py-4 font-bold text-text whitespace-nowrap" data-i18n={ct.nameKey}>{ct.name}</th>
              ))}
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <tr>
              <td class="px-5 py-3.5 font-medium text-text" data-i18n="charter.capacity">Capacity</td>
              <td class="text-center px-6 py-3.5 text-text-muted" data-i18n="charter.spec_guests_small">2–8 guests</td>
              <td class="text-center px-6 py-3.5 text-text-muted" data-i18n="charter.spec_guests_large">6–30 guests</td>
            </tr>
            <tr>
              <td class="px-5 py-3.5 font-medium text-text" data-i18n="charter.boat_length">Boat length</td>
              <td class="text-center px-6 py-3.5 text-text-muted">4–7 m</td>
              <td class="text-center px-6 py-3.5 text-text-muted">12–40 m</td>
            </tr>
            <tr>
              <td class="px-5 py-3.5 font-medium text-text" data-i18n="charter.duration">Duration</td>
              <td class="text-center px-6 py-3.5 text-text-muted" data-i18n="charter.day_trips">Day trips</td>
              <td class="text-center px-6 py-3.5 text-text-muted" data-i18n="charter.day_to_multi">Day to multi-week</td>
            </tr>
            <tr>
              <td class="px-5 py-3.5 font-medium text-text" data-i18n="charter.skipper">Skipper</td>
              <td class="text-center px-6 py-3.5 text-text-muted" data-i18n="charter.not_required">Not required</td>
              <td class="text-center px-6 py-3.5 text-text-muted" data-i18n="charter.full_crew">Full crew included</td>
            </tr>
            <tr>
              <td class="px-5 py-3.5 font-medium text-text" data-i18n="charter.experience_needed">Experience needed</td>
              <td class="text-center px-6 py-3.5 text-text-muted" data-i18n="charter.no_experience">No experience needed</td>
              <td class="text-center px-6 py-3.5 text-text-muted" data-i18n="charter.crew_handles">Crew handles everything</td>
            </tr>
            <tr>
              <td class="px-5 py-3.5 font-medium text-text" data-i18n="charter.from_price">From price</td>
              <td class="text-center px-6 py-3.5 font-bold text-text">€80<span data-i18n="charter.per_day">/day</span></td>
              <td class="text-center px-6 py-3.5 font-bold text-text">€1500<span data-i18n="charter.per_day">/day</span></td>
            </tr>
            <tr>
              <td class="px-5 py-3.5 font-medium text-text" data-i18n="charter.best_for">Best for</td>
              <td class="text-center px-6 py-3.5 text-text-muted" data-i18n="charter.beginners">Beginners & casual trips</td>
              <td class="text-center px-6 py-3.5 text-text-muted" data-i18n="charter.vip_events">VIP events & celebrations</td>
            </tr>
            <tr>
              <td class="px-5 py-4"></td>
              {charterTypes.map((ct) => (
                <td class="text-center px-6 py-4">
                  <a href={l(`/boat-rental?charter=${ct.slug}`)} class="inline-flex items-center px-4 py-2 rounded-lg bg-primary text-white text-xs font-semibold hover:bg-primary-dark transition-colors" data-i18n="charter.browse">
                    Browse
                  </a>
                </td>
              ))}
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-16 bg-primary">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4" data-i18n="charter.help_title">Need help choosing a charter?</h2>
      <p class="text-lg text-white/80 mb-8 max-w-2xl mx-auto" data-i18n="charter.help_desc">
        Our team can help you find the perfect charter for your group, budget, and experience level.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href={l("/boat-rental")} class="inline-flex items-center px-6 py-3 rounded-xl bg-white text-text font-bold text-sm hover:bg-gray-50 transition-colors" data-i18n="charter.browse_all">
          Browse all boats
        </a>
        <a href={l("/contact")} class="inline-flex items-center px-6 py-3 rounded-xl bg-white/15 border border-white/25 text-white font-bold text-sm hover:bg-white/25 transition-colors" data-i18n="charter.contact_advice">
          Contact us for advice
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
