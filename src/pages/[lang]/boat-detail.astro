      if (mobilePrice) mobilePrice.textContent = "\u20AC" + price.toLocaleString();
      if (mobilePriceUnit) mobilePriceUnit.textContent = priceUnit;

      // Show content
      contentEl?.classList.remove("hidden");
      loadingEl?.classList.add("hidden");

      // ========== INTERACTIONS ==========

      // Gallery lightbox
      const lightbox = document.getElementById("lightbox");
      const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
      const lightboxCounter = document.getElementById("lightbox-counter");
      let lightboxIndex = 0;

      function showLightbox(index: number) {
        if (!lightbox || !lightboxImg || images.length === 0) return;
        lightboxIndex = ((index % images.length) + images.length) % images.length;
        lightboxImg.src = images[lightboxIndex];
        if (lightboxCounter) lightboxCounter.textContent = `${lightboxIndex + 1} / ${images.length}`;
        lightbox.classList.remove("hidden");
        lightbox.classList.add("flex");
        document.body.style.overflow = "hidden";
      }

      function hideLightbox() {
        if (!lightbox) return;
        lightbox.classList.add("hidden");
        lightbox.classList.remove("flex");
        document.body.style.overflow = "";
      }

      document.querySelectorAll(".gallery-thumb").forEach(el => {
        el.addEventListener("click", () => {
          const idx = parseInt(el.getAttribute("data-index") || "0");
          showLightbox(idx);
        });
      });
      document.querySelectorAll(".gallery-open-btn").forEach(el => {
        el.addEventListener("click", (e) => {
          e.stopPropagation();
          showLightbox(0);
        });
      });

      document.getElementById("lightbox-close")?.addEventListener("click", hideLightbox);
      document.getElementById("lightbox-prev")?.addEventListener("click", () => showLightbox(lightboxIndex - 1));
      document.getElementById("lightbox-next")?.addEventListener("click", () => showLightbox(lightboxIndex + 1));
      lightbox?.addEventListener("click", (e) => { if (e.target === lightbox) hideLightbox(); });
      document.addEventListener("keydown", (e) => {
        if (!lightbox || lightbox.classList.contains("hidden")) return;
        if (e.key === "Escape") hideLightbox();
        if (e.key === "ArrowLeft") showLightbox(lightboxIndex - 1);
        if (e.key === "ArrowRight") showLightbox(lightboxIndex + 1);
      });

      // Read more (description)
      const readMoreBtn = document.getElementById("desc-read-more");
      const descTextEl = document.getElementById("desc-text");
      readMoreBtn?.addEventListener("click", () => {
        descTextEl?.classList.remove("line-clamp-4");
        readMoreBtn.remove();
      });

      // Equipment show more
      const equipMoreBtn = document.getElementById("equip-more-btn");
      const equipAll = document.getElementById("equipment-all");
      equipMoreBtn?.addEventListener("click", () => {
        equipAll?.classList.remove("hidden");
        equipMoreBtn.remove();
      });

      // Date inputs + price summary
      const today = new Date().toISOString().split("T")[0];
      const startInput = document.getElementById("booking-start") as HTMLInputElement;
      const endInput = document.getElementById("booking-end") as HTMLInputElement;
      if (startInput) startInput.setAttribute("min", today);
      if (endInput) endInput.setAttribute("min", today);

      function updatePriceSummary() {
        const start = startInput?.value;
        const end = endInput?.value;
        const summary = document.getElementById("price-summary");
        if (!start || !end || !summary) return;
        const days = Math.ceil((new Date(end).getTime() - new Date(start).getTime()) / (1000 * 60 * 60 * 24));
        if (days <= 0) { summary.classList.add("hidden"); return; }
        const total = days * price;
        const daysEl = document.getElementById("booking-days");
        const subtotalEl = document.getElementById("booking-subtotal");
        const totalEl = document.getElementById("booking-total");
        if (daysEl) daysEl.textContent = String(days);
        if (subtotalEl) subtotalEl.textContent = "\u20AC" + total.toLocaleString();
        if (totalEl) totalEl.textContent = "\u20AC" + total.toLocaleString();
        summary.classList.remove("hidden");
      }
      startInput?.addEventListener("change", updatePriceSummary);
      endInput?.addEventListener("change", updatePriceSummary);

      // Contact owner buttons
      function handleContactClick(btn: Element) {
        const oid = btn.getAttribute("data-owner-id");
        if (oid) {
          const params = new URLSearchParams();
          params.set("with", oid);
          params.set("boatId", boatId!);
          params.set("boatTitle", boatTitle);
          window.location.href = "/" + getLangPrefix() + "/messages?" + params.toString();
        } else {
          window.location.href = "/" + getLangPrefix() + "/messages";
        }
      }
      document.getElementById("contact-owner-btn")?.addEventListener("click", function() { handleContactClick(this); });
      document.getElementById("contact-owner-btn-sidebar")?.addEventListener("click", function() { handleContactClick(this); });

      // Share button
      document.getElementById("share-btn")?.addEventListener("click", async () => {
        if (navigator.share) {
          try { await navigator.share({ title: boatTitle, url: window.location.href }); } catch {}
        } else {
          await navigator.clipboard.writeText(window.location.href);
          const btn = document.getElementById("share-btn");
          if (btn) { const orig = btn.innerHTML; btn.innerHTML = '<svg class="h-4 w-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg> Copied!'; setTimeout(() => { btn.innerHTML = orig; }, 2000); }
        }
      });

      // Mobile book button scrolls to sidebar or shows booking on mobile
      document.getElementById("mobile-book-btn")?.addEventListener("click", () => {
        const sidebar = document.getElementById("boat-sidebar");
        if (sidebar) {
          sidebar.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });

      // Dispatch event for booking/favorites/reviews scripts
      document.dispatchEvent(new CustomEvent("boat-detail-loaded", { detail: { boat, boatId } }));

    } catch (err) {
      console.error("Error loading boat:", err);
      loadingEl?.classList.add("hidden");
      errorEl?.classList.remove("hidden");
    }
  }

  loadBoatDetail();
</script>

<!-- Booking logic -->
<script>
  import { auth } from "../../lib/firebase";
  import { onAuthStateChanged } from "firebase/auth";
  import { getBoatReviews } from "../../lib/api";

  let currentUser: any = null;

  onAuthStateChanged(auth, (user) => {
    currentUser = user;
  });

  document.addEventListener("boat-detail-loaded", async (e: any) => {
    const { boatId } = e.detail;

    // Load reviews
    const loadingEl = document.getElementById("reviews-loading");
    const emptyEl = document.getElementById("reviews-empty");
    const listEl = document.getElementById("reviews-list");
    const showMoreBtn = document.getElementById("reviews-show-more");

    try {
      const reviews = await getBoatReviews(boatId);
      loadingEl?.classList.add("hidden");
      if (reviews.length === 0) {
        emptyEl?.classList.remove("hidden");
      } else {
        const MAX_VISIBLE = 3;
        let html = "";
        for (let r = 0; r < reviews.length; r++) {
          const review = reviews[r];
          const date = review.createdAt
            ? new Date(review.createdAt).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })
            : "";
          let stars = "";
          for (let i = 1; i <= 5; i++) {
            stars += `<svg class="h-3.5 w-3.5 ${i <= review.rating ? "text-yellow-400" : "text-gray-200"}" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>`;
          }
          const div = document.createElement("div");
          div.textContent = review.userName || "Anonymous";
          const safeName = div.innerHTML;
          div.textContent = review.comment || "";
          const safeComment = div.innerHTML;

          const hiddenClass = r >= MAX_VISIBLE ? "review-hidden hidden" : "";

          html += `
            <div class="review-item ${hiddenClass}">
              <div class="flex items-center gap-3 mb-2">
                <div class="h-9 w-9 rounded-full bg-gray-200 flex items-center justify-center text-xs font-bold text-gray-500 flex-shrink-0">${safeName.charAt(0).toUpperCase()}</div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2">
                    <span class="text-sm font-semibold text-text">${safeName}</span>
                    <span class="text-xs text-gray-400">${date}</span>
                  </div>
                  <div class="flex items-center gap-0.5 mt-0.5">${stars}</div>
                </div>
              </div>
              <p class="text-sm text-text-muted ml-12">${safeComment}</p>
            </div>
          `;
        }
        if (listEl) listEl.innerHTML = html;

        if (reviews.length > MAX_VISIBLE && showMoreBtn) {
          showMoreBtn.textContent = `Show more reviews (${reviews.length - MAX_VISIBLE} more)`;
          showMoreBtn.classList.remove("hidden");
          showMoreBtn.addEventListener("click", () => {
            document.querySelectorAll(".review-hidden").forEach(el => el.classList.remove("hidden", "review-hidden"));
            showMoreBtn.remove();
          });
        }
      }
    } catch {
      loadingEl?.classList.add("hidden");
      emptyEl?.classList.remove("hidden");
    }

    // Booking button
    const bookBtn = document.getElementById("request-booking-btn") as HTMLButtonElement;
    const startInput = document.getElementById("booking-start") as HTMLInputElement;
    const endInput = document.getElementById("booking-end") as HTMLInputElement;
    const successDiv = document.getElementById("booking-success");
    const errorDiv = document.getElementById("booking-error");
    const errorText = document.getElementById("booking-error-text");

    const ownerId = bookBtn?.getAttribute("data-owner-id") || "";
    const dailyRate = parseFloat(bookBtn?.getAttribute("data-price") || "0");
    const boatTitle = bookBtn?.getAttribute("data-boat-title") || "";
    const boatImage = bookBtn?.getAttribute("data-boat-image") || "";

    function showError(msg: string) {
      if (errorText) errorText.textContent = msg;
      errorDiv?.classList.remove("hidden");
      successDiv?.classList.add("hidden");
    }

    bookBtn?.addEventListener("click", async () => {
      successDiv?.classList.add("hidden");
      errorDiv?.classList.add("hidden");

      if (!currentUser) {
        window.location.href = "/" + getLangPrefix() + "/login?redirect=" + encodeURIComponent(window.location.pathname);
        return;
      }
      if (ownerId && currentUser.uid === ownerId) { showError("You cannot book your own boat."); return; }
      if (!ownerId) { showError("This boat is not available for booking."); return; }

      const startVal = startInput?.value;
      const endVal = endInput?.value;
      if (!startVal || !endVal) { showError("Please select both start and end dates."); return; }

      const startDate = new Date(startVal);
      const endDate = new Date(endVal);
      if (endDate <= startDate) { showError("End date must be after start date."); return; }

      // Redirect to confirm-booking page with all necessary params
      const params = new URLSearchParams({
        boatId,
        startDate: startVal,
        endDate: endVal,
      });
      window.location.href = "/" + getLangPrefix() + "/confirm-booking?" + params.toString();
    });
  });
</script>

<!-- Favorites -->
<script>
  import { auth, db } from "../../lib/firebase";
  import { onAuthStateChanged } from "firebase/auth";
  import { doc, setDoc, deleteDoc, getDoc, serverTimestamp } from "firebase/firestore";

  let currentUser: any = null;
  let isFavorited = false;

  onAuthStateChanged(auth, (user) => { currentUser = user; });

  document.addEventListener("boat-detail-loaded", async (e: any) => {
    const { boatId } = e.detail;
    const favBtn = document.getElementById("detail-fav-btn");
    const favIcon = document.getElementById("detail-fav-icon");
    const favText = document.getElementById("detail-fav-text");
    if (!favBtn) return;

    function updateFavUI(fav: boolean) {
      isFavorited = fav;
      if (favIcon) {
        favIcon.setAttribute("fill", fav ? "currentColor" : "none");
        favIcon.classList.toggle("text-pink", fav);
        favIcon.classList.toggle("text-gray-400", !fav);
      }
      if (favText) favText.textContent = fav ? "Saved to favorites" : "Add to favorites";
    }

    if (currentUser && boatId) {
      try {
        const snap = await getDoc(doc(db, "users", currentUser.uid, "favorites", boatId));
        updateFavUI(snap.exists());
      } catch {}
    }

    favBtn.addEventListener("click", async () => {
      if (!currentUser) {
        window.location.href = "/" + getLangPrefix() + "/login?redirect=" + encodeURIComponent(window.location.pathname);
        return;
      }
      if (!boatId) return;
      const favRef = doc(db, "users", currentUser.uid, "favorites", boatId);
      updateFavUI(!isFavorited);
      try {
        if (isFavorited) {
          const title = document.querySelector("h1")?.textContent?.trim() || "";
          const image = (document.getElementById("main-image") as HTMLImageElement)?.src || "";
          await setDoc(favRef, { boatId, title, image, location: "", price: 0, priceUnit: "/ day", type: "", rating: 0, reviewCount: 0, addedAt: serverTimestamp() });
        } else {
          await deleteDoc(favRef);
        }
      } catch {
        updateFavUI(!isFavorited);
      }
    });
  });
</script>
