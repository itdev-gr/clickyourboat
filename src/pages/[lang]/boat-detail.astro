        `;
      }

      // ========== SIDEBAR ==========
      const sidebarEl = document.getElementById("boat-sidebar");
      if (sidebarEl) {
        let extrasHtml = "";
        if (extras.length > 0) {
          extrasHtml = `
            <div class="pt-3 border-t border-gray-100">
              <p class="text-xs font-semibold text-text-muted uppercase tracking-wide mb-2">Optional extras</p>
              ${extras.map(ex => `<div class="flex justify-between text-sm mb-1"><span class="text-text-muted">${esc(ex.name)}</span><span class="text-text font-medium">${ex.pricePerDay > 0 ? "&euro;" + ex.pricePerDay + "/day" : "Free"}</span></div>`).join("")}
            </div>
          `;
        }

        sidebarEl.innerHTML = `
          <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
            <div class="flex items-baseline gap-1 mb-5">
              <span class="text-2xl font-extrabold text-text">&euro;${price.toLocaleString()}</span>
              <span class="text-sm text-text-muted">${esc(priceUnit)}</span>
            </div>

            <div class="grid grid-cols-2 gap-2 mb-3">
              <div>
                <label for="booking-start" class="block text-xs font-semibold text-text-muted mb-1">Start date</label>
                <input type="date" id="booking-start" class="w-full rounded-lg border border-gray-200 px-3 py-2.5 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
              </div>
              <div>
                <label for="booking-end" class="block text-xs font-semibold text-text-muted mb-1">End date</label>
                <input type="date" id="booking-end" class="w-full rounded-lg border border-gray-200 px-3 py-2.5 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
