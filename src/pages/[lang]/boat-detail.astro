              class="w-full mt-3 rounded-xl bg-primary px-6 py-3 text-sm font-bold text-white hover:bg-primary-dark transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
              data-boat-id="${esc(boatId)}"
              data-owner-id="${esc(ownerId)}"
              data-price="${price}"
              data-boat-title="${esc(boatTitle)}"
              data-boat-image="${esc(images[0] || "")}"
            >${instantBooking ? "Book now" : "Continue Booking"}</button>
            <p class="text-xs text-text-muted text-center mt-2">You won't be charged yet</p>

            <div id="booking-success" class="hidden mt-3 p-3 bg-green-50 border border-green-200 rounded-lg">
              <p class="text-sm text-green-800 font-medium">Booking request sent!</p>
              <p class="text-xs text-green-600 mt-1">The owner has been notified. <a href={l("/dashboard")} class="underline font-semibold">View your bookings</a></p>
            </div>
            <div id="booking-error" class="hidden mt-3 p-3 bg-red-50 border border-red-200 rounded-lg">
              <p class="text-sm text-red-800 font-medium" id="booking-error-text">Something went wrong</p>
