---
import { getLangs, localizeHref } from "../../lib/i18n-utils";
export function getStaticPaths() { return getLangs(); }
const { lang } = Astro.params;
import Layout from "../../layouts/Layout.astro";

const title = "Boat Details — TapYourBoat";
const description = "View boat details on TapYourBoat";
const l = (href: string) => localizeHref(href, lang);
---
<Layout lang={lang} title={title} description={description}>
  <!-- Loading state -->
  <div id="boat-loading" class="flex items-center justify-center py-20">
    <div class="h-8 w-8 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
  </div>

  <!-- Error state -->
  <div id="boat-error" class="hidden text-center py-20">
    <h1 class="text-2xl font-bold text-text mb-2">Boat not found</h1>
    <p class="text-text-muted mb-6">This boat may have been removed or is no longer available.</p>
    <a href={l("/boat-rental")} class="inline-flex items-center px-6 py-3 rounded-xl bg-primary text-white text-sm font-semibold hover:bg-primary-dark transition-colors">
      Browse all boats
    </a>
  </div>

  <!-- Boat content (populated by JS) -->
  <div id="boat-content" class="hidden">
    <!-- Breadcrumb + Title bar -->
    <div id="boat-header" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-4 pb-2"></div>

    <!-- Gallery -->
    <div id="boat-gallery" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mb-6"></div>

    <!-- Two-column layout -->
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-12">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-8 lg:gap-12">
        <!-- Left column -->
        <div class="min-w-0">
          <div id="boat-summary" class="pb-6 border-b border-gray-200"></div>
          <div id="boat-features" class="py-6 border-b border-gray-200"></div>
          <div id="boat-description" class="py-6 border-b border-gray-200"></div>
          <div id="boat-equipment" class="py-6 border-b border-gray-200 hidden"></div>
          <div id="boat-reviews" class="py-6 border-b border-gray-200"></div>
          <div id="boat-owner" class="py-6 border-b border-gray-200"></div>
          <div id="boat-location" class="py-6 border-b border-gray-200"></div>
          <div id="boat-specs" class="py-6 border-b border-gray-200 hidden"></div>
          <div id="boat-conditions" class="py-6 border-b border-gray-200 hidden"></div>
          <div id="boat-faq" class="py-6"></div>
        </div>

        <!-- Right sidebar (sticky) -->
        <div class="hidden lg:block">
          <div id="boat-sidebar" class="sticky top-20 space-y-4"></div>
        </div>
      </div>
    </div>

    <!-- Mobile fixed bottom bar -->
    <div id="mobile-booking-bar" class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 px-4 py-3 lg:hidden z-40 flex items-center justify-between">
      <div>
        <span id="mobile-price" class="text-lg font-extrabold text-text"></span>
        <span id="mobile-price-unit" class="text-sm text-text-muted"></span>
      </div>
      <button id="mobile-book-btn" class="px-6 py-2.5 rounded-xl bg-primary text-white text-sm font-bold hover:bg-primary-dark transition-colors">Book</button>
    </div>
  </div>

  <!-- Lightbox modal -->
  <div id="lightbox" class="fixed inset-0 bg-black/90 z-50 hidden items-center justify-center">
    <button id="lightbox-close" class="absolute top-4 right-4 h-10 w-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors z-10">
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 h-10 w-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors">
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/></svg>
    </button>
    <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 h-10 w-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors">
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
    </button>
    <img id="lightbox-img" src="" alt="" class="max-h-[90vh] max-w-[90vw] object-contain" />
    <div id="lightbox-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white text-sm font-medium bg-black/50 px-3 py-1 rounded-full"></div>
  </div>
</Layout>

<!-- Main detail loader -->
<script>

  function getLangPrefix() {
    return document.documentElement.dataset.langPrefix || "en";
  }
  import { getBoatListing } from "../../lib/api";
  import { db } from "../../lib/firebase";
  import { doc, getDoc } from "firebase/firestore";

  function esc(s: string): string {
    return s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
  }

  const starSvg = '<svg class="h-4 w-4 text-pink" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>';
  const checkSvg = '<svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>';

  async function loadBoatDetail() {
    const loadingEl = document.getElementById("boat-loading");
    const errorEl = document.getElementById("boat-error");
    const contentEl = document.getElementById("boat-content");

    const pathParts = window.location.pathname.split("/").filter(Boolean);
    const boatIdx = pathParts.indexOf("boat");
    const boatId = (boatIdx >= 0 ? pathParts[boatIdx + 1] : null) || new URLSearchParams(window.location.search).get("id");

    if (!boatId) {
      loadingEl?.classList.add("hidden");
      errorEl?.classList.remove("hidden");
      return;
    }

    try {
      const boat = await getBoatListing(boatId);

      if (!boat) {
        loadingEl?.classList.add("hidden");
        errorEl?.classList.remove("hidden");
        return;
      }

      const images: string[] = boat.images || [];
      const price = boat.price || boat.pricePerDay || 0;
      const priceUnit = boat.priceUnit || "/ day";
      const boatTitle = boat.listingTitle || boat.title || boat.boatName || [boat.manufacturer, boat.model].filter(Boolean).join(" ") || "Boat";
      const boatType = boat.boatType || boat.type || "";
      const boatTypeLabel = boatType ? boatType.charAt(0).toUpperCase() + boatType.slice(1) : "";
      const city = boat.city || (typeof boat.location === "object" ? boat.location?.city : "") || "";
      const harbour = boat.harbour || "";
      const country = typeof boat.location === "object" ? boat.location?.country || "" : "";
      const locationStr = [city, harbour].filter(Boolean).join(", ") || [city, country].filter(Boolean).join(", ") || "Location not specified";
      const capacity = boat.capacity || 0;
      const enginePower = boat.enginePower || boat.horsepower || 0;
      const boatLength = boat.length || 0;
      const cabins = boat.cabins || 0;
      const berths = boat.berths || 0;
      const bathrooms = boat.bathrooms || 0;
      const year = boat.year || boat.yearOfConstruction || 0;
      const manufacturer = boat.manufacturer || "";
      const model = boat.model || "";
      const equipment: string[] = boat.equipment || [];
      const perks: string[] = boat.perks || [];
      const description = boat.description || "";
      const rating = boat.rating || 0;
      const reviewCount = boat.reviewCount || 0;
      const skipperAvailable = boat.skipperAvailable || false;
      const instantBooking = boat.instantBooking || boat.bookingMode === "instant" || false;
      const ownerId = boat.ownerId || "";
      const engineType = boat.engineType || "";
      const width = boat.width || 0;
      const draft = boat.draft || 0;
      const speed = boat.speed || 0;
      const fuelCost = boat.fuelCost || "";
      const licenceRequired = boat.licenceRequired || "";
      const checkInTime = boat.checkInTime || "";
      const checkOutTime = boat.checkOutTime || "";
      const extras: any[] = boat.extras || [];

      document.title = `${boatTitle} — TapYourBoat`;

      // ========== HEADER (breadcrumb + title) ==========
      const headerEl = document.getElementById("boat-header");
      if (headerEl) {
        let ratingBadge = "";
        if (rating > 0) {
          ratingBadge = `<span class="inline-flex items-center gap-1">${starSvg}<span class="font-bold text-text">${rating}</span><span class="text-text-muted">(${reviewCount} reviews)</span></span>`;
        }

        let tagsList = "";
        if (skipperAvailable) tagsList += `<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-gray-100 text-xs font-medium text-text"><svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/></svg>With or without a skipper</span>`;
        if (boatTypeLabel) tagsList += `<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-gray-100 text-xs font-medium text-text">${esc(boatTypeLabel)}</span>`;
        if (instantBooking) tagsList += `<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-gray-100 text-xs font-medium text-text"><svg class="h-3.5 w-3.5 text-pink" fill="currentColor" viewBox="0 0 20 20"><path d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"/></svg>Instant booking</span>`;

        headerEl.innerHTML = `
          <nav class="mb-3 text-sm text-text-muted" aria-label="Breadcrumb">
            <ol class="flex items-center gap-1.5 flex-wrap">
              <li><a href={l("/boat-rental")} class="hover:text-primary transition-colors">Boat rental</a></li>
              <li class="text-gray-300">&gt;</li>
              ${city ? `<li><a href={l("/boat-rental")} class="hover:text-primary transition-colors">Boat rental ${esc(city)}</a></li><li class="text-gray-300">&gt;</li>` : ""}
              ${boatTypeLabel ? `<li><a href={l("/boat-rental")} class="hover:text-primary transition-colors">${esc(boatTypeLabel)}</a></li><li class="text-gray-300">&gt;</li>` : ""}
              <li class="text-text font-medium truncate max-w-[300px]">${esc(boatTitle)}</li>
            </ol>
          </nav>
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-2">
            <h1 class="text-xl sm:text-2xl font-bold text-text leading-tight">${esc(boatTitle)}</h1>
            <div class="flex items-center gap-3 flex-shrink-0">
              <button id="share-btn" class="inline-flex items-center gap-1.5 text-sm text-text-muted hover:text-text transition-colors">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z"/></svg>
                Share
              </button>
              <button id="detail-fav-btn" class="inline-flex items-center gap-1.5 text-sm text-text-muted hover:text-text transition-colors" data-boat-id="${esc(boatId)}">
                <svg id="detail-fav-icon" class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
                <span id="detail-fav-text">Add to favorites</span>
              </button>
            </div>
          </div>
          <div class="flex items-center gap-3 flex-wrap text-sm">
            ${ratingBadge}
            ${tagsList ? `<div class="flex items-center gap-2 flex-wrap">${tagsList}</div>` : ""}
          </div>
        `;
      }

      // ========== GALLERY ==========
      const galleryEl = document.getElementById("boat-gallery");
      if (galleryEl) {
        if (images.length > 0) {
          let secondaryHtml = images.slice(1, 5).map((img, i) => {
            const isLast = i === Math.min(images.length - 2, 3);
            const remaining = images.length - 5;
            let overlay = "";
            if (isLast && remaining > 0) {
              overlay = `<div class="gallery-open-btn absolute inset-0 bg-black/40 flex items-center justify-center cursor-pointer hover:bg-black/50 transition-colors"><span class="text-white font-semibold text-sm">View all photos</span></div>`;
            }
            return `<div class="overflow-hidden bg-gray-100 relative cursor-pointer gallery-thumb" data-index="${i + 1}"><img src="${esc(img)}" alt="${esc(boatTitle)} - Photo ${i + 2}" class="h-full w-full object-cover hover:scale-105 transition-transform duration-300" loading="lazy" />${overlay}</div>`;
          }).join("");

          galleryEl.innerHTML = `
            <div class="relative grid grid-cols-1 md:grid-cols-[1.2fr_1fr] gap-2 rounded-2xl overflow-hidden">
              <div class="aspect-[4/3] md:aspect-auto overflow-hidden bg-gray-100 cursor-pointer gallery-thumb" data-index="0">
                <img id="main-image" src="${esc(images[0])}" alt="${esc(boatTitle)}" class="h-full w-full object-cover hover:scale-105 transition-transform duration-300" loading="eager" />
              </div>
              <div class="hidden md:grid grid-cols-2 grid-rows-2 gap-2">${secondaryHtml}</div>
              <button class="gallery-open-btn absolute bottom-4 right-4 md:hidden inline-flex items-center gap-2 px-4 py-2 bg-white rounded-lg text-sm font-medium text-text shadow-lg hover:bg-gray-50 transition-colors">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/></svg>
                ${images.length} photos
              </button>
            </div>
          `;
        } else {
          galleryEl.innerHTML = `<div class="aspect-[16/9] rounded-2xl bg-gray-100 flex items-center justify-center"><p class="text-text-muted">No photos available</p></div>`;
        }
      }

      // ========== SUMMARY ==========
      const summaryEl = document.getElementById("boat-summary");
      if (summaryEl) {
        let summaryParts: string[] = [];
        if (capacity > 0) summaryParts.push(`${capacity} people`);
        if (enginePower > 0) summaryParts.push(`${enginePower} HP`);
        if (boatLength > 0) summaryParts.push(`${boatLength}m`);
        if (cabins > 0) summaryParts.push(`${cabins} cabin${cabins > 1 ? "s" : ""}`);

        summaryEl.innerHTML = `
          <div class="flex items-center gap-3 mb-1">
            <span class="text-base font-semibold text-text">${esc(boatTypeLabel || "Boat")} owned by <span id="owner-name-inline">Owner</span></span>
          </div>
          <p class="text-sm text-text-muted">${summaryParts.join(" &middot; ")}</p>
        `;
      }

      // ========== FEATURES (badges) ==========
      const featuresEl = document.getElementById("boat-features");
      if (featuresEl) {
        let features = "";
        if (skipperAvailable) {
          features += `
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 h-10 w-10 rounded-full bg-gray-100 flex items-center justify-center">
                <svg class="h-5 w-5 text-text" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/></svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-text">With or without a skipper</p>
                <p class="text-xs text-text-muted">Choose to sail on your own or with a skipper</p>
              </div>
            </div>`;
        }
        if (perks.includes("free-cancel")) {
          features += `
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 h-10 w-10 rounded-full bg-green-50 flex items-center justify-center">
                <svg class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-text">Free cancellation</p>
                <p class="text-xs text-text-muted">Cancel at least 24 hours before your booking starts for a full refund</p>
              </div>
            </div>`;
        }
        if (perks.includes("flexible-cancel")) {
          features += `
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 h-10 w-10 rounded-full bg-blue-50 flex items-center justify-center">
                <svg class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"/></svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-text">Flexible cancellation</p>
                <p class="text-xs text-text-muted">Flexible cancellation policy available</p>
              </div>
            </div>`;
        }
        if (perks.includes("fuel")) {
          features += `
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 h-10 w-10 rounded-full bg-amber-50 flex items-center justify-center">
                <svg class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/></svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-text">Fuel included</p>
                <p class="text-xs text-text-muted">Fuel costs are included in the rental price</p>
              </div>
            </div>`;
        }
        if (instantBooking) {
          features += `
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 h-10 w-10 rounded-full bg-pink/10 flex items-center justify-center">
                <svg class="h-5 w-5 text-pink" fill="currentColor" viewBox="0 0 20 20"><path d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"/></svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-text">Instant booking</p>
                <p class="text-xs text-text-muted">Book immediately without waiting for owner confirmation</p>
              </div>
            </div>`;
        }

        if (features) {
          featuresEl.innerHTML = `<div class="space-y-4">${features}</div>`;
        } else {
          featuresEl.classList.add("hidden");
        }
      }

      // ========== DESCRIPTION ==========
      const descEl = document.getElementById("boat-description");
      if (descEl) {
        const descText = description || `Experience the ${boatTypeLabel || "boat"} in ${locationStr}. Perfect for groups of up to ${capacity || "several"} people.`;
        const isLong = descText.length > 300;
        descEl.innerHTML = `
          <h2 class="text-lg font-bold text-text mb-3">Description</h2>
          <div id="desc-text" class="text-sm text-text-muted leading-relaxed ${isLong ? "line-clamp-4" : ""}">${esc(descText)}</div>
          ${isLong ? `<button id="desc-read-more" class="mt-2 text-sm font-semibold text-primary hover:text-primary-dark transition-colors">Read more</button>` : ""}
        `;
      }

      // ========== EQUIPMENT ==========
      const equipEl = document.getElementById("boat-equipment");
      if (equipEl && equipment.length > 0) {
        equipEl.classList.remove("hidden");
        const shown = equipment.slice(0, 8);
        const hasMore = equipment.length > 8;
        let eqGrid = shown.map(e => `
          <div class="flex items-center gap-2.5">
            ${checkSvg}
            <span class="text-sm text-text">${esc(e)}</span>
          </div>
        `).join("");

        equipEl.innerHTML = `
          <h2 class="text-lg font-bold text-text mb-4">Equipment available on the boat</h2>
          <div id="equipment-grid-display" class="grid grid-cols-1 sm:grid-cols-2 gap-3">${eqGrid}</div>
          ${hasMore ? `
            <div id="equipment-all" class="hidden grid grid-cols-1 sm:grid-cols-2 gap-3 mt-3">${equipment.slice(8).map(e => `<div class="flex items-center gap-2.5">${checkSvg}<span class="text-sm text-text">${esc(e)}</span></div>`).join("")}</div>
            <button id="equip-more-btn" class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:text-primary-dark transition-colors">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
              View all equipment (${equipment.length})
            </button>
          ` : ""}
        `;
      }

      // ========== REVIEWS ==========
      const reviewsEl = document.getElementById("boat-reviews");
      if (reviewsEl) {
        let ratingOverview = "";
        if (rating > 0) {
          ratingOverview = `
            <div class="flex items-center gap-2 mb-4">
              ${starSvg}
              <span class="text-lg font-bold text-text">${rating}</span>
              <span class="text-sm text-text-muted">(${reviewCount} reviews)</span>
            </div>`;
        }
        reviewsEl.innerHTML = `
          <h2 class="text-lg font-bold text-text mb-4">Reviews</h2>
          ${ratingOverview}
          <div id="reviews-loading" class="flex items-center justify-center py-6">
