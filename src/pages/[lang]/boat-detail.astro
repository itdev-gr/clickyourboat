                  <span class="text-sm font-medium text-text pr-4">${esc(f.q)}</span>
                  <svg class="h-4 w-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
                </summary>
                <div class="px-4 pb-4 text-sm text-text-muted leading-relaxed">${esc(f.a)}</div>
