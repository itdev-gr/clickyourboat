<!-- UI logic — no dependencies, always works -->
<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    // Boat type selection
    var typeBtns = document.querySelectorAll(".boat-type-btn");
    var typeInput = document.getElementById("boat-type-input");

    typeBtns.forEach(function (btn) {
      btn.addEventListener("click", function () {
        typeBtns.forEach(function (b) {
          b.classList.remove("border-primary", "bg-primary/5", "ring-2", "ring-primary");
          b.classList.add("border-gray-200");
        });
        btn.classList.remove("border-gray-200");
        btn.classList.add("border-primary", "bg-primary/5", "ring-2", "ring-primary");
        typeInput.value = btn.getAttribute("data-type");
      });
    });

    // Upload zone click trigger
    var uploadTrigger = document.getElementById("upload-click-trigger");
    var photoInput = document.getElementById("photo-input");
    if (uploadTrigger && photoInput) {
      uploadTrigger.addEventListener("click", function () {
        photoInput.click();
      });
    }

    // Track selected files in a mutable array (FileList is immutable)
    window.__selectedFiles = [];

    // Photo preview on file select
    var previewGrid = document.getElementById("photo-previews");
    if (photoInput && previewGrid) {
      photoInput.addEventListener("change", function () {
        var files = photoInput.files;
        if (!files || files.length === 0) return;

        // Clear placeholder slots
        previewGrid.innerHTML = "";

        // Populate mutable files array
        window.__selectedFiles = [];
        for (var j = 0; j < files.length; j++) {
          window.__selectedFiles.push(files[j]);
        }

        for (var i = 0; i < files.length; i++) {
          (function (file, index) {
            var reader = new FileReader();
            reader.onload = function (e) {
              var div = document.createElement("div");
              div.className = "relative aspect-square rounded-xl overflow-hidden border border-gray-200 bg-white group";
              div.setAttribute("data-file-index", index);
              div.innerHTML =
                '<img src="' + e.target.result + '" alt="Boat photo" class="h-full w-full object-cover" />' +
                '<button type="button" class="absolute top-2 right-2 h-6 w-6 rounded-full bg-black/60 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity remove-photo">' +
                '<svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>' +
                '</button>';
              previewGrid.appendChild(div);

              div.querySelector(".remove-photo").addEventListener("click", function () {
                // Null out the file so it's excluded on submit
                window.__selectedFiles[index] = null;
                div.remove();
              });
            };
            reader.readAsDataURL(file);
          })(files[i], i);
        }
      });
    }

    // Drag & drop highlight
    var uploadZone = document.getElementById("upload-zone");
    if (uploadZone) {
      ["dragenter", "dragover"].forEach(function (evt) {
        uploadZone.addEventListener(evt, function (e) {
          e.preventDefault();
          uploadZone.classList.add("border-primary", "bg-primary/5");
        });
      });
      ["dragleave", "drop"].forEach(function (evt) {
        uploadZone.addEventListener(evt, function (e) {
          e.preventDefault();
          uploadZone.classList.remove("border-primary", "bg-primary/5");
        });
      });
    }
  });
</script>

<!-- Firebase auth check + listings query -->
<script>
  import { auth, db } from "../lib/firebase";
  import { onAuthStateChanged } from "firebase/auth";
  import { collection, query, where, orderBy, getDocs } from "firebase/firestore";
  import { createBoatListing, updateBoatListing, deleteBoatListing } from "../lib/api";

  const loading = document.getElementById("auth-loading");
  const gate = document.getElementById("auth-gate");
  const form = document.getElementById("listing-form");
  const myListings = document.getElementById("my-listings");
  const listingsGrid = document.getElementById("listings-grid");
  const listingsLoading = document.getElementById("listings-loading");
  const addNewBtn = document.getElementById("add-new-listing-btn");
  const backBtn = document.getElementById("back-to-listings-btn");
  const listingsError = document.getElementById("listings-error");
  const listingsRetryBtn = document.getElementById("listings-retry-btn");
  const listingsTabs = document.getElementById("listings-tabs");

  // Track whether this user has listings (to show/hide back button)
  let userHasListings = false;

  // Draft support state
  let editingBoatId: string | null = null;
  let existingImageUrls: string[] = [];

  // Track cards with their status for filtering
  let allListingCards: { el: HTMLElement; status: string }[] = [];
  let activeTab = "all";

  function hideAll() {
    gate?.classList.add("hidden");
    form?.classList.add("hidden");
    myListings?.classList.add("hidden");
  }

  function showForm() {
    hideAll();
    form?.classList.remove("hidden");
    if (userHasListings) {
      backBtn?.classList.remove("hidden");
    }
  }

  function showListings() {
    hideAll();
    myListings?.classList.remove("hidden");
    backBtn?.classList.add("hidden");
  }

  // --- Tab filtering ---
  function updateTabCounts() {
    const total = allListingCards.length;
    const published = allListingCards.filter(c => c.status !== "draft").length;
    const drafts = allListingCards.filter(c => c.status === "draft").length;
    const tabs = document.querySelectorAll(".listings-tab");
    tabs.forEach(tab => {
      const key = tab.getAttribute("data-tab");
      const countEl = tab.querySelector(".tab-count");
      if (!countEl) return;
      if (key === "all") countEl.textContent = `(${total})`;
      else if (key === "published") countEl.textContent = `(${published})`;
      else if (key === "drafts") countEl.textContent = `(${drafts})`;
    });
  }

  function filterByTab(tab: string) {
    activeTab = tab;
    allListingCards.forEach(({ el, status }) => {
      if (tab === "all") el.style.display = "";
      else if (tab === "published") el.style.display = status !== "draft" ? "" : "none";
      else if (tab === "drafts") el.style.display = status === "draft" ? "" : "none";
    });
    // Update active tab styling
    document.querySelectorAll(".listings-tab").forEach(btn => {
      if (btn.getAttribute("data-tab") === tab) {
        btn.classList.remove("bg-white", "text-gray-600", "border", "border-gray-300", "hover:bg-gray-50");
        btn.classList.add("bg-primary", "text-white");
      } else {
        btn.classList.remove("bg-primary", "text-white");
        btn.classList.add("bg-white", "text-gray-600", "border", "border-gray-300", "hover:bg-gray-50");
      }
    });
  }

  // Tab click handlers
  document.querySelectorAll(".listings-tab").forEach(btn => {
    btn.addEventListener("click", () => {
      filterByTab(btn.getAttribute("data-tab") || "all");
    });
  });

  // "Add New Listing" button — resets form then shows it
  addNewBtn?.addEventListener("click", () => {
    resetForm();
    showForm();
  });

  // "Back to My Listings" link
  backBtn?.addEventListener("click", showListings);

  // Retry button for listings load error
  listingsRetryBtn?.addEventListener("click", () => {
    listingsError?.classList.add("hidden");
    listingsLoading?.classList.remove("hidden");
    const user = auth.currentUser;
    if (!user) return;
    (async () => {
      try {
        const q = query(
          collection(db, "boats"),
          where("ownerId", "==", user.uid),
          orderBy("createdAt", "desc")
        );
        const snapshot = await getDocs(q);
        if (snapshot.empty) {
          userHasListings = false;
          showForm();
          backBtn?.classList.add("hidden");
        } else {
          userHasListings = true;
          listingsGrid!.innerHTML = "";
          allListingCards = [];
          snapshot.docs.forEach((d) => {
            const data = d.data();
            const card = renderListingCard({ id: d.id, ...data });
            listingsGrid!.appendChild(card);
            allListingCards.push({ el: card, status: data.status || "published" });
          });
          updateTabCounts();
          listingsTabs?.classList.remove("hidden");
          listingsLoading?.classList.add("hidden");
          listingsGrid?.classList.remove("hidden");
          filterByTab("all");
        }
      } catch (retryErr) {
        console.error("Retry failed:", retryErr);
        listingsLoading?.classList.add("hidden");
        listingsError?.classList.remove("hidden");
      }
    })();
  });

  function renderListingCard(boat: { id: string; boatType?: string; type?: string; manufacturer?: string; model?: string; title?: string; city?: string; harbour?: string; location?: { city?: string }; images?: string[]; createdAt?: any; skipper?: string; capacity?: number; length?: number; status?: string; professional?: string; company?: string; website?: string }) {
    const card = document.createElement("article");
    card.className = "boat-card bg-white rounded-xl border border-gray-200/80 overflow-hidden hover:shadow-lg transition-shadow duration-200 group";
    card.setAttribute("data-boat-type", boat.boatType || boat.type || "");

    const name = boat.manufacturer && boat.model
      ? `${boat.manufacturer} ${boat.model}`
      : boat.title || "Untitled";
    const city = boat.city || boat.location?.city || "";
    const harbour = boat.harbour || "";
    const location = harbour && city ? `${city}, ${harbour}` : city || "—";
    const boatType = boat.boatType || boat.type || "";
    const boatTypeLabel = boatType ? boatType.charAt(0).toUpperCase() + boatType.slice(1) : "";
    const images = boat.images || [];
    const firstImage = images.length > 0 ? images[0] : null;

    // Status: backward compat — missing status treated as published
    const boatStatus = boat.status || "published";
    const isDraft = boatStatus === "draft";

    // Check if "New" (created within last 7 days) — only for published
    let isNew = false;
    if (!isDraft && boat.createdAt) {
      const created = boat.createdAt?.toDate ? boat.createdAt.toDate() : (boat.createdAt instanceof Date ? boat.createdAt : null);
      if (created) {
        const sevenDaysAgo = new Date();
        sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
        isNew = created > sevenDaysAgo;
      }
    }

    // Image or placeholder
    const imagePart = firstImage
      ? `<img src="${firstImage}" alt="${name}" class="h-full w-full object-cover" loading="lazy" decoding="async" />`
      : `<div class="h-full w-full flex items-center justify-center">
           <svg class="h-12 w-12 text-gray-300" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5">
             <path d="M6 30c0 0 6-6 18-6s18 6 18 6" stroke-linecap="round"/>
             <path d="M14 24l8-10h8l-4 10" stroke-linecap="round" stroke-linejoin="round"/>
           </svg>
         </div>`;

    // Carousel dots
    const dots = images.length > 1
      ? `<div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5">
          ${images.map((_, i) => `<span class="h-2 w-2 rounded-full ${i === 0 ? 'bg-white' : 'bg-white/50'}"></span>`).join("")}
         </div>`
      : "";

    // Badge: Draft (amber) or New (star)
    const statusBadge = isDraft
      ? `<div class="absolute top-3 left-3 inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-amber-100 text-xs font-semibold text-amber-800">
           <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/></svg>
           Draft
         </div>`
      : isNew
        ? `<div class="absolute top-3 left-3 flex items-center gap-1 text-xs font-semibold text-gray-700">
             <svg class="h-3.5 w-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
             New
           </div>`
        : "";

    // Skipper tag
    const skipperTag = boat.skipper === "yes"
      ? `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-gray-50 border border-gray-200 text-[11px] text-text-muted">
           <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4m-7.07-3.93l2.83-2.83m8.48-8.48l2.83-2.83M2 12h4m12 0h4m-3.93 7.07l-2.83-2.83M6.76 6.76L3.93 3.93"/></svg>
           Skipper included
         </span>`
      : boat.skipper === "no"
        ? `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-gray-50 border border-gray-200 text-[11px] text-text-muted">
             <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4m-7.07-3.93l2.83-2.83m8.48-8.48l2.83-2.83M2 12h4m12 0h4m-3.93 7.07l-2.83-2.83M6.76 6.76L3.93 3.93"/></svg>
             Without skipper
           </span>`
        : "";

    // Boat type tag
    const boatTypeTag = boatTypeLabel
      ? `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-gray-50 border border-gray-200 text-[11px] text-text-muted">
           <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 17h18M5 17l2-7h10l2 7"/></svg>
           ${boatTypeLabel}
         </span>`
      : "";

    // Specs line
    const specParts: string[] = [];
    if (boat.capacity && boat.capacity > 0) specParts.push(`Up to ${boat.capacity} people`);
    if (boat.length && boat.length > 0) specParts.push(`${boat.length} m`);
    const specsLine = specParts.length > 0 ? specParts.join(" · ") : "";

    if (isDraft) {
      card.style.opacity = "0.85";
    }

    // Status badge for footer
    const footerBadge = isDraft
      ? `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-amber-100 text-[11px] font-semibold text-amber-800">Draft</span>`
      : `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-green-100 text-[11px] font-semibold text-green-800">Published</span>`;

    card.innerHTML = `
      <div class="relative aspect-[4/3] overflow-hidden bg-gray-100">
        ${imagePart}
        ${dots}
        ${statusBadge}
        <button class="absolute top-3 right-3 h-8 w-8 rounded-full bg-white/80 backdrop-blur-sm flex items-center justify-center hover:bg-white transition-colors" aria-label="Save to favorites">
          <svg class="h-4 w-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
        </button>
      </div>
      <div class="p-4">
        <div class="flex items-start justify-between gap-2 mb-1">
          <h3 class="text-sm font-semibold text-text truncate">${location}</h3>
        </div>
        <p class="text-xs text-text-muted truncate mb-2.5">${name}</p>
        ${(skipperTag || boatTypeTag) ? `<div class="flex flex-wrap gap-1.5 mb-2.5">${skipperTag}${boatTypeTag}</div>` : ""}
        ${specsLine ? `<p class="text-xs text-text-muted mb-3">${specsLine}</p>` : ""}
        <div class="flex items-center justify-between pt-2 border-t border-gray-100">
          ${footerBadge}
          <div class="flex items-center gap-1">
            <button type="button" class="card-edit-btn h-8 w-8 rounded-lg flex items-center justify-center text-gray-400 hover:text-primary hover:bg-primary/5 transition-colors" aria-label="Edit listing" title="Edit">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/></svg>
            </button>
            <button type="button" class="card-delete-btn h-8 w-8 rounded-lg flex items-center justify-center text-gray-400 hover:text-red-600 hover:bg-red-50 transition-colors" aria-label="Delete listing" title="Delete">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/></svg>
            </button>
          </div>
        </div>
      </div>
    `;

    // Edit button — works for all statuses
    card.querySelector(".card-edit-btn")?.addEventListener("click", (e) => {
      e.stopPropagation();
      loadBoatIntoForm(boat.id, boat);
    });

    // Delete button
    card.querySelector(".card-delete-btn")?.addEventListener("click", async (e) => {
      e.stopPropagation();
      if (!confirm(`Are you sure you want to delete "${name}"? This action cannot be undone.`)) return;
      try {
        await deleteBoatListing(boat.id);
        // Remove from tracking array
        allListingCards = allListingCards.filter(c => c.el !== card);
        card.remove();
        updateTabCounts();
        // If no listings left, show form
        if (allListingCards.length === 0) {
          userHasListings = false;
          showForm();
          backBtn?.classList.add("hidden");
        }
      } catch (err) {
        console.error("Failed to delete listing:", err);
        alert("Failed to delete listing. Please try again.");
      }
    });

    return card;
  }

  // --- Form elements ---
  const boatForm = document.getElementById("boat-form") as HTMLFormElement | null;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;
  const submitSpinner = document.getElementById("submit-spinner");
  const submitText = document.getElementById("submit-text");
  const draftBtn = document.getElementById("draft-btn") as HTMLButtonElement | null;
  const draftSpinner = document.getElementById("draft-spinner");
  const draftText = document.getElementById("draft-text");
  const formSuccess = document.getElementById("form-success");
  const formError = document.getElementById("form-error");
  const formErrorMsg = document.getElementById("form-error-msg");

  const photoPlaceholder = `<div class="aspect-square rounded-xl border-2 border-dashed border-gray-200 bg-white flex items-center justify-center">
    <svg class="h-8 w-8 text-gray-300" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5">
      <rect x="10" y="10" width="28" height="28" rx="4" />
      <circle cx="20" cy="22" r="4" />
      <path d="M10 34l8-8 6 6 4-4 10 10" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </div>`;

  // --- Reset form ---
  function resetForm() {
    editingBoatId = null;
    existingImageUrls = [];
    boatForm?.reset();
    (window as any).__selectedFiles = [];

    // Reset boat type selection UI
    document.querySelectorAll(".boat-type-btn").forEach((b) => {
      b.classList.remove("border-primary", "bg-primary/5", "ring-2", "ring-primary");
      b.classList.add("border-gray-200");
    });
    (document.getElementById("boat-type-input") as HTMLInputElement).value = "";

    // Reset photo previews to placeholders
    const previewGrid = document.getElementById("photo-previews");
    if (previewGrid) {
      previewGrid.innerHTML = photoPlaceholder + photoPlaceholder + photoPlaceholder;
    }

    // Hide banners
    formSuccess?.classList.add("hidden");
    formError?.classList.add("hidden");
  }

  // --- Load existing boat into form for editing ---
  function loadBoatIntoForm(boatId: string, boatData: any) {
    resetForm();
    editingBoatId = boatId;

    // Set form field values
    const setValue = (id: string, val: any) => {
      const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null;
      if (el) el.value = val ?? "";
    };
    setValue("city", boatData.city);
    setValue("harbour", boatData.harbour);
    setValue("professional", boatData.professional);
    setValue("manufacturer", boatData.manufacturer);
    setValue("model", boatData.model);
    setValue("skipper", boatData.skipper);
    setValue("capacity", boatData.capacity || "");
    setValue("length", boatData.length || "");
    setValue("company", boatData.company);
    setValue("website", boatData.website);

    // Set boat type
    if (boatData.boatType) {
      (document.getElementById("boat-type-input") as HTMLInputElement).value = boatData.boatType;
      document.querySelectorAll(".boat-type-btn").forEach((b) => {
        if (b.getAttribute("data-type") === boatData.boatType) {
          b.classList.remove("border-gray-200");
          b.classList.add("border-primary", "bg-primary/5", "ring-2", "ring-primary");
        }
      });
    }

    // Render existing images as previews
    existingImageUrls = boatData.images || [];
    const previewGrid = document.getElementById("photo-previews");
    if (previewGrid && existingImageUrls.length > 0) {
      previewGrid.innerHTML = "";
      existingImageUrls.forEach((url: string, idx: number) => {
        const div = document.createElement("div");
        div.className = "relative aspect-square rounded-xl overflow-hidden border border-gray-200 bg-white group";
        div.innerHTML =
          `<img src="${url}" alt="Boat photo" class="h-full w-full object-cover" />` +
          `<button type="button" class="absolute top-2 right-2 h-6 w-6 rounded-full bg-black/60 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity remove-existing-photo">` +
          `<svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>` +
          `</button>`;
        previewGrid.appendChild(div);

        div.querySelector(".remove-existing-photo")?.addEventListener("click", () => {
          existingImageUrls = existingImageUrls.filter((_, i) => i !== idx);
          div.remove();
        });
      });
    }

    // Switch to form view
    showForm();
    // Scroll to top
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  // --- Shared save function ---
  async function saveBoat(status: "draft" | "published") {
    // Hide previous banners
    formSuccess?.classList.add("hidden");
    formError?.classList.add("hidden");

    const currentUser = auth.currentUser;
    if (!currentUser) return;

    // Validate boat type only for publish
    const boatType = (document.getElementById("boat-type-input") as HTMLInputElement).value;
    if (status === "published" && !boatType) {
      formError?.classList.remove("hidden");
      if (formErrorMsg) formErrorMsg.textContent = "Please select a boat type.";
      return;
    }

    // Collect form values
    const getValue = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLSelectElement)?.value || "";
    const data = {
      boatType: (boatType || "") as any,
      city: getValue("city"),
      harbour: getValue("harbour"),
      professional: getValue("professional") as "yes" | "no",
      manufacturer: getValue("manufacturer"),
      model: getValue("model"),
      skipper: getValue("skipper") as any,
      capacity: Number(getValue("capacity")) || 0,
      length: Number(getValue("length")) || 0,
      company: getValue("company"),
      website: (() => {
        const raw = getValue("website").trim();
        if (!raw) return "";
        return raw.match(/^https?:\/\//) ? raw : "https://" + raw;
      })(),
      ownerId: currentUser.uid,
      status,
    };

    // Get new files (filter out nulls from removed photos)
    const files: File[] = ((window as any).__selectedFiles || []).filter((f: any) => f != null);

    // Determine which button to show loading state on
    const isPublish = status === "published";
    const activeBtn = isPublish ? submitBtn : draftBtn;
    const activeSpinner = isPublish ? submitSpinner : draftSpinner;
    const activeText = isPublish ? submitText : draftText;
    const originalText = isPublish ? "Publish" : "Save as Draft";

    // Loading state
    if (activeBtn) activeBtn.disabled = true;
    if (submitBtn && !isPublish) submitBtn.disabled = true;
    if (draftBtn && isPublish) draftBtn.disabled = true;
    activeSpinner?.classList.remove("hidden");
    if (activeText) activeText.textContent = "Saving...";

    try {
      if (editingBoatId) {
        await updateBoatListing(editingBoatId, data, files, existingImageUrls);
      } else {
        await createBoatListing(data, files);
      }

      // Success
      formSuccess?.classList.remove("hidden");
      if (formSuccess) {
        const msgEl = formSuccess.querySelector("p");
        if (msgEl) msgEl.textContent = status === "draft"
          ? "Draft saved successfully!"
          : "Your boat has been published!";
      }

      resetForm();

      // Re-query and switch to listings view
      userHasListings = true;
      setTimeout(async () => {
        try {
          const q = query(
            collection(db, "boats"),
            where("ownerId", "==", currentUser.uid),
            orderBy("createdAt", "desc")
          );
          const snapshot = await getDocs(q);
          listingsGrid!.innerHTML = "";
          allListingCards = [];
          snapshot.docs.forEach((doc) => {
            const cardData = doc.data();
            const card = renderListingCard({ id: doc.id, ...cardData });
            listingsGrid!.appendChild(card);
            allListingCards.push({ el: card, status: cardData.status || "published" });
          });
          updateTabCounts();
          listingsTabs?.classList.remove("hidden");
          listingsLoading?.classList.add("hidden");
          listingsGrid?.classList.remove("hidden");
          filterByTab(activeTab);
          showListings();
        } catch (err) {
          console.error("Failed to refresh listings:", err);
        }
      }, 1500);
    } catch (err: any) {
      console.error("Failed to save listing:", err);
      formError?.classList.remove("hidden");
      if (formErrorMsg) formErrorMsg.textContent = err?.message || "Something went wrong. Please try again.";
    } finally {
      if (submitBtn) submitBtn.disabled = false;
      if (draftBtn) draftBtn.disabled = false;
      activeSpinner?.classList.add("hidden");
      if (activeText) activeText.textContent = originalText;
    }
  }

  // --- Form submit (Publish) ---
  boatForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    await saveBoat("published");
  });

  // --- Draft button ---
  draftBtn?.addEventListener("click", async () => {
    await saveBoat("draft");
  });

  onAuthStateChanged(auth, async (user) => {
    loading?.classList.add("hidden");

    if (!user) {
      hideAll();
      gate?.classList.remove("hidden");
      return;
    }

    // User is logged in — query their boats
    gate?.classList.add("hidden");

    try {
      const q = query(
        collection(db, "boats"),
        where("ownerId", "==", user.uid),
        orderBy("createdAt", "desc")
      );
      const snapshot = await getDocs(q);

      if (snapshot.empty) {
        // No listings — show the form directly
        userHasListings = false;
        showForm();
        backBtn?.classList.add("hidden");
      } else {
        // Has listings — render cards
        userHasListings = true;
        listingsGrid!.innerHTML = "";
        allListingCards = [];
        snapshot.docs.forEach((doc) => {
          const data = doc.data();
          const card = renderListingCard({ id: doc.id, ...data });
          listingsGrid!.appendChild(card);
          allListingCards.push({ el: card, status: data.status || "published" });
        });
        updateTabCounts();
        listingsTabs?.classList.remove("hidden");
        listingsLoading?.classList.add("hidden");
        listingsGrid?.classList.remove("hidden");
        filterByTab("all");
        showListings();
      }
    } catch (err) {
      console.error("Failed to fetch listings:", err);
      listingsLoading?.classList.add("hidden");
      listingsError?.classList.remove("hidden");
      showListings();
    }
  });
</script>

<!-- Fallback: if Firebase fails to load, show auth gate after timeout -->
<script is:inline>
  setTimeout(function () {
    var loading = document.getElementById("auth-loading");
    var gate = document.getElementById("auth-gate");
    if (loading && !loading.classList.contains("hidden")) {
      loading.classList.add("hidden");
      gate.classList.remove("hidden");
    }
  }, 3000);
</script>
