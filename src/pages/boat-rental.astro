---
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/boat-rental/Sidebar.astro";
import BoatCard from "../components/boat-rental/BoatCard.astro";
import { trendingBoats, allBoats } from "../lib/mock-boats";

const title = "Boat Rental — Find the Perfect Boat | BoatHaven";
const description =
  "Rent a boat from over 50,000 listings in 600+ destinations. Motorboats, sailboats, catamarans, yachts — with or without skipper. Best prices guaranteed.";
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: "Boat Rental",
      description: description,
      url: "https://boathaven.com/boat-rental",
      publisher: {
        "@type": "Organization",
        name: "BoatHaven",
        url: "https://boathaven.com",
      },
      breadcrumb: {
        "@type": "BreadcrumbList",
        itemListElement: [
          { "@type": "ListItem", position: 1, name: "Home", item: "https://boathaven.com" },
          { "@type": "ListItem", position: 2, name: "Boat Rental", item: "https://boathaven.com/boat-rental" },
        ],
      },
    })} />
  </Fragment>

  <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8 py-6">
    <!-- Breadcrumb -->
    <nav class="mb-4 text-xs text-text-muted" aria-label="Breadcrumb">
      <ol id="breadcrumb-list" class="flex items-center gap-1.5">
        <li><a href="/" class="hover:text-primary transition-colors">BoatHaven</a></li>
        <li>/</li>
        <li id="breadcrumb-current" class="text-text font-medium">Boat rental</li>
      </ol>
    </nav>

    <!-- Active filter chip (hidden by default, shown by JS when ?type= present) -->
    <div id="filter-chip" class="mb-4 flex items-center gap-2 hidden">
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-primary/10 text-primary text-sm font-medium">
        <span id="filter-chip-label"></span>
        <a href="/boat-rental" class="hover:bg-primary/20 rounded-full p-0.5 transition-colors" aria-label="Clear filter">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </a>
      </span>
      <span id="filter-chip-count" class="text-sm text-text-muted"></span>
    </div>

    <!-- Two-column layout -->
    <div class="flex gap-10 lg:gap-14">
      <!-- Left sidebar (hidden on mobile, shown on lg+) -->
      <div class="hidden lg:block">
        <Sidebar />
      </div>

      <!-- Mobile filter toggle -->
      <button
        id="mobile-filter-btn"
        class="lg:hidden fixed bottom-6 left-1/2 -translate-x-1/2 z-40 inline-flex items-center gap-2 px-5 py-3 rounded-full bg-text text-white text-sm font-semibold shadow-xl hover:bg-gray-800 transition-colors"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"/></svg>
        Filters
      </button>

      <!-- Main content area -->
      <div class="flex-1 min-w-0">
        <!-- Date prompt banner -->
        <div class="bg-amber-50 border border-amber-200/60 rounded-xl px-5 py-3.5 mb-6 flex items-center justify-between" id="date-banner">
          <div class="flex items-center gap-3">
            <svg class="h-5 w-5 text-amber-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
            <p class="text-sm text-amber-900">Add dates to find your ideal boat for the best price</p>
          </div>
          <button class="text-amber-600 hover:text-amber-800 transition-colors p-1" id="close-banner" aria-label="Dismiss">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <!-- No results (hidden by default) -->
        <div id="no-results" class="text-center py-16 hidden">
          <svg class="mx-auto h-16 w-16 text-text-muted/40 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <h2 class="text-xl font-bold text-text mb-2">No boats found</h2>
          <p id="no-results-text" class="text-text-muted mb-6">We couldn't find any boats matching your criteria.</p>
          <a href="/boat-rental" class="inline-flex items-center px-6 py-3 rounded-xl bg-primary text-white text-sm font-semibold hover:bg-primary-dark transition-colors">
            View all boats
          </a>
        </div>

        <!-- Top trending section -->
        <section id="trending-section" class="mb-10" aria-labelledby="trending-heading">
          <div class="mb-4">
            <h2 id="trending-heading" class="text-xl font-bold text-text">Top trending boat</h2>
            <p class="text-xs text-text-muted flex items-center gap-1 mt-0.5">
              How we rank results
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4m0-4h.01"/></svg>
            </p>
          </div>
          <div id="trending-grid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
            {trendingBoats.map((boat) => (
              <BoatCard boat={boat} />
            ))}
          </div>
        </section>

        <!-- All boats section -->
        <section id="all-boats-section" aria-labelledby="all-boats-heading">
          <div class="mb-4">
            <h2 id="all-boats-heading" class="text-xl font-bold text-text">+100 boats available</h2>
            <p class="text-xs text-text-muted flex items-center gap-1 mt-0.5">
              How we rank results
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4m0-4h.01"/></svg>
            </p>
          </div>
          <div id="all-boats-grid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
            {allBoats.map((boat) => (
              <BoatCard boat={boat} />
            ))}
          </div>

          <!-- Load more -->
          <div id="load-more-wrap" class="mt-8 text-center">
            <button class="inline-flex items-center gap-2 px-8 py-3 rounded-xl border border-gray-200 text-sm font-semibold text-text hover:border-gray-400 transition-colors">
              Show more boats
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
          </div>
        </section>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    var params = new URLSearchParams(window.location.search);
    var rawType = params.get("type") || "";
    // Map boat-types page slugs to our internal filter types
    var slugAliases = {
      motorboat: "motor", sailboat: "sailing", rib: "motor", houseboat: "motor"
    };
    var typeParam = slugAliases[rawType] || rawType;
    var validTypes = ["sailing", "motor", "catamaran", "yacht", "luxury", "party"];
    var typeLabels = {
      sailing: "Sailing", motor: "Motor", catamaran: "Catamaran",
      yacht: "Yacht", luxury: "Luxury", party: "Party"
    };

    // Dismiss banner
    var closeBanner = document.getElementById("close-banner");
    if (closeBanner) closeBanner.addEventListener("click", function () {
      var banner = document.getElementById("date-banner");
      if (banner) banner.remove();
    });

    if (validTypes.indexOf(typeParam) === -1) return; // No filter active

    var label = typeLabels[typeParam];

    // Update breadcrumb
    var breadcrumbCurrent = document.getElementById("breadcrumb-current");
    var breadcrumbList = document.getElementById("breadcrumb-list");
    if (breadcrumbCurrent && breadcrumbList) {
      // Insert "Boat rental" link before the current item
      var separator = document.createElement("li");
      separator.textContent = "/";
      var link = document.createElement("li");
      var a = document.createElement("a");
      a.href = "/boat-rental";
      a.className = "hover:text-primary transition-colors";
      a.textContent = "Boat rental";
      link.appendChild(a);
      breadcrumbList.insertBefore(link, breadcrumbCurrent);
      breadcrumbList.insertBefore(separator, breadcrumbCurrent);
      breadcrumbCurrent.textContent = label;
    }

    // Show filter chip
    var filterChip = document.getElementById("filter-chip");
    var chipLabel = document.getElementById("filter-chip-label");
    var chipCount = document.getElementById("filter-chip-count");
    if (filterChip) filterChip.classList.remove("hidden");
    if (chipLabel) chipLabel.textContent = label;

    // Filter boat cards in both grids
    function filterGrid(gridId) {
      var grid = document.getElementById(gridId);
      if (!grid) return 0;
      var cards = grid.querySelectorAll(".boat-card");
      var visible = 0;
      cards.forEach(function (card) {
        if (card.getAttribute("data-boat-type") === typeParam) {
          card.style.display = "";
          visible++;
        } else {
          card.style.display = "none";
        }
      });
      return visible;
    }

    var trendingVisible = filterGrid("trending-grid");
    var allVisible = filterGrid("all-boats-grid");
    var total = trendingVisible + allVisible;

    // Update count
    if (chipCount) chipCount.textContent = total + (total === 1 ? " boat" : " boats") + " found";

    // Hide trending section if no trending matches
    if (trendingVisible === 0) {
      var trendingSection = document.getElementById("trending-section");
      if (trendingSection) trendingSection.style.display = "none";
    } else {
      var trendingHeading = document.getElementById("trending-heading");
      if (trendingHeading) trendingHeading.textContent = "Top " + label.toLowerCase() + " boats";
    }

    // Update all boats heading
    var allHeading = document.getElementById("all-boats-heading");
    if (allHeading) allHeading.textContent = allVisible + " " + label.toLowerCase() + " " + (allVisible === 1 ? "boat" : "boats") + " available";

    // Hide load more when filtering
    var loadMore = document.getElementById("load-more-wrap");
    if (loadMore) loadMore.style.display = "none";

    // Show empty state if nothing matches
    if (total === 0) {
      var noResults = document.getElementById("no-results");
      var noResultsText = document.getElementById("no-results-text");
      if (noResults) noResults.classList.remove("hidden");
      if (noResultsText) noResultsText.textContent = "We couldn't find any " + label.toLowerCase() + " boats matching your criteria.";
      var trendingSection2 = document.getElementById("trending-section");
      var allSection = document.getElementById("all-boats-section");
      if (trendingSection2) trendingSection2.style.display = "none";
      if (allSection) allSection.style.display = "none";
    }
  });
</script>
