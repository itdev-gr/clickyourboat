---
import { getLangs, localizeHref } from "../../lib/i18n-utils";
export function getStaticPaths() { return getLangs(); }
const { lang } = Astro.params;
import Layout from "../../layouts/Layout.astro";

const title = "Booking Confirmed — TapYourBoat";
const description = "Your booking has been confirmed. Thank you for choosing TapYourBoat!";
const l = (href: string) => localizeHref(href, lang);
---
<Layout lang={lang} title={title} description={description}>
  <div class="min-h-[60vh] flex items-center justify-center px-4 py-16">
    <div class="max-w-lg w-full text-center">
      <div class="mx-auto mb-6 h-20 w-20 rounded-full bg-green-100 flex items-center justify-center">
        <svg class="h-10 w-10 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
      </div>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-text mb-3">Booking confirmed!</h1>
      <p class="text-text-muted mb-2">Your payment was successful and your booking request has been sent to the owner.</p>
      <p class="text-text-muted mb-6 text-sm">You will receive a confirmation once the owner approves your booking.</p>

      <div id="confirmation-warning" class="hidden mb-6 rounded-xl border border-amber-200 bg-amber-50 p-4 text-left">
        <p class="text-sm font-medium text-amber-800">Your payment was received, but automatic confirmation is still processing. Don't worry — our team will confirm your booking shortly.</p>
      </div>

      <!-- Booking details parsed from URL params -->
      <div id="booking-details" class="hidden mb-8 rounded-xl border border-gray-200 bg-gray-50 p-5 text-left">
        <h2 class="text-sm font-bold text-text uppercase tracking-wide mb-3">Booking Details</h2>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-text-muted">Check-in</span>
            <span id="detail-start" class="font-semibold text-text">—</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-muted">Check-out</span>
            <span id="detail-end" class="font-semibold text-text">—</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-muted">Duration</span>
            <span id="detail-duration" class="font-semibold text-text">—</span>
          </div>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href={l("/bookings")} class="inline-flex items-center px-6 py-3 rounded-xl bg-primary text-white text-sm font-bold hover:bg-primary-dark transition-colors">
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
          View my bookings
        </a>
        <a href={l("/")} class="inline-flex items-center px-6 py-3 rounded-xl bg-white text-text text-sm font-bold border border-gray-200 hover:bg-gray-50 transition-colors">
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1" /></svg>
          Back to home
        </a>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", async () => {
      const params = new URLSearchParams(window.location.search);
      const sessionId = params.get("session_id");
      const startDate = params.get("startDate");
      const endDate = params.get("endDate");

      // Verify payment with server if session_id is present
      if (sessionId) {
        try {
          const res = await fetch(`${import.meta.env.PUBLIC_SUPABASE_URL}/functions/v1/confirm-order`, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "Authorization": `Bearer ${import.meta.env.PUBLIC_SUPABASE_ANON_KEY}`,
            },
            body: JSON.stringify({ sessionId }),
          });
          const data = await res.json();
          if (!res.ok) {
            console.error("Order confirmation failed:", data.error);
            const w = document.getElementById("confirmation-warning");
            if (w) w.classList.remove("hidden");
          }
        } catch (err) {
          console.error("Order confirmation failed:", err);
          const w = document.getElementById("confirmation-warning");
          if (w) w.classList.remove("hidden");
        }
      }

      if (startDate && endDate) {
        const fmt = (dateStr: string) => {
          const d = new Date(dateStr + "T00:00:00");
          return d.toLocaleDateString(undefined, { weekday: "short", year: "numeric", month: "short", day: "numeric" });
        };

        const start = new Date(startDate + "T00:00:00");
        const end = new Date(endDate + "T00:00:00");
        const diffDays = Math.round((end.getTime() - start.getTime()) / (1000 * 60 * 60 * 24));

        const detailStart = document.getElementById("detail-start");
        const detailEnd = document.getElementById("detail-end");
        const detailDuration = document.getElementById("detail-duration");
        const wrapper = document.getElementById("booking-details");

        if (detailStart) detailStart.textContent = fmt(startDate);
        if (detailEnd) detailEnd.textContent = fmt(endDate);
        if (detailDuration) detailDuration.textContent = diffDays === 1 ? "1 day" : `${diffDays} days`;
        if (wrapper) wrapper.classList.remove("hidden");
      }
    });
  </script>
</Layout>

