---
import { getLangs, localizeHref } from "../../lib/i18n-utils";
export function getStaticPaths() { return getLangs(); }
const { lang } = Astro.params;
import Layout from "../../layouts/Layout.astro";

const title = "List Your Boat — TapYourBoat";
const description = "List your boat on TapYourBoat and start earning. Reach thousands of renters in 600+ destinations worldwide.";
const l = (href: string) => localizeHref(href, lang);
---
<Layout lang={lang} title={title} description={description} hideFooter>
  <!-- Loading state -->
  <div id="auth-loading" class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <div class="h-8 w-8 border-2 border-primary border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
      <p class="text-sm text-text-muted" data-i18n="lyb.auth_gate.loading">Loading...</p>
    </div>
  </div>

  <!-- Not logged in: Login prompt -->
  <div id="auth-gate" class="hidden">
    <div class="min-h-[60vh] flex items-center justify-center px-4 py-16">
      <div class="max-w-md w-full text-center">
        <div class="mx-auto mb-6 h-16 w-16 rounded-full bg-primary/10 flex items-center justify-center">
          <svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
        </div>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-text mb-3" data-i18n="lyb.auth_gate.title">Log in to list your boat</h1>
        <p class="text-text-muted mb-8 max-w-sm mx-auto" data-i18n="lyb.auth_gate.desc">
          You need to be logged in to list your boat on TapYourBoat. Sign in or create an account to get started.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a
            href={l("/login?redirect=/list-your-boat")}
            class="inline-flex items-center px-6 py-3 rounded-xl bg-primary text-white text-sm font-bold hover:bg-primary-dark transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
          >
            <span data-i18n="lyb.auth_gate.login">Log in</span>
          </a>
          <a
            href={l("/login?signup&redirect=/list-your-boat")}
            class="inline-flex items-center px-6 py-3 rounded-xl border border-gray-200 text-sm font-bold text-text hover:bg-gray-50 transition-colors"
          >
            <span data-i18n="lyb.auth_gate.create">Create account</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Logged in: User's existing listings -->
  <div id="my-listings" class="hidden">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-bold text-text" data-i18n="lyb.listings.title">My Listings</h1>
        <button
          type="button"
          id="add-new-listing-btn"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-primary text-white text-sm font-bold hover:bg-primary-dark transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          <span data-i18n="lyb.listings.add_new">Add New Listing</span>
        </button>
      </div>

      <!-- Filter tabs -->
      <div id="listings-tabs" class="hidden flex gap-2 mb-6">
        <button type="button" data-tab="all" class="listings-tab px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-primary text-white"><span data-i18n="lyb.listings.all">All</span> <span class="tab-count">(0)</span></button>
        <button type="button" data-tab="published" class="listings-tab px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-white text-gray-600 border border-gray-300 hover:bg-gray-50"><span data-i18n="lyb.listings.published">Published</span> <span class="tab-count">(0)</span></button>
        <button type="button" data-tab="pending" class="listings-tab px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-white text-gray-600 border border-gray-300 hover:bg-gray-50"><span data-i18n="lyb.listings.pending">Pending</span> <span class="tab-count">(0)</span></button>
        <button type="button" data-tab="drafts" class="listings-tab px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-white text-gray-600 border border-gray-300 hover:bg-gray-50"><span data-i18n="lyb.listings.drafts">Drafts</span> <span class="tab-count">(0)</span></button>
      </div>

      <!-- Loading spinner -->
      <div id="listings-loading" class="flex items-center justify-center py-16">
        <div class="text-center">
          <div class="h-8 w-8 border-2 border-primary border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
          <p class="text-sm text-text-muted" data-i18n="lyb.listings.loading">Loading your listings...</p>
        </div>
      </div>

      <!-- Error banner -->
      <div id="listings-error" class="hidden rounded-xl border border-red-200 bg-red-50 p-6 text-center">
        <p class="text-sm text-red-700 mb-3" data-i18n="lyb.listings.error">Failed to load your listings. Please try again.</p>
        <button type="button" id="listings-retry-btn" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-red-600 text-white text-sm font-medium hover:bg-red-700 transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"/></svg>
          <span data-i18n="lyb.listings.retry">Retry</span>
        </button>
      </div>

      <!-- Listings grid -->
      <div id="listings-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 hidden"></div>
    </div>
  </div>

  <!-- Logged in: Boat listing form (Wizard) -->
  <div id="listing-form" class="hidden">
    <div class="flex min-h-[calc(100vh-64px)]">
      <!-- Sidebar -->
      <aside id="wizard-sidebar" class="hidden lg:flex flex-col w-[280px] bg-white border-r border-gray-200 shrink-0 sticky top-[64px] h-[calc(100vh-64px)] overflow-y-auto">
        <div class="p-6 border-b border-gray-200">
          <h2 class="text-lg font-bold text-pink" data-i18n="lyb.wizard.greeting">Ahoy there Captain!</h2>
          <p class="text-sm text-text-muted mt-1" data-i18n="lyb.wizard.complete_all">Complete all sections to publish your listing</p>
          <div class="mt-4 h-2 bg-gray-100 rounded-full overflow-hidden">
            <div id="wizard-progress" class="h-full bg-pink rounded-full transition-all" style="width:0%"></div>
          </div>
          <p id="wizard-progress-text" class="text-xs text-text-muted mt-1">0 of 5 sections completed</p>
        </div>
        <nav class="flex-1 overflow-y-auto py-2" id="wizard-nav"></nav>
        <div class="p-6 border-t border-gray-200">
          <p class="text-xs text-text-muted" data-i18n="lyb.wizard.help">Need some help?</p>
          <p class="text-sm font-semibold text-text mt-1">+30 210 1234567</p>
        </div>
      </aside>

      <!-- Mobile floating menu button -->
      <button type="button" id="mobile-nav-toggle" class="lg:hidden fixed bottom-6 left-4 z-[55] h-14 w-14 rounded-full bg-pink text-white shadow-xl flex items-center justify-center hover:opacity-90 transition-opacity" aria-label="Open section menu">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>

      <!-- Mobile section drawer -->
      <div id="mobile-section-drawer" class="fixed inset-0 z-[60] pointer-events-none lg:hidden" aria-hidden="true">
        <div id="mobile-section-backdrop" class="absolute inset-0 bg-black/40 opacity-0 transition-opacity duration-300"></div>
        <div id="mobile-section-panel" class="absolute top-0 left-0 h-full w-72 max-w-[85vw] bg-white shadow-2xl -translate-x-full transition-transform duration-300 ease-out flex flex-col">
          <!-- Header -->
          <div class="flex items-center justify-between p-4 border-b border-gray-200">
            <span class="text-sm font-bold text-pink" data-i18n="lyb.wizard.greeting">Sections</span>
            <button type="button" id="mobile-section-close" class="p-2 rounded-lg text-text-muted hover:bg-gray-100 transition-colors" aria-label="Close menu">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
          <!-- Progress -->
          <div class="px-4 py-3 border-b border-gray-100">
            <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
              <div id="mobile-wizard-progress" class="h-full bg-pink rounded-full transition-all duration-300" style="width:0%"></div>
            </div>
            <p id="mobile-nav-label" class="text-xs text-text-muted mt-1.5">General</p>
          </div>
          <!-- Nav items -->
          <nav id="mobile-nav-drawer" class="flex-1 overflow-y-auto py-2"></nav>
        </div>
      </div>

      <!-- Main content -->
      <main class="flex-1 bg-gray-50 overflow-y-auto">
        <!-- Top bar -->
        <div class="sticky top-0 z-10 bg-white border-b border-gray-200 px-4 sm:px-6 py-3 flex items-center justify-between">
          <button type="button" id="wizard-back-btn" class="inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:text-primary-dark transition-colors">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/></svg>
            <span data-i18n="lyb.wizard.back">Back</span>
          </button>
          <div class="flex items-center gap-2">
            <button type="button" id="wizard-preview-btn" class="px-4 py-2 rounded-lg bg-gray-800 text-white text-sm font-medium hover:bg-gray-700 transition-colors" data-i18n="lyb.wizard.preview">Preview</button>
            <button type="button" id="wizard-save-btn" class="px-4 py-2 rounded-lg bg-pink text-white text-sm font-medium hover:opacity-90 transition-opacity" data-i18n="lyb.wizard.save">Save</button>
          </div>
        </div>

        <!-- Content area -->
        <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8">

          <!-- ===== Section 1: General ===== -->
          <div id="wizard-section-general" class="wizard-section">
            <h2 class="text-xl font-bold text-text mb-6" data-i18n="lyb.general.title">General Information</h2>
            <div class="mb-8">
              <label class="block text-sm font-semibold text-text mb-4"><span data-i18n="lyb.general.type">Type</span> <span class="text-red-500">*</span></label>
              <div class="grid grid-cols-3 sm:grid-cols-6 gap-3" id="boat-type-grid">
                <button type="button" data-type="motorboat" class="boat-type-btn flex flex-col items-center justify-center h-[110px] rounded-xl border border-gray-200 hover:border-primary hover:bg-primary/5 transition-colors cursor-pointer">
                  <svg class="h-10 w-10 text-gray-500 mb-2" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><path d="M6 30c0 0 6-6 18-6s18 6 18 6" stroke-linecap="round"/><path d="M14 24l8-10h8l-4 10" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  <span class="text-xs font-medium text-text" data-i18n="lyb.general.motorboat">Motorboat</span>
                </button>
                <button type="button" data-type="sailboat" class="boat-type-btn flex flex-col items-center justify-center h-[110px] rounded-xl border border-gray-200 hover:border-primary hover:bg-primary/5 transition-colors cursor-pointer">
                  <svg class="h-10 w-10 text-gray-500 mb-2" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><path d="M24 8v24" stroke-linecap="round"/><path d="M24 8L14 30h20L24 8z" stroke-linejoin="round"/><path d="M8 34c0 0 6-4 16-4s16 4 16 4" stroke-linecap="round"/></svg>
                  <span class="text-xs font-medium text-text" data-i18n="lyb.general.sailboat">Sailboat</span>
                </button>
                <button type="button" data-type="rib" class="boat-type-btn flex flex-col items-center justify-center h-[110px] rounded-xl border border-gray-200 hover:border-primary hover:bg-primary/5 transition-colors cursor-pointer">
                  <svg class="h-10 w-10 text-gray-500 mb-2" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><path d="M6 28c2-4 8-6 18-6s16 2 18 6" stroke-linecap="round"/><path d="M16 22l4-6h8l4 6" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 32h32" stroke-linecap="round"/></svg>
                  <span class="text-xs font-medium text-text" data-i18n="lyb.general.rib">RIB</span>
                </button>
                <button type="button" data-type="catamaran" class="boat-type-btn flex flex-col items-center justify-center h-[110px] rounded-xl border border-gray-200 hover:border-primary hover:bg-primary/5 transition-colors cursor-pointer">
                  <svg class="h-10 w-10 text-gray-500 mb-2" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><path d="M10 32l4-14h6l-2 14" stroke-linecap="round" stroke-linejoin="round"/><path d="M30 32l4-14h6l-2 14" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 28h32" stroke-linecap="round"/><path d="M12 32h24" stroke-linecap="round"/></svg>
                  <span class="text-xs font-medium text-text" data-i18n="lyb.general.catamaran">Catamaran</span>
                </button>
                <button type="button" data-type="without-licence" class="boat-type-btn flex flex-col items-center justify-center h-[110px] rounded-xl border border-gray-200 hover:border-primary hover:bg-primary/5 transition-colors cursor-pointer">
                  <svg class="h-10 w-10 text-gray-500 mb-2" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><path d="M8 30c2-4 8-6 16-6s14 2 16 6" stroke-linecap="round"/><path d="M18 24l4-8h4l4 8" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 34h28" stroke-linecap="round"/></svg>
                  <span class="text-xs font-medium text-text leading-tight text-center" data-i18n-html="lyb.general.without_licence">Boat without<br/>licence</span>
                </button>
                <button type="button" data-type="yacht" class="boat-type-btn flex flex-col items-center justify-center h-[110px] rounded-xl border border-gray-200 hover:border-primary hover:bg-primary/5 transition-colors cursor-pointer">
                  <svg class="h-10 w-10 text-gray-500 mb-2" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><path d="M6 32c2-6 10-10 18-10s14 4 18 10" stroke-linecap="round"/><path d="M24 22V10" stroke-linecap="round"/><path d="M24 10l10 8H24" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 36h32" stroke-linecap="round"/></svg>
                  <span class="text-xs font-medium text-text" data-i18n="lyb.general.yacht">Yacht</span>
                </button>
              </div>
              <input type="hidden" name="boatType" id="boat-type-input" />
            </div>
            <div class="mb-6 max-w-xs">
              <label for="skipperAvailable" class="block text-sm font-semibold text-text mb-2"><span data-i18n="lyb.general.skipper">Skipper</span> <span class="text-red-500">*</span></label>
              <div class="relative"><select id="skipperAvailable" name="skipperAvailable" required class="w-full appearance-none rounded-xl border border-gray-200 px-4 py-3.5 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent bg-white pr-10">
                <option value="no" data-i18n="lyb.general.no">No</option><option value="yes" data-i18n="lyb.general.yes">Yes</option>
              </select><svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg></div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">
              <div>
                <label for="city" class="block text-sm font-semibold text-text mb-2" data-i18n="lyb.general.city">City</label>
                <input type="text" id="city" name="city" class="w-full rounded-xl border border-gray-200 px-4 py-3.5 text-sm text-text placeholder:text-text-muted/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
              </div>
              <div>
                <label for="harbour" class="block text-sm font-semibold text-text mb-2"><span data-i18n="lyb.general.harbour">Harbour</span> <span class="text-red-500">*</span></label>
                <input type="text" id="harbour" name="harbour" placeholder="Enter harbour name" data-i18n-placeholder="lyb.general.harbour_ph" required class="w-full rounded-xl border border-gray-200 px-4 py-3.5 text-sm text-text placeholder:text-text-muted/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 items-start mb-6">
              <div>
                <label for="professional" class="block text-sm font-semibold text-text mb-2" data-i18n="lyb.general.professional">Are you a professional?</label>
                <div class="relative">
                  <select id="professional" name="professional" class="w-full appearance-none rounded-xl border border-gray-200 px-4 py-3.5 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent bg-white pr-10">
                    <option value="yes">Yes</option><option value="no">No</option>
                  </select>
                  <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </div>
              </div>
              <div class="bg-amber-50 border border-amber-200/60 rounded-xl p-4">
                <p class="text-sm text-amber-900"><strong data-i18n="lyb.general.attention">Attention:</strong> <span data-i18n="lyb.general.attention_text">Your status must be accurately indicated. Presenting yourself as a "non-professional" when that is not the case constitutes a misleading commercial practice.</span></p>
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">
              <div>
                <label for="manufacturer" class="block text-sm font-semibold text-text mb-2"><span data-i18n="lyb.general.manufacturer">Manufacturer</span> <span class="text-red-500">*</span></label>
                <input type="text" id="manufacturer" name="manufacturer" placeholder="Manufacturer" data-i18n-placeholder="lyb.general.manufacturer_ph" required class="w-full rounded-xl border border-gray-200 px-4 py-3.5 text-sm text-text placeholder:text-text-muted/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
              </div>
              <div>
                <label for="model" class="block text-sm font-semibold text-text mb-2"><span data-i18n="lyb.general.model">Model</span> <span class="text-red-500">*</span></label>
                <input type="text" id="model" name="model" placeholder="Model" data-i18n-placeholder="lyb.general.model_ph" required class="w-full rounded-xl border border-gray-200 px-4 py-3.5 text-sm text-text placeholder:text-text-muted/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
              </div>
            </div>
            <div class="mb-6">
              <label for="boatName" class="block text-sm font-semibold text-text mb-2"><span data-i18n="lyb.general.boat_name">Boat name</span> <span class="text-red-500">*</span></label>
              <input type="text" id="boatName" name="boatName" placeholder="Give your boat a name" data-i18n-placeholder="lyb.general.boat_name_ph" required class="w-full rounded-xl border border-gray-200 px-4 py-3.5 text-sm text-text placeholder:text-text-muted/50 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent max-w-md" />
            </div>
            <div class="flex justify-end mt-8">
              <button type="button" class="section-save-btn px-8 py-3 rounded-full bg-pink text-white text-sm font-bold hover:opacity-90 transition-opacity" data-section="general">Next</button>
            </div>
          </div>

          <!-- ===== Section 2: Description ===== -->
          <div id="wizard-section-description" class="wizard-section hidden">
            <h2 class="text-xl font-bold text-text mb-6" data-i18n="lyb.desc.title">Description</h2>
            <div class="mb-6">
              <label class="block text-sm font-semibold text-text mb-3"><span data-i18n="lyb.desc.languages">Languages of the listing</span> <span class="text-red-500">*</span></label>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-2" id="language-grid">
                <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 cursor-pointer"><input type="checkbox" name="languages" value="en" class="lang-cb h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" checked /><span class="text-sm text-text" data-i18n="lyb.desc.english">English</span></label>
                <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 cursor-pointer"><input type="checkbox" name="languages" value="el" class="lang-cb h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" /><span class="text-sm text-text" data-i18n="lyb.desc.greek">Greek</span></label>
                <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 cursor-pointer"><input type="checkbox" name="languages" value="fr" class="lang-cb h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" /><span class="text-sm text-text" data-i18n="lyb.desc.french">French</span></label>
                <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 cursor-pointer"><input type="checkbox" name="languages" value="es" class="lang-cb h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" /><span class="text-sm text-text" data-i18n="lyb.desc.spanish">Spanish</span></label>
                <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 cursor-pointer"><input type="checkbox" name="languages" value="it" class="lang-cb h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" /><span class="text-sm text-text" data-i18n="lyb.desc.italian">Italian</span></label>
                <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-gray-50 cursor-pointer"><input type="checkbox" name="languages" value="de" class="lang-cb h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" /><span class="text-sm text-text" data-i18n="lyb.desc.deutsch">Deutsch</span></label>
