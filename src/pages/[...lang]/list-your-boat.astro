  // ---- Photo upload previews ----
  window.__selectedFiles = [];
  var photoInput = document.getElementById("photo-input");
  var previewGrid = document.getElementById("photo-previews");
  var uploadZone = document.getElementById("upload-zone");
  var photoCountEl = document.getElementById("photo-count");
  var MAX_PHOTOS = 15;

  function getExistingCount() {
    return (window.__existingPreviewUrls || []).length;
  }
  function getNewCount() {
    return (window.__selectedFiles || []).filter(function (f) { return f != null; }).length;
  }
  function getTotalCount() {
    return getExistingCount() + getNewCount();
  }
  function updatePhotoCount() {
    var total = getTotalCount();
    if (photoCountEl) photoCountEl.textContent = total + " / " + MAX_PHOTOS + " photos";
    if (uploadZone) {
      if (total >= MAX_PHOTOS) {
        uploadZone.classList.add("opacity-50", "pointer-events-none");
      } else {
        uploadZone.classList.remove("opacity-50", "pointer-events-none");
      }
    }
  }
  window.updatePhotoCount = updatePhotoCount;

  if (uploadZone && photoInput) {
    uploadZone.addEventListener("click", function (e) {
      if (e.target === photoInput) return; // avoid double trigger
      photoInput.click();
    });
  }
  var browseLink = document.getElementById("photo-browse-link");
  if (browseLink && photoInput) {
    browseLink.addEventListener("click", function (e) {
      e.stopPropagation();
      photoInput.click();
    });
  }
  if (photoInput && previewGrid) {
    photoInput.addEventListener("change", function () {
      var files = photoInput.files;
      if (!files || files.length === 0) return;
      var currentTotal = getTotalCount();
      var slotsLeft = MAX_PHOTOS - currentTotal;
      if (slotsLeft <= 0) {
        alert("Maximum " + MAX_PHOTOS + " photos allowed.");
        photoInput.value = "";
        return;
      }
      var filesToAdd = [];
      for (var j = 0; j < files.length && j < slotsLeft; j++) { filesToAdd.push(files[j]); }
      if (files.length > slotsLeft) {
        alert("Only " + slotsLeft + " more photo(s) can be added. The rest were ignored.");
      }
      for (var i = 0; i < filesToAdd.length; i++) {
        (function (file) {
          var idx = window.__selectedFiles.length;
          window.__selectedFiles.push(file);
          var reader = new FileReader();
          reader.onload = function (e) {
            var div = document.createElement("div");
            div.className = "relative aspect-square rounded-xl overflow-hidden border border-gray-200 bg-white group";
            div.innerHTML = '<img src="' + e.target.result + '" alt="Boat photo" class="h-full w-full object-cover" />' +
              '<button type="button" class="absolute top-2 right-2 h-6 w-6 rounded-full bg-black/60 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity remove-photo">' +
              '<svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>';
            previewGrid.appendChild(div);
            div.querySelector(".remove-photo").addEventListener("click", function () { window.__selectedFiles[idx] = null; div.remove(); updatePhotoCount(); });
          };
          reader.readAsDataURL(file);
        })(filesToAdd[i]);
      }
      photoInput.value = "";
      updatePhotoCount();
    });
  }

  // ---- Drag & drop ----
  if (uploadZone) {
