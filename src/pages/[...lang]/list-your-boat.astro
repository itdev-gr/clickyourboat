  function openSectionDrawer() {
    if (!sectionDrawer) return;
    sectionDrawer.classList.remove("pointer-events-none");
    sectionDrawer.setAttribute("aria-hidden", "false");
    sectionBackdrop?.classList.remove("opacity-0");
    sectionBackdrop?.classList.add("opacity-100");
    sectionPanel?.classList.remove("-translate-x-full");
    sectionPanel?.classList.add("translate-x-0");
    document.body.style.overflow = "hidden";
  }

  function closeSectionDrawer() {
    if (!sectionDrawer) return;
    sectionBackdrop?.classList.remove("opacity-100");
    sectionBackdrop?.classList.add("opacity-0");
    sectionPanel?.classList.remove("translate-x-0");
    sectionPanel?.classList.add("-translate-x-full");
    document.body.style.overflow = "";
    setTimeout(function () {
      sectionDrawer.classList.add("pointer-events-none");
      sectionDrawer.setAttribute("aria-hidden", "true");
    }, 300);
  }

