  // ---- Translate select options ----
  function translateSelectOptions() {
    var yesNoMap = { "yes": tr("lyb.general.yes","Yes"), "no": tr("lyb.general.no","No") };
    ["professional", "licenceRequired", "yachtInsured", "equippedOffshore", "renovated"].forEach(function(id) {
      var sel = document.getElementById(id);
      if (sel) {
        Array.from(sel.options).forEach(function(opt) {
          if (yesNoMap[opt.value]) opt.textContent = yesNoMap[opt.value];
        });
      }
    });
    // Fuel cost options
    var fuelSel = document.getElementById("fuelCost");
    if (fuelSel) {
      Array.from(fuelSel.options).forEach(function(opt) {
        if (opt.value === "included") opt.textContent = tr("lyb.booking.fuel_included","Included");
        else if (opt.value === "not-included") opt.textContent = tr("lyb.booking.fuel_not_included","Not included");
        else if (opt.value === "by-arrangement") opt.textContent = tr("lyb.booking.fuel_arrangement","By arrangement");
      });
    }
    // Engine type options
    var engineSel = document.getElementById("engineType");
    if (engineSel) {
      Array.from(engineSel.options).forEach(function(opt) {
        if (opt.value === "") opt.textContent = tr("lyb.other.select","Select...");
        else if (opt.value === "inboard") opt.textContent = tr("lyb.other.inboard","Inboard");
        else if (opt.value === "outboard") opt.textContent = tr("lyb.other.outboard","Outboard");
        else if (opt.value === "electric") opt.textContent = tr("lyb.other.electric","Electric");
        else if (opt.value === "none") opt.textContent = tr("lyb.other.none","None");
      });
    }
    // Unavail reason options
    var reasonSel = document.getElementById("unavail-reason");
    if (reasonSel) {
      Array.from(reasonSel.options).forEach(function(opt) {
        if (opt.value === "personal") opt.textContent = tr("lyb.calendar.personal","Personal");
        else if (opt.value === "maintenance") opt.textContent = tr("lyb.calendar.maintenance","Maintenance");
        else if (opt.value === "booked-elsewhere") opt.textContent = tr("lyb.calendar.booked_elsewhere","Booked elsewhere");
        else if (opt.value === "other") opt.textContent = tr("lyb.calendar.other","Other");
      });
    }
    // Payment option checkboxes → sync hidden field
    document.querySelectorAll(".payment-option-cb").forEach(function(cb) {
      cb.addEventListener("change", function() {
        var opts = [];
        document.querySelectorAll(".payment-option-cb:checked").forEach(function(c) { opts.push(Number(c.value)); });
        if (opts.length === 0) { cb.checked = true; opts.push(Number(cb.value)); }
        var hidden = document.getElementById("downpaymentPercentage");
        if (hidden) hidden.value = JSON.stringify(opts);
