      if (!from || !to) return;
      window.__unavailPeriods.push({ startDate: from, endDate: to, reason: reason });
      renderUnavailPeriods();
    });
  }
  window.renderUnavailPeriods = function () {
    if (!unavailList) return;
    unavailList.innerHTML = "";
    window.__unavailPeriods.forEach(function (p, i) {
      var row = document.createElement("div");
      row.className = "flex items-center justify-between bg-white rounded-lg border border-gray-200 px-4 py-2";
      row.innerHTML = '<span class="text-sm text-text">' + p.startDate + ' ' + tr("lyb.price.to","to") + ' ' + p.endDate + ' (' + p.reason + ')</span>' +
        '<button type="button" class="text-red-500 hover:text-red-700 text-xs font-medium">' + tr("lyb.price.remove","Remove") + '</button>';
      row.querySelector("button").addEventListener("click", function () { window.__unavailPeriods.splice(i, 1); renderUnavailPeriods(); });
      unavailList.appendChild(row);
    });
  };

  // ---- Calendar grid (simple two-month view) ----
  window.renderCalendarGrid = function () {
    var container = document.getElementById("calendar-grid");
    if (!container) return;
    container.innerHTML = "";
    var today = new Date();
    for (var m = 0; m < 2; m++) {
      var month = new Date(today.getFullYear(), today.getMonth() + m, 1);
      var monthName = month.toLocaleString(lang === "el" ? "el-GR" : "en-US", { month: "long", year: "numeric" });
      var daysInMonth = new Date(month.getFullYear(), month.getMonth() + 1, 0).getDate();
      var firstDay = month.getDay() || 7; // Mon=1
      var html = '<div class="bg-white rounded-xl border border-gray-200 p-4"><h4 class="text-sm font-bold text-text mb-3 text-center">' + monthName + '</h4>';
      html += '<div class="grid grid-cols-7 gap-1 text-center text-xs text-text-muted mb-1"><span>' + tr("lyb.calendar.mo","Mo") + '</span><span>' + tr("lyb.calendar.tu","Tu") + '</span><span>' + tr("lyb.calendar.we","We") + '</span><span>' + tr("lyb.calendar.th","Th") + '</span><span>' + tr("lyb.calendar.fr","Fr") + '</span><span>' + tr("lyb.calendar.sa","Sa") + '</span><span>' + tr("lyb.calendar.su","Su") + '</span></div>';
      html += '<div class="grid grid-cols-7 gap-1 text-center text-xs">';
      for (var e = 1; e < firstDay; e++) html += '<span></span>';
      for (var d = 1; d <= daysInMonth; d++) {
        var dateStr = month.getFullYear() + '-' + String(month.getMonth() + 1).padStart(2, '0') + '-' + String(d).padStart(2, '0');
        var isToday = (d === today.getDate() && month.getMonth() === today.getMonth() && month.getFullYear() === today.getFullYear());
        var isUnavail = (window.__unavailPeriods || []).some(function (p) { return dateStr >= p.startDate && dateStr <= p.endDate; });
        var cls = "py-1 rounded";
        if (isToday) cls += " bg-pink text-white font-bold";
        else if (isUnavail) cls += " bg-red-100 text-red-600 line-through";
        else cls += " text-text hover:bg-gray-50";
        html += '<span class="' + cls + '">' + d + '</span>';
      }
      html += '</div></div>';
      container.insertAdjacentHTML("beforeend", html);
    }
  };
  renderCalendarGrid();

  // ---- Dynamic extras ----
  var extrasList = document.getElementById("extras-list");
  var addExtraBtn = document.getElementById("add-extra-btn");
  if (addExtraBtn && extrasList) {
    addExtraBtn.addEventListener("click", function () {
      var row = document.createElement("div");
      row.className = "flex flex-wrap items-center gap-3 bg-white rounded-lg border border-gray-200 p-3";
      row.innerHTML = '<input type="text" placeholder="' + tr("lyb.extras.name_ph","Extra name") + '" class="extra-name flex-1 min-w-[120px] rounded-lg border border-gray-200 px-3 py-2 text-sm" />' +
        '<div class="flex items-center"><input type="number" placeholder="0" class="extra-price w-20 rounded-l-lg border border-r-0 border-gray-200 px-3 py-2 text-sm" min="0" /><span class="inline-flex items-center h-[38px] px-2 border border-gray-200 rounded-r-lg bg-gray-50 text-xs text-text-muted">EUR/day</span></div>' +
        '<label class="flex items-center gap-1.5 text-sm text-text"><input type="checkbox" class="extra-mandatory h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" />' + tr("lyb.extras.mandatory","Mandatory") + '</label>' +
        '<button type="button" class="text-red-500 hover:text-red-700 text-sm" onclick="this.parentElement.remove()">' + tr("lyb.price.remove","Remove") + '</button>';
      extrasList.appendChild(row);
    });
  }

  // ---- Standard discount toggles ----
  document.querySelectorAll(".add-std-discount-btn").forEach(function (btn) {
    btn.addEventListener("click", function () {
      var config = btn.nextElementSibling;
      if (config) {
        config.classList.toggle("hidden");
        btn.textContent = config.classList.contains("hidden") ? "+ Add" : "- Remove";
      }
    });
  });

  // ---- Length-of-stay discounts ----
  var lenDiscList = document.getElementById("length-discounts-list");
  var addLenBtn = document.getElementById("add-length-discount-btn");
  if (addLenBtn && lenDiscList) {
    addLenBtn.addEventListener("click", function () {
      var row = document.createElement("div");
      row.className = "flex flex-wrap items-center gap-3 bg-white rounded-lg border border-gray-200 p-3";
      row.innerHTML = '<div class="flex items-center gap-1"><label class="text-xs text-text">' + tr("lyb.disc.min_days","Min days") + '</label><input type="number" class="len-disc-days w-16 rounded-lg border border-gray-200 px-2 py-1.5 text-sm" min="2" value="7" /></div>' +
        '<div class="flex items-center gap-1"><label class="text-xs text-text">' + tr("lyb.disc.pct","Discount %") + '</label><input type="number" class="len-disc-pct w-16 rounded-lg border border-gray-200 px-2 py-1.5 text-sm" min="1" max="100" value="10" /></div>' +
        '<button type="button" class="text-red-500 hover:text-red-700 text-sm" onclick="this.parentElement.remove()">' + tr("lyb.price.remove","Remove") + '</button>';
      lenDiscList.appendChild(row);
    });
  }

  // ---- Custom discounts ----
  var customDiscList = document.getElementById("custom-discounts-list");
  var addCustomBtn = document.getElementById("add-custom-discount-btn");
  if (addCustomBtn && customDiscList) {
    addCustomBtn.addEventListener("click", function () {
      var row = document.createElement("div");
      row.className = "flex flex-wrap items-center gap-3 bg-white rounded-lg border border-gray-200 p-3";
      row.innerHTML = '<input type="text" placeholder="' + tr("lyb.disc.name_ph","Discount name") + '" class="custom-disc-label flex-1 min-w-[120px] rounded-lg border border-gray-200 px-3 py-2 text-sm" />' +
        '<div class="flex items-center gap-1"><label class="text-xs text-text">%</label><input type="number" class="custom-disc-pct w-16 rounded-lg border border-gray-200 px-2 py-1.5 text-sm" min="1" max="100" value="10" /></div>' +
        '<button type="button" class="text-red-500 hover:text-red-700 text-sm" onclick="this.parentElement.remove()">' + tr("lyb.price.remove","Remove") + '</button>';
      customDiscList.appendChild(row);
    });
  }

  // ---- Preview functionality ----
  var previewModal = document.getElementById("preview-modal");
  var previewBtn = document.getElementById("wizard-preview-btn");
  var previewCloseBtn = document.getElementById("preview-close-btn");
  var previewCloseBtn2 = document.getElementById("preview-close-btn-2");
  var previewBackdrop = document.getElementById("preview-backdrop");

  function openPreview() {
    if (!previewModal) return;
    var gv = function (id) { var el = document.getElementById(id); return el ? el.value || "" : ""; };

    // --- Title ---
    var titleEl = document.getElementById("preview-title");
    var listingTitle = gv("listingTitle");
    var mfr = gv("manufacturer");
    var mdl = gv("model");
    var bName = gv("boatName");
    if (titleEl) titleEl.textContent = listingTitle || (mfr && mdl ? mfr + " " + mdl : "") || bName || tr("lyb.preview.untitled","Untitled Listing");

    // --- Location ---
    var locEl = document.getElementById("preview-location");
    if (locEl) {
      var city = gv("city");
      var harbour = gv("harbour");
      var loc = harbour && city ? city + ", " + harbour : city || tr("lyb.preview.location_not_set","Location not set");
      locEl.querySelector("span").textContent = loc;
    }

    // --- Tags ---
    var tagsEl = document.getElementById("preview-tags");
    if (tagsEl) {
      tagsEl.innerHTML = "";
      var boatType = gv("boat-type-input");
      if (boatType) {
        tagsEl.innerHTML += '<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-gray-50 border border-gray-200 text-xs text-text-muted"><svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 17h18M5 17l2-7h10l2 7"/></svg>' + boatType.charAt(0).toUpperCase() + boatType.slice(1) + '</span>';
      }
      var bookingMode = document.querySelector('input[name="bookingMode"]:checked');
      if (bookingMode && bookingMode.value === "instant") {
        tagsEl.innerHTML += '<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-gray-800 text-white text-xs font-semibold"><svg class="h-3 w-3 text-pink-light" fill="currentColor" viewBox="0 0 20 20"><path d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"/></svg>' + tr("lyb.preview.instant_booking","Instant booking") + '</span>';
      }
      var fuelVal = gv("fuelCost");
      if (fuelVal === "included") {
        tagsEl.innerHTML += '<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-green-50 border border-green-200 text-xs text-green-700"><svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>' + tr("lyb.preview.fuel_included","Fuel included") + '</span>';
      }
      var licence = gv("licenceRequired");
      if (licence === "no") {
        tagsEl.innerHTML += '<span class="inline-flex items-center px-2.5 py-1 rounded-full bg-gray-50 border border-gray-200 text-xs text-text-muted">' + tr("lyb.preview.no_licence","No licence needed") + '</span>';
      }
    }

    // --- Specs grid ---
    var specsEl = document.getElementById("preview-specs");
    if (specsEl) {
      specsEl.innerHTML = "";
      var specItems = [
        { label: tr("lyb.preview.capacity","Capacity"), val: gv("capacity"), unit: " " + tr("lyb.preview.people","people") },
        { label: tr("lyb.preview.length","Length"), val: gv("length"), unit: " m" },
        { label: tr("lyb.preview.width","Width"), val: gv("width"), unit: " m" },
        { label: tr("lyb.preview.cabins","Cabins"), val: gv("cabins"), unit: "" },
        { label: tr("lyb.preview.berths","Berths"), val: gv("berths"), unit: "" },
        { label: tr("lyb.preview.bathrooms","Bathrooms"), val: gv("bathrooms"), unit: "" },
        { label: tr("lyb.preview.horsepower","Horsepower"), val: gv("horsepower"), unit: " hp" },
        { label: tr("lyb.preview.speed","Speed"), val: gv("speed"), unit: " kn" }
      ];
      specItems.forEach(function (s) {
        if (s.val && s.val !== "0") {
          specsEl.innerHTML += '<div class="bg-gray-50 rounded-lg p-3 text-center"><p class="text-lg font-bold text-text">' + s.val + '<span class="text-xs font-normal text-text-muted">' + s.unit + '</span></p><p class="text-xs text-text-muted">' + s.label + '</p></div>';
        }
      });
    }

    // --- Description ---
    var descBlock = document.getElementById("preview-description-block");
    var descEl = document.getElementById("preview-description");
    var descVal = gv("description");
    if (descBlock && descEl) {
      if (descVal) { descBlock.classList.remove("hidden"); descEl.textContent = descVal; }
      else { descBlock.classList.add("hidden"); }
    }

    // --- Equipment ---
    var eqBlock = document.getElementById("preview-equipment-block");
    var eqEl = document.getElementById("preview-equipment");
    if (eqBlock && eqEl) {
      var checked = document.querySelectorAll("input.equip-cb:checked");
      if (checked.length > 0) {
        eqBlock.classList.remove("hidden");
        eqEl.innerHTML = "";
        checked.forEach(function (cb) {
          // Find the label text next to this checkbox
          var labelText = cb.parentElement ? cb.parentElement.querySelector("span") : null;
          var name = labelText ? labelText.textContent : cb.value;
          eqEl.innerHTML += '<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-primary/5 border border-primary/20 text-xs text-primary font-medium"><svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>' + name + '</span>';
        });
      } else { eqBlock.classList.add("hidden"); }
    }

    // --- Extras ---
    var extrasBlock = document.getElementById("preview-extras-block");
    var extrasEl = document.getElementById("preview-extras");
    if (extrasBlock && extrasEl) {
      var extraRows = document.querySelectorAll("#extras-list > div");
      if (extraRows.length > 0) {
        extrasBlock.classList.remove("hidden");
        extrasEl.innerHTML = "";
        extraRows.forEach(function (row) {
          var n = row.querySelector(".extra-name");
          var p = row.querySelector(".extra-price");
          var m = row.querySelector(".extra-mandatory");
          if (n && n.value) {
            var mLabel = m && m.checked ? '<span class="text-[10px] text-amber-700 bg-amber-50 px-1.5 py-0.5 rounded-full">' + tr("lyb.extras.mandatory","Mandatory") + '</span>' : '<span class="text-[10px] text-text-muted">' + tr("lyb.extras.optional","Optional") + '</span>';
            extrasEl.innerHTML += '<div class="flex items-center justify-between py-1"><span class="text-sm text-text">' + n.value + '</span><div class="flex items-center gap-2">' + mLabel + '<span class="text-sm font-semibold text-text">' + (p && p.value ? "€" + p.value + "/day" : tr("lyb.preview.free","Free")) + '</span></div></div>';
          }
        });
      } else { extrasBlock.classList.add("hidden"); }
    }

    // --- Price card ---
    var priceEl = document.getElementById("preview-price");
    var priceVal = gv("pricePerDay");
    if (priceEl) priceEl.textContent = priceVal ? "€" + Number(priceVal).toLocaleString() : "—";

    var bookingModeEl = document.getElementById("preview-booking-mode");
    if (bookingModeEl) {
      var bm = document.querySelector('input[name="bookingMode"]:checked');
      if (bm && bm.value === "instant") {
        bookingModeEl.innerHTML = '<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-gray-800 text-white text-xs font-semibold"><svg class="h-3 w-3 text-pink-light" fill="currentColor" viewBox="0 0 20 20"><path d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"/></svg>' + tr("lyb.preview.instant_booking","Instant booking") + '</span>';
      } else {
        bookingModeEl.innerHTML = '<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-gray-100 text-xs text-text-muted">' + tr("lyb.preview.confirmation_required","Confirmation required") + '</span>';
      }
    }

    var detailsList = document.getElementById("preview-details-list");
    if (detailsList) {
      detailsList.innerHTML = "";
      var details = [
        { label: tr("lyb.preview.checkin","Check-in"), val: gv("checkInTime") },
        { label: tr("lyb.preview.checkout","Check-out"), val: gv("checkOutTime") },
        { label: tr("lyb.preview.fuel","Fuel"), val: gv("fuelCost") ? gv("fuelCost").replace(/-/g, " ").replace(/^\w/, function (c) { return c.toUpperCase(); }) : "" },
        { label: tr("lyb.preview.licence","Licence"), val: gv("licenceRequired") === "yes" ? tr("lyb.preview.licence_required","Required") : gv("licenceRequired") === "no" ? tr("lyb.preview.licence_not_required","Not required") : "" },
        { label: tr("lyb.preview.deposit","Deposit"), val: gv("securityDeposit") ? "€" + gv("securityDeposit") : "" },
        { label: tr("lyb.preview.downpayment","Payment options"), val: (function() { try { var opts = JSON.parse(gv("downpaymentPercentage")); return opts.map(function(o) { return o === 100 ? "100%" : o + "% prepayment"; }).join(", "); } catch(e) { return gv("downpaymentPercentage"); } })() },
        { label: tr("lyb.preview.min_days","Min. days"), val: gv("reservationMinDays") && gv("reservationMinDays") !== "0" ? gv("reservationMinDays") : "" },
        { label: tr("lyb.preview.engine","Engine"), val: gv("engineType") ? gv("engineType").charAt(0).toUpperCase() + gv("engineType").slice(1) : "" },
        { label: tr("lyb.preview.year","Year"), val: gv("yearOfConstruction") && gv("yearOfConstruction") !== "0" ? gv("yearOfConstruction") : "" }
      ];
      details.forEach(function (d) {
        if (d.val) {
          detailsList.innerHTML += '<div class="flex items-center justify-between"><span class="text-text-muted">' + d.label + '</span><span class="font-medium text-text">' + d.val + '</span></div>';
        }
      });
    }

    // --- Photos ---
    var mainImgEl = document.getElementById("preview-main-image");
    var thumbsEl = document.getElementById("preview-thumbs");
    if (mainImgEl && thumbsEl) {
      // Collect all image sources: existing URLs + newly selected files
      var allImages = [];
      // Existing uploaded images
      (window.__existingPreviewUrls || []).forEach(function (url) { allImages.push({ type: "url", src: url }); });
      // From photo previews in the form
      var previewImgs = document.querySelectorAll("#photo-previews img");
      previewImgs.forEach(function (img) { allImages.push({ type: "url", src: img.src }); });

      // Deduplicate
      var seen = {};
      allImages = allImages.filter(function (item) {
        if (seen[item.src]) return false;
        seen[item.src] = true;
        return true;
      });

      if (allImages.length > 0) {
        mainImgEl.innerHTML = '<img src="' + allImages[0].src + '" alt="Boat" class="h-full w-full object-cover" />';
        thumbsEl.innerHTML = "";
        allImages.forEach(function (img, i) {
          var thumb = document.createElement("button");
          thumb.type = "button";
          thumb.className = "shrink-0 h-16 w-20 rounded-lg overflow-hidden border-2 transition-colors " + (i === 0 ? "border-pink" : "border-transparent hover:border-gray-300");
          thumb.innerHTML = '<img src="' + img.src + '" alt="" class="h-full w-full object-cover" />';
          thumb.addEventListener("click", function () {
            mainImgEl.innerHTML = '<img src="' + img.src + '" alt="Boat" class="h-full w-full object-cover" />';
            thumbsEl.querySelectorAll("button").forEach(function (b) { b.classList.remove("border-pink"); b.classList.add("border-transparent"); });
            thumb.classList.remove("border-transparent");
            thumb.classList.add("border-pink");
          });
          thumbsEl.appendChild(thumb);
        });
      } else {
        mainImgEl.innerHTML = '<p class="text-sm text-text-muted">' + tr("lyb.preview.no_photos","No photos uploaded yet") + '</p>';
        thumbsEl.innerHTML = "";
      }
    }

    // Show modal
    previewModal.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  }

  function closePreview() {
    if (previewModal) previewModal.classList.add("hidden");
    document.body.style.overflow = "";
  }

  if (previewBtn) previewBtn.addEventListener("click", openPreview);
  if (previewCloseBtn) previewCloseBtn.addEventListener("click", closePreview);
  if (previewCloseBtn2) previewCloseBtn2.addEventListener("click", closePreview);
  if (previewBackdrop) previewBackdrop.addEventListener("click", closePreview);

  // Close on Escape key
  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape" && previewModal && !previewModal.classList.contains("hidden")) {
      closePreview();
    }
  });
});
</script>


<script>
  import { onAuthChange } from "../../lib/auth";
  import { supabase } from "../../lib/supabase";
  import { createBoatListing, updateBoatListing, deleteBoatListing, createEmptyDraft, updateBoatSection, uploadBoatDocument, uploadBoatPhotos, getBoatListing } from "../../lib/api";

  // Access globals from the is:inline script (read lazily — inline script may not have run yet)
  function getSECTIONS() { return (window as any).SECTIONS; }
  function callShowWizardSection(id: string) { return (window as any).showWizardSection?.(id); }

  let currentAuthUser: any = null;

  // i18n helper — reads from window.__i18n populated by the i18n client script
  function tr(key: string, fallback: string): string {
    const i18n = (window as any).__i18n;
    if (!i18n?.translations?.[key]) return fallback;
    const lang = i18n.getLang?.() || "en";
    return i18n.translations[key][lang] || fallback;
  }

  const loading = document.getElementById("auth-loading");
  const gate = document.getElementById("auth-gate");
  const form = document.getElementById("listing-form");
  const myListings = document.getElementById("my-listings");
  const listingsGrid = document.getElementById("listings-grid");
  const listingsLoading = document.getElementById("listings-loading");
  const addNewBtn = document.getElementById("add-new-listing-btn");
  const wizardBackBtn = document.getElementById("wizard-back-btn");
  const listingsError = document.getElementById("listings-error");
  const listingsRetryBtn = document.getElementById("listings-retry-btn");
  const listingsTabs = document.getElementById("listings-tabs");
  const formSuccess = document.getElementById("form-success");
  const formError = document.getElementById("form-error");
  const formErrorMsg = document.getElementById("form-error-msg");
  const saveBtn = document.getElementById("wizard-save-btn");

  let userHasListings = false;
  let editingBoatId: string | null = null;
  let existingImageUrls: string[] = [];
  let allListingCards: { el: HTMLElement; status: string }[] = [];
  let activeTab = "all";

  function hideAll() {
    gate?.classList.add("hidden");
    form?.classList.add("hidden");
    myListings?.classList.add("hidden");
  }

  function showForm() {
    hideAll();
    form?.classList.remove("hidden");
  }

  function showListings() {
    hideAll();
    myListings?.classList.remove("hidden");
  }

  // --- Tab filtering ---
  function updateTabCounts() {
    const total = allListingCards.length;
    const published = allListingCards.filter(c => c.status === "published").length;
    const pending = allListingCards.filter(c => c.status === "pending").length;
    const drafts = allListingCards.filter(c => c.status === "draft").length;
    document.querySelectorAll(".listings-tab").forEach(tab => {
      const key = tab.getAttribute("data-tab");
      const countEl = tab.querySelector(".tab-count");
      if (!countEl) return;
      if (key === "all") countEl.textContent = `(${total})`;
      else if (key === "published") countEl.textContent = `(${published})`;
      else if (key === "pending") countEl.textContent = `(${pending})`;
      else if (key === "drafts") countEl.textContent = `(${drafts})`;
    });
  }

  function filterByTab(tab: string) {
    activeTab = tab;
    allListingCards.forEach(({ el, status }) => {
      if (tab === "all") el.style.display = "";
      else if (tab === "published") el.style.display = status === "published" ? "" : "none";
      else if (tab === "pending") el.style.display = status === "pending" ? "" : "none";
      else if (tab === "drafts") el.style.display = status === "draft" ? "" : "none";
    });
    document.querySelectorAll(".listings-tab").forEach(btn => {
      if (btn.getAttribute("data-tab") === tab) {
        btn.classList.remove("bg-white", "text-gray-600", "border", "border-gray-300", "hover:bg-gray-50");
        btn.classList.add("bg-primary", "text-white");
      } else {
        btn.classList.remove("bg-primary", "text-white");
        btn.classList.add("bg-white", "text-gray-600", "border", "border-gray-300", "hover:bg-gray-50");
      }
    });
  }

  document.querySelectorAll(".listings-tab").forEach(btn => {
    btn.addEventListener("click", () => { filterByTab(btn.getAttribute("data-tab") || "all"); });
  });

  // --- "Add New Listing" → create draft then open wizard ---
  addNewBtn?.addEventListener("click", async () => {
    const user = currentAuthUser;
    if (!user) return;
    try {
      addNewBtn.textContent = tr("lyb.msg.creating", "Creating...");
      (addNewBtn as HTMLButtonElement).disabled = true;
      const boatId = await createEmptyDraft(user.id);
      editingBoatId = boatId;
      existingImageUrls = [];
      resetWizardForm();
      showForm();
      (window as any).showWizardSection("general");
    } catch (err) {
      console.error("Failed to create draft:", err);
      alert(tr("lyb.msg.create_draft_fail", "Failed to create draft. Please try again."));
    } finally {
      addNewBtn.innerHTML = '<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg> ' + tr("lyb.listings.add_new", "Add New Listing");
      (addNewBtn as HTMLButtonElement).disabled = false;
    }
  });

  // --- "Back" button in wizard ---
  wizardBackBtn?.addEventListener("click", () => {
    if (userHasListings) showListings();
    else history.back();
  });

  // Retry button
  listingsRetryBtn?.addEventListener("click", () => {
    listingsError?.classList.add("hidden");
    listingsLoading?.classList.remove("hidden");
    const user = currentAuthUser;
    if (user) loadUserListings(user.id);
  });

  // --- Render listing card ---
  function renderListingCard(boat: any) {
    const card = document.createElement("article");
    card.className = "boat-card bg-white rounded-xl border border-gray-200/80 overflow-hidden hover:shadow-lg transition-shadow duration-200 group";
    const name = boat.manufacturer && boat.model ? `${boat.manufacturer} ${boat.model}` : boat.boatName || boat.listingTitle || boat.title || "Untitled";
    const city = boat.city || boat.location?.city || "";
    const harbour = boat.harbour || "";
    const location = harbour && city ? `${city}, ${harbour}` : city || "—";
    const boatType = boat.boatType || boat.type || "";
    const boatTypeLabel = boatType ? boatType.charAt(0).toUpperCase() + boatType.slice(1) : "";
    const images = boat.images || [];
    const firstImage = images.length > 0 ? images[0] : null;
    const boatStatus = boat.status || "published";
    const isDraft = boatStatus === "draft";
    const isPending = boatStatus === "pending";
    let isNew = false;
    if (boatStatus === "published" && (boat.createdAt || boat.created_at)) {
      const createdVal = boat.createdAt || boat.created_at;
      const created = createdVal instanceof Date ? createdVal : new Date(createdVal);
      if (created && !isNaN(created.getTime())) { const d = new Date(); d.setDate(d.getDate() - 7); isNew = created > d; }
    }
    const imagePart = firstImage
      ? `<img src="${firstImage}" alt="${name}" class="h-full w-full object-cover" loading="lazy" />`
      : `<div class="h-full w-full flex items-center justify-center"><svg class="h-12 w-12 text-gray-300" fill="none" viewBox="0 0 48 48" stroke="currentColor" stroke-width="1.5"><path d="M6 30c0 0 6-6 18-6s18 6 18 6" stroke-linecap="round"/><path d="M14 24l8-10h8l-4 10" stroke-linecap="round" stroke-linejoin="round"/></svg></div>`;
    const statusBadge = isDraft
      ? `<div class="absolute top-3 left-3 inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-amber-100 text-xs font-semibold text-amber-800">${tr("lyb.listings.status_draft", "Draft")}</div>`
      : isPending ? `<div class="absolute top-3 left-3 inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-blue-100 text-xs font-semibold text-blue-800">${tr("lyb.listings.status_review", "In Review")}</div>`
      : isNew ? `<div class="absolute top-3 left-3 flex items-center gap-1 text-xs font-semibold text-gray-700"><svg class="h-3.5 w-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>${tr("lyb.listings.status_new", "New")}</div>` : "";
    const footerBadge = isDraft
      ? `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-amber-100 text-[11px] font-semibold text-amber-800">${tr("lyb.listings.status_draft", "Draft")}</span>`
      : isPending ? `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-blue-100 text-[11px] font-semibold text-blue-800">${tr("lyb.listings.status_review", "In Review")}</span>`
      : `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-green-100 text-[11px] font-semibold text-green-800">${tr("lyb.listings.status_published", "Published")}</span>`;
    const boatTypeTag = boatTypeLabel ? `<span class="inline-flex items-center px-2 py-0.5 rounded-full bg-gray-50 border border-gray-200 text-[11px] text-text-muted">${boatTypeLabel}</span>` : "";
    if (isDraft) card.style.opacity = "0.85";
    card.innerHTML = `
      <div class="relative aspect-[4/3] overflow-hidden bg-gray-100">${imagePart}${statusBadge}</div>
      <div class="p-4">
        <h3 class="text-sm font-semibold text-text truncate mb-1">${location}</h3>
        <p class="text-xs text-text-muted truncate mb-2.5">${name}</p>
        ${boatTypeTag ? `<div class="flex flex-wrap gap-1.5 mb-2.5">${boatTypeTag}</div>` : ""}
        <div class="flex items-center justify-between pt-2 border-t border-gray-100">
          ${footerBadge}
          <div class="flex items-center gap-1">
            <button type="button" class="card-edit-btn h-8 w-8 rounded-lg flex items-center justify-center text-gray-400 hover:text-primary hover:bg-primary/5 transition-colors" title="Edit">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/></svg>
            </button>
            <button type="button" class="card-delete-btn h-8 w-8 rounded-lg flex items-center justify-center text-gray-400 hover:text-red-600 hover:bg-red-50 transition-colors" title="Delete">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/></svg>
            </button>
          </div>
        </div>
      </div>`;
    card.style.cursor = "pointer";
    card.addEventListener("click", async () => {
      await loadBoatIntoWizard(boat.id);
    });
    card.querySelector(".card-edit-btn")?.addEventListener("click", async (e) => {
      e.stopPropagation();
      await loadBoatIntoWizard(boat.id);
    });
    card.querySelector(".card-delete-btn")?.addEventListener("click", async (e) => {
      e.stopPropagation();
      if (!confirm(tr("lyb.msg.delete_confirm", `Delete "${name}"? This cannot be undone.`).replace("{name}", name))) return;
      try {
        await deleteBoatListing(boat.id);
        allListingCards = allListingCards.filter(c => c.el !== card);
        card.remove();
        updateTabCounts();
        if (allListingCards.length === 0) { userHasListings = false; showForm(); }
      } catch (err) { console.error("Delete failed:", err); alert(tr("lyb.msg.delete_fail", "Failed to delete.")); }
    });
    return card;
  }

  // --- Reset wizard form ---
  function resetWizardForm() {
    existingImageUrls = [];
    (window as any).__selectedFiles = [];
    (window as any).__unavailPeriods = [];
    (window as any).__existingPreviewUrls = [];
    // Reset all inputs
    document.querySelectorAll("#listing-form input[type=text], #listing-form input[type=number], #listing-form textarea").forEach((el: any) => { el.value = ""; });
    document.querySelectorAll("#listing-form select").forEach((el: any) => { el.selectedIndex = 0; });
    document.querySelectorAll("#listing-form input[type=checkbox]").forEach((el: any) => { el.checked = false; });
    document.querySelectorAll("#listing-form input[type=radio]").forEach((el: any) => { el.checked = false; });
    // Reset boat type
    document.querySelectorAll(".boat-type-btn").forEach(b => { b.classList.remove("border-primary", "bg-primary/5", "ring-2", "ring-primary"); b.classList.add("border-gray-200"); });
    (document.getElementById("boat-type-input") as HTMLInputElement).value = "";
    // Reset dynamic lists
    const ppList = document.getElementById("price-periods-list"); if (ppList) ppList.innerHTML = "";
    const unavailList = document.getElementById("unavail-periods-list"); if (unavailList) unavailList.innerHTML = "";
    const extrasList = document.getElementById("extras-list"); if (extrasList) extrasList.innerHTML = "";
    const lenDisc = document.getElementById("length-discounts-list"); if (lenDisc) lenDisc.innerHTML = "";
    const customDisc = document.getElementById("custom-discounts-list"); if (customDisc) customDisc.innerHTML = "";
    const photoPreview = document.getElementById("photo-previews"); if (photoPreview) photoPreview.innerHTML = "";
    (window as any).__selectedFiles = []; (window as any).__existingPreviewUrls = []; if ((window as any).updatePhotoCount) (window as any).updatePhotoCount();
    // Reset discount toggles
    document.querySelectorAll(".discount-config").forEach(c => c.classList.add("hidden"));
    document.querySelectorAll(".add-std-discount-btn").forEach((b: any) => { b.textContent = "+ Add"; });
    // Reset section checkmarks
    document.querySelectorAll(".section-check, .mobile-section-check").forEach(c => c.classList.add("hidden"));
    // Reset progress
    updateProgress([]);
    // Hide banners
    formSuccess?.classList.add("hidden");
    formError?.classList.add("hidden");
  }

  // --- Load existing boat into wizard ---
  async function loadBoatIntoWizard(boatId: string) {
    try {
      const data = await getBoatListing(boatId);
      if (!data) { alert(tr("lyb.msg.boat_not_found", "Boat not found")); return; }
      editingBoatId = boatId;
      resetWizardForm();
      const setValue = (id: string, val: any) => { const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null; if (el && val != null) el.value = String(val); };
      // General
      if (data.boatType) {
        (document.getElementById("boat-type-input") as HTMLInputElement).value = data.boatType;
        document.querySelectorAll(".boat-type-btn").forEach(b => {
          if (b.getAttribute("data-type") === data.boatType) { b.classList.remove("border-gray-200"); b.classList.add("border-primary", "bg-primary/5", "ring-2", "ring-primary"); }
        });
      }
      setValue("city", data.city); setValue("harbour", data.harbour); setValue("professional", data.professional);
      setValue("manufacturer", data.manufacturer); setValue("model", data.model); setValue("boatName", data.boatName);
      setValue("skipperAvailable", data.skipperAvailable ? "yes" : "no");
      // Description
      if (data.languages) { data.languages.forEach((l: string) => { const cb = document.querySelector(`input.lang-cb[value="${l}"]`) as HTMLInputElement; if (cb) cb.checked = true; }); }
      setValue("listingTitle", data.listingTitle); setValue("description", data.description);
      // Price
      setValue("pricePerDay", data.pricePerDay); setValue("reservationMinDays", data.reservationMinDays); setValue("reservationMaxDays", data.reservationMaxDays);
      // Booking
      if (data.bookingMode) { const radio = document.querySelector(`input[name="bookingMode"][value="${data.bookingMode}"]`) as HTMLInputElement; if (radio) { radio.checked = true; radio.dispatchEvent(new Event("change")); } }
      setValue("checkInTime", data.checkInTime); setValue("checkOutTime", data.checkOutTime);
      setValue("checkInTimeDayRental", data.checkInTimeDayRental); setValue("checkOutTimeDayRental", data.checkOutTimeDayRental);
      // Load payment options checkboxes
      (() => {
        let opts: number[] = [];
        const raw = data.downpaymentPercentage;
        if (Array.isArray(raw)) opts = raw;
        else if (typeof raw === "string") { try { opts = JSON.parse(raw); } catch { opts = [Number(raw) || 100]; } }
        else if (typeof raw === "number") opts = [raw];
        else opts = [30, 100];
        const cb30 = document.getElementById("paymentOption30") as HTMLInputElement;
        const cb100 = document.getElementById("paymentOption100") as HTMLInputElement;
        if (cb30) cb30.checked = opts.includes(30);
        if (cb100) cb100.checked = opts.includes(100);
        const hidden = document.getElementById("downpaymentPercentage") as HTMLInputElement;
        if (hidden) hidden.value = JSON.stringify(opts);
      })();
      setValue("fuelCost", data.fuelCost); setValue("licenceRequired", data.licenceRequired);
      // Documents
      setValue("securityDeposit", data.securityDeposit); setValue("yachtInsured", data.yachtInsured);
      // Show existing certificate previews
      if (data.insuranceCertificateUrl) {
        const preview = document.getElementById("insurance-cert-preview");
        if (preview) preview.innerHTML = `<a href="${data.insuranceCertificateUrl}" target="_blank" rel="noopener" class="underline text-primary">✓ ${tr("lyb.docs.uploaded", "Uploaded")} – ${tr("lyb.docs.view", "View")}</a>`;
      }
      if (data.ownershipCertificateUrl) {
        const preview = document.getElementById("ownership-cert-preview");
        if (preview) preview.innerHTML = `<a href="${data.ownershipCertificateUrl}" target="_blank" rel="noopener" class="underline text-primary">✓ ${tr("lyb.docs.uploaded", "Uploaded")} – ${tr("lyb.docs.view", "View")}</a>`;
      }
      // Other
      setValue("engineType", data.engineType); setValue("horsepower", data.horsepower); setValue("width", data.width);
      setValue("boatDraft", data.draft); setValue("equippedOffshore", data.equippedOffshore); setValue("crewMembers", data.crewMembers);
      setValue("tenderHorsepower", data.tenderHorsepower); setValue("yearOfConstruction", data.yearOfConstruction);
      setValue("renovated", data.renovated); setValue("fuelConsumption", data.fuel); setValue("speed", data.speed);
      setValue("capacity", data.capacity); setValue("length", data.length); setValue("cabins", data.cabins);
      setValue("berths", data.berths); setValue("bathrooms", data.bathrooms);
      // Equipment
      if (data.equipment) { data.equipment.forEach((eq: string) => { const cb = document.querySelector(`input.equip-cb[value="${eq}"]`) as HTMLInputElement; if (cb) cb.checked = true; }); }
      // Unavailability periods
      if (data.unavailabilityPeriods) { (window as any).__unavailPeriods = [...data.unavailabilityPeriods]; (window as any).renderUnavailPeriods(); (window as any).renderCalendarGrid(); }
      // Images
      existingImageUrls = data.images || [];
      (window as any).__existingPreviewUrls = [...existingImageUrls];
      const photoPreview = document.getElementById("photo-previews");
      if (photoPreview && existingImageUrls.length > 0) {
        existingImageUrls.forEach((url: string, idx: number) => {
          const div = document.createElement("div");
          div.className = "relative aspect-square rounded-xl overflow-hidden border border-gray-200 bg-white group";
          div.innerHTML = `<img src="${url}" alt="Photo" class="h-full w-full object-cover" /><button type="button" class="absolute top-2 right-2 h-6 w-6 rounded-full bg-black/60 text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity remove-existing-photo"><svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>`;
          photoPreview.appendChild(div);
          div.querySelector(".remove-existing-photo")?.addEventListener("click", () => { existingImageUrls = existingImageUrls.filter((_: string, i: number) => i !== idx); (window as any).__existingPreviewUrls = [...existingImageUrls]; div.remove(); (window as any).updatePhotoCount(); });
        });
        (window as any).updatePhotoCount();
      }
      // Section completion
      if (data.completedSections) {
        completedSectionsSet = new Set(data.completedSections);
        updateProgress(data.completedSections);
      }
      showForm();
      (window as any).showWizardSection("general");
    } catch (err) { console.error("Failed to load boat:", err); alert(tr("lyb.msg.load_fail", "Failed to load boat data.")); }
  }

  // --- Collect section data ---
  function collectSectionData(section: string): Record<string, any> {
    const gv = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLSelectElement)?.value || "";
    const gn = (id: string) => { const v = Number(gv(id)); return isNaN(v) ? 0 : v; };
    switch (section) {
      case "general": return { boatType: gv("boat-type-input"), city: gv("city"), harbour: gv("harbour"), professional: gv("professional"), manufacturer: gv("manufacturer"), model: gv("model"), boatName: gv("boatName"), skipperAvailable: gv("skipperAvailable") === "yes" };
      case "description": {
        const langs: string[] = []; document.querySelectorAll("input.lang-cb:checked").forEach((cb: any) => langs.push(cb.value));
        return { languages: langs, listingTitle: gv("listingTitle"), description: gv("description") };
      }
      case "price": {
        const periods: any[] = [];
        document.querySelectorAll("#price-periods-list > div").forEach(row => {
          const s = (row.querySelector(".pp-start") as HTMLInputElement)?.value;
          const e = (row.querySelector(".pp-end") as HTMLInputElement)?.value;
          const p = Number((row.querySelector(".pp-price") as HTMLInputElement)?.value) || 0;
          if (s && e) periods.push({ startDate: s, endDate: e, pricePerDay: p });
        });
        // Discounts
        const discounts: any[] = [];
        document.querySelectorAll(".std-discount-pct").forEach((inp: any) => {
          if (!inp.closest(".discount-config")?.classList.contains("hidden")) {
            discounts.push({ type: inp.getAttribute("data-type"), percentage: Number(inp.value) || 0 });
          }
        });
        document.querySelectorAll("#length-discounts-list > div").forEach(row => {
          const days = Number((row.querySelector(".len-disc-days") as HTMLInputElement)?.value) || 0;
          const pct = Number((row.querySelector(".len-disc-pct") as HTMLInputElement)?.value) || 0;
          if (days && pct) discounts.push({ type: "length-of-stay", percentage: pct, minDays: days });
        });
        document.querySelectorAll("#custom-discounts-list > div").forEach(row => {
          const label = (row.querySelector(".custom-disc-label") as HTMLInputElement)?.value;
          const pct = Number((row.querySelector(".custom-disc-pct") as HTMLInputElement)?.value) || 0;
          if (label && pct) discounts.push({ type: "custom", percentage: pct, label });
        });
        // Extras
        const extras: any[] = [];
        document.querySelectorAll("#extras-list > div").forEach(row => {
          const n = (row.querySelector(".extra-name") as HTMLInputElement)?.value;
          const p = Number((row.querySelector(".extra-price") as HTMLInputElement)?.value) || 0;
          const m = (row.querySelector(".extra-mandatory") as HTMLInputElement)?.checked || false;
          if (n) extras.push({ name: n, pricePerDay: p, mandatory: m });
        });
        return {
          pricePerDay: gn("pricePerDay"), currency: "EUR", pricePeriods: periods, reservationMinDays: gn("reservationMinDays"), reservationMaxDays: gn("reservationMaxDays"),
          bookingMode: gv("bookingMode") || "confirmation", checkInTime: gv("checkInTime"), checkOutTime: gv("checkOutTime"), checkInTimeDayRental: gv("checkInTimeDayRental"), checkOutTimeDayRental: gv("checkOutTimeDayRental"), downpaymentPercentage: (function() { try { return JSON.parse(gv("downpaymentPercentage")); } catch(e) { return [100]; } })(), fuelCost: gv("fuelCost"), licenceRequired: gv("licenceRequired"),
          discounts, extras
        };
      }
      case "calendar": return { unavailabilityPeriods: (window as any).__unavailPeriods || [] };
      case "insurance": return { securityDeposit: gn("securityDeposit"), yachtInsured: gv("yachtInsured") };
      case "equipment": {
        const eq: string[] = []; document.querySelectorAll("input.equip-cb:checked").forEach((cb: any) => eq.push(cb.value));
        return { equipment: eq, engineType: gv("engineType"), horsepower: gn("horsepower"), width: gn("width"), draft: gn("boatDraft"), equippedOffshore: gv("equippedOffshore"), crewMembers: gn("crewMembers"), tenderHorsepower: gn("tenderHorsepower"), yearOfConstruction: gn("yearOfConstruction"), renovated: gv("renovated"), fuel: gn("fuelConsumption"), speed: gn("speed"), capacity: gn("capacity"), length: gn("length"), cabins: gn("cabins"), berths: gn("berths"), bathrooms: gn("bathrooms") };
      }
      default: return {};
    }
  }

  // --- Progress tracking ---
  function updateProgress(completedSections: string[]) {
    const total = 6;
    const done = completedSections.length;
    const pct = Math.round((done / total) * 100);
    const bar = document.getElementById("wizard-progress");
    const mobileBar = document.getElementById("mobile-wizard-progress");
    const text = document.getElementById("wizard-progress-text");
    if (bar) bar.style.width = pct + "%";
    if (mobileBar) mobileBar.style.width = pct + "%";
    if (text) text.textContent = tr("lyb.msg.progress", `${done} of ${total} sections completed`).replace("{done}", String(done)).replace("{total}", String(total));
    // Update desktop checkmarks
    document.querySelectorAll(".wizard-nav-btn").forEach(btn => {
      const sec = btn.getAttribute("data-section");
      const check = btn.querySelector(".section-check");
      if (check) { if (sec && completedSections.includes(sec)) check.classList.remove("hidden"); else check.classList.add("hidden"); }
    });
    // Update mobile checkmarks
    document.querySelectorAll(".mobile-nav-btn").forEach(btn => {
      const sec = btn.getAttribute("data-section");
      const check = btn.querySelector(".mobile-section-check");
      if (check) { if (sec && completedSections.includes(sec)) check.classList.remove("hidden"); else check.classList.add("hidden"); }
    });
  }

  // --- Per-section save handlers ---
  let completedSectionsSet = new Set<string>();
  document.querySelectorAll(".section-save-btn").forEach(btn => {
    btn.addEventListener("click", async () => {
      if (!editingBoatId) {
        const user = currentAuthUser;
        if (!user) { alert(tr("lyb.msg.no_draft", "No active draft. Please sign in first.")); return; }
        editingBoatId = await createEmptyDraft(user.id);
      }
      const section = btn.getAttribute("data-section");
      if (!section) return;
      const btnEl = btn as HTMLButtonElement;
      const origText = btnEl.textContent;
      btnEl.textContent = tr("lyb.msg.saving", "Saving...");
      btnEl.disabled = true;
      formSuccess?.classList.add("hidden");
      formError?.classList.add("hidden");
      try {
        // Validate required fields for general section
        if (section === "general") {
          const boatType = (document.getElementById("boat-type-input") as HTMLInputElement)?.value;
          const harbour = (document.getElementById("harbour") as HTMLInputElement)?.value?.trim();
          const manufacturer = (document.getElementById("manufacturer") as HTMLInputElement)?.value?.trim();
          const model = (document.getElementById("model") as HTMLInputElement)?.value?.trim();
          const boatName = (document.getElementById("boatName") as HTMLInputElement)?.value?.trim();
          const missing: string[] = [];
          if (!boatType) missing.push(tr("lyb.general.type", "Type"));
          if (!harbour) missing.push(tr("lyb.general.harbour", "Harbour"));
          if (!manufacturer) missing.push(tr("lyb.general.manufacturer", "Manufacturer"));
          if (!model) missing.push(tr("lyb.general.model", "Model"));
          if (!boatName) missing.push(tr("lyb.general.boat_name", "Boat Name"));
          if (missing.length > 0) {
            throw new Error(tr("lyb.msg.fill_required", "Please fill in the required fields:") + " " + missing.join(", "));
          }
        }
        // Validate required fields for description section
        if (section === "description") {
          const langs = document.querySelectorAll("input.lang-cb:checked");
          const missing: string[] = [];
          if (langs.length === 0) missing.push(tr("lyb.desc.languages", "at least one Language"));
          if (missing.length > 0) {
            throw new Error(tr("lyb.msg.fill_required", "Please fill in the required fields:") + " " + missing.join(", "));
          }
          // Upload photos
          const newFiles: File[] = ((window as any).__selectedFiles || []).filter((f: any) => f != null);
          if (newFiles.length === 0 && existingImageUrls.length === 0) {
            throw new Error(tr("lyb.msg.upload_photo", "Please upload at least one photo."));
          }
          if (newFiles.length > 0) {
            const newUrls = await uploadBoatPhotos(editingBoatId, newFiles, currentAuthUser?.id);
            if (newUrls.length < newFiles.length) {
              const failed = newFiles.length - newUrls.length;
              alert(tr("lyb.msg.photo_upload_partial", `${failed} photo(s) failed to upload. The rest were saved successfully.`).replace("{count}", String(failed)));
            }
            existingImageUrls = [...existingImageUrls, ...newUrls];
          }
          const descData = collectSectionData(section);
          descData.images = existingImageUrls;
          await updateBoatSection(editingBoatId, descData);
        } else if (section === "price") {
          const price = Number((document.getElementById("pricePerDay") as HTMLInputElement)?.value);
          if (!price || price <= 0) {
            throw new Error(tr("lyb.msg.fill_price", "Please fill in the required field: Price / day"));
          }
          const data = collectSectionData(section);
          await updateBoatSection(editingBoatId, data);
        } else if (section === "insurance") {
          const deposit = Number((document.getElementById("securityDeposit") as HTMLInputElement)?.value);
          if (isNaN(deposit) || (document.getElementById("securityDeposit") as HTMLInputElement)?.value === "") {
            throw new Error(tr("lyb.msg.fill_deposit", "Please fill in the required field: Security deposit"));
          }
          const data = collectSectionData(section);
          // Upload insurance cert
          const insuranceInput = document.getElementById("insurance-cert-input") as HTMLInputElement;
          if (insuranceInput?.files?.[0]) {
            data.insuranceCertificateUrl = await uploadBoatDocument(editingBoatId, insuranceInput.files[0], "insurance");
          }
          // Upload ownership cert
          const ownershipInput = document.getElementById("ownership-cert-input") as HTMLInputElement;
          if (ownershipInput?.files?.[0]) {
            data.ownershipCertificateUrl = await uploadBoatDocument(editingBoatId, ownershipInput.files[0], "ownership");
          }
          await updateBoatSection(editingBoatId, data);
        } else if (section === "calendar") {
          const data = collectSectionData(section);
          await updateBoatSection(editingBoatId, data);
        } else {
          // Validate required fields for other/technical section
          if (section === "equipment") {
            const hp = (document.getElementById("horsepower") as HTMLInputElement)?.value;
            const w = (document.getElementById("width") as HTMLInputElement)?.value;
            const d = (document.getElementById("boatDraft") as HTMLInputElement)?.value;
            const l = (document.getElementById("length") as HTMLInputElement)?.value;
            const missing: string[] = [];
            if (!hp) missing.push(tr("lyb.other.horsepower", "Horsepower"));
            if (!w) missing.push(tr("lyb.other.width", "Width"));
            if (!d) missing.push(tr("lyb.other.draft", "Draft"));
            if (!l) missing.push(tr("lyb.other.length", "Length"));
            if (missing.length > 0) {
              throw new Error(tr("lyb.msg.fill_required", "Please fill in the required fields:") + " " + missing.join(", "));
            }
          }
          const data = collectSectionData(section);
          await updateBoatSection(editingBoatId, data);
        }
        completedSectionsSet.add(section);
        const completed = Array.from(completedSectionsSet);
        await updateBoatSection(editingBoatId, { completedSections: completed });
        updateProgress(completed);
        formSuccess?.classList.remove("hidden");
        const successMsg = formSuccess?.querySelector("p");
        if (successMsg) successMsg.textContent = tr("lyb.msg.section_saved", "Section saved successfully!");
        // After successful save, advance to next section or publish on last
        const _sections = getSECTIONS();
        const currentIdx = _sections ? _sections.findIndex(function(s: any) { return s.id === section; }) : -1;
        if (currentIdx >= 0 && currentIdx < _sections.length - 1) {
          // Not the last section — advance to next
          const nextSection = _sections[currentIdx + 1].id;
          setTimeout(function() {
            formSuccess?.classList.add("hidden");
            callShowWizardSection(nextSection);
          }, 600);
        } else if (section === _sections[_sections.length - 1]?.id) {
          // Last section — submit for review
          const requiredSections = ["general", "description", "price"];
          const missing = requiredSections.filter(function(s) { return !completedSectionsSet.has(s); });
          if (missing.length > 0) {
            formSuccess?.classList.add("hidden");
            alert(tr("lyb.msg.complete_before_publish", "Please complete these sections before publishing:") + " " + missing.join(", "));
            return;
          }
          await updateBoatSection(editingBoatId, { status: "pending" });
          alert(tr("lyb.msg.submitted", "Your listing has been submitted for review. It will be visible once approved by our team."));
          userHasListings = true;
          const user = currentAuthUser;
          if (user) { await loadUserListings(user.id); showListings(); }
        }
      } catch (err: any) {
        console.error("Save failed:", err);
        formError?.classList.remove("hidden");
        if (formErrorMsg) formErrorMsg.textContent = err?.message || tr("lyb.msg.save_fail", "Failed to save. Please try again.");
      } finally {
        btnEl.textContent = origText;
        btnEl.disabled = false;
      }
    });
  });

  // --- Save button (top bar) — saves current section as draft, no validation ---
  saveBtn?.addEventListener("click", async () => {
    if (!editingBoatId) {
      // Create draft first if not editing
      const user = currentAuthUser;
      if (!user) return;
      editingBoatId = await createEmptyDraft(user.id);
    }
    // Find currently active section
    const activeSectionEl = document.querySelector('.wizard-section:not(.hidden)') as HTMLElement;
    const activeSection = activeSectionEl?.id?.replace('section-', '') || 'general';
    try {
      (saveBtn as HTMLButtonElement).disabled = true;
      saveBtn!.textContent = tr("lyb.msg.saving", "Saving...");
      const data = collectSectionData(activeSection);
      // For description section, include existing image URLs
      if (activeSection === "description") {
        const existingUrls = (window as any).__existingPreviewUrls || [];
        const newFiles: File[] = ((window as any).__selectedFiles || []).filter((f: any) => f != null);
        if (newFiles.length > 0) {
          const newUrls = await uploadBoatPhotos(editingBoatId, newFiles, currentAuthUser?.id);
          data.images = [...existingUrls, ...newUrls];
        } else {
          data.images = existingUrls;
        }
      }
      await updateBoatSection(editingBoatId, data);
      saveBtn!.textContent = tr("lyb.msg.saved", "Saved!");
      setTimeout(() => { if (saveBtn) saveBtn.textContent = tr("lyb.wizard.save", "Save"); }, 1500);
    } catch (err) {
      console.error("Save failed:", err);
      if (saveBtn) saveBtn.textContent = tr("lyb.wizard.save", "Save");
    } finally {
      (saveBtn as HTMLButtonElement).disabled = false;
    }
  });

  // --- Load user listings ---
  async function loadUserListings(uid: string) {
    try {
      const { data: rows, error } = await supabase
        .from("boats")
        .select("*")
        .eq("owner_id", uid)
        .order("created_at", { ascending: false });
      if (error) throw error;
      if (!rows || rows.length === 0) {
        userHasListings = false;
        listingsLoading?.classList.add("hidden");
        resetWizardForm();
        showForm();
        (window as any).showWizardSection("general");
      } else {
        userHasListings = true;
        listingsGrid!.innerHTML = "";
        allListingCards = [];
        rows.forEach((row: any) => {
          const card = renderListingCard(row);
          listingsGrid!.appendChild(card);
          allListingCards.push({ el: card, status: row.status || "published" });
        });
        updateTabCounts();
        listingsTabs?.classList.remove("hidden");
        listingsLoading?.classList.add("hidden");
        listingsGrid?.classList.remove("hidden");
        filterByTab("all");
        showListings();
      }
    } catch (err) {
      console.error("Failed to fetch listings:", err);
      listingsLoading?.classList.add("hidden");
      listingsError?.classList.remove("hidden");
      showListings();
    }
  }

  // --- Auth state ---
  onAuthChange(async (user) => {
    currentAuthUser = user;
    loading?.classList.add("hidden");
    if (!user) { hideAll(); gate?.classList.remove("hidden"); return; }
    gate?.classList.add("hidden");
    if (form && !form.classList.contains("hidden")) return;
    await loadUserListings(user.id);
  });
</script>


<script is:inline>
  setTimeout(function () {
    var loading = document.getElementById("auth-loading");
    var gate = document.getElementById("auth-gate");
    if (loading && !loading.classList.contains("hidden")) {
      loading.classList.add("hidden");
      gate.classList.remove("hidden");
    }
  }, 3000);
</script>
