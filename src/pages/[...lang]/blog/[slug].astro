---
import { getLangs, localizeHref, getLangFromParam, pickText } from "../../../lib/i18n-utils";
import Layout from "../../../layouts/Layout.astro";
import { formatDate } from "../../../lib/utils";
import { mockArticles } from "../../../lib/mock-data";
import type { Article } from "../../../types";

export async function getStaticPaths() {
  let articles: Article[] = mockArticles;
  try {
    const { getLatestArticles } = await import("../../../lib/api");
    const firestoreArticles = await getLatestArticles(100);
    if (firestoreArticles.length > 0) articles = firestoreArticles;
  } catch {
    // Firestore unavailable
  }
  const langs: (string | undefined)[] = [undefined, "gr"];
  return articles.flatMap((a) =>
    langs.map((lang) => ({ params: { lang, slug: a.slug } }))
  );
}

const { lang } = Astro.params;

// Get all articles for this page
let allArticles: Article[] = mockArticles;
try {
  const { getLatestArticles } = await import("../../../lib/api");
  const firestoreArticles = await getLatestArticles(100);
  if (firestoreArticles.length > 0) {
    allArticles = firestoreArticles;
  }
} catch {
  // Firestore unavailable — use mock data
}

const { slug } = Astro.params;
const article = allArticles.find((a) => a.slug === slug);

if (!article) {
  return Astro.redirect(l("/404"));
}

// Get other articles for "More articles" section
const otherArticles = allArticles.filter((a) => a.slug !== slug).slice(0, 3);

const resolvedLang = getLangFromParam(lang);
const pt = (v: { en: string; el: string } | string) => pickText(v, resolvedLang);
const title = `${pt(article.title)} — TapYourBoat Blog`;
const description = pt(article.summary);
const l = (href: string) => localizeHref(href, lang);

const readTime = resolvedLang === "el" ? "λεπτά ανάγνωση" : "min read";
const contentText = pt(article.content) || "";
const wordCount = contentText.replace(/<[^>]*>/g, "").split(/\s+/).length;
const minutes = Math.max(1, Math.round(wordCount / 200));
---

<Layout lang={lang} title={title} description={description}>
  <!-- Hero with image background -->
  <div class="relative">
    <div class="absolute inset-0 h-[480px] bg-gradient-to-b from-slate-900/60 to-slate-900/20 z-10"></div>
    <div class="absolute inset-0 h-[480px] overflow-hidden">
      <img
        src={article.image}
        alt={pt(article.title)}
        class="h-full w-full object-cover"
        loading="eager"
      />
    </div>

    <div class="relative z-20 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 pt-12 pb-32">
      <!-- Breadcrumb -->
      <nav class="mb-8 text-sm text-white/70" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5">
          <li><a href={l("/")} class="hover:text-white transition-colors" data-i18n="nav.home">Home</a></li>
          <li class="text-white/40">/</li>
          <li><a href={l("/blog")} class="hover:text-white transition-colors" data-i18n="blog.title_short">Blog</a></li>
          <li class="text-white/40">/</li>
          <li class="text-white font-medium truncate max-w-[200px]">{pt(article.title)}</li>
        </ol>
      </nav>

      <!-- Title area -->
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-4">
          {article.createdAt && (
            <time class="text-sm text-white/80 font-medium" datetime={article.createdAt?.toISOString?.() ?? ""}>
              {formatDate(article.createdAt)}
            </time>
          )}
          <span class="w-1 h-1 rounded-full bg-white/40"></span>
          <span class="text-sm text-white/80">{minutes} {readTime}</span>
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight tracking-tight">
          {pt(article.title)}
        </h1>
      </div>
    </div>
  </div>

  <!-- Main content card, pulled up over the hero -->
  <div class="relative z-30 -mt-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <!-- Summary card -->
      <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-6 sm:p-8 mb-8">
        <p class="text-lg sm:text-xl text-text-muted leading-relaxed font-medium italic">
          {pt(article.summary)}
        </p>
      </div>

      <!-- Article content -->
      <article class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-8 lg:p-10">
        <div class="article-body">
          {contentText ? (
            <Fragment set:html={contentText} />
          ) : (
            <div class="bg-surface rounded-xl p-8 text-center">
              <p class="text-text-muted">Full article content coming soon. Stay tuned!</p>
            </div>
          )}
        </div>
      </article>

      <!-- Back to blog -->
      <div class="mt-8 mb-16">
        <a href={l("/blog")} class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-primary-dark transition-colors group">
          <svg class="h-4 w-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
          <span data-i18n="blog.back_to_all">Back to all articles</span>
        </a>
      </div>
    </div>
  </div>

  <!-- More articles -->
  {otherArticles.length > 0 && (
    <section class="bg-surface py-16 border-t border-gray-100">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-text mb-8" data-i18n="blog.more_articles">More articles</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {otherArticles.map((a) => (
            <a href={l(`/blog/${a.slug}`)} class="group block">
              <article class="bg-white rounded-xl overflow-hidden border border-gray-100 hover:shadow-lg transition-shadow h-full flex flex-col">
                <div class="aspect-[16/9] overflow-hidden">
                  <img
                    src={a.image}
                    alt={pt(a.title)}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <div class="p-5 flex flex-col flex-1">
                  <time class="text-xs text-text-muted font-medium" datetime={a.createdAt?.toISOString?.() ?? ""}>
                    {a.createdAt ? formatDate(a.createdAt) : ""}
                  </time>
                  <h3 class="mt-2 text-lg font-bold text-text group-hover:text-primary transition-colors line-clamp-2">
                    {pt(a.title)}
                  </h3>
                  <p class="mt-2 text-sm text-text-muted line-clamp-2 flex-1">
                    {pt(a.summary)}
                  </p>
                </div>
              </article>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
