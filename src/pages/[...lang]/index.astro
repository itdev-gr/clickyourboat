---
import { getLangs, localizeHref } from "../../lib/i18n-utils";
export function getStaticPaths() { return getLangs(); }
const { lang } = Astro.params;
import Layout from "../../layouts/Layout.astro";
import HeroSection from "../../components/home/HeroSection.astro";
import BoatsForRentSection from "../../components/home/BoatsForRentSection.astro";
import SocialProofSection from "../../components/home/SocialProofSection.astro";
import DestinationsSection from "../../components/home/DestinationsSection.astro";
import CategoriesSection from "../../components/home/CategoriesSection.astro";
import OwnerCtaSection from "../../components/home/OwnerCtaSection.astro";
import ArticlesSection from "../../components/home/ArticlesSection.astro";
import TrustSection from "../../components/home/TrustSection.astro";
import FaqSection from "../../components/home/FaqSection.astro";

import { mockDestinations, mockReviews, mockArticles } from "../../lib/mock-data";

// Try Firestore, fall back to mock data
let destinations = mockDestinations;
let reviews = mockReviews;
let articles = mockArticles;
let featuredBoats: import("../../types").Boat[] = [];

try {
  const { getTopDestinations, getTopReviews, getLatestArticles, getFeaturedBoats } = await import("../../lib/api");
  const [fbDestinations, fbReviews, fbArticles, fbBoats] = await Promise.all([
    getTopDestinations(8),
    getTopReviews(6),
    getLatestArticles(3),
    getFeaturedBoats(8).catch(() => []),
  ]);
  if (fbDestinations.length > 0) destinations = fbDestinations;
  if (fbReviews.length > 0) reviews = fbReviews;
  if (fbArticles.length > 0) articles = fbArticles;
  if (fbBoats.length > 0) featuredBoats = fbBoats;
} catch {
  // Firestore unavailable — mock data used
}

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      name: "TapYourBoat",
      url: "https://tapyourboat.com",
      logo: "https://tapyourboat.com/logo.svg",
      description:
        "Boat rental marketplace with thousands of boats worldwide.",
      sameAs: [
        "https://facebook.com/tapyourboat",
        "https://instagram.com/tapyourboat",
        "https://twitter.com/tapyourboat",
      ],
    },
    {
      "@type": "WebSite",
      name: "TapYourBoat",
      url: "https://tapyourboat.com",
      potentialAction: {
        "@type": "SearchAction",
        target: "https://tapyourboat.com/boat-rental?location={search_term_string}",
        "query-input": "required name=search_term_string",
      },
    },
    ...reviews.map((r) => ({
      "@type": "Review",
      author: { "@type": "Person", name: r.userName },
      reviewRating: {
        "@type": "Rating",
        ratingValue: r.rating,
        bestRating: 5,
      },
      reviewBody: r.comment,
      itemReviewed: { "@type": "Product", name: r.boatName },
    })),
    ...articles.map((a) => ({
      "@type": "Article",
      headline: a.title,
      image: a.image,
      description: a.summary,
      datePublished: a.createdAt?.toISOString?.() ?? "",
      publisher: { "@type": "Organization", name: "TapYourBoat" },
    })),
  ],
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    { "@type": "Question", name: "How does booking work?", acceptedAnswer: { "@type": "Answer", text: "Browse our selection of boats, choose your dates and destination, and book instantly. You'll receive a confirmation email with all the details. The boat owner will contact you before your trip to arrange the handover." } },
    { "@type": "Question", name: "Do I need a license?", acceptedAnswer: { "@type": "Answer", text: "License requirements depend on the destination and boat type. Many locations offer boats that don't require a license, and you can always book with a professional skipper. Check the specific listing for requirements." } },
    { "@type": "Question", name: "What's included in the rental?", acceptedAnswer: { "@type": "Answer", text: "Each listing specifies what's included. Typically, the boat, safety equipment, and basic amenities are provided. Fuel, food, and port fees are usually extra. Some listings include a skipper, while others offer it as an add-on." } },
    { "@type": "Question", name: "What is the cancellation policy?", acceptedAnswer: { "@type": "Answer", text: "Our standard cancellation policy offers a full refund if cancelled 30 days before the trip, 50% refund for 15-30 days, and no refund within 15 days. Some owners offer flexible cancellation — look for the 'Flexible' badge on listings." } },
  ],
};
const l = (href: string) => localizeHref(href, lang);
const title = "Boat Rental Greece — Rent a Boat Online | TapYourBoat";
const description = "Rent boats in Greece. Sailboats, motorboats, catamarans & yachts with or without skipper. Book online at TapYourBoat.";
---
<Layout lang={lang} title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <HeroSection lang={lang} />
  <BoatsForRentSection boats={featuredBoats} lang={lang} />
  <DestinationsSection lang={lang} />
  <SocialProofSection reviews={reviews} />
  <CategoriesSection lang={lang} />
  <OwnerCtaSection lang={lang} />
  <ArticlesSection articles={articles} lang={lang} />
  <TrustSection />
  <FaqSection />
</Layout>
