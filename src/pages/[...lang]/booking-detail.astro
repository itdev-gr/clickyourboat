---
import { getLangs, localizeHref } from "../../lib/i18n-utils";
export function getStaticPaths() { return getLangs(); }
const { lang } = Astro.params;
import Layout from "../../layouts/Layout.astro";

const title = "Booking Details — TapYourBoat";
const description = "View your booking details, payment status, and owner information.";
const l = (href: string) => localizeHref(href, lang);
---
<Layout lang={lang} title={title} description={description}>
  <!-- Loading -->
  <div id="page-loading" class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <div class="h-8 w-8 border-2 border-primary border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
      <p class="text-sm text-text-muted">Loading booking details...</p>
    </div>
  </div>

  <!-- Error -->
  <div id="page-error" class="hidden min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <p class="text-lg font-bold text-text mb-2">Booking not found</p>
      <p class="text-sm text-text-muted mb-4">We couldn't find this booking.</p>
      <a href={l("/bookings")} class="inline-flex items-center px-5 py-2.5 rounded-xl bg-primary text-white text-sm font-bold hover:bg-primary-dark transition-colors">Back to bookings</a>
    </div>
  </div>

  <!-- Content -->
  <div id="page-content" class="hidden py-8">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">

      <!-- Back + Status -->
      <div class="flex items-center justify-between mb-6">
        <a href={l("/bookings")} class="inline-flex items-center gap-2 text-sm text-text-muted hover:text-text transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/></svg>
          Back to bookings
        </a>
        <span id="status-badge" class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold"></span>
      </div>

      <!-- Boat Info -->
      <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden mb-4">
        <div id="boat-image-wrapper" class="hidden aspect-[3/1] bg-gray-100 overflow-hidden">
          <img id="boat-image" src="" alt="" class="h-full w-full object-cover" />
        </div>
        <div class="p-6">
          <h1 id="boat-title" class="text-xl font-bold text-text mb-1"></h1>
          <p id="boat-type-location" class="text-sm text-text-muted mb-3"></p>
          <div id="boat-specs" class="flex flex-wrap gap-3 text-xs text-text-muted"></div>
        </div>
      </div>

      <!-- Owner Info -->
      <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-4">
        <h2 class="text-base font-bold text-text mb-4">Boat owner</h2>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <div id="owner-avatar" class="h-12 w-12 rounded-full bg-primary/10 text-primary flex items-center justify-center text-lg font-bold flex-shrink-0 overflow-hidden">
              <img id="owner-avatar-img" class="h-full w-full object-cover hidden" alt="" />
              <span id="owner-initials"></span>
            </div>
            <div>
              <p id="owner-name" class="text-sm font-semibold text-text"></p>
              <p id="owner-member-since" class="text-xs text-text-muted"></p>
            </div>
          </div>
          <button id="message-owner-btn" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-gray-100 text-sm font-medium text-text hover:bg-gray-200 transition-colors">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 01.778-.332 48.294 48.294 0 005.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/></svg>
            Message owner
          </button>
        </div>
      </div>

      <!-- Booking Details -->
      <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-4">
        <h2 class="text-base font-bold text-text mb-4">Booking details</h2>
        <div class="grid grid-cols-2 gap-4 text-sm">
          <div>
            <p class="text-text-muted mb-1">Check-in</p>
            <p id="detail-start" class="font-semibold text-text">—</p>
          </div>
          <div>
            <p class="text-text-muted mb-1">Check-out</p>
            <p id="detail-end" class="font-semibold text-text">—</p>
          </div>
          <div>
            <p class="text-text-muted mb-1">Duration</p>
            <p id="detail-duration" class="font-semibold text-text">—</p>
          </div>
          <div>
            <p class="text-text-muted mb-1">Insurance</p>
            <p id="detail-insurance" class="font-semibold text-text">—</p>
          </div>
          <div>
            <p class="text-text-muted mb-1">Skipper</p>
            <p id="detail-skipper" class="font-semibold text-text">—</p>
          </div>
          <div>
            <p class="text-text-muted mb-1">Weather guarantee</p>
            <p id="detail-weather" class="font-semibold text-text">—</p>
          </div>
        </div>
        <div id="detail-message-wrapper" class="hidden mt-4 pt-4 border-t border-gray-100">
          <p class="text-text-muted text-sm mb-1">Your message</p>
          <p id="detail-message" class="text-sm text-text bg-gray-50 p-3 rounded-lg"></p>
        </div>
      </div>

      <!-- Payment Summary -->
      <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-4">
        <h2 class="text-base font-bold text-text mb-4">Payment summary</h2>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between"><span class="text-text-muted">Charter price</span><span class="text-text font-medium" id="pay-charter"></span></div>
          <div id="pay-insurance-row" class="hidden flex justify-between"><span class="text-text-muted" id="pay-insurance-label">Insurance</span><span class="text-text font-medium" id="pay-insurance"></span></div>
          <div id="pay-skipper-row" class="hidden flex justify-between"><span class="text-text-muted">Skipper</span><span class="text-text font-medium" id="pay-skipper"></span></div>
          <div id="pay-weather-row" class="hidden flex justify-between"><span class="text-text-muted">Weather Guarantee</span><span class="text-text font-medium" id="pay-weather"></span></div>
          <div class="flex justify-between"><span class="text-text-muted">Service Fee</span><span class="text-text font-medium" id="pay-service"></span></div>
          <div id="pay-platform-row" class="hidden flex justify-between"><span class="text-text-muted">Platform Fee</span><span class="text-text font-medium" id="pay-platform"></span></div>
          <div class="border-t border-gray-200 pt-2 mt-2 flex justify-between">
            <span class="font-bold text-text">Total</span>
            <span class="font-bold text-text text-lg" id="pay-total"></span>
          </div>
        </div>

        <!-- Payment status info -->
        <div id="payment-status-info" class="mt-4"></div>

        <!-- Security deposit info -->
        <div id="deposit-info" class="hidden mt-4 p-4 bg-amber-50 border border-amber-200 rounded-xl">
          <div class="flex items-start gap-3">
            <svg class="h-5 w-5 text-amber-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
            <div>
              <p class="text-sm font-semibold text-amber-900">Security Deposit: <span id="deposit-amount"></span></p>
              <p class="text-xs text-amber-800 mt-1">This amount is required before the pick-up of the boat and is fully refundable after the trip, provided no damages occur.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div id="actions" class="flex flex-wrap gap-3 mb-8"></div>

    </div>
  </div>
</Layout>

<script>
  function getLangPrefix() { return document.documentElement.dataset.langPrefix || ""; }
  function localPath(path: string): string { const p = getLangPrefix(); return p ? "/" + p + path : path; }
  import { supabase } from "../../lib/supabase";
  import { onAuthChange } from "../../lib/auth";
  import { getBoatListing, cancelOrder } from "../../lib/api";

  const $ = (id: string) => document.getElementById(id);
  const params = new URLSearchParams(window.location.search);
  const orderId = params.get("orderId");

  if (!orderId) {
    $("page-loading")?.classList.add("hidden");
    $("page-error")?.classList.remove("hidden");
  } else {
    init();
  }

  async function init() {
    try {
      // Fetch order
      const { data: order, error } = await supabase
        .from("orders")
        .select("*")
        .eq("id", orderId!)
        .maybeSingle();
      if (error || !order) throw new Error("Order not found");

      const breakdown = order.price_breakdown || {};
      const fmt = (n: number) => "\u20AC" + n.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 2 });

      // Fetch boat
      let boat: any = null;
      try { boat = await getBoatListing(order.boat_id); } catch {}

      // Fetch owner profile
      const { data: owner } = await supabase
        .from("profiles")
        .select("display_name, photo_url, first_name, last_name, created_at")
        .eq("id", order.owner_id)
        .maybeSingle();

      // Status badge
      const statusStyles: Record<string, { bg: string; text: string; label: string }> = {
        requested: { bg: "bg-blue-100", text: "text-blue-800", label: "Requested" },
        accepted: { bg: "bg-amber-100", text: "text-amber-800", label: "Waiting payment" },
        pending: { bg: "bg-yellow-100", text: "text-yellow-800", label: "Payment processing" },
        paid: { bg: "bg-green-100", text: "text-green-800", label: "Paid" },
        partially_paid: { bg: "bg-amber-100", text: "text-amber-800", label: "Partially paid (30%)" },
        confirmed: { bg: "bg-green-100", text: "text-green-800", label: "Confirmed" },
        cancelled: { bg: "bg-gray-100", text: "text-gray-600", label: "Cancelled" },
        completed: { bg: "bg-emerald-100", text: "text-emerald-800", label: "Completed" },
      };
      const status = order.status || "requested";
      const style = statusStyles[status] || statusStyles.requested;
      const badge = $("status-badge");
      if (badge) {
        badge.textContent = style.label;
        badge.classList.add(style.bg, style.text);
      }

      // Boat info
      const boatTitle = order.boat_title || boat?.listingTitle || boat?.boatName || "Boat";
      const titleEl = $("boat-title");
      if (titleEl) titleEl.textContent = boatTitle;

      if (order.boat_image || (boat?.images && boat.images[0])) {
        const imgWrapper = $("boat-image-wrapper");
        const imgEl = $("boat-image") as HTMLImageElement;
        if (imgWrapper && imgEl) {
          imgEl.src = order.boat_image || boat.images[0];
          imgEl.alt = boatTitle;
          imgWrapper.classList.remove("hidden");
        }
      }

      const typeLocation = $("boat-type-location");
      if (typeLocation) {
        const parts: string[] = [];
        if (boat?.boatType) parts.push(boat.boatType.charAt(0).toUpperCase() + boat.boatType.slice(1));
        if (boat?.city) parts.push(boat.city);
        if (boat?.harbour) parts.push(boat.harbour);
        typeLocation.textContent = parts.join(" \u00b7 ") || "";
      }

      const specsEl = $("boat-specs");
      if (specsEl && boat) {
        let specs = "";
        if (boat.capacity) specs += `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-gray-50 border border-gray-200"><svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>${boat.capacity} guests</span>`;
        if (boat.length) specs += `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-gray-50 border border-gray-200">${boat.length}m</span>`;
        if (boat.cabins) specs += `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-gray-50 border border-gray-200">${boat.cabins} cabins</span>`;
        if (boat.horsepower) specs += `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-gray-50 border border-gray-200">${boat.horsepower} HP</span>`;
        specsEl.innerHTML = specs;
      }

      // Owner info
      const ownerName = owner?.display_name || [owner?.first_name, owner?.last_name].filter(Boolean).join(" ") || "Owner";
      const nameEl = $("owner-name");
      if (nameEl) nameEl.textContent = ownerName;

      const initialsEl = $("owner-initials");
      if (initialsEl) initialsEl.textContent = ownerName.split(" ").map((w: string) => w[0]).join("").toUpperCase().slice(0, 2);

      if (owner?.photo_url) {
        const avatarImg = $("owner-avatar-img") as HTMLImageElement;
        if (avatarImg) { avatarImg.src = owner.photo_url; avatarImg.classList.remove("hidden"); }
      }

      if (owner?.created_at) {
        const since = $("owner-member-since");
        if (since) since.textContent = "Member since " + new Date(owner.created_at).toLocaleDateString("en-GB", { month: "short", year: "numeric" });
      }

      // Message owner button
      $("message-owner-btn")?.addEventListener("click", () => {
        const params = new URLSearchParams();
        params.set("with", order.owner_id);
        params.set("boatId", order.boat_id);
        params.set("boatTitle", boatTitle);
        window.location.href = localPath("/messages?" + params.toString());
      });

      // Booking details
      const fmtDate = (d: string) => new Date(d + "T00:00:00").toLocaleDateString("en-GB", { weekday: "short", day: "numeric", month: "short", year: "numeric" });
      const startEl = $("detail-start");
      const endEl = $("detail-end");
      if (startEl && order.start_date) startEl.textContent = fmtDate(order.start_date);
      if (endEl && order.end_date) endEl.textContent = fmtDate(order.end_date);

      const days = Math.max(1, Math.ceil((new Date(order.end_date).getTime() - new Date(order.start_date).getTime()) / (1000 * 60 * 60 * 24)));
      const durEl = $("detail-duration");
      if (durEl) durEl.textContent = breakdown.isHalfDay ? "Half day" : days === 1 ? "1 day" : `${days} days`;

      const insEl = $("detail-insurance");
      if (insEl) {
        const insMap: Record<string, string> = { "multi-risk": "Multi-risk", "assistance": "Assistance", "none": "No insurance" };
        insEl.textContent = insMap[order.insurance_type] || order.insurance_type || "—";
      }

      const skipEl = $("detail-skipper");
      if (skipEl) skipEl.textContent = order.skipper_included ? "Yes" : "No";

      const weaEl = $("detail-weather");
      if (weaEl) weaEl.textContent = order.weather_guarantee ? "Yes" : "No";

      if (order.renter_message) {
        const msgWrapper = $("detail-message-wrapper");
        const msgEl = $("detail-message");
        if (msgWrapper) msgWrapper.classList.remove("hidden");
        if (msgEl) msgEl.textContent = order.renter_message;
      }

      // Payment summary
      const charterEl = $("pay-charter");
      if (charterEl) charterEl.textContent = fmt(breakdown.charterPrice || 0);

      if (breakdown.insuranceTot > 0) {
        $("pay-insurance-row")?.classList.remove("hidden");
        $("pay-insurance-row")?.classList.add("flex");
        const v = $("pay-insurance");
        if (v) v.textContent = fmt(breakdown.insuranceTot);
      }
      if (breakdown.skipperTot > 0) {
        $("pay-skipper-row")?.classList.remove("hidden");
        $("pay-skipper-row")?.classList.add("flex");
        const v = $("pay-skipper");
        if (v) v.textContent = fmt(breakdown.skipperTot);
      }
      if (breakdown.weatherTot > 0) {
        $("pay-weather-row")?.classList.remove("hidden");
        $("pay-weather-row")?.classList.add("flex");
        const v = $("pay-weather");
        if (v) v.textContent = fmt(breakdown.weatherTot);
      }
      const svcEl = $("pay-service");
      if (svcEl) svcEl.textContent = fmt(breakdown.serviceFee || 0);
      if (breakdown.platformFee > 0) {
        $("pay-platform-row")?.classList.remove("hidden");
        $("pay-platform-row")?.classList.add("flex");
        const v = $("pay-platform");
        if (v) v.textContent = fmt(breakdown.platformFee);
      }

      const totalEl = $("pay-total");
      if (totalEl) totalEl.textContent = fmt(order.total_price || 0);

      // Payment status info
      const payInfo = $("payment-status-info");
      if (payInfo) {
        if (status === "paid") {
          payInfo.innerHTML = `<div class="p-3 bg-green-50 border border-green-200 rounded-lg"><p class="text-sm text-green-800 font-medium">Payment completed</p><p class="text-xs text-green-700 mt-0.5">Full payment of ${fmt(order.total_price)} received.</p></div>`;
        } else if (status === "partially_paid") {
          const balance = breakdown.charterBalance || 0;
          payInfo.innerHTML = `<div class="p-3 bg-amber-50 border border-amber-200 rounded-lg"><p class="text-sm text-amber-800 font-medium">30% prepayment received</p><p class="text-xs text-amber-700 mt-0.5">Amount paid: ${fmt(order.total_price)}. Remaining balance: ${fmt(balance)} — due before the trip.</p></div>`;
        } else if (status === "accepted") {
          payInfo.innerHTML = `<div class="p-3 bg-blue-50 border border-blue-200 rounded-lg"><p class="text-sm text-blue-800 font-medium">Payment required</p><p class="text-xs text-blue-700 mt-0.5">Your booking request has been accepted. Please complete your payment.</p></div>`;
        } else if (status === "requested") {
          payInfo.innerHTML = `<div class="p-3 bg-blue-50 border border-blue-100 rounded-lg"><p class="text-sm text-blue-800 font-medium">Awaiting owner response</p><p class="text-xs text-blue-700 mt-0.5">Your booking request has been sent. The owner will review it shortly.</p></div>`;
        } else if (status === "cancelled") {
          payInfo.innerHTML = `<div class="p-3 bg-gray-50 border border-gray-200 rounded-lg"><p class="text-sm text-gray-600 font-medium">Booking cancelled</p></div>`;
        }
      }

      // Security deposit
      const secDep = Number(boat?.securityDeposit) || breakdown.securityDeposit || 0;
      if (secDep > 0) {
        $("deposit-info")?.classList.remove("hidden");
        const depAmt = $("deposit-amount");
        if (depAmt) depAmt.textContent = fmt(secDep);
      }

      // Action buttons
      const actionsEl = $("actions");
      if (actionsEl) {
        let btns = "";
        if (status === "accepted") {
          btns += `<a href="${localPath("/pay-booking?orderId=" + order.id)}" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-primary text-white text-sm font-bold hover:bg-primary-dark transition-colors"><svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/></svg>Pay now</a>`;
        }
        if (status === "requested" || status === "accepted") {
          btns += `<button id="cancel-btn" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-red-200 text-red-600 text-sm font-medium hover:bg-red-50 transition-colors"><svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>Cancel booking</button>`;
        }
        btns += `<a href="${localPath("/boat-detail?id=" + order.boat_id)}" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-gray-200 text-text text-sm font-medium hover:bg-gray-50 transition-colors"><svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>View boat listing</a>`;
        actionsEl.innerHTML = btns;

        // Cancel handler
        $("cancel-btn")?.addEventListener("click", async () => {
          if (!confirm("Are you sure you want to cancel this booking?")) return;
          try {
            await cancelOrder(order.id);
            window.location.reload();
          } catch (err) {
            alert("Failed to cancel booking.");
          }
        });
      }

      // Show page
      $("page-loading")?.classList.add("hidden");
      $("page-content")?.classList.remove("hidden");

    } catch (err) {
      console.error("[BookingDetail] Error:", err);
      $("page-loading")?.classList.add("hidden");
      $("page-error")?.classList.remove("hidden");
    }
  }
</script>
