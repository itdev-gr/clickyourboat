---
import { getLangs, localizeHref } from "../../lib/i18n-utils";
export function getStaticPaths() { return getLangs(); }
const { lang } = Astro.params;
import Layout from "../../layouts/Layout.astro";

const title = "My Bookings — TapYourBoat";
const description = "View and manage your boat bookings on TapYourBoat.";
const l = (href: string) => localizeHref(href, lang);
---
<Layout lang={lang} title={title} description={description}>
  <!-- Loading state -->
  <div id="auth-loading" class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <div class="h-8 w-8 border-2 border-primary border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
      <p class="text-sm text-text-muted" data-i18n="common.loading">Loading...</p>
    </div>
  </div>

  <!-- Not logged in -->
  <div id="auth-gate" class="hidden">
    <div class="min-h-[60vh] flex items-center justify-center px-4 py-16">
      <div class="max-w-md w-full text-center">
        <div class="mx-auto mb-6 h-16 w-16 rounded-full bg-primary/10 flex items-center justify-center">
          <svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
        </div>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-text mb-3">Log in to view your bookings</h1>
        <p class="text-text-muted mb-8 max-w-sm mx-auto">You need to be logged in to see your bookings.</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href={l("/login?redirect=/bookings")} class="inline-flex items-center px-6 py-3 rounded-xl bg-primary text-white text-sm font-bold hover:bg-primary-dark transition-colors">Log in</a>
          <a href={l("/login?signup&redirect=/bookings")} class="inline-flex items-center px-6 py-3 rounded-xl border border-gray-200 text-sm font-semibold text-text hover:border-gray-400 transition-colors">Create account</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bookings content -->
  <div id="bookings-content" class="hidden">
    <div class="flex min-h-[calc(100vh-64px)]">

      <!-- ===== Left Sidebar ===== -->
      <aside class="hidden lg:flex flex-col w-72 bg-gray-800 text-white flex-shrink-0">
        <div class="flex flex-col items-center pt-10 pb-6 px-6 border-b border-gray-700">
          <div id="sidebar-avatar" class="h-24 w-24 rounded-full bg-gray-600 flex items-center justify-center text-2xl font-bold text-white mb-4 overflow-hidden">
            <img id="sidebar-avatar-img" class="h-full w-full object-cover hidden" alt="" />
            <span id="sidebar-avatar-initials"></span>
          </div>
          <h2 id="sidebar-name" class="text-lg font-bold text-center"></h2>
        </div>
        <nav class="flex-1 py-4 px-3 space-y-0.5">
          <a href={l("/dashboard")} class="sidebar-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
            Dashboard
          </a>
          <a href={l("/account")} class="sidebar-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
            Profile
          </a>
          <a href={l("/messages")} class="sidebar-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            Messages
          </a>
          <a id="sidebar-my-offers" href={l("/my-offers")} class="sidebar-link hidden items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
            My Offers
          </a>
          <a href={l("/bookings")} class="sidebar-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium bg-gray-700 text-white transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
            Bookings
          </a>
          <a href={l("/list-your-boat")} class="sidebar-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>
            Listings
          </a>
          <a href={l("/favorites")} class="sidebar-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
            Favourites
          </a>
          <div class="pt-2 mt-2 border-t border-gray-700">
            <button id="sidebar-logout-btn" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium text-gray-400 hover:bg-gray-700 hover:text-white transition-colors w-full">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9"/></svg>
              Log out
            </button>
          </div>
        </nav>
      </aside>

      <!-- ===== Main Content ===== -->
      <main class="flex-1 bg-gray-50 overflow-y-auto">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

          <h1 class="text-2xl font-bold text-text mb-2">My Bookings</h1>
          <p class="text-sm text-text-muted mb-6">View and manage your boat rental bookings.</p>

          <!-- Filter tabs -->
          <div class="flex gap-2 mb-6 flex-wrap">
            <button type="button" data-tab="all" class="booking-tab px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-primary text-white">All</button>
            <button type="button" data-tab="pending" class="booking-tab px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-white text-gray-600 border border-gray-300 hover:bg-gray-50">Pending</button>
            <button type="button" data-tab="confirmed" class="booking-tab px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-white text-gray-600 border border-gray-300 hover:bg-gray-50">Confirmed</button>
            <button type="button" data-tab="completed" class="booking-tab px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-white text-gray-600 border border-gray-300 hover:bg-gray-50">Completed</button>
            <button type="button" data-tab="cancelled" class="booking-tab px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-white text-gray-600 border border-gray-300 hover:bg-gray-50">Cancelled</button>
          </div>

          <!-- Loading -->
          <div id="bookings-loading" class="flex items-center justify-center py-16">
            <div class="text-center">
              <div class="h-8 w-8 border-2 border-primary border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
              <p class="text-sm text-text-muted">Loading your bookings...</p>
            </div>
          </div>

          <!-- Empty state -->
          <div id="bookings-empty" class="hidden">
            <div class="bg-white rounded-xl border border-gray-200 p-12 text-center">
              <svg class="mx-auto h-16 w-16 text-gray-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
              </svg>
              <h2 class="text-lg font-bold text-text mb-2">No bookings yet</h2>
              <p class="text-sm text-text-muted mb-6 max-w-sm mx-auto">Browse available boats and make your first booking to get started.</p>
              <a href={l("/boat-rental")} class="inline-flex items-center px-6 py-3 rounded-xl bg-primary text-white text-sm font-bold hover:bg-primary-dark transition-colors">
                Browse boats
              </a>
            </div>
          </div>

          <!-- No results for filter -->
          <div id="bookings-no-filter" class="hidden">
            <div class="bg-white rounded-xl border border-gray-200 p-8 text-center">
              <p class="text-sm text-text-muted">No bookings match this filter.</p>
            </div>
          </div>

          <!-- Bookings list -->
          <div id="bookings-list" class="space-y-4"></div>

        </div>
      </main>
    </div>
  </div>
</Layout>

<script>

  function getLangPrefix() {
    return document.documentElement.dataset.langPrefix || "";
  }
  function localPath(path: string): string {
    const p = getLangPrefix();
    return p ? "/" + p + path : path;
  }
  import { supabase } from "../../lib/supabase";
  import { onAuthChange, signOutUser } from "../../lib/auth";
  import { getUserOrders, cancelOrder } from "../../lib/api";

  function getInitials(name: string | null): string {
    if (!name) return "?";
    return name.split(" ").map(w => w[0]).join("").toUpperCase().slice(0, 2);
  }

  function escapeHtml(text: string): string {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }

  const $ = (id: string) => document.getElementById(id);

  const statusStyles: Record<string, { bg: string; text: string; label: string }> = {
    pending: { bg: "bg-blue-100", text: "text-blue-800", label: "Pending" },
    confirmed: { bg: "bg-green-100", text: "text-green-800", label: "Confirmed" },
    cancelled: { bg: "bg-gray-100", text: "text-gray-600", label: "Cancelled" },
    completed: { bg: "bg-emerald-100", text: "text-emerald-800", label: "Completed" },
  };

  let allBookings: any[] = [];
  let currentFilter = "all";
  let currentUid = "";

  // Tab filter logic
  document.querySelectorAll(".booking-tab").forEach(tab => {
    tab.addEventListener("click", () => {
      const filter = tab.getAttribute("data-tab") || "all";
      currentFilter = filter;

      document.querySelectorAll(".booking-tab").forEach(t => {
        t.classList.remove("bg-primary", "text-white");
        t.classList.add("bg-white", "text-gray-600", "border", "border-gray-300");
      });
      tab.classList.remove("bg-white", "text-gray-600", "border", "border-gray-300");
      tab.classList.add("bg-primary", "text-white");

      renderBookings();
    });
  });

  function renderBookings() {
    const listEl = $("bookings-list");
    const emptyEl = $("bookings-empty");
    const noFilterEl = $("bookings-no-filter");
    if (!listEl) return;

    const filtered = currentFilter === "all"
      ? allBookings
      : allBookings.filter(b => b.status === currentFilter);

    if (allBookings.length === 0) {
      emptyEl?.classList.remove("hidden");
      noFilterEl?.classList.add("hidden");
      listEl.innerHTML = "";
      return;
    }

    emptyEl?.classList.add("hidden");

    if (filtered.length === 0) {
      noFilterEl?.classList.remove("hidden");
      listEl.innerHTML = "";
      return;
    }

    noFilterEl?.classList.add("hidden");

    let html = "";
    for (const booking of filtered) {
      const status = booking.status || "pending";
      const style = statusStyles[status] || statusStyles.pending;
      const boatTitle = escapeHtml(booking.boatTitle || "Untitled Boat");
      const thumb = booking.boatImage;
      const dateRange = `${booking.startDate || "?"} \u2014 ${booking.endDate || "?"}`;
      const price = booking.totalPrice ? `\u20AC${booking.totalPrice.toLocaleString()}` : "";
      const createdAt = booking.createdAt
        ? new Date(booking.createdAt).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })
        : "";

      // Calculate days
      let daysText = "";
      if (booking.startDate && booking.endDate) {
        const days = Math.ceil((new Date(booking.endDate).getTime() - new Date(booking.startDate).getTime()) / (1000 * 60 * 60 * 24));
        if (days > 0) daysText = `${days} day${days > 1 ? "s" : ""}`;
      }

      html += `
        <div class="booking-card bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-md transition-shadow" data-status="${status}">
          <div class="flex flex-col sm:flex-row">
            <!-- Image -->
            <div class="sm:w-48 flex-shrink-0">
              <div class="aspect-[4/3] sm:aspect-auto sm:h-full bg-gray-100 overflow-hidden">
                ${thumb
                  ? `<a href={l("/boat-detail?id=${booking.boatId}")}><img src="${escapeHtml(thumb)}" alt="${boatTitle}" class="h-full w-full object-cover" loading="lazy" /></a>`
                  : `<div class="h-full w-full flex items-center justify-center min-h-[120px]"><svg class="h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z"/></svg></div>`
                }
              </div>
            </div>

            <!-- Details -->
            <div class="flex-1 p-5">
              <div class="flex items-start justify-between gap-3 mb-2">
                <div>
                  <a href={l("/boat-detail?id=${booking.boatId}")} class="text-base font-bold text-text hover:text-primary transition-colors">${boatTitle}</a>
                  <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold ${style.bg} ${style.text}">${style.label}</span>
                </div>
                ${price ? `<span class="text-lg font-bold text-text flex-shrink-0">${price}</span>` : ""}
              </div>

              <div class="flex items-center gap-4 text-sm text-text-muted mb-3 flex-wrap">
                <span class="inline-flex items-center gap-1.5">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
                  ${dateRange}
                </span>
                ${daysText ? `<span class="text-gray-400">&middot;</span><span>${daysText}</span>` : ""}
              </div>

              ${createdAt ? `<p class="text-xs text-gray-400 mb-3">Booked on ${createdAt}</p>` : ""}

              <div class="flex items-center gap-2 flex-wrap">
                <a href={l("/boat-detail?id=${booking.boatId}")} class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-gray-100 text-sm font-medium text-text hover:bg-gray-200 transition-colors">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  View boat
                </a>
                ${booking.ownerId ? `
                  <button type="button" class="message-owner-btn inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-gray-100 text-sm font-medium text-text hover:bg-gray-200 transition-colors"
                    data-owner-id="${escapeHtml(booking.ownerId)}"
                    data-boat-id="${escapeHtml(booking.boatId)}"
                    data-boat-title="${boatTitle}"
                  >
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 01.778-.332 48.294 48.294 0 005.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/></svg>
                    Message owner
                  </button>
                ` : ""}
                ${status === "pending" ? `
                  <button type="button" class="cancel-booking-btn inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium text-red-600 border border-red-200 hover:bg-red-50 transition-colors"
                    data-id="${escapeHtml(booking.id)}"
                  >
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                    Cancel booking
                  </button>
                ` : ""}
              </div>
            </div>
          </div>
        </div>
      `;
    }

    listEl.innerHTML = html;
    bindActions();
  }

  function bindActions() {
    // Cancel buttons
    document.querySelectorAll(".cancel-booking-btn").forEach(btn => {
      btn.addEventListener("click", async () => {
        const orderId = btn.getAttribute("data-id");
        if (!orderId || !confirm("Are you sure you want to cancel this booking?")) return;
        try {
          (btn as HTMLButtonElement).disabled = true;
          (btn as HTMLButtonElement).textContent = "Cancelling...";
          await cancelOrder(orderId);
          // Reload bookings
          await loadBookings(currentUid);
        } catch (err) {
          console.error("Cancel failed:", err);
          alert("Failed to cancel booking. Please try again.");
          (btn as HTMLButtonElement).disabled = false;
          (btn as HTMLButtonElement).textContent = "Cancel booking";
        }
      });
    });

    // Message owner buttons
    document.querySelectorAll(".message-owner-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        const ownerId = btn.getAttribute("data-owner-id");
        const boatId = btn.getAttribute("data-boat-id");
        const boatTitle = btn.getAttribute("data-boat-title");
        if (ownerId) {
          const params = new URLSearchParams();
          params.set("with", ownerId);
          if (boatId) params.set("boatId", boatId);
          if (boatTitle) params.set("boatTitle", boatTitle);
          window.location.href = localPath("/messages?") + params.toString();
        }
      });
    });
  }

  async function loadBookings(uid: string) {
    const loadingEl = $("bookings-loading");
    const emptyEl = $("bookings-empty");
    const listEl = $("bookings-list");

    loadingEl?.classList.remove("hidden");
    emptyEl?.classList.add("hidden");
    if (listEl) listEl.innerHTML = "";

    try {
      allBookings = await getUserOrders(uid);
      loadingEl?.classList.add("hidden");
      renderBookings();
    } catch (err) {
      console.error("[Bookings] Error loading bookings:", err);
      loadingEl?.classList.add("hidden");
      emptyEl?.classList.remove("hidden");
    }
  }

  // Auth gate
  let fallbackTimer = setTimeout(() => {
    $("auth-loading")?.classList.add("hidden");
    $("auth-gate")?.classList.remove("hidden");
  }, 3000);

  onAuthChange(async (user) => {
    clearTimeout(fallbackTimer);

    if (!user) {
      $("auth-loading")?.classList.add("hidden");
      $("auth-gate")?.classList.remove("hidden");
      $("bookings-content")?.classList.add("hidden");
      return;
    }

    $("auth-loading")?.classList.add("hidden");
    $("auth-gate")?.classList.add("hidden");
    $("bookings-content")?.classList.remove("hidden");

    // Set sidebar info
    const initials = getInitials(user.user_metadata?.display_name);
    const displayName = user.user_metadata?.display_name || user.email || "User";
    const sidebarName = $("sidebar-name");
    const sidebarInitials = $("sidebar-avatar-initials");
    const sidebarImg = $("sidebar-avatar-img") as HTMLImageElement;

    if (sidebarName) sidebarName.textContent = displayName;
    if (sidebarInitials) sidebarInitials.textContent = initials;
    if (user.user_metadata?.avatar_url && sidebarImg) {
      sidebarImg.src = user.user_metadata?.avatar_url;
      sidebarImg.classList.remove("hidden");
    }

    // Show owner/admin sidebar items
    try {
      const { data: profile } = await supabase.from("profiles").select("user_type").eq("id", user.id).single();
      const userType = profile?.user_type || "user";
      if (userType === "owner" || userType === "admin") {
        $("sidebar-my-offers")?.classList.remove("hidden");
        $("sidebar-my-offers")?.classList.add("flex");
      }
    } catch (e) {}

    currentUid = user.id;
    loadBookings(user.id);
  });

  // Sidebar logout
  $("sidebar-logout-btn")?.addEventListener("click", async () => {
    await signOutUser();
    window.location.href = localPath("/");
  });
</script>
