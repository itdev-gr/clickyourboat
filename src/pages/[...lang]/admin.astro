          <div id="tab-messages" class="admin-tab-content hidden">
            <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
              <!-- Filters bar -->
              <div class="px-6 py-4 border-b border-gray-100 flex items-center flex-wrap gap-3">
                <h2 class="text-lg font-bold text-text mr-2">All Conversations</h2>
                <input type="text" id="adminmsg-participant-input" placeholder="Search participant (name or email)…" class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent w-64" />
                <select id="adminmsg-state-filter" class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary">
                  <option value="all">All states</option>
                  <option value="open">Open</option>
                  <option value="flagged">Flagged</option>
                  <option value="reviewed">Reviewed</option>
                </select>
                <input type="text" id="adminmsg-content-input" placeholder="Search message content…" class="px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent w-64" />
                <button type="button" id="adminmsg-refresh-btn" class="ml-auto px-3 py-1.5 text-sm font-medium text-gray-600 border border-gray-300 rounded-lg hover:bg-gray-50">Refresh</button>
              </div>

              <!-- Loading -->
              <div id="adminmsg-loading" class="flex items-center justify-center py-12">
                <div class="h-6 w-6 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
              </div>

              <!-- Error -->
              <div id="adminmsg-error" class="hidden px-6 py-4 text-sm text-red-600 bg-red-50 border-b border-red-100"></div>

              <!-- Empty -->
              <div id="adminmsg-empty" class="hidden px-6 py-12 text-center">
                <p class="text-sm text-text-muted">No conversations match these filters</p>
              </div>

              <!-- Table -->
              <div id="adminmsg-table-wrap" class="hidden overflow-x-auto">
                <table class="w-full text-sm">
                  <thead class="bg-gray-50 text-left">
                    <tr>
                      <th class="px-6 py-3 font-semibold text-gray-600">Participants</th>
                      <th class="px-6 py-3 font-semibold text-gray-600">Boat</th>
                      <th class="px-6 py-3 font-semibold text-gray-600">Last message</th>
                      <th class="px-6 py-3 font-semibold text-gray-600">Updated</th>
                      <th class="px-6 py-3 font-semibold text-gray-600">Flag</th>
                    </tr>
                  </thead>
                  <tbody id="adminmsg-tbody" class="divide-y divide-gray-100"></tbody>
                </table>
              </div>

              <!-- Pagination -->
              <div id="adminmsg-pagination" class="hidden px-6 py-3 border-t border-gray-100 flex items-center justify-between text-sm">
                <span id="adminmsg-pagination-info" class="text-gray-500"></span>
                <div class="flex items-center gap-2">
                  <button type="button" id="adminmsg-prev-btn" class="px-3 py-1 border border-gray-300 rounded-lg hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed">‹ Prev</button>
                  <span id="adminmsg-page-indicator" class="text-gray-600"></span>
                  <button type="button" id="adminmsg-next-btn" class="px-3 py-1 border border-gray-300 rounded-lg hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed">Next ›</button>
                </div>
              </div>
            </div>
          </div>

        </div>
      </main>
    </div>
  </div>

  <dialog id="boat-detail-modal" class="boat-detail-modal w-[min(960px,95vw)] max-h-[90vh] p-0 rounded-2xl shadow-2xl backdrop:bg-black/50">
    <div class="flex items-start justify-between gap-4 p-5 border-b border-gray-100 sticky top-0 bg-white rounded-t-2xl z-10">
      <div class="min-w-0">
        <h2 id="bdm-title" class="text-lg font-bold text-text truncate">Boat details</h2>
        <p id="bdm-subtitle" class="text-xs text-text-muted mt-0.5 font-mono"></p>
      </div>
      <button type="button" id="bdm-close" class="h-8 w-8 rounded-lg flex items-center justify-center text-gray-400 hover:text-gray-700 hover:bg-gray-100 transition-colors flex-shrink-0" aria-label="Close">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="overflow-y-auto p-5" style="max-height:calc(90vh - 73px);">
      <div id="bdm-loading" class="py-12 flex items-center justify-center">
        <div class="h-6 w-6 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
      </div>
      <div id="bdm-error" class="hidden py-12 text-center text-sm text-red-600"></div>
      <div id="bdm-content" class="hidden space-y-5"></div>
    </div>
  </dialog>
</Layout>

<script is:inline>
  // --- Shared tab switching function ---
  function switchToTab(tab) {
    // Update top tab buttons
    document.querySelectorAll(".admin-tab").forEach(function(b) {
      if (b.getAttribute("data-admin-tab") === tab) {
        b.classList.remove("bg-white", "text-gray-600", "border", "border-gray-300", "hover:bg-gray-50");
        b.classList.add("bg-primary", "text-white");
      } else {
        b.classList.remove("bg-primary", "text-white");
        b.classList.add("bg-white", "text-gray-600", "border", "border-gray-300", "hover:bg-gray-50");
      }
    });
    // Update sidebar buttons
    document.querySelectorAll(".sidebar-tab").forEach(function(b) {
      if (b.getAttribute("data-sidebar-tab") === tab) {
        b.classList.remove("text-gray-300", "hover:bg-gray-700", "hover:text-white");
        b.classList.add("bg-gray-700", "text-white");
      } else {
        b.classList.remove("bg-gray-700", "text-white");
        b.classList.add("text-gray-300", "hover:bg-gray-700", "hover:text-white");
      }
    });
    // Show/hide tab content
    document.querySelectorAll(".admin-tab-content").forEach(function(c) {
      c.classList.add("hidden");
    });
    var target = document.getElementById("tab-" + tab);
    if (target) target.classList.remove("hidden");
  }

  // Top tab buttons
  document.querySelectorAll(".admin-tab").forEach(function(btn) {
    btn.addEventListener("click", function() {
      switchToTab(btn.getAttribute("data-admin-tab"));
    });
  });

  // Sidebar buttons
  document.querySelectorAll(".sidebar-tab").forEach(function(btn) {
    btn.addEventListener("click", function() {
      switchToTab(btn.getAttribute("data-sidebar-tab"));
    });
  });
</script>

<script>
  import { supabase } from "../../lib/supabase";
  import { onAuthChange, signOutUser } from "../../lib/auth";
  import {
    isUserAdmin, getAllUsers, getAllListings, getListingsByStatus,
    updateListingStatus, updateUserType, adminDeleteUser, deleteBoatListing,
    getAllOrders, updateOrderStatus, promoteToOwnerIfNeeded,
    getChargeSettings, saveChargeSettings, getBoatFullRow
  } from "../../lib/api";

  const lang = document.documentElement.dataset.langPrefix || "";
  const dateLang = lang === "gr" ? "el-GR" : "en-GB";
  function localPath(path: string): string {
    return lang ? "/" + lang + path : path;
  }

  function getInitials(name: string | null): string {
    if (!name) return "?";
    return name.split(" ").map(w => w[0]).join("").toUpperCase().slice(0, 2);
  }

  function escapeHtml(text: string): string {
    const div = document.createElement("div");
    div.textContent = text;
    return div.innerHTML;
  }

  function formatDate(val: any): string {
    if (!val) return "—";
    const d = val instanceof Date ? val : new Date(val);
    return d.toLocaleDateString(dateLang, { day: "numeric", month: "short", year: "numeric" });
  }

  function statusBadgeHtml(status: string): string {
    const map: Record<string, string> = {
      draft: "bg-amber-100 text-amber-800",
      pending: "bg-blue-100 text-blue-800",
      published: "bg-green-100 text-green-800",
    };
    const cls = map[status] || "bg-gray-100 text-gray-800";
    const label = status.charAt(0).toUpperCase() + status.slice(1);
    return `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold ${cls}">${label}</span>`;
  }

  function typeBadgeHtml(type: string): string {
    if (type === "admin") {
      return `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold bg-purple-100 text-purple-800">Admin</span>`;
    }
    if (type === "owner") {
      return `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold bg-blue-100 text-blue-800">Owner</span>`;
    }
    return `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold bg-gray-100 text-gray-800">User</span>`;
  }

  const $ = (id: string) => document.getElementById(id);

  // Data stores
  let allListingsData: any[] = [];
  let allUsersData: any[] = [];
  let pendingData: any[] = [];
  let allOrdersData: any[] = [];

  // Owner name cache
  let ownerCache: Record<string, string> = {};

  async function getOwnerName(ownerId: string): Promise<string> {
    if (ownerCache[ownerId]) return ownerCache[ownerId];
    try {
      const { data } = await supabase.from("profiles").select("display_name, first_name, email").eq("id", ownerId).single();
      if (data) {
        const name = data.display_name || data.first_name || data.email || ownerId;
        ownerCache[ownerId] = name;
        return name;
      }
    } catch {}
    ownerCache[ownerId] = ownerId;
    return ownerId;
  }

  function boatName(boat: any): string {
    return [boat.manufacturer, boat.model].filter(Boolean).join(" ") || boat.boatName || boat.listingTitle || "Untitled";
  }

  // --- Render pending table ---
  async function renderPendingTable(data: any[]) {
    const loading = $("pending-loading");
    const empty = $("pending-empty");
    const wrap = $("pending-table-wrap");
    const tbody = $("pending-tbody");

    loading?.classList.add("hidden");

    if (data.length === 0) {
      empty?.classList.remove("hidden");
      wrap?.classList.add("hidden");
      $("pending-count")!.textContent = "0";
      const spc0 = $("sidebar-pending-count");
      if (spc0) spc0.textContent = "0";
      return;
    }

    empty?.classList.add("hidden");
    wrap?.classList.remove("hidden");
    $("pending-count")!.textContent = String(data.length);
    const spc = $("sidebar-pending-count");
    if (spc) spc.textContent = String(data.length);

    let html = "";
    for (const boat of data) {
      const name = escapeHtml(boatName(boat));
      const city = escapeHtml(boat.city || "—");
      const thumb = boat.images?.[0];
      const ownerName = escapeHtml(await getOwnerName(boat.ownerId));
      const date = formatDate(boat.createdAt);

      html += `<tr class="pending-row" data-search="${name.toLowerCase()} ${city.toLowerCase()} ${ownerName.toLowerCase()}">
        <td class="px-6 py-4">
          <div class="flex items-center gap-3">
            <div class="h-10 w-10 rounded-lg bg-gray-100 flex-shrink-0 overflow-hidden">
              ${thumb ? `<img src="${escapeHtml(thumb)}" class="h-full w-full object-cover" alt="" />` : `<div class="h-full w-full flex items-center justify-center text-gray-300"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a2.25 2.25 0 002.25-2.25V5.25a2.25 2.25 0 00-2.25-2.25H3.75a2.25 2.25 0 00-2.25 2.25v13.5a2.25 2.25 0 002.25 2.25z"/></svg></div>`}
            </div>
            <span class="font-medium text-text">${name}</span>
          </div>
        </td>
        <td class="px-6 py-4 text-text-muted">${ownerName}</td>
        <td class="px-6 py-4 text-text-muted">${city}</td>
        <td class="px-6 py-4 text-text-muted">${date}</td>
        <td class="px-6 py-4 text-right">
          <div class="flex items-center justify-end gap-2">
            <button type="button" class="view-btn px-3 py-1.5 rounded-lg bg-white border border-gray-300 text-gray-700 text-xs font-medium hover:bg-gray-50 transition-colors" data-id="${boat.id}">View</button>
            <button type="button" class="approve-btn px-3 py-1.5 rounded-lg bg-green-600 text-white text-xs font-medium hover:bg-green-700 transition-colors" data-id="${boat.id}">Approve</button>
            <button type="button" class="reject-btn px-3 py-1.5 rounded-lg bg-red-600 text-white text-xs font-medium hover:bg-red-700 transition-colors" data-id="${boat.id}">Decline</button>
          </div>
        </td>
      </tr>`;
    }
    if (tbody) tbody.innerHTML = html;

    // Bind view (opens full boat-detail modal)
    tbody?.querySelectorAll(".view-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        const id = btn.getAttribute("data-id");
        if (id) openBoatModal(id);
      });
    });

    // Bind approve/reject
    tbody?.querySelectorAll(".approve-btn").forEach(btn => {
      btn.addEventListener("click", async () => {
        const id = btn.getAttribute("data-id")!;
        try {
          (btn as HTMLButtonElement).disabled = true;
          btn.textContent = "...";
          await updateListingStatus(id, "published");
          await promoteToOwnerIfNeeded(id);
          pendingData = pendingData.filter(b => b.id !== id);
          renderPendingTable(pendingData);
          // Also refresh all listings if loaded
          const idx = allListingsData.findIndex(b => b.id === id);
          if (idx >= 0) allListingsData[idx].status = "published";
          renderAllListingsTable(allListingsData);
        } catch (err) {
          console.error("Approve failed:", err);
          alert("Failed to approve listing.");
          (btn as HTMLButtonElement).disabled = false;
          btn.textContent = "Approve";
        }
      });
    });

    tbody?.querySelectorAll(".reject-btn").forEach(btn => {
      btn.addEventListener("click", async () => {
        const id = btn.getAttribute("data-id")!;
        if (!confirm("Decline this listing? The owner will need to make changes and resubmit.")) return;
        try {
          (btn as HTMLButtonElement).disabled = true;
          btn.textContent = "...";
          await updateListingStatus(id, "draft");
          pendingData = pendingData.filter(b => b.id !== id);
          renderPendingTable(pendingData);
          const idx = allListingsData.findIndex(b => b.id === id);
          if (idx >= 0) allListingsData[idx].status = "draft";
          renderAllListingsTable(allListingsData);
        } catch (err) {
          console.error("Decline failed:", err);
          alert("Failed to decline listing.");
          (btn as HTMLButtonElement).disabled = false;
          btn.textContent = "Decline";
        }
      });
    });
  }

  // --- Search filtering for pending ---
  $("pending-search")?.addEventListener("input", (e) => {
    const term = (e.target as HTMLInputElement).value.toLowerCase();
    document.querySelectorAll(".pending-row").forEach(row => {
      const search = row.getAttribute("data-search") || "";
      (row as HTMLElement).style.display = search.includes(term) ? "" : "none";
    });
  });

  // --- Render all listings table ---
  async function renderAllListingsTable(data: any[]) {
    const loading = $("listings-loading");
    const empty = $("listings-empty");
    const wrap = $("listings-table-wrap");
    const tbody = $("listings-tbody");
    const statusFilter = $("listings-status-filter") as HTMLSelectElement;
    const searchInput = $("listings-search") as HTMLInputElement;

    loading?.classList.add("hidden");

    // Apply filters
    let filtered = data;
    const statusVal = statusFilter?.value || "all";
    if (statusVal !== "all") {
      filtered = filtered.filter(b => b.status === statusVal);
    }
    const searchTerm = searchInput?.value?.toLowerCase() || "";
    if (searchTerm) {
      filtered = filtered.filter(b => {
        const name = boatName(b).toLowerCase();
        const city = (b.city || "").toLowerCase();
        return name.includes(searchTerm) || city.includes(searchTerm);
      });
    }

    if (filtered.length === 0) {
      empty?.classList.remove("hidden");
      wrap?.classList.add("hidden");
      return;
    }

    empty?.classList.add("hidden");
    wrap?.classList.remove("hidden");

    let html = "";
    for (const boat of filtered) {
      const name = escapeHtml(boatName(boat));
      const city = escapeHtml(boat.city || "—");
      const thumb = boat.images?.[0];
      const ownerName = escapeHtml(await getOwnerName(boat.ownerId || ""));
      const date = formatDate(boat.createdAt);
      const status = boat.status || "published";

      html += `<tr>
        <td class="px-6 py-4">
          <div class="flex items-center gap-3">
            <div class="h-10 w-10 rounded-lg bg-gray-100 flex-shrink-0 overflow-hidden">
              ${thumb ? `<img src="${escapeHtml(thumb)}" class="h-full w-full object-cover" alt="" />` : `<div class="h-full w-full flex items-center justify-center text-gray-300"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a2.25 2.25 0 002.25-2.25V5.25a2.25 2.25 0 00-2.25-2.25H3.75a2.25 2.25 0 00-2.25 2.25v13.5a2.25 2.25 0 002.25 2.25z"/></svg></div>`}
            </div>
            <span class="font-medium text-text">${name}</span>
          </div>
        </td>
        <td class="px-6 py-4 text-text-muted">${ownerName}</td>
        <td class="px-6 py-4 text-text-muted">${city}</td>
        <td class="px-6 py-4">${statusBadgeHtml(status)}</td>
        <td class="px-6 py-4 text-text-muted">${date}</td>
        <td class="px-6 py-4 text-right">
          <div class="flex items-center justify-end gap-2">
            <select class="listing-status-select px-2 py-1 text-xs border border-gray-300 rounded-lg" data-id="${boat.id}" data-current="${status}">
              <option value="draft" ${status === "draft" ? "selected" : ""}>Draft</option>
              <option value="pending" ${status === "pending" ? "selected" : ""}>Pending</option>
              <option value="published" ${status === "published" ? "selected" : ""}>Published</option>
            </select>
            <button type="button" class="listing-delete-btn h-8 w-8 rounded-lg flex items-center justify-center text-gray-400 hover:text-red-600 hover:bg-red-50 transition-colors" data-id="${boat.id}" data-name="${name}" title="Delete">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/></svg>
            </button>
          </div>
        </td>
      </tr>`;
    }
    if (tbody) tbody.innerHTML = html;

    // Bind status change
    tbody?.querySelectorAll(".listing-status-select").forEach(sel => {
      sel.addEventListener("change", async (e) => {
        const id = sel.getAttribute("data-id")!;
        const newStatus = (sel as HTMLSelectElement).value;
        try {
          await updateListingStatus(id, newStatus);
          if (newStatus === "published") {
            await promoteToOwnerIfNeeded(id);
          }
          const idx = allListingsData.findIndex(b => b.id === id);
          if (idx >= 0) allListingsData[idx].status = newStatus;
          // Refresh pending if needed
          pendingData = allListingsData.filter(b => b.status === "pending");
          renderPendingTable(pendingData);
          renderAllListingsTable(allListingsData);
        } catch (err) {
          console.error("Status change failed:", err);
          alert("Failed to update status.");
          (sel as HTMLSelectElement).value = sel.getAttribute("data-current")!;
        }
      });
    });

    // Bind delete
    tbody?.querySelectorAll(".listing-delete-btn").forEach(btn => {
      btn.addEventListener("click", async () => {
        const id = btn.getAttribute("data-id")!;
        const name = btn.getAttribute("data-name") || "this listing";
        if (!confirm(`Delete "${name}"? This cannot be undone.`)) return;
        try {
          await deleteBoatListing(id);
          allListingsData = allListingsData.filter(b => b.id !== id);
          pendingData = pendingData.filter(b => b.id !== id);
          renderAllListingsTable(allListingsData);
          renderPendingTable(pendingData);
        } catch (err) {
          console.error("Delete failed:", err);
          alert("Failed to delete listing.");
        }
      });
    });
  }

  // Listings filter/search events
  $("listings-status-filter")?.addEventListener("change", () => renderAllListingsTable(allListingsData));
  $("listings-search")?.addEventListener("input", () => renderAllListingsTable(allListingsData));

  // --- Render users table ---
  async function renderUsersTable(data: any[]) {
    const loading = $("users-loading");
    const empty = $("users-empty");
    const wrap = $("users-table-wrap");
    const tbody = $("users-tbody");

    loading?.classList.add("hidden");

    if (data.length === 0) {
      empty?.classList.remove("hidden");
      wrap?.classList.add("hidden");
      return;
    }

    empty?.classList.add("hidden");
    wrap?.classList.remove("hidden");

    let html = "";
    for (const user of data) {
      const name = escapeHtml(user.displayName || user.firstName || "Unknown");
      const email = escapeHtml(user.email || "—");
      const type = user.type || "user";
      const date = formatDate(user.createdAt);
      const photo = user.photoURL;
      const initials = getInitials(user.displayName || user.firstName);

      html += `<tr class="user-row cursor-pointer hover:bg-gray-50 transition-colors" data-search="${name.toLowerCase()} ${email.toLowerCase()}" data-uid="${user.uid}">
        <td class="px-6 py-4">
          <div class="flex items-center gap-3">
            <div class="h-10 w-10 rounded-full bg-gray-200 flex items-center justify-center text-sm font-bold text-gray-500 flex-shrink-0 overflow-hidden">
              ${photo ? `<img src="${escapeHtml(photo)}" class="h-full w-full object-cover" alt="" />` : `<span>${escapeHtml(initials)}</span>`}
            </div>
            <div class="flex items-center gap-2">
              <span class="font-medium text-text">${name}</span>
              <svg class="user-chevron h-4 w-4 text-gray-400 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
            </div>
          </div>
        </td>
        <td class="px-6 py-4 text-text-muted">${email}</td>
        <td class="px-6 py-4">${typeBadgeHtml(type)}</td>
        <td class="px-6 py-4 text-text-muted">${date}</td>
        <td class="px-6 py-4 text-right" onclick="event.stopPropagation()">
          <div class="flex items-center justify-end gap-2">
            <select class="user-type-select px-2 py-1.5 rounded-lg text-xs font-medium border border-gray-300 bg-white text-gray-700 cursor-pointer" data-uid="${user.uid}" data-current="${type}">
              <option value="user" ${type === "user" ? "selected" : ""}>User</option>
              <option value="owner" ${type === "owner" ? "selected" : ""}>Owner</option>
              <option value="admin" ${type === "admin" ? "selected" : ""}>Admin</option>
            </select>
            <button type="button" class="user-delete-btn h-8 w-8 rounded-lg flex items-center justify-center text-gray-400 hover:text-red-600 hover:bg-red-50 transition-colors" data-uid="${user.uid}" data-name="${name}" title="Delete user">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/></svg>
            </button>
          </div>
        </td>
      </tr>
      <tr class="user-boats-row hidden" data-boats-uid="${user.uid}">
        <td colspan="5" class="px-6 py-0">
          <div class="user-boats-content py-4 pl-14">
            <div class="user-boats-loading text-xs text-text-muted flex items-center gap-2">
              <div class="h-4 w-4 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
              Loading boats...
            </div>
            <div class="user-boats-list hidden"></div>
            <div class="user-boats-empty hidden text-xs text-text-muted italic">No published boats for this user.</div>
          </div>
        </td>
      </tr>`;
    }
    if (tbody) tbody.innerHTML = html;

    // Bind user type change
    tbody?.querySelectorAll(".user-type-select").forEach(sel => {
      sel.addEventListener("change", async () => {
        const uid = sel.getAttribute("data-uid")!;
        const selectEl = sel as HTMLSelectElement;
        const newType = selectEl.value as "user" | "owner" | "admin";
        const oldType = sel.getAttribute("data-current")!;
        if (!confirm(`Change this user's role to "${newType}"?`)) {
          selectEl.value = oldType;
          return;
        }
        try {
          selectEl.disabled = true;

          // Immediately update the badge in the same row for instant feedback
          const row = sel.closest("tr");
          if (row) {
            const badgeCell = row.querySelectorAll("td")[2];
            if (badgeCell) badgeCell.innerHTML = typeBadgeHtml(newType);
          }
          sel.setAttribute("data-current", newType);

          // Persist to database
          await updateUserType(uid, newType);

          // Update local data and fully re-render table
          const idx = allUsersData.findIndex(u => u.uid === uid);
          if (idx >= 0) allUsersData[idx].type = newType;
          await renderUsersTable(allUsersData);

          // Re-apply search filter if active
          const searchInput = $("users-search") as HTMLInputElement;
          if (searchInput && searchInput.value) {
            const term = searchInput.value.toLowerCase();
            document.querySelectorAll(".user-row").forEach(r => {
              const search = r.getAttribute("data-search") || "";
              (r as HTMLElement).style.display = search.includes(term) ? "" : "none";
            });
          }

          // Brief success flash on the updated row
          const updatedRow = tbody?.querySelector(`tr[data-uid="${uid}"]`) as HTMLElement;
          if (updatedRow) {
            updatedRow.classList.add("bg-green-50");
            setTimeout(() => updatedRow.classList.remove("bg-green-50"), 1500);
          }
        } catch (err) {
          console.error("Type change failed:", err);
          alert("Failed to update user type.");
          selectEl.value = oldType;
          sel.setAttribute("data-current", oldType);
          // Revert badge
          const row = sel.closest("tr");
          if (row) {
            const badgeCell = row.querySelectorAll("td")[2];
            if (badgeCell) badgeCell.innerHTML = typeBadgeHtml(oldType);
          }
          selectEl.disabled = false;
        }
      });
    });

    // Bind delete
    tbody?.querySelectorAll(".user-delete-btn").forEach(btn => {
      btn.addEventListener("click", async () => {
        const uid = btn.getAttribute("data-uid")!;
        const name = btn.getAttribute("data-name") || "this user";
        if (!confirm(`Delete user "${name}"? This will remove their profile record.`)) return;
        try {
          await adminDeleteUser(uid);
          allUsersData = allUsersData.filter(u => u.uid !== uid);
          await renderUsersTable(allUsersData);
        } catch (err) {
          console.error("Delete failed:", err);
          alert("Failed to delete user.");
        }
      });
    });

    // Bind row click to expand/collapse boats
    const userBoatsCache: Record<string, any[]> = {};
    tbody?.querySelectorAll(".user-row").forEach(row => {
      row.addEventListener("click", async () => {
        const uid = row.getAttribute("data-uid")!;
        const boatsRow = tbody.querySelector(`.user-boats-row[data-boats-uid="${uid}"]`) as HTMLElement;
        if (!boatsRow) return;

        const chevron = row.querySelector(".user-chevron") as SVGElement;
        const isOpen = !boatsRow.classList.contains("hidden");

        // Close all other open rows
        tbody.querySelectorAll(".user-boats-row").forEach(r => {
          r.classList.add("hidden");
        });
        tbody.querySelectorAll(".user-chevron").forEach(c => {
          (c as HTMLElement).style.transform = "";
        });

        if (isOpen) return; // was open, now closed

        boatsRow.classList.remove("hidden");
        if (chevron) chevron.style.transform = "rotate(180deg)";

        // Load boats if not cached
        const loadingEl = boatsRow.querySelector(".user-boats-loading") as HTMLElement;
        const listEl = boatsRow.querySelector(".user-boats-list") as HTMLElement;
        const emptyEl = boatsRow.querySelector(".user-boats-empty") as HTMLElement;

        if (userBoatsCache[uid]) {
          renderUserBoats(userBoatsCache[uid], listEl, emptyEl, loadingEl);
          return;
        }

        loadingEl?.classList.remove("hidden");
        listEl?.classList.add("hidden");
        emptyEl?.classList.add("hidden");

        try {
          const statusOrder: Record<string, number> = { draft: 0, pending: 1, published: 2, declined: 3 };
          const userBoats = allListingsData
            .filter(b => b.ownerId === uid)
            .sort((a, b) => (statusOrder[a.status] ?? 9) - (statusOrder[b.status] ?? 9));
          userBoatsCache[uid] = userBoats;
          renderUserBoats(userBoats, listEl, emptyEl, loadingEl);
        } catch (err) {
          console.error("Failed to load user boats:", err);
          loadingEl?.classList.add("hidden");
          emptyEl?.classList.remove("hidden");
          if (emptyEl) emptyEl.textContent = "Failed to load boats.";
        }
      });
    });
  }

  function renderUserBoats(boats: any[], listEl: HTMLElement, emptyEl: HTMLElement, loadingEl: HTMLElement) {
    loadingEl?.classList.add("hidden");

    if (boats.length === 0) {
      emptyEl?.classList.remove("hidden");
      listEl?.classList.add("hidden");
      if (emptyEl) emptyEl.textContent = "This user has no boats yet.";
      return;
    }

    emptyEl?.classList.add("hidden");
    listEl?.classList.remove("hidden");

    let html = `<p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Boats (${boats.length}) <span class="font-normal normal-case tracking-normal text-gray-400">— click any boat to see all stored data</span></p><div class="grid gap-2">`;
    for (const boat of boats) {
      const name = escapeHtml(boatName(boat));
      const city = escapeHtml(boat.city || "—");
      const thumb = boat.images?.[0];
      const price = boat.pricePerDay ? `€${boat.pricePerDay}/day` : "";

      html += `<div class="user-boat-tile flex items-center gap-3 p-2 rounded-lg bg-gray-50 border border-gray-100 cursor-pointer hover:bg-white hover:border-primary/40 hover:shadow-sm transition-all" data-boat-id="${escapeHtml(boat.id)}">
        <div class="h-10 w-10 rounded-lg bg-gray-200 flex-shrink-0 overflow-hidden">
          ${thumb ? `<img src="${escapeHtml(thumb)}" class="h-full w-full object-cover" alt="" />` : `<div class="h-full w-full flex items-center justify-center text-gray-300"><svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a2.25 2.25 0 002.25-2.25V5.25a2.25 2.25 0 00-2.25-2.25H3.75a2.25 2.25 0 00-2.25 2.25v13.5a2.25 2.25 0 002.25 2.25z"/></svg></div>`}
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-text truncate">${name}</p>
          <p class="text-xs text-text-muted">${city}${price ? ` · ${price}` : ""}</p>
        </div>
        ${statusBadgeHtml(boat.status || "draft")}
      </div>`;
    }
    html += `</div>`;
    listEl.innerHTML = html;

    listEl.querySelectorAll<HTMLElement>(".user-boat-tile").forEach(tile => {
      tile.addEventListener("click", (e) => {
        e.stopPropagation();
        const id = tile.getAttribute("data-boat-id");
        if (id) openBoatModal(id);
      });
    });
  }

  // Users search
  $("users-search")?.addEventListener("input", (e) => {
    const term = (e.target as HTMLInputElement).value.toLowerCase();
    document.querySelectorAll(".user-row").forEach(row => {
      const search = row.getAttribute("data-search") || "";
      (row as HTMLElement).style.display = search.includes(term) ? "" : "none";
    });
  });

  // --- Auth gate + admin check ---
  let fallbackTimer = setTimeout(() => {
    $("auth-loading")?.classList.add("hidden");
    $("auth-gate")?.classList.remove("hidden");
  }, 3000);

  onAuthChange(async (user) => {
    clearTimeout(fallbackTimer);
    const loading = $("auth-loading");
    const gate = $("auth-gate");
    const denied = $("access-denied");
    const content = $("admin-content");

    if (!user) {
      loading?.classList.add("hidden");
      gate?.classList.remove("hidden");
      content?.classList.add("hidden");
      denied?.classList.add("hidden");
      return;
    }

    // Check admin
    const isAdmin = await isUserAdmin(user.id);
    loading?.classList.add("hidden");

    if (!isAdmin) {
      gate?.classList.add("hidden");
      denied?.classList.remove("hidden");
      content?.classList.add("hidden");
      return;
    }

    gate?.classList.add("hidden");
    denied?.classList.add("hidden");
    content?.classList.remove("hidden");

    // Set sidebar info
    const initials = getInitials(user.user_metadata?.display_name);
    const displayName = user.user_metadata?.display_name || user.email || "Admin";
    const sidebarName = $("sidebar-name");
    const sidebarInitials = $("sidebar-avatar-initials");
    const sidebarImg = $("sidebar-avatar-img") as HTMLImageElement;

    if (sidebarName) sidebarName.textContent = displayName;
    if (sidebarInitials) sidebarInitials.textContent = initials;
    if (user.user_metadata?.avatar_url && sidebarImg) {
      sidebarImg.src = user.user_metadata?.avatar_url;
      sidebarImg.classList.remove("hidden");
    }

    // Load charges settings (no await needed, runs independently)
    loadCharges();

    // Load data in parallel — use allSettled so one failure doesn't block the others
    const [listingsRes, usersRes, ordersRes] = await Promise.allSettled([
      getAllListings(),
      getAllUsers(),
      getAllOrders(),
    ]);

    if (listingsRes.status === "fulfilled") {
      allListingsData = listingsRes.value;
      pendingData = allListingsData.filter(b => b.status === "pending");
      renderPendingTable(pendingData);
      renderAllListingsTable(allListingsData);
    } else {
      console.error("Failed to load listings:", listingsRes.reason);
    }

    if (usersRes.status === "fulfilled") {
      allUsersData = usersRes.value;
      renderUsersTable(allUsersData);
    } else {
      console.error("Failed to load users:", usersRes.reason);
    }

    if (ordersRes.status === "fulfilled") {
      allOrdersData = ordersRes.value;
      renderOrdersTable(allOrdersData);
    } else {
      console.error("Failed to load orders:", ordersRes.reason);
    }
  });

  // --- Render orders table ---
  function orderStatusBadge(status: string): string {
    const map: Record<string, string> = {
      pending: "bg-blue-100 text-blue-800",
      confirmed: "bg-green-100 text-green-800",
      cancelled: "bg-gray-100 text-gray-600",
      completed: "bg-emerald-100 text-emerald-800",
    };
    const cls = map[status] || "bg-gray-100 text-gray-800";
    const label = status.charAt(0).toUpperCase() + status.slice(1);
    return `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold ${cls}">${label}</span>`;
  }

  async function renderOrdersTable(data: any[]) {
    const loading = $("orders-loading");
    const empty = $("orders-empty");
    const wrap = $("orders-table-wrap");
    const tbody = $("orders-tbody");
    const statusFilter = $("orders-status-filter") as HTMLSelectElement;

    loading?.classList.add("hidden");

    // Apply filter
    let filtered = data;
    const statusVal = statusFilter?.value || "all";
    if (statusVal !== "all") {
      filtered = filtered.filter(o => o.status === statusVal);
    }

    if (filtered.length === 0) {
      empty?.classList.remove("hidden");
      wrap?.classList.add("hidden");
      return;
    }

    empty?.classList.add("hidden");
    wrap?.classList.remove("hidden");

    let html = "";
    for (const order of filtered) {
      const boatTitle = escapeHtml(order.boatTitle || "Unknown Boat");
      const renterName = escapeHtml(order.renterName || "Unknown");
      const dates = `${order.startDate || "?"} \u2014 ${order.endDate || "?"}`;
      const price = order.totalPrice ? `\u20AC${order.totalPrice.toLocaleString()}` : "\u2014";
      const status = order.status || "pending";

      let actions = "";
      if (status === "pending") {
        actions = `
          <button type="button" class="order-approve-btn px-3 py-1.5 rounded-lg bg-green-600 text-white text-xs font-medium hover:bg-green-700 transition-colors" data-id="${order.id}">Approve</button>
          <button type="button" class="order-reject-btn px-3 py-1.5 rounded-lg bg-red-600 text-white text-xs font-medium hover:bg-red-700 transition-colors" data-id="${order.id}">Reject</button>
        `;
      } else if (status === "confirmed") {
        actions = `<button type="button" class="order-cancel-btn px-3 py-1.5 rounded-lg bg-gray-200 text-gray-700 text-xs font-medium hover:bg-gray-300 transition-colors" data-id="${order.id}">Cancel</button>`;
      }

      html += `<tr>
        <td class="px-6 py-4 font-medium text-text">${boatTitle}</td>
        <td class="px-6 py-4 text-text-muted">${renterName}</td>
        <td class="px-6 py-4 text-text-muted text-xs">${dates}</td>
        <td class="px-6 py-4 text-text font-medium">${price}</td>
        <td class="px-6 py-4">${orderStatusBadge(status)}</td>
        <td class="px-6 py-4 text-right">
          <div class="flex items-center justify-end gap-2">${actions}</div>
        </td>
      </tr>`;
    }
    if (tbody) tbody.innerHTML = html;

    // Bind approve
    tbody?.querySelectorAll(".order-approve-btn").forEach(btn => {
      btn.addEventListener("click", async () => {
        const id = btn.getAttribute("data-id")!;
        try {
          (btn as HTMLButtonElement).disabled = true;
          btn.textContent = "...";
          await updateOrderStatus(id, "confirmed");
          const idx = allOrdersData.findIndex(o => o.id === id);
          if (idx >= 0) allOrdersData[idx].status = "confirmed";
          renderOrdersTable(allOrdersData);
        } catch (err) {
          console.error("Approve order failed:", err);
          alert("Failed to approve order.");
          (btn as HTMLButtonElement).disabled = false;
          btn.textContent = "Approve";
        }
      });
    });

    // Bind reject
    tbody?.querySelectorAll(".order-reject-btn").forEach(btn => {
      btn.addEventListener("click", async () => {
        const id = btn.getAttribute("data-id")!;
        if (!confirm("Reject this order?")) return;
        try {
          (btn as HTMLButtonElement).disabled = true;
          btn.textContent = "...";
          await updateOrderStatus(id, "cancelled");
          const idx = allOrdersData.findIndex(o => o.id === id);
          if (idx >= 0) allOrdersData[idx].status = "cancelled";
          renderOrdersTable(allOrdersData);
        } catch (err) {
          console.error("Reject order failed:", err);
          alert("Failed to reject order.");
          (btn as HTMLButtonElement).disabled = false;
          btn.textContent = "Reject";
        }
      });
    });

    // Bind cancel
    tbody?.querySelectorAll(".order-cancel-btn").forEach(btn => {
      btn.addEventListener("click", async () => {
        const id = btn.getAttribute("data-id")!;
        if (!confirm("Cancel this order?")) return;
        try {
          (btn as HTMLButtonElement).disabled = true;
          btn.textContent = "...";
          await updateOrderStatus(id, "cancelled");
          const idx = allOrdersData.findIndex(o => o.id === id);
          if (idx >= 0) allOrdersData[idx].status = "cancelled";
          renderOrdersTable(allOrdersData);
        } catch (err) {
          console.error("Cancel order failed:", err);
          alert("Failed to cancel order.");
          (btn as HTMLButtonElement).disabled = false;
          btn.textContent = "Cancel";
        }
      });
    });
  }

  // Orders filter event
  $("orders-status-filter")?.addEventListener("change", () => renderOrdersTable(allOrdersData));

  // --- Charges tab ---
  async function loadCharges() {
    try {
      const settings = await getChargeSettings();
      const commInput = $("charge-commission") as HTMLInputElement;
      const feeInput = $("charge-service-fee") as HTMLInputElement;
      const platInput = $("charge-platform-fee") as HTMLInputElement;
      if (commInput) commInput.value = String(settings.commissionPercent);
      if (feeInput) feeInput.value = String(settings.serviceFee);
      if (platInput) platInput.value = String(settings.platformFeePercent);
    } catch (err) {
      console.error("Failed to load charges:", err);
    }
    $("charges-loading")?.classList.add("hidden");
    $("charges-form")?.classList.remove("hidden");
  }

  $("charges-save-btn")?.addEventListener("click", async () => {
    const btn = $("charges-save-btn") as HTMLButtonElement;
    const msg = $("charges-save-msg")!;
    const commissionPercent = parseFloat(($("charge-commission") as HTMLInputElement).value) || 0;
    const serviceFee = parseFloat(($("charge-service-fee") as HTMLInputElement).value) || 0;
    const platformFeePercent = parseFloat(($("charge-platform-fee") as HTMLInputElement).value) || 0;

    btn.disabled = true;
    btn.textContent = "Saving...";
    msg.classList.add("hidden");

    try {
      await saveChargeSettings({ commissionPercent, serviceFee, platformFeePercent });
      msg.textContent = "Saved!";
      msg.classList.remove("hidden");
      setTimeout(() => msg.classList.add("hidden"), 3000);
    } catch (err) {
      console.error("Failed to save charges:", err);
      alert("Failed to save charge settings.");
    }
    btn.disabled = false;
    btn.textContent = "Save Changes";
  });

  // Sidebar logout
  $("sidebar-logout-btn")?.addEventListener("click", async () => {
    await signOutUser();
    window.location.href = localPath("/");
  });

  // --- Boat detail modal ---
  type FieldSpec = { key: string; label?: string; render?: "text" | "date" | "url" | "json" | "images" | "array" };
  type GroupSpec = { title: string; fields: FieldSpec[] };

