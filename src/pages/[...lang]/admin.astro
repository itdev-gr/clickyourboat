  function humanizeKey(k: string): string {
    return k.replace(/_/g, " ").replace(/\b\w/g, c => c.toUpperCase());
  }

  function renderFieldValue(row: any, spec: FieldSpec): string {
    const v = row[spec.key];
    if (v === null || v === undefined || v === "") return `<span class="text-gray-400 italic">—</span>`;

    switch (spec.render) {
      case "date":
        try { return escapeHtml(new Date(v).toLocaleString(dateLang)); } catch { return escapeHtml(String(v)); }
      case "url":
        return `<a href="${escapeHtml(String(v))}" target="_blank" rel="noopener" class="text-primary hover:underline break-all">${escapeHtml(String(v))}</a> <a href="${escapeHtml(String(v))}" target="_blank" rel="noopener" class="ml-1 inline-flex items-center px-1.5 py-0.5 text-[10px] font-semibold rounded bg-primary/10 text-primary hover:bg-primary/20">Open ↗</a>`;
      case "json":
        return `<pre class="text-xs bg-gray-50 border border-gray-200 rounded p-2 overflow-x-auto whitespace-pre-wrap">${escapeHtml(JSON.stringify(v, null, 2))}</pre>`;
      case "array":
        if (!Array.isArray(v) || v.length === 0) return `<span class="text-gray-400 italic">empty</span>`;
        return v.map(x => `<span class="inline-block px-2 py-0.5 mr-1 mb-1 text-xs rounded bg-gray-100 text-gray-700">${escapeHtml(String(x))}</span>`).join("");
      case "images":
        if (!Array.isArray(v) || v.length === 0) return `<span class="text-gray-400 italic">no images</span>`;
        return `<div class="grid grid-cols-4 gap-2">${v.map(u => `<a href="${escapeHtml(u)}" target="_blank" rel="noopener" class="block h-20 rounded overflow-hidden bg-gray-100 hover:ring-2 hover:ring-primary"><img src="${escapeHtml(u)}" class="h-full w-full object-cover" alt="" loading="lazy" /></a>`).join("")}</div>`;
      default:
        if (typeof v === "boolean") return v ? "✓ true" : "✗ false";
        if (typeof v === "object") return `<pre class="text-xs bg-gray-50 border border-gray-200 rounded p-2 overflow-x-auto whitespace-pre-wrap">${escapeHtml(JSON.stringify(v, null, 2))}</pre>`;
        return escapeHtml(String(v));
    }
  }

  function renderGroup(row: any, group: GroupSpec): string {
    const rows = group.fields.map(f => {
      const label = escapeHtml(f.label || humanizeKey(f.key));
      const value = renderFieldValue(row, f);
      return `<div class="grid grid-cols-[180px_1fr] gap-3 py-2 border-b border-gray-50 last:border-0">
        <div class="text-xs font-medium text-gray-500 pt-1">${label}</div>
        <div class="text-sm text-text break-words">${value}</div>
      </div>`;
    }).join("");
    return `<details class="rounded-lg border border-gray-200 bg-white" open>
      <summary class="cursor-pointer px-4 py-2.5 text-sm font-semibold text-text bg-gray-50 rounded-lg list-none flex items-center justify-between">
        <span>${escapeHtml(group.title)}</span>
        <svg class="h-4 w-4 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
      </summary>
      <div class="px-4 py-2">${rows}</div>
    </details>`;
  }

  async function openBoatModal(boatId: string) {
    const dlg = $("boat-detail-modal") as HTMLDialogElement | null;
    if (!dlg) return;
    const loading = $("bdm-loading");
    const errorEl = $("bdm-error");
    const content = $("bdm-content");
    const title = $("bdm-title");
    const subtitle = $("bdm-subtitle");

    loading?.classList.remove("hidden");
    errorEl?.classList.add("hidden");
    content?.classList.add("hidden");
    if (content) content.innerHTML = "";
    if (title) title.textContent = "Boat details";
    if (subtitle) subtitle.textContent = boatId;

    try { dlg.showModal(); } catch { dlg.setAttribute("open", ""); }

    try {
      const row = await getBoatFullRow(boatId);
      if (!row) {
        if (errorEl) { errorEl.textContent = "Boat not found."; errorEl.classList.remove("hidden"); }
        loading?.classList.add("hidden");
        return;
      }

      if (title) title.textContent = row.boat_name || row.listing_title || "Boat details";
      if (subtitle) subtitle.textContent = `${row.id} · ${row.status || "—"}`;

      const knownKeys = new Set<string>();
      BOAT_FIELD_GROUPS.forEach(g => g.fields.forEach(f => knownKeys.add(f.key)));
      const unknownEntries = Object.keys(row).filter(k => !knownKeys.has(k));

      let html = BOAT_FIELD_GROUPS.map(g => renderGroup(row, g)).join("");

      if (unknownEntries.length > 0) {
        const unknownGroup: GroupSpec = {
          title: "Other columns",
          fields: unknownEntries.map(k => ({ key: k })),
        };
        html += renderGroup(row, unknownGroup);
      }

      html += `<details class="rounded-lg border border-gray-200 bg-white">
        <summary class="cursor-pointer px-4 py-2.5 text-sm font-semibold text-text bg-gray-50 rounded-lg list-none">
          Raw JSON
        </summary>
        <pre class="text-xs bg-gray-900 text-gray-100 p-4 overflow-x-auto rounded-b-lg">${escapeHtml(JSON.stringify(row, null, 2))}</pre>
      </details>`;

      if (content) content.innerHTML = html;
      loading?.classList.add("hidden");
      content?.classList.remove("hidden");
    } catch (err) {
      console.error("Failed to load boat", err);
      loading?.classList.add("hidden");
      if (errorEl) { errorEl.textContent = "Failed to load boat data."; errorEl.classList.remove("hidden"); }
    }
  }

  $("bdm-close")?.addEventListener("click", () => {
    ($("boat-detail-modal") as HTMLDialogElement | null)?.close();
  });
  $("boat-detail-modal")?.addEventListener("click", (e) => {
    const dlg = e.currentTarget as HTMLDialogElement;
    const rect = dlg.getBoundingClientRect();
    const me = e as MouseEvent;
    const inside = me.clientX >= rect.left && me.clientX <= rect.right && me.clientY >= rect.top && me.clientY <= rect.bottom;
    if (!inside) dlg.close();
  });
</script>