---
import Layout from "../layouts/Layout.astro";

const title = "Athens Boat Tours — Boat Trips From Athens Greece | BoatHaven";
const description =
  "Athens, a city of ancient ruins and modern elegance, offers an unmatched maritime experience best enjoyed from the sea. Explore our Athens boat tours and trips.";

const tours = [
  {
    name: "ARSIDA, PATROKLOS & SOUNIO: Half Day Tour",
    slug: "arsida-patroklos-sounio",
    image: "https://boat4all.gr/wp-content/uploads/2024/10/ARSIDA-PATROKLOS-SOUNIO-Half-Day-Tour-compressed.jpg",
    description: "Explore three iconic spots, Arsida, Patroklos, and Sounio, on this half-day journey with crystal-clear waters and coastal views.",
    href: "https://boat4all.gr/tour/arsida-patroklos-sounio-half-day-tour/",
  },
  {
    name: "HYDRA & POROS: Full Day Tour",
    slug: "hydra-poros",
    image: "https://boat4all.gr/wp-content/uploads/2024/10/HYDRA-POROS-Full-Day-Tour-compressed-1.jpg",
    description: "Sail through vibrant history with picturesque landscapes, quaint villages, and crystal waters.",
    href: "https://boat4all.gr/tour/hydra-poros-full-day-tour/",
  },
  {
    name: "ATHENIAN RIVIERA & FLEVES",
    slug: "athenian-riviera-fleves",
    image: "https://boat4all.gr/wp-content/uploads/2024/10/HYDRA-POROS-Full-Day-Tour-compressed.jpg",
    description: "Cruise along the Athenian Riviera to Fleves Island with sandy beaches and seaside charm.",
    href: "https://boat4all.gr/tour/athenian-riviera-fleves/",
  },
  {
    name: "AIGINA ISLAND Boat Tour",
    slug: "aigina-island",
    image: "https://boat4all.gr/wp-content/uploads/2024/10/AIGINA-ISLAND-compressed.jpg",
    description: "Sail to Aigina Island, famous for ancient sites and charming villages, perfect for sightseeing and sunbathing.",
    href: "https://boat4all.gr/tour/aigina-island/",
  },
  {
    name: "AGISTRI ISLAND ESCAPE: A Serene Boat Tour Adventure",
    slug: "agistri-island-escape",
    image: "https://boat4all.gr/wp-content/uploads/2024/10/AGISTRI-ISLAND-ESCAPE-A-Serene-Boat-Tour-Adventure-compressed.jpg",
    description: "Discover Agistri's hidden beauty, turquoise waters, and tranquil beaches ideal for serenity seekers.",
    href: "https://boat4all.gr/tour/agistri-island-escape-a-serene-boat-tour-adventure/",
  },
  {
    name: "KEA ISLAND BOAT TOUR: Discover the Hidden Gem of the Cyclades",
    slug: "kea-island",
    image: "https://boat4all.gr/wp-content/uploads/2025/07/IMG_7878-750x540.jpg",
    description: "Sail to Kea, a Cycladic treasure with pristine beaches and traditional charm for adventurers.",
    href: "https://boat4all.gr/tour/kea-island-boat-tour-discover-the-hidden-gem-of-the-cyclades/",
  },
  {
    name: "Honeymoon Bliss Boat Tour",
    slug: "honeymoon-bliss",
    image: "https://boat4all.gr/wp-content/uploads/2024/10/Honeymoon-Bliss-Tour-compressed.jpg",
    description: "Celebrate love with romantic cruise through magical waters, intimate settings, beautiful sunsets.",
    href: "https://boat4all.gr/tour/honeymoon-bliss-tour/",
  },
  {
    name: "Historical Explorer Boat Tour",
    slug: "historical-explorer",
    image: "https://boat4all.gr/wp-content/uploads/2024/10/Historical-Explorer-Tour-compressed.jpg",
    description: "Embark on journey through ancient past, exploring historic ruins and coastal sites.",
    href: "https://boat4all.gr/tour/historical-explorer-tour/",
  },
  {
    name: "Bachelor/Bachelorette Party Cruise",
    slug: "bachelor-bachelorette",
    image: "https://boat4all.gr/wp-content/uploads/2024/10/Bachelorette-Party-Cruise-compressed.jpg",
    description: "Celebrate in style with private boat party surrounded by stunning seascapes for bride/groom-to-be.",
    href: "https://boat4all.gr/tour/bachelor-bachelorette-party-cruise/",
  },
  {
    name: "Family Adventure Boat Tour",
    slug: "family-adventure",
    image: "https://boat4all.gr/wp-content/uploads/2024/10/Family-Adventure-Tour-compressed.jpg",
    description: "Enjoy fun-filled day on water perfect for families with activities, swimming for all ages.",
    href: "https://boat4all.gr/tour/family-adventure-tour/",
  },
  {
    name: "A Thrilling Launch from Athens to Aegina's Charms",
    slug: "athens-to-aegina",
    image: "https://boat4all.gr/wp-content/uploads/2024/10/A-Thrilling-Launch-from-Athens-to-Aeginas-Charms-compressed.jpg",
    description: "Journey from Athens to Aegina discovering local delights and beaches blending adventure with relaxation.",
    href: "https://boat4all.gr/tour/a-thrilling-launch-from-athens-to-aeginas-charms/",
  },
  {
    name: "Art and Culture Boat Tour",
    slug: "art-and-culture",
    image: "https://boat4all.gr/wp-content/uploads/2024/10/Art-and-Culture-Tour-compressed.jpg",
    description: "Delve into Greece's artistic heritage visiting coastal galleries and unique artistic hubs.",
    href: "https://boat4all.gr/tour/art-and-culture-tour/",
  },
];
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: "Athens Boat Tours",
      description,
      url: "https://boathaven.com/destinations",
      publisher: { "@type": "Organization", name: "BoatHaven" },
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="relative h-[360px] sm:h-[420px] overflow-hidden">
    <img
      src="https://boat4all.gr/wp-content/uploads/2024/10/ARSIDA-PATROKLOS-SOUNIO-Half-Day-Tour-compressed.jpg"
      alt="Athens boat tours on the Aegean Sea"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/35 to-black/65"></div>
    <div class="relative z-10 flex flex-col items-center justify-center h-full text-center px-4">
      <p class="text-sm sm:text-base text-white/70 uppercase tracking-widest font-medium mb-3">Choose Your Destination</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight mb-4">
        Athens Boat Tours & Trips
      </h1>
      <p class="text-lg sm:text-xl text-white/85 max-w-2xl">
        Athens, a city of ancient ruins and modern elegance, offers an unmatched maritime experience best enjoyed from the sea
      </p>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-12 sm:py-16 bg-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-text-muted leading-relaxed text-base sm:text-lg">
        The Athenian coastline is renowned for its stunning cliffs, calm waters, pristine coves, and charming coastal towns. Whether you're looking for a relaxing getaway or an exciting boat tour, an Athens boat trip lets you explore the Athenian Riviera, where you can escape traffic, crowded beaches, and charming coastal towns.
      </p>
    </div>
  </section>

  <!-- Tour Cards Grid -->
  <section class="pb-16 sm:pb-20 bg-white" aria-labelledby="tours-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 text-center">
        <h2 id="tours-heading" class="text-2xl sm:text-3xl font-bold text-text">
          Athens Boat Tours, Including Private Customizable Experiences
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {tours.map((tour) => (
          <a
            href={tour.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group block rounded-2xl overflow-hidden border border-gray-200 bg-white hover:shadow-xl transition-shadow duration-300"
          >
            <!-- Image -->
            <div class="relative aspect-[4/3] overflow-hidden">
              <img
                src={tour.image}
                alt={tour.name}
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent"></div>
            </div>

            <!-- Content -->
            <div class="p-5">
              <h3 class="font-bold text-text text-base sm:text-lg mb-2 group-hover:text-primary transition-colors leading-snug">
                {tour.name}
              </h3>
              <p class="text-sm text-text-muted leading-relaxed mb-4">
                {tour.description}
              </p>
              <span class="inline-flex items-center gap-2 text-sm font-semibold text-primary group-hover:text-primary-dark transition-colors">
                Explore Now
                <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Explore Athens by Boat -->
  <section class="py-16 sm:py-20 bg-surface" aria-labelledby="why-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 id="why-heading" class="text-2xl sm:text-3xl font-bold text-text">Why Explore Athens by Boat?</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-2xl p-6 text-center">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-4">
            <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
          </div>
          <h3 class="font-bold text-text mb-2">Escape the Crowds</h3>
          <p class="text-sm text-text-muted">No need to battle the busy streets or packed tours. Instead, experience the tranquility of the open seas.</p>
        </div>
        <div class="bg-white rounded-2xl p-6 text-center">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-4">
            <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21"/></svg>
          </div>
          <h3 class="font-bold text-text mb-2">Historical Perspective</h3>
          <p class="text-sm text-text-muted">Enjoy unique views of Athens' iconic ruins and monuments, making it a truly unique and memorable experience.</p>
        </div>
        <div class="bg-white rounded-2xl p-6 text-center">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-4">
            <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
          </div>
          <h3 class="font-bold text-text mb-2">Luxury & Comfort</h3>
          <p class="text-sm text-text-muted">Sail in style with soft drinks, snacks, and modern amenities. Choose between shared and private tours.</p>
        </div>
        <div class="bg-white rounded-2xl p-6 text-center">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-4">
            <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z"/></svg>
          </div>
          <h3 class="font-bold text-text mb-2">Hidden Treasures</h3>
          <p class="text-sm text-text-muted">Uncover secluded beaches, local swim spots, and fresh seafood tavernas only accessible by boat.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Onboard -->
  <section class="py-16 sm:py-20 bg-white" aria-labelledby="onboard-heading">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 id="onboard-heading" class="text-2xl sm:text-3xl font-bold text-text">What to Expect Onboard</h2>
        <p class="mt-2 text-text-muted">Every tour comes with everything you need for the perfect day at sea</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {[
          "Modern boats with spacious seating, Wi-Fi, and air-conditioned lounges",
          "Experienced captains ensuring smooth sailing and safety",
          "Complimentary snacks, refreshments, and lunch aboard",
          "Swimming stops at the Aegean's most breathtaking waters",
          "Destinations perfect for snorkeling, sunbathing, and photography",
          "Personalised itineraries for private charters",
        ].map((item) => (
          <div class="flex items-start gap-3 p-3 rounded-xl bg-surface">
            <svg class="h-5 w-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            <span class="text-sm text-text-muted">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-16 bg-primary">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">Ready to explore Athens by sea?</h2>
      <p class="text-lg text-white/80 mb-8 max-w-2xl mx-auto">
        The best time for an Athens boat tour is from May to October, when the weather is warm and the sea conditions are ideal. Book your unforgettable maritime experience today.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/boat-rental" class="inline-flex items-center px-6 py-3 rounded-xl bg-white text-text font-bold text-sm hover:bg-gray-50 transition-colors">
          Browse all boats
        </a>
        <a href="/charter-types" class="inline-flex items-center px-6 py-3 rounded-xl bg-white/15 border border-white/25 text-white font-bold text-sm hover:bg-white/25 transition-colors">
          Explore charter types
        </a>
      </div>
    </div>
  </section>
</Layout>
