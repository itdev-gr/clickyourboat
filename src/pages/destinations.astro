---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: "Popular Destinations",
      description,
      url: "https://boathaven.com/destinations",
      publisher: { "@type": "Organization", name: "BoatHaven" },
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="relative h-[360px] sm:h-[420px] overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1920&q=80&auto=format"
      alt="Beautiful Mediterranean coastline from the sea"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/35 to-black/65"></div>
    <div class="relative z-10 flex flex-col items-center justify-center h-full text-center px-4">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight mb-4">
        Popular Destinations
      </h1>
      <p class="text-lg sm:text-xl text-white/85 max-w-2xl">
        Discover the best sailing locations across the Mediterranean and beyond
      </p>
    </div>
  </section>

  <!-- Quick nav pills -->
  <div class="sticky top-16 z-30 bg-white border-b border-border">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="flex gap-2 py-3 overflow-x-auto scrollbar-hide" aria-label="Destinations">
        {destinations.map((d) => (
          <a
            href={`#${d.slug}`}
            class="flex-shrink-0 px-4 py-2 rounded-full border border-gray-200 text-sm font-medium text-text-muted hover:border-primary hover:text-primary transition-colors"
          >
            {d.flag} {d.name}
          </a>
        ))}
      </nav>
    </div>
  </div>

  <!-- Destination cards -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 space-y-24">
    {destinations.map((dest, i) => (
      <section id={dest.slug} class="scroll-mt-32" aria-labelledby={`${dest.slug}-heading`}>
        <div class:list={["grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center", i % 2 !== 0 && "lg:direction-rtl"]}>
          <!-- Image -->
          <div class:list={["relative rounded-2xl overflow-hidden aspect-[4/3] group", i % 2 !== 0 && "lg:order-2"]}>
            <img
              src={dest.image}
              alt={`Boat rental in ${dest.name}, ${dest.country}`}
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
            <div class="absolute bottom-4 left-4">
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white/20 backdrop-blur-sm text-white text-sm font-medium">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                {dest.country}
              </span>
            </div>
            <div class="absolute bottom-4 right-4">
              <span class="inline-flex items-center px-3 py-1.5 rounded-full bg-white/20 backdrop-blur-sm text-white text-sm font-medium">
                {dest.boats.toLocaleString()} boats
              </span>
            </div>
          </div>

          <!-- Content -->
          <div class:list={[i % 2 !== 0 && "lg:order-1"]}>
            <h2 id={`${dest.slug}-heading`} class="text-3xl sm:text-4xl font-extrabold text-text mb-3">
              {dest.name}
            </h2>
            <p class="text-lg text-primary font-medium mb-4">{dest.flag} {dest.country}</p>
            <p class="text-text-muted leading-relaxed mb-6">{dest.description}</p>

            <!-- Highlights -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-8">
              {dest.highlights.map((h) => (
                <div class="flex items-center gap-2">
                  <svg class="h-4 w-4 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                  <span class="text-sm text-text-muted">{h}</span>
                </div>
              ))}
            </div>

            <!-- CTA -->
            <a
              href={dest.href}
              class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-primary text-white text-sm font-semibold hover:bg-primary-dark transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
            >
              Explore {dest.name}
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </a>
          </div>
        </div>
      </section>
    ))}
  </div>

  <!-- All locations by region -->
  <section class="bg-surface py-16 sm:py-20" aria-labelledby="all-locations-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 id="all-locations-heading" class="text-2xl sm:text-3xl font-bold text-text">All destinations by region</h2>
        <p class="mt-2 text-text-muted">Browse boat rentals across all our sailing locations</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-8">
        {regions.map((region) => (
          <div>
            <h3 class="font-bold text-text text-sm mb-3 flex items-center gap-1.5">
              <span class="text-base">{region.flag}</span>
              {region.name}
            </h3>
            <ul class="space-y-2">
              {region.locations.map((loc) => (
                <li>
                  <a
                    href={loc.href}
                    class="text-sm text-text-muted hover:text-primary transition-colors"
                  >
                    {loc.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-16 bg-primary">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4">Ready to set sail?</h2>
      <p class="text-lg text-white/80 mb-8 max-w-2xl mx-auto">
        Browse thousands of boats across the Mediterranean's most beautiful destinations.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/boat-rental" class="inline-flex items-center px-6 py-3 rounded-xl bg-white text-text font-bold text-sm hover:bg-gray-50 transition-colors">
          Browse all boats
        </a>
        <a href="/charter-types" class="inline-flex items-center px-6 py-3 rounded-xl bg-white/15 border border-white/25 text-white font-bold text-sm hover:bg-white/25 transition-colors">
          Explore charter types
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
