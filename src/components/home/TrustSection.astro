---

<section id="how-it-works" class="py-20 bg-surface" aria-labelledby="trust-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 id="trust-heading" class="text-3xl sm:text-4xl font-bold text-text" data-i18n="trust.title">
        Why choose BoatHaven
      </h2>
      <p class="mt-3 text-text-muted text-lg max-w-2xl mx-auto" data-i18n="trust.subtitle">
        We take care of everything so you can focus on enjoying the sea
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {trustItems.map((item) => (
        <div class="text-center group">
          <div class="mx-auto mb-4 h-16 w-16 rounded-2xl bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-colors duration-300" set:html={item.icon} />
          <h3 class="text-lg font-bold text-text mb-2" data-i18n={item.titleKey}>{item.title}</h3>
          <p class="text-sm text-text-muted leading-relaxed" data-i18n={item.descKey}>{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
