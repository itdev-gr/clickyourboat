  },
  {
    name: "Historical Explorer Boat Tour",
    image: "https://boat4all.gr/wp-content/uploads/2024/10/Historical-Explorer-Tour-compressed.jpg",
    description: "Embark on journey through ancient past, exploring historic ruins and coastal sites.",
    href: "https://boat4all.gr/tour/historical-explorer-tour/",
  },
  {
    name: "Bachelor/Bachelorette Party Cruise",
    image: "https://boat4all.gr/wp-content/uploads/2024/10/Bachelorette-Party-Cruise-compressed.jpg",
    description: "Celebrate in style with private boat party surrounded by stunning seascapes for bride/groom-to-be.",
    href: "https://boat4all.gr/tour/bachelor-bachelorette-party-cruise/",
  },
  {
    name: "Family Adventure Boat Tour",
    image: "https://boat4all.gr/wp-content/uploads/2024/10/Family-Adventure-Tour-compressed.jpg",
    description: "Enjoy fun-filled day on water perfect for families with activities, swimming for all ages.",
    href: "https://boat4all.gr/tour/family-adventure-tour/",
  },
  {
    name: "Athens to Aegina's Charms",
    image: "https://boat4all.gr/wp-content/uploads/2024/10/A-Thrilling-Launch-from-Athens-to-Aeginas-Charms-compressed.jpg",
    description: "Journey from Athens to Aegina discovering local delights and beaches blending adventure with relaxation.",
    href: "https://boat4all.gr/tour/a-thrilling-launch-from-athens-to-aeginas-charms/",
  },
  {
    name: "Art and Culture Boat Tour",
    image: "https://boat4all.gr/wp-content/uploads/2024/10/Art-and-Culture-Tour-compressed.jpg",
