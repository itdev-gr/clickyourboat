---
import type { Boat, BoatListing } from "../../types";
import { localizeHref } from "../../lib/i18n-utils";

// Boats come from getFeaturedBoats() which spreads BoatListing fields
// (length, capacity, yearOfConstruction…) onto each Boat at runtime.
type FeaturedBoat = Boat & Partial<BoatListing>;

interface Props {
  boats: FeaturedBoat[];
  lang?: string;
}

const { boats = [], lang = "en" } = Astro.props;
const l = (href: string) => localizeHref(href, lang);

// Map raw boat_type → human label shown in the dark badge
const typeLabel = (t: string): string => {
  switch ((t || "").toLowerCase()) {
    case "rib":
      return "RIB";
    case "motorboat":
    case "motor":
      return "Motorboat";
    case "yacht":
      return "Motor yacht";
    case "sailboat":
    case "sailing":
      return "Sailboat";
    case "catamaran":
      return "Catamaran";
    case "without-licence":
      return "No licence";
    default:
      return "Boat";
  }
};

// Length like "7.5 m" — trim pointless decimals
const fmtLen = (n: number | undefined): string => {
  const v = Number(n);
  if (!v || isNaN(v)) return "";
  return Number.isInteger(v) ? `${v} m` : `${v.toFixed(1)} m`;
};
---

{boats.length > 0 && (
  <section id="boats-for-rent" class="py-16 sm:py-20" aria-labelledby="boats-for-rent-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-10 max-w-2xl">
        <h2 id="boats-for-rent-heading" class="text-3xl sm:text-4xl font-bold text-text tracking-tight" data-i18n="boats_rent.title">
          Boats for rent
        </h2>
        <p class="mt-3 text-text-muted text-base sm:text-lg leading-relaxed" data-i18n="boats_rent.subtitle">
          RIBs, motorboats and luxury yachts, handpicked and ready for your day on the Aegean.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 sm:gap-6">
        {boats.map((boat) => {
          const img = boat.images && boat.images.length > 0 ? boat.images[0] : "";
          const len = fmtLen(boat.length);
          const guests = boat.capacity || 0;
          const year = boat.yearOfConstruction || 0;
          const name = (boat.title || "").trim() || "Boat";
          return (
            <article class="group flex flex-col rounded-2xl bg-white border border-gray-200/80 overflow-hidden shadow-sm hover:shadow-lg transition-shadow duration-300">
              <div class="relative aspect-[4/3] overflow-hidden bg-gray-100">
                {img ? (
                  <img
                    src={img}
                    alt={name}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    width="400"
                    height="300"
                    loading="lazy"
                    decoding="async"
                  />
                ) : (
                  <div class="h-full w-full flex items-center justify-center text-gray-300">
                    <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17h18M5 17l2-7h10l2 7M9 10V6h6v4"/></svg>
                  </div>
                )}

                <span class="absolute top-3 left-3 inline-flex items-center px-3 py-1 rounded-full bg-gray-900/85 backdrop-blur-sm text-white text-xs font-semibold">
                  {typeLabel(boat.type)}
                </span>

                <span class="absolute top-3 right-3 inline-flex items-center px-3 py-1 rounded-full bg-primary text-white text-xs font-semibold shadow-sm">
                  €{Number(boat.pricePerDay).toLocaleString("en-US")} /&nbsp;<span data-i18n="boats_rent.day">day</span>
                </span>
              </div>

              <div class="flex flex-col flex-1 p-4 sm:p-5">
                <h3 class="text-lg font-bold text-text truncate">{name}</h3>

                <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1.5 text-sm text-text-muted">
                  {len && (
                    <span class="inline-flex items-center gap-1.5">
                      <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 4l-3 3 3 3M4 7h16M17 14l3 3-3 3M20 17H4"/></svg>
                      {len}
                    </span>
                  )}
                  {guests > 0 && (
                    <span class="inline-flex items-center gap-1.5">
                      <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-1a4 4 0 00-4-4h-1m-7 5H2v-1a4 4 0 014-4h1m4-2a4 4 0 100-8 4 4 0 000 8zm7-3a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                      {guests}&nbsp;<span data-i18n="boats_rent.guests">guests</span>
                    </span>
                  )}
                  {year > 1900 && (
                    <span class="inline-flex items-center gap-1.5">
                      <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                      {year}
                    </span>
                  )}
                </div>

                <a
                  href={l(`/boat-detail?id=${boat.id}`)}
                  class="mt-5 inline-flex items-center justify-center gap-2 w-full rounded-lg bg-primary px-4 py-2.5 text-sm font-semibold text-white hover:bg-primary-dark transition-colors"
                >
                  <span data-i18n="boats_rent.see_details">See details</span>
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
                </a>
              </div>
            </article>
          );
        })}
      </div>

      <div class="mt-10">
        <a
          href={l("/boat-rental")}
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-gray-200 text-sm font-semibold text-text hover:border-primary hover:text-primary transition-colors"
        >
          <span data-i18n="boats_rent.view_all">View all boats</span>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>
    </div>
  </section>
)}
