---
import type { Review } from "../../types";
import { getInitials } from "../../lib/utils";

interface Props {
  reviews: Review[];
}

const { reviews } = Astro.props;

function renderStars(rating: number): string {
  let html = "";
  for (let i = 1; i <= 5; i++) {
    if (i <= Math.floor(rating)) {
      html += `<svg class="h-4 w-4 text-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>`;
    } else {
      html += `<svg class="h-4 w-4 text-slate-300" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>`;
    }
  }
  return html;
}
---

<section class="py-20 bg-surface" aria-labelledby="reviews-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 id="reviews-heading" class="text-3xl sm:text-4xl font-bold text-text" data-i18n="social.title">
        What our sailors say
      </h2>
      <p class="mt-3 text-text-muted text-lg max-w-2xl mx-auto" data-i18n="social.subtitle">
        Trusted by thousands of happy boaters around the world
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {reviews.map((review) => (
        <article class="bg-white rounded-xl p-6 shadow-sm border border-border hover:shadow-md transition-shadow">
          <div class="flex items-center gap-3 mb-4">
            <div class="h-10 w-10 rounded-full bg-primary-light/20 text-primary flex items-center justify-center text-sm font-bold">
              {getInitials(review.userName)}
            </div>
            <div>
              <p class="font-semibold text-sm text-text">{review.userName}</p>
              <p class="text-xs text-text-muted">{review.location}</p>
            </div>
          </div>
          <div class="flex items-center gap-0.5 mb-3" set:html={renderStars(review.rating)} />
          <p class="text-sm text-text-muted leading-relaxed mb-3">
            "{review.comment}"
          </p>
          <p class="text-xs text-text-muted font-medium">
            on <span class="text-text">{review.boatName}</span>
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
