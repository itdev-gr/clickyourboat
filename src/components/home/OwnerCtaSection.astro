---
import { localizeHref } from "../../lib/i18n-utils";

interface Props {
  lang?: string;
}

// Earnings estimator is hydrated as an island

const { lang = "en" } = Astro.props;
const l = (href: string) => localizeHref(href, lang);
---

<section class="py-20 bg-primary" aria-labelledby="owner-cta-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Copy -->
      <div>
        <h2 id="owner-cta-heading" class="text-3xl sm:text-4xl font-bold text-white mb-4" data-i18n="owner.title">
          Own a boat? Start earning today.
        </h2>
        <p class="text-lg text-white/80 mb-6 max-w-lg" data-i18n="owner.subtitle">
          Join thousands of boat owners who earn extra income by listing their boat on BoatHaven. It's free to list and we handle the payments.
        </p>
        <ul class="space-y-3 mb-8">
          <li class="flex items-center gap-3 text-white/90">
            <svg class="h-5 w-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            <span data-i18n="owner.free_list">Free to list your boat</span>
          </li>
          <li class="flex items-center gap-3 text-white/90">
            <svg class="h-5 w-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            <span data-i18n="owner.secure_payments">Secure payments guaranteed</span>
          </li>
          <li class="flex items-center gap-3 text-white/90">
            <svg class="h-5 w-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            <span data-i18n="owner.insurance">Insurance coverage included</span>
          </li>
        </ul>
        <a
          href={l("/list-your-boat")}
          class="inline-flex items-center px-6 py-3 rounded-lg bg-accent text-text font-bold hover:bg-accent-dark transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-primary"
        >
          <span data-i18n="owner.list_boat">List Your Boat</span>
        </a>
      </div>

      <!-- Right: Earnings Estimator -->
      <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 sm:p-8 border border-white/20">
        <h3 class="text-xl font-bold text-white mb-6" data-i18n="owner.estimate_title">Estimate your earnings</h3>
        <form id="earnings-form" class="space-y-5">
          <div>
            <label for="est-boat-type" class="block text-sm font-medium text-white/90 mb-1.5" data-i18n="owner.boat_type">Boat type</label>
            <select
              id="est-boat-type"
              class="w-full rounded-lg bg-white/10 border border-white/20 px-4 py-2.5 text-sm text-white focus:outline-none focus:ring-2 focus:ring-accent"
            >
              <option value="sailing" class="text-text">Sailing</option>
              <option value="motor" class="text-text">Motor</option>
              <option value="catamaran" class="text-text">Catamaran</option>
              <option value="yacht" class="text-text">Yacht</option>
            </select>
          </div>

          <div>
            <label for="est-location" class="block text-sm font-medium text-white/90 mb-1.5" data-i18n="owner.location">Location</label>
            <input
              type="text"
              id="est-location"
              placeholder="e.g. Ibiza, Athens..."
              data-i18n-placeholder="owner.location_placeholder"
              class="w-full rounded-lg bg-white/10 border border-white/20 px-4 py-2.5 text-sm text-white placeholder:text-white/40 focus:outline-none focus:ring-2 focus:ring-accent"
            />
          </div>

          <div>
            <label for="est-days" class="block text-sm font-medium text-white/90 mb-1.5" data-i18n="owner.days_available">
              Days available per year: <span id="est-days-value" class="text-accent font-bold">60</span>
            </label>
            <input
              type="range"
              id="est-days"
              min="10"
              max="200"
              value="60"
              class="w-full accent-accent"
            />
            <div class="flex justify-between text-xs text-white/50 mt-1">
              <span data-i18n="owner.days_10">10 days</span>
              <span data-i18n="owner.days_200">200 days</span>
            </div>
          </div>

          <!-- Result -->
          <div class="bg-white/10 rounded-xl p-5 text-center">
            <p class="text-sm text-white/70 mb-1" data-i18n="owner.estimated_earnings">Estimated yearly earnings</p>
            <p id="est-result" class="text-4xl font-extrabold text-accent">
              &euro;12,750
            </p>
          </div>

          <button
            type="button"
            id="est-calculate-btn"
            class="w-full rounded-lg bg-accent text-text font-bold py-3 hover:bg-accent-dark transition-colors focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-primary"
          >
            <span data-i18n="owner.estimate_btn">Estimate Earnings</span>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  import { estimateEarnings, formatCurrency } from "../../lib/utils";

  const typeSelect = document.getElementById("est-boat-type") as HTMLSelectElement;
  const daysRange = document.getElementById("est-days") as HTMLInputElement;
  const daysValue = document.getElementById("est-days-value") as HTMLSpanElement;
  const result = document.getElementById("est-result") as HTMLParagraphElement;
  const calcBtn = document.getElementById("est-calculate-btn") as HTMLButtonElement;

  function calculate() {
    const boatType = typeSelect.value;
    const days = parseInt(daysRange.value);
    const earnings = estimateEarnings(boatType, days);
    result.textContent = `€${earnings.toLocaleString("en-US", { minimumFractionDigits: 0 })}`;
  }

  daysRange?.addEventListener("input", () => {
    daysValue.textContent = daysRange.value;
  });

  calcBtn?.addEventListener("click", calculate);

  // Calculate on load
  calculate();
</script>
