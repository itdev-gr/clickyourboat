---
import { localizeHref } from "../../lib/i18n-utils";

interface Props {
  lang?: string;
}

const { lang = "en" } = Astro.props;
const l = (href: string) => localizeHref(href, lang);

const categories = [
  {
    label: "Sailing",
    slug: "sailing",
    i18n: "cat.sailing",
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3L4 19h16L12 3z"/><path stroke-linecap="round" d="M12 3v16"/></svg>`,
  },
  {
    label: "Motor",
    slug: "motor",
    i18n: "cat.motor",
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17h18M5 17l2-7h10l2 7"/><circle cx="12" cy="13" r="1.5"/></svg>`,
  },
  {
    label: "Catamaran",
    slug: "catamaran",
    i18n: "cat.catamaran",
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" d="M4 18h16M7 18V10l5-5 5 5v8"/><path stroke-linecap="round" d="M7 14h10"/></svg>`,
  },
  {
    label: "Yacht",
    slug: "yacht",
    i18n: "cat.yacht",
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 19c3-2 6-3 9-3s6 1 9 3"/><path stroke-linecap="round" d="M12 16V4"/><path d="M12 4l8 8H12" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    label: "Luxury",
    slug: "luxury",
    i18n: "cat.luxury",
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>`,
  },
  {
    label: "Party",
    slug: "party",
    i18n: "cat.party",
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2z"/></svg>`,
  },
];
---

<section id="categories" class="py-16 bg-surface" aria-labelledby="categories-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 id="categories-heading" class="text-2xl sm:text-3xl font-bold text-text mb-8" data-i18n="cat.title">
      Browse by category
    </h2>

    <!-- Desktop: grid -->
    <div class="hidden sm:grid sm:grid-cols-3 lg:grid-cols-6 gap-4">
      {categories.map((cat) => (
        <a
          href={l(`/boat-rental?type=${cat.slug}`)}
          class="flex flex-col items-center gap-3 rounded-xl bg-white border border-border p-6 hover:border-primary hover:shadow-md transition-all group"
        >
          <div class="text-text-muted group-hover:text-primary transition-colors" set:html={cat.icon} />
          <span class="text-sm font-semibold text-text group-hover:text-primary transition-colors" data-i18n={cat.i18n}>
            {cat.label}
          </span>
        </a>
      ))}
    </div>

    <!-- Mobile: carousel -->
    <div class="sm:hidden">
      <div
        id="cat-carousel"
        class="flex gap-3 overflow-x-auto snap-x snap-mandatory scrollbar-hide -mx-4 px-4 pb-2"
      >
        {categories.map((cat, i) => (
          <a
            href={l(`/boat-rental?type=${cat.slug}`)}
            class="cat-slide flex-shrink-0 snap-center flex flex-col items-center justify-center gap-3 rounded-xl bg-white border border-border p-5 w-[calc(50%-6px)] hover:border-primary hover:shadow-md transition-all group"
            data-index={i}
          >
            <div class="text-text-muted group-hover:text-primary transition-colors" set:html={cat.icon} />
            <span class="text-sm font-semibold text-text group-hover:text-primary transition-colors text-center" data-i18n={cat.i18n}>
              {cat.label}
            </span>
          </a>
        ))}
      </div>

      <!-- Dots -->
      <div id="cat-dots" class="flex justify-center gap-1.5 mt-4">
        {Array.from({ length: Math.ceil(categories.length / 2) }).map((_, i) => (
          <button
            class:list={[
              "cat-dot h-1.5 rounded-full transition-all duration-300",
              i === 0 ? "w-6 bg-primary" : "w-1.5 bg-gray-300",
            ]}
            data-page={i}
            aria-label={`Page ${i + 1}`}
          />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function initCatCarousel() {
    const carousel = document.getElementById("cat-carousel");
    const dots = document.querySelectorAll<HTMLButtonElement>(".cat-dot");
    if (!carousel || dots.length === 0) return;

    const totalPages = dots.length;

    function updateDots(activeIndex: number) {
      dots.forEach((dot, i) => {
        if (i === activeIndex) {
          dot.classList.remove("w-1.5", "bg-gray-300");
          dot.classList.add("w-6", "bg-primary");
        } else {
          dot.classList.remove("w-6", "bg-primary");
          dot.classList.add("w-1.5", "bg-gray-300");
        }
      });
    }

    // Scroll listener to detect current page
    let ticking = false;
    carousel.addEventListener("scroll", () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          const scrollLeft = carousel.scrollLeft;
          const maxScroll = carousel.scrollWidth - carousel.clientWidth;
          const progress = maxScroll > 0 ? scrollLeft / maxScroll : 0;
          const page = Math.round(progress * (totalPages - 1));
          updateDots(Math.min(page, totalPages - 1));
          ticking = false;
        });
        ticking = true;
      }
    });

    // Dot click to scroll
    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        const maxScroll = carousel.scrollWidth - carousel.clientWidth;
        const targetScroll = totalPages > 1 ? (i / (totalPages - 1)) * maxScroll : 0;
        carousel.scrollTo({ left: targetScroll, behavior: "smooth" });
      });
    });
  }

  // Run on page load and Astro navigation
  initCatCarousel();
  document.addEventListener("astro:after-swap", initCatCarousel);
</script>
