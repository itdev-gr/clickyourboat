---
const faqs = [
  {
    question: "How does booking work?",
    answer:
      "Browse our selection of boats, choose your dates and destination, and book instantly. You'll receive a confirmation email with all the details. The boat owner will contact you before your trip to arrange the handover.",
    questionKey: "faq.q1",
    answerKey: "faq.a1",
  },
  {
    question: "Do I need a license?",
    answer:
      "License requirements depend on the destination and boat type. Many locations offer boats that don't require a license, and you can always book with a professional skipper. Check the specific listing for requirements.",
    questionKey: "faq.q2",
    answerKey: "faq.a2",
  },
  {
    question: "What's included in the rental?",
    answer:
      "Each listing specifies what's included. Typically, the boat, safety equipment, and basic amenities are provided. Fuel, food, and port fees are usually extra. Some listings include a skipper, while others offer it as an add-on.",
    questionKey: "faq.q3",
    answerKey: "faq.a3",
  },
  {
    question: "What is the cancellation policy?",
    answer:
      "Our standard cancellation policy offers a full refund if cancelled 30 days before the trip, 50% refund for 15-30 days, and no refund within 15 days. Some owners offer flexible cancellation — look for the 'Flexible' badge on listings.",
    questionKey: "faq.q4",
    answerKey: "faq.a4",
  },
];
---

<section id="faq" class="py-20" aria-labelledby="faq-heading">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 id="faq-heading" class="text-3xl sm:text-4xl font-bold text-text" data-i18n="faq.title">
        Frequently asked questions
      </h2>
      <p class="mt-3 text-text-muted text-lg" data-i18n="faq.subtitle">
        Everything you need to know before setting sail
      </p>
    </div>

    <div class="space-y-3" role="list">
      {faqs.map((faq, index) => (
        <div
          class="border border-border rounded-xl overflow-hidden"
          role="listitem"
        >
          <button
            class="faq-toggle w-full flex items-center justify-between px-6 py-4 text-left hover:bg-surface/50 transition-colors focus:outline-none focus:ring-2 focus:ring-inset focus:ring-primary"
            aria-expanded="false"
            aria-controls={`faq-answer-${index}`}
            id={`faq-btn-${index}`}
          >
            <span class="font-semibold text-text pr-4" data-i18n={faq.questionKey}>{faq.question}</span>
            <svg
              class="faq-icon h-5 w-5 text-text-muted flex-shrink-0 transition-transform duration-200"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div
            id={`faq-answer-${index}`}
            role="region"
            aria-labelledby={`faq-btn-${index}`}
            class="faq-content hidden"
          >
            <div class="px-6 pb-5 text-sm text-text-muted leading-relaxed" data-i18n={faq.answerKey}>
              {faq.answer}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const toggles = document.querySelectorAll(".faq-toggle");

  toggles.forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      const contentId = toggle.getAttribute("aria-controls")!;
      const content = document.getElementById(contentId)!;
      const icon = toggle.querySelector(".faq-icon")!;

      // Close all others
      toggles.forEach((other) => {
        if (other !== toggle) {
          other.setAttribute("aria-expanded", "false");
          const otherId = other.getAttribute("aria-controls")!;
          document.getElementById(otherId)?.classList.add("hidden");
          other.querySelector(".faq-icon")?.classList.remove("rotate-180");
        }
      });

      // Toggle current
      toggle.setAttribute("aria-expanded", String(!expanded));
      content.classList.toggle("hidden");
      icon.classList.toggle("rotate-180");
    });

    // Keyboard support
    toggle.addEventListener("keydown", (e) => {
      const event = e as KeyboardEvent;
      if (event.key === "Enter" || event.key === " ") {
        event.preventDefault();
        (toggle as HTMLButtonElement).click();
      }
    });
  });
</script>
