---
import { localizeHref } from "../../lib/i18n-utils";

interface Props {
  lang?: string;
}

// Mosaic-style destination grid — matches Click&Boat's layout
const destinations = [
  {
    name: "Athens",
    country: "Greece",
    image: "https://images.unsplash.com/photo-1555993539-1732b0258235?w=600&q=80&auto=format",
    boats: 1240,
    href: "/boat-rental?location=athens",
    size: "large",
  },
  {
    name: "Saint-Tropez",
    country: "France",
    image: "https://images.unsplash.com/photo-1533104816931-20fa691ff6ca?w=600&q=80&auto=format",
    boats: 856,
    href: "/boat-rental?location=saint-tropez",
    size: "medium",
  },
  {
    name: "Split",
    country: "Croatia",
    image: "https://images.unsplash.com/photo-1592150621744-aca64f48394a?w=600&q=80&auto=format",
    boats: 1080,
    href: "/boat-rental?location=split",
    size: "medium",
  },
  {
    name: "Ibiza",
    country: "Spain",
    image: "https://images.unsplash.com/photo-1539037116277-4db20889f2d4?w=600&q=80&auto=format",
    boats: 920,
    href: "/boat-rental?location=ibiza",
    size: "medium",
  },
  {
    name: "Amalfi Coast",
    country: "Italy",
    image: "https://images.unsplash.com/photo-1534008897995-27a23e859048?w=600&q=80&auto=format",
    boats: 745,
    href: "/boat-rental?location=amalfi",
    size: "large",
  },
  {
    name: "Dubrovnik",
    country: "Croatia",
    image: "https://images.unsplash.com/photo-1555990538-1e6c53b44ce5?w=600&q=80&auto=format",
    boats: 680,
    href: "/boat-rental?location=dubrovnik",
    size: "medium",
  },
];

const { lang = "en" } = Astro.props;
const l = (href: string) => localizeHref(href, lang);
---

<section class="py-16 sm:py-20 bg-white" aria-labelledby="popular-dest-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-10">
      <h2 id="popular-dest-heading" class="text-2xl sm:text-3xl font-bold text-text">
        Popular destinations for boat rental
      </h2>
      <p class="mt-2 text-text-muted text-base">
        Explore our most popular locations and find the perfect boat
      </p>
    </div>

    <!-- Mosaic Grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 auto-rows-[200px] sm:auto-rows-[220px] lg:auto-rows-[240px]">
      {destinations.map((dest, i) => (
        <a
          href={dest.href}
          class:list={[
            "group relative overflow-hidden rounded-2xl block",
            i === 0 && "col-span-2 row-span-2",
            i === 4 && "col-span-2 row-span-1 lg:row-span-2",
          ]}
        >
          <img
            src={dest.image}
            alt={`Boat rental in ${dest.name}`}
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <p class="text-white/70 text-xs font-medium uppercase tracking-wider mb-0.5">{dest.country}</p>
            <h3 class="text-white font-bold text-lg sm:text-xl">{dest.name}</h3>
            <p class="text-white/80 text-sm mt-1">{dest.boats.toLocaleString()} boats</p>
          </div>
          <!-- Hover arrow -->
          <div class="absolute top-4 right-4 h-8 w-8 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/></svg>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-8 text-center">
      <a
        href={l("/destinations")}
        class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-primary-dark transition-colors"
      >
        View all destinations
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </a>
    </div>
  </div>
</section>
