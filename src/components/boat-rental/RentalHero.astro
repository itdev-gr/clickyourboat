---
import { localizeHref } from "../../lib/i18n-utils";

interface Props {
  lang?: string;
}

// Hero section with search — mirrors Click&Boat's boat rental page hero

const { lang = "en" } = Astro.props;
const l = (href: string) => localizeHref(href, lang);
---

<section class="relative bg-white">
  <!-- Hero Image -->
  <div class="relative h-[420px] sm:h-[480px] lg:h-[520px] overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1567899378494-47b22a2ae96a?w=1920&q=80&auto=format"
      alt="Boat rental on crystal clear waters"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/30 to-black/60"></div>

    <div class="relative z-10 flex flex-col items-center justify-center h-full text-center px-4">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-4 tracking-tight" data-i18n="nav.boat_rental">
        Boat Rental
      </h1>
      <p class="text-lg sm:text-xl text-white/90 max-w-2xl mb-2" data-i18n="rental_hero.subtitle">
        Find the perfect boat for your next adventure. Over 50,000 boats available in more than 600 destinations worldwide.
      </p>
    </div>
  </div>

  <!-- Search Bar — overlapping hero bottom -->
  <div class="mx-auto max-w-5xl px-4 -mt-10 relative z-20">
    <form
      action={l("/boat-rental")}
      method="get"
      class="bg-white rounded-2xl shadow-xl border border-gray-100 p-5 sm:p-6"
      role="search"
      aria-label="Search boats for rental"
    >
      <!-- Tabs -->
      <div class="flex gap-1 mb-5 border-b border-gray-100 pb-3">
        <button type="button" class="rental-tab px-4 py-2 text-sm font-semibold rounded-full bg-primary text-white transition-colors" data-tab="rental" data-i18n="rental_hero.boat_rentals">
          Boat rentals
        </button>
        <button type="button" class="rental-tab px-4 py-2 text-sm font-semibold rounded-full text-text-muted hover:bg-surface transition-colors" data-tab="experience" data-i18n="rental_hero.daily_experiences">
          Daily experiences
        </button>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 items-end">
        <!-- Location -->
        <div class="lg:col-span-1">
          <label for="rental-location" class="block text-xs font-semibold text-text-muted uppercase tracking-wide mb-1.5" data-i18n="rental_hero.where">Where</label>
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
            <input
              type="text"
              id="rental-location"
              name="location"
              placeholder="Destination"
              data-i18n-placeholder="rental_hero.destination_placeholder"
              class="w-full rounded-xl border border-gray-200 bg-surface pl-10 pr-4 py-3 text-sm text-text placeholder:text-text-muted/60 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
            />
          </div>
        </div>

        <!-- Start Date -->
        <div>
          <label for="rental-start" class="block text-xs font-semibold text-text-muted uppercase tracking-wide mb-1.5" data-i18n="rental_hero.start_date">Start date</label>
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
            <input type="date" id="rental-start" name="startDate" class="w-full rounded-xl border border-gray-200 bg-surface pl-10 pr-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
          </div>
        </div>

        <!-- End Date -->
        <div>
          <label for="rental-end" class="block text-xs font-semibold text-text-muted uppercase tracking-wide mb-1.5" data-i18n="rental_hero.end_date">End date</label>
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
            <input type="date" id="rental-end" name="endDate" class="w-full rounded-xl border border-gray-200 bg-surface pl-10 pr-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" />
          </div>
        </div>

        <!-- Boat Type -->
        <div>
          <label for="rental-type" class="block text-xs font-semibold text-text-muted uppercase tracking-wide mb-1.5" data-i18n="rental_hero.boat_type">Boat type</label>
          <select id="rental-type" name="type" class="w-full rounded-xl border border-gray-200 bg-surface px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent appearance-none">
            <option value="" data-i18n="rental_hero.all_types">All types</option>
            <option value="motorboat" data-i18n="rental_hero.motorboat">Motorboat</option>
            <option value="sailboat" data-i18n="rental_hero.sailboat">Sailboat</option>
            <option value="catamaran" data-i18n="rental_hero.catamaran">Catamaran</option>
            <option value="yacht" data-i18n="rental_hero.yacht">Yacht</option>
            <option value="rib" data-i18n="rental_hero.rib">RIB</option>
            <option value="houseboat" data-i18n="rental_hero.houseboat">Houseboat</option>
            <option value="jet-ski" data-i18n="rental_hero.jet_ski">Jet Ski</option>
          </select>
        </div>

        <!-- Search Button -->
        <div>
          <button
            type="submit"
            class="w-full rounded-xl bg-primary px-6 py-3 text-sm font-bold text-white hover:bg-primary-dark transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 flex items-center justify-center gap-2"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
            <span data-i18n="rental_hero.search">Search</span>
          </button>
        </div>
      </div>

      <!-- Quick filters row -->
      <div class="flex flex-wrap items-center gap-3 mt-4 pt-4 border-t border-gray-100">
        <span class="text-xs text-text-muted font-medium" data-i18n="rental_hero.popular">Popular:</span>
        <a href={l("/boat-rental?location=ibiza")} class="text-xs px-3 py-1.5 rounded-full border border-gray-200 text-text-muted hover:border-primary hover:text-primary transition-colors">Ibiza</a>
        <a href={l("/boat-rental?location=santorini")} class="text-xs px-3 py-1.5 rounded-full border border-gray-200 text-text-muted hover:border-primary hover:text-primary transition-colors">Santorini</a>
        <a href={l("/boat-rental?location=split")} class="text-xs px-3 py-1.5 rounded-full border border-gray-200 text-text-muted hover:border-primary hover:text-primary transition-colors">Split</a>
        <a href={l("/boat-rental?location=amalfi")} class="text-xs px-3 py-1.5 rounded-full border border-gray-200 text-text-muted hover:border-primary hover:text-primary transition-colors">Amalfi Coast</a>
        <a href={l("/boat-rental?location=athens")} class="text-xs px-3 py-1.5 rounded-full border border-gray-200 text-text-muted hover:border-primary hover:text-primary transition-colors">Athens</a>
        <a href={l("/boat-rental?location=dubrovnik")} class="text-xs px-3 py-1.5 rounded-full border border-gray-200 text-text-muted hover:border-primary hover:text-primary transition-colors">Dubrovnik</a>
      </div>
    </form>
  </div>
</section>

<script>
  // Tab switching
  const tabs = document.querySelectorAll(".rental-tab");
  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      tabs.forEach((t) => {
        t.classList.remove("bg-primary", "text-white");
        t.classList.add("text-text-muted");
      });
      tab.classList.add("bg-primary", "text-white");
      tab.classList.remove("text-text-muted");
    });
  });
</script>
