---
import type { BoatListing } from "../../lib/mock-boats";

interface Props {
  boat: BoatListing;
}

const { boat } = Astro.props;
---

<article class="bg-white rounded-xl border border-gray-200/80 overflow-hidden hover:shadow-lg transition-shadow duration-200 group">
  <!-- Image area -->
  <div class="relative aspect-[4/3] overflow-hidden bg-gray-100">
    <img
      src={boat.images[0]}
      alt={boat.title}
      class="h-full w-full object-cover"
      loading="lazy"
      decoding="async"
    />

    <!-- Carousel dots -->
    <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5">
      {boat.images.map((_, i) => (
        <span class:list={["h-2 w-2 rounded-full", i === 0 ? "bg-white" : "bg-white/50"]} />
      ))}
    </div>

    <!-- Top badges -->
    <div class="absolute top-3 left-3 flex gap-1.5">
      {boat.discountOffer && (
        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-pink text-white text-xs font-semibold">
          Discount offer
        </span>
      )}
      {boat.instantBooking && (
        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-gray-800 text-white text-xs font-semibold">
          <svg class="h-3 w-3 text-pink-light" fill="currentColor" viewBox="0 0 20 20"><path d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"/></svg>
          Instant booking
        </span>
      )}
    </div>

    <!-- Heart button -->
    <button
      class="absolute top-3 right-3 h-8 w-8 rounded-full bg-white/80 backdrop-blur-sm flex items-center justify-center hover:bg-white transition-colors"
      aria-label="Save to favorites"
    >
      <svg class="h-4 w-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
    </button>

    <!-- New badge -->
    {boat.isNew && (
      <div class="absolute top-3 right-3 flex items-center gap-1 text-xs font-semibold text-gray-700">
        <svg class="h-3.5 w-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        New
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="p-4">
    <!-- Location + Rating -->
    <div class="flex items-start justify-between gap-2 mb-1">
      <h3 class="text-sm font-semibold text-text truncate">{boat.location}</h3>
      {boat.rating > 0 && (
        <div class="flex items-center gap-1 flex-shrink-0">
          <svg class="h-3.5 w-3.5 text-pink" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <span class="text-xs font-semibold text-text">{boat.rating}</span>
          <span class="text-xs text-text-muted">({boat.reviewCount})</span>
        </div>
      )}
    </div>

    <!-- Title -->
    <p class="text-xs text-text-muted truncate mb-2.5">{boat.title}</p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-1.5 mb-2.5">
      {boat.tags.map((tag) => (
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-gray-50 border border-gray-200 text-[11px] text-text-muted">
          {tag.icon === "skipper" && (
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4m-7.07-3.93l2.83-2.83m8.48-8.48l2.83-2.83M2 12h4m12 0h4m-3.93 7.07l-2.83-2.83M6.76 6.76L3.93 3.93"/></svg>
          )}
          {tag.icon === "no-skipper" && (
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4m-7.07-3.93l2.83-2.83m8.48-8.48l2.83-2.83M2 12h4m12 0h4m-3.93 7.07l-2.83-2.83M6.76 6.76L3.93 3.93"/></svg>
          )}
          {tag.icon === "no-licence" && (
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4"/></svg>
          )}
          {tag.icon === "boat-type" && (
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 17h18M5 17l2-7h10l2 7"/></svg>
          )}
          {tag.icon === "super-owner" && (
            <span class="text-pink">🌸</span>
          )}
          {tag.label}
        </span>
      ))}
    </div>

    <!-- Specs -->
    <p class="text-xs text-text-muted mb-3">{boat.specs}</p>

    <!-- Perks + Price -->
    <div class="flex items-end justify-between border-t border-gray-100 pt-3">
      <div class="space-y-0.5">
        {boat.perks.includes("fuel") && (
          <p class="text-xs text-green-600 flex items-center gap-1">
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Fuel included
          </p>
        )}
        {boat.perks.includes("free-cancel") && (
          <p class="text-xs text-green-600 flex items-center gap-1">
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Free cancellation
          </p>
        )}
        {boat.perks.includes("flexible-cancel") && (
          <p class="text-xs text-green-600 flex items-center gap-1">
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Flexible cancellation
          </p>
        )}
      </div>
      <div class="text-right">
        <span class="text-[11px] text-text-muted">From</span>
        <span class="text-base font-bold text-text ml-1">€{boat.price.toLocaleString()}</span>
        {boat.priceUnit && <span class="text-xs text-text-muted"> {boat.priceUnit}</span>}
      </div>
    </div>
  </div>
</article>
