---
// FAQ accordion — matches Click&Boat's comprehensive FAQ section
const faqs = [
  {
    question: "How does boat rental work on TapYourBoat?",
    answer: "Renting a boat on TapYourBoat is simple. Search for a boat by destination, dates, and type. Browse listings, read reviews, and send a booking request to the owner. Once accepted, pay securely online and you're all set. Meet the owner at the marina on your rental day and enjoy your time on the water.",
  },
  {
    question: "What types of boats are available for rent?",
    answer: "We offer a wide variety of boats including motorboats, sailboats, catamarans, yachts, RIBs (rigid inflatable boats), houseboats, jet skis, and gulets. Whether you're looking for a small boat for a day trip or a luxury yacht for a week-long charter, you'll find it on TapYourBoat.",
  },
  {
    question: "Do I need a boating license to rent a boat?",
    answer: "License requirements vary by destination and boat type. Many locations offer boats that don't require a license, especially smaller motorboats and RIBs. For larger vessels, you may need a valid boating license. You can also hire a professional skipper who will navigate for you — no license needed on your part.",
  },
  {
    question: "How much does it cost to rent a boat?",
    answer: "Prices vary depending on the boat type, size, location, and season. Small motorboats start from around €100/day, while luxury yachts can cost several thousand per day. Many owners offer weekly discounts. Fuel costs are typically not included and are paid separately.",
  },
  {
    question: "What is included in the rental price?",
    answer: "The rental price generally includes the boat, basic safety equipment (life jackets, fire extinguisher), and standard amenities. Some listings include a skipper, fuel, or water toys. Extras like fuel, food, drinks, port fees, and cleaning are usually additional. Each listing clearly shows what's included.",
  },
  {
    question: "Can I rent a boat with a skipper?",
    answer: "Yes! Many boats on TapYourBoat are available with a professional skipper. This is a great option if you don't have a license, want to relax, or want a local guide to show you the best spots. You can filter search results to show only boats with skipper available.",
  },
  {
    question: "What should I pack for a boat trip?",
    answer: "We recommend bringing sunscreen, sunglasses, a hat, non-marking shoes (soft-soled), a light jacket for wind, swimwear, towels, and any personal medications. For multi-day charters, pack light — storage on boats is limited. The boat owner will advise on any specific items needed.",
  },
  {
    question: "What is the cancellation policy?",
    answer: "Cancellation policies vary by listing. Our standard policy offers a full refund if cancelled 30 days before departure, 50% refund for 15-30 days, and no refund within 15 days. Some owners offer flexible cancellation. Check the specific listing for details before booking.",
  },
  {
    question: "Is insurance included?",
    answer: "Yes, all rentals on TapYourBoat include basic insurance coverage for both the renter and the boat. This covers damage and liability during your rental period. Additional comprehensive insurance options are available at checkout for extra peace of mind.",
  },
];
---

<section class="py-16 sm:py-20 bg-surface" aria-labelledby="rental-faq-heading">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 id="rental-faq-heading" class="text-2xl sm:text-3xl font-bold text-text">
        Frequently asked questions about boat rental
      </h2>
      <p class="mt-2 text-text-muted text-base">
        Everything you need to know before renting a boat
      </p>
    </div>

    <div class="space-y-3" role="list">
      {faqs.map((faq, index) => (
        <div
          class="bg-white border border-gray-100 rounded-xl overflow-hidden"
          role="listitem"
        >
          <button
            class="rental-faq-toggle w-full flex items-center justify-between px-6 py-4 text-left hover:bg-surface/50 transition-colors focus:outline-none focus:ring-2 focus:ring-inset focus:ring-primary"
            aria-expanded="false"
            aria-controls={`rental-faq-${index}`}
          >
            <span class="font-semibold text-sm sm:text-base text-text pr-4">{faq.question}</span>
            <svg
              class="rental-faq-icon h-5 w-5 text-text-muted flex-shrink-0 transition-transform duration-200"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div
            id={`rental-faq-${index}`}
            class="rental-faq-content hidden"
          >
            <div class="px-6 pb-5 text-sm text-text-muted leading-relaxed">
              {faq.answer}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const toggles = document.querySelectorAll(".rental-faq-toggle");

  toggles.forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      const contentId = toggle.getAttribute("aria-controls")!;
      const content = document.getElementById(contentId)!;
      const icon = toggle.querySelector(".rental-faq-icon")!;

      // Close all others
      toggles.forEach((other) => {
        if (other !== toggle) {
          other.setAttribute("aria-expanded", "false");
          const otherId = other.getAttribute("aria-controls")!;
          document.getElementById(otherId)?.classList.add("hidden");
          other.querySelector(".rental-faq-icon")?.classList.remove("rotate-180");
        }
      });

      toggle.setAttribute("aria-expanded", String(!expanded));
      content.classList.toggle("hidden");
      icon.classList.toggle("rotate-180");
    });
  });
</script>
