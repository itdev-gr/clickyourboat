---
// How it works — two panels for Renter & Owner like Click&Boat
const renterSteps = [
  {
    step: "1",
    title: "Search & Compare",
    description: "Browse thousands of boats by destination, type, and date. Compare prices and read reviews from verified guests.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>`,
  },
  {
    step: "2",
    title: "Book & Message",
    description: "Send a booking request to the owner. Chat directly to ask questions and arrange details for your trip.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z"/></svg>`,
  },
  {
    step: "3",
    title: "Pay & Enjoy",
    description: "Pay securely online. Meet the owner at the marina, board your boat, and enjoy an unforgettable experience on the water.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
];

const ownerSteps = [
  {
    step: "1",
    title: "Create Your Listing",
    description: "Add your boat with photos, description, pricing, and availability calendar. It only takes a few minutes.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>`,
  },
  {
    step: "2",
    title: "Manage Rentals",
    description: "Receive booking requests, chat with renters, and manage your calendar. Accept or decline at your convenience.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>`,
  },
  {
    step: "3",
    title: "Earn Money",
    description: "Get paid securely after each rental. Track your earnings and grow your boat rental business effortlessly.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>`,
  },
];
---

<section class="py-16 sm:py-20 bg-white" aria-labelledby="how-it-works-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 id="how-it-works-heading" class="text-2xl sm:text-3xl font-bold text-text">
        How does it work?
      </h2>
      <p class="mt-2 text-text-muted text-base max-w-2xl mx-auto">
        Whether you're renting a boat or listing yours, we make it simple
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
      <!-- Renter Panel -->
      <div class="bg-surface rounded-2xl p-8 border border-gray-100">
        <div class="flex items-center gap-3 mb-8">
          <div class="h-10 w-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-text">For Renters</h3>
        </div>

        <div class="space-y-6">
          {renterSteps.map((s) => (
            <div class="flex gap-4">
              <div class="flex-shrink-0 h-10 w-10 rounded-full bg-primary text-white flex items-center justify-center text-sm font-bold">
                {s.step}
              </div>
              <div>
                <h4 class="font-semibold text-text mb-1">{s.title}</h4>
                <p class="text-sm text-text-muted leading-relaxed">{s.description}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8">
          <a href="/boat-rental" class="inline-flex items-center px-5 py-2.5 rounded-xl bg-primary text-white text-sm font-semibold hover:bg-primary-dark transition-colors">
            Find a boat
            <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>
      </div>

      <!-- Owner Panel -->
      <div class="bg-surface rounded-2xl p-8 border border-gray-100">
        <div class="flex items-center gap-3 mb-8">
          <div class="h-10 w-10 rounded-xl bg-accent/10 text-accent-dark flex items-center justify-center">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-text">For Owners</h3>
        </div>

        <div class="space-y-6">
          {ownerSteps.map((s) => (
            <div class="flex gap-4">
              <div class="flex-shrink-0 h-10 w-10 rounded-full bg-accent text-text flex items-center justify-center text-sm font-bold">
                {s.step}
              </div>
              <div>
                <h4 class="font-semibold text-text mb-1">{s.title}</h4>
                <p class="text-sm text-text-muted leading-relaxed">{s.description}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8">
          <a href="/list-your-boat" class="inline-flex items-center px-5 py-2.5 rounded-xl bg-accent text-text text-sm font-bold hover:bg-accent-dark transition-colors">
            List your boat
            <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
