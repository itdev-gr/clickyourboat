---
// Trust / safety / insurance banner — matches Click&Boat's "Navigate safely" section
---

<section class="py-14 bg-white border-y border-gray-100" aria-labelledby="trust-banner-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 id="trust-banner-heading" class="text-2xl sm:text-3xl font-bold text-text" data-i18n="trust_banner.title">
        Navigate safely with TapYourBoat
      </h2>
      <p class="mt-2 text-text-muted text-base max-w-xl mx-auto" data-i18n="trust_banner.subtitle">
        Your safety is our priority. Every trip is backed by comprehensive protection.
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
      <!-- Secure Payments -->
      <div class="flex flex-col items-center text-center group">
        <div class="h-14 w-14 rounded-2xl bg-green-50 text-green-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
        </div>
        <h3 class="text-sm font-bold text-text mb-1" data-i18n="trust_banner.secure_title">Secure Payments</h3>
        <p class="text-xs text-text-muted leading-relaxed" data-i18n="trust_banner.secure_desc_full">All transactions are encrypted and fully protected</p>
      </div>

      <!-- Verified Boats -->
      <div class="flex flex-col items-center text-center group">
        <div class="h-14 w-14 rounded-2xl bg-blue-50 text-primary flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>
        </div>
        <h3 class="text-sm font-bold text-text mb-1" data-i18n="trust_banner.verified_title">Verified Boats</h3>
        <p class="text-xs text-text-muted leading-relaxed" data-i18n="trust_banner.verified_desc_full">Every listing is checked for quality and safety</p>
      </div>

      <!-- 24/7 Support -->
      <div class="flex flex-col items-center text-center group">
        <div class="h-14 w-14 rounded-2xl bg-purple-50 text-purple-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>
        </div>
        <h3 class="text-sm font-bold text-text mb-1" data-i18n="trust_banner.support_title">24/7 Support</h3>
        <p class="text-xs text-text-muted leading-relaxed" data-i18n="trust_banner.support_desc_full">Our team is available around the clock to help</p>
      </div>

      <!-- Insurance -->
      <div class="flex flex-col items-center text-center group">
        <div class="h-14 w-14 rounded-2xl bg-amber-50 text-amber-600 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
          <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.249-8.25-3.286zm0 13.036h.008v.008H12v-.008z"/></svg>
        </div>
        <h3 class="text-sm font-bold text-text mb-1" data-i18n="trust_banner.insurance_title">Insurance Coverage</h3>
        <p class="text-xs text-text-muted leading-relaxed" data-i18n="trust_banner.insurance_desc_full">Comprehensive protection on every trip</p>
      </div>
    </div>
  </div>
</section>
