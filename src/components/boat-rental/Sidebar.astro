---
// Left sidebar filters — fully functional filter panel
const boatTypeOptions = [
  { label: "Motor", value: "motor" },
  { label: "Sailing", value: "sailing" },
  { label: "Catamaran", value: "catamaran" },
  { label: "Yacht", value: "yacht" },
  { label: "Luxury", value: "luxury" },
  { label: "Party", value: "party" },
];

const idealForOptions = [
  "Wakeboard and water skis",
  "Water-based activities",
  "Unique experience",
  "Fishing",
  "Events",
];

const equipmentOptions = [
  "Wakeboard",
  "Towable Tube",
  "Watermaker",
  "Generator",
  "Air Conditioning",
  "External speakers",
  "Paddle board",
];
---

<aside class="w-full lg:w-[280px] flex-shrink-0 filter-sidebar" aria-label="Filters">
  <div class="sticky top-20 space-y-6">
    <!-- Tabs: Boat Rentals / Daily experiences -->
    <div class="border border-gray-200 rounded-xl overflow-hidden">
      <div class="grid grid-cols-2">
        <button class="sidebar-tab px-4 py-3 text-left border-b-2 border-pink bg-white" data-tab="rentals">
          <span class="block text-sm font-bold text-pink">Boat Rentals</span>
          <span class="block text-xs text-text-muted">All boat rentals</span>
        </button>
        <button class="sidebar-tab px-4 py-3 text-left border-b-2 border-transparent bg-gray-50 hover:bg-white transition-colors" data-tab="experiences">
          <span class="block text-sm font-bold text-text">Daily experiences</span>
          <span class="block text-xs text-text-muted">Activities with captain</span>
        </button>
      </div>
    </div>

    <!-- Where / Dates / Rental type -->
    <div class="border border-gray-200 rounded-xl divide-y divide-gray-200">
      <!-- Where -->
      <div class="px-4 py-3">
        <div class="flex items-center gap-3 mb-2">
          <svg class="h-5 w-5 text-text-muted flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
          <p class="text-sm font-semibold text-text">Where</p>
        </div>
        <input
          type="text"
          class="filter-location w-full px-3 py-2 rounded-lg border border-gray-200 text-sm text-text placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-pink focus:border-transparent"
          placeholder="City or harbour..."
        />
      </div>
      <!-- Dates -->
      <div class="px-4 py-3">
        <div class="flex items-center gap-3 mb-2">
          <svg class="h-5 w-5 text-text-muted flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
          <p class="text-sm font-semibold text-text">Dates</p>
        </div>
        <div class="grid grid-cols-2 gap-2">
          <input
            type="date"
            class="filter-date-start w-full px-3 py-2 rounded-lg border border-gray-200 text-sm text-text focus:outline-none focus:ring-2 focus:ring-pink focus:border-transparent"
          />
          <input
            type="date"
            class="filter-date-end w-full px-3 py-2 rounded-lg border border-gray-200 text-sm text-text focus:outline-none focus:ring-2 focus:ring-pink focus:border-transparent"
          />
        </div>
        <p class="text-[10px] text-text-muted mt-1">Boats available for your chosen period</p>
      </div>
      <!-- Rental type -->
      <div class="px-4 py-3">
        <div class="flex items-center gap-3 mb-2">
          <svg class="h-5 w-5 text-text-muted flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4m-7.07-3.93l2.83-2.83m8.48-8.48l2.83-2.83M2 12h4m12 0h4m-3.93 7.07l-2.83-2.83M6.76 6.76L3.93 3.93"/></svg>
          <p class="text-sm font-semibold text-text">Rental type</p>
        </div>
        <div class="space-y-2">
          <label class="flex items-center gap-2.5 cursor-pointer group">
            <input type="radio" name="rental-type" value="all" class="filter-rental-type h-4 w-4 border-gray-300 text-pink focus:ring-pink" checked />
            <span class="text-sm text-text group-hover:text-text">All</span>
          </label>
          <label class="flex items-center gap-2.5 cursor-pointer group">
            <input type="radio" name="rental-type" value="with-skipper" class="filter-rental-type h-4 w-4 border-gray-300 text-pink focus:ring-pink" />
            <span class="text-sm text-text group-hover:text-text">With skipper</span>
          </label>
          <label class="flex items-center gap-2.5 cursor-pointer group">
            <input type="radio" name="rental-type" value="without-skipper" class="filter-rental-type h-4 w-4 border-gray-300 text-pink focus:ring-pink" />
            <span class="text-sm text-text group-hover:text-text">Without skipper</span>
          </label>
          <label class="flex items-center gap-2.5 cursor-pointer group">
            <input type="radio" name="rental-type" value="no-licence" class="filter-rental-type h-4 w-4 border-gray-300 text-pink focus:ring-pink" />
            <span class="text-sm text-text group-hover:text-text">No licence required</span>
          </label>
        </div>
      </div>
    </div>

    <!-- Boat type -->
    <div>
      <h3 class="text-sm font-bold text-text mb-3">Boat type</h3>
      <div class="space-y-2.5">
        {boatTypeOptions.map((opt) => (
          <label class="flex items-center gap-2.5 cursor-pointer group">
            <input type="checkbox" class="filter-boat-type h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" data-filter-value={opt.value} />
            <span class="text-sm text-text group-hover:text-text">{opt.label}</span>
          </label>
        ))}
      </div>
    </div>

    <!-- Price per day -->
    <div>
      <h3 class="text-sm font-bold text-text mb-3">Price per day</h3>
      <div class="px-1">
        <div class="flex items-center gap-3">
          <input
            type="range"
            min="0"
            max="1200"
            value="0"
            class="filter-price-min w-full accent-pink h-1"
          />
        </div>
        <div class="flex items-center gap-2 mt-3">
          <div class="flex items-center border border-gray-200 rounded-lg px-3 py-1.5 flex-1">
            <span class="text-xs text-text-muted mr-1">Min</span>
            <input type="number" class="filter-price-min-input w-full text-xs text-text bg-transparent outline-none" value="0" min="0" max="1200" />
          </div>
          <span class="text-text-muted text-xs">-</span>
          <div class="flex items-center border border-gray-200 rounded-lg px-3 py-1.5 flex-1">
            <span class="text-xs text-text-muted mr-1">Max</span>
            <input type="number" class="filter-price-max-input w-full text-xs text-text bg-transparent outline-none" value="1200" min="0" max="1200" />
          </div>
        </div>
        <div class="flex items-center gap-3 mt-2">
          <input
            type="range"
            min="0"
            max="1200"
            value="1200"
            class="filter-price-max w-full accent-pink h-1"
          />
        </div>
        <div class="flex justify-between mt-1">
          <span class="filter-price-min-label text-xs text-text-muted">&euro; 0</span>
          <span class="filter-price-max-label text-xs text-text-muted">&euro; 1200+</span>
        </div>
      </div>
    </div>

    <!-- Number steppers -->
    <div class="flex items-center justify-between">
      <span class="text-sm font-bold text-text">Number of people</span>
      <div class="flex items-center gap-2">
        <button class="stepper-btn h-8 w-8 rounded-full border border-gray-300 flex items-center justify-center text-text-muted hover:border-gray-400 transition-colors" data-stepper="people" data-dir="down" aria-label="Decrease people">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M5 12h14"/></svg>
        </button>
        <span class="stepper-value text-sm font-semibold text-text w-5 text-center" data-stepper="people">1</span>
        <button class="stepper-btn h-8 w-8 rounded-full border border-gray-300 flex items-center justify-center text-text-muted hover:border-gray-400 transition-colors" data-stepper="people" data-dir="up" aria-label="Increase people">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 5v14m-7-7h14"/></svg>
        </button>
      </div>
    </div>

    <div class="flex items-center justify-between">
      <span class="text-sm font-bold text-text">Number of cabins</span>
      <div class="flex items-center gap-2">
        <button class="stepper-btn h-8 w-8 rounded-full border border-gray-300 flex items-center justify-center text-text-muted hover:border-gray-400 transition-colors" data-stepper="cabins" data-dir="down" aria-label="Decrease cabins">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M5 12h14"/></svg>
        </button>
        <span class="stepper-value text-sm font-semibold text-text w-5 text-center" data-stepper="cabins">0</span>
        <button class="stepper-btn h-8 w-8 rounded-full border border-gray-300 flex items-center justify-center text-text-muted hover:border-gray-400 transition-colors" data-stepper="cabins" data-dir="up" aria-label="Increase cabins">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 5v14m-7-7h14"/></svg>
        </button>
      </div>
    </div>

    <div class="flex items-center justify-between">
      <span class="text-sm font-bold text-text">Number of berths</span>
      <div class="flex items-center gap-2">
        <button class="stepper-btn h-8 w-8 rounded-full border border-gray-300 flex items-center justify-center text-text-muted hover:border-gray-400 transition-colors" data-stepper="berths" data-dir="down" aria-label="Decrease berths">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M5 12h14"/></svg>
        </button>
        <span class="stepper-value text-sm font-semibold text-text w-5 text-center" data-stepper="berths">0</span>
        <button class="stepper-btn h-8 w-8 rounded-full border border-gray-300 flex items-center justify-center text-text-muted hover:border-gray-400 transition-colors" data-stepper="berths" data-dir="up" aria-label="Increase berths">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 5v14m-7-7h14"/></svg>
        </button>
      </div>
    </div>

    <!-- Boat length -->
    <div>
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-bold text-text">Boat length</h3>
        <span class="filter-length-label text-xs text-text-muted">0 - 15+ m</span>
      </div>
      <input type="range" min="0" max="15" value="15" class="filter-length w-full accent-pink h-1" />
    </div>

    <!-- Engine power -->
    <div>
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-bold text-text">Engine power</h3>
        <span class="filter-engine-label text-xs text-text-muted">0 - 400+ hp</span>
      </div>
      <input type="range" min="0" max="400" value="400" class="filter-engine w-full accent-pink h-1" />
    </div>

    <!-- Toggles -->
    <div class="space-y-4">
      <!-- Super Owners -->
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="text-sm font-bold text-text">Super Owners</p>
          <p class="text-xs text-text-muted">Rent from well-reputed boat owners</p>
        </div>
        <button class="filter-toggle relative h-6 w-11 rounded-full bg-gray-200 transition-colors flex-shrink-0" role="switch" aria-checked="false" data-filter-toggle="superOwner">
          <span class="absolute top-0.5 left-0.5 h-5 w-5 rounded-full bg-white shadow transition-transform"></span>
        </button>
      </div>

      <!-- Instant booking -->
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="text-sm font-bold text-text">Instant booking</p>
          <p class="text-xs text-text-muted">Book without waiting for owner's confirmation</p>
        </div>
        <button class="filter-toggle relative h-6 w-11 rounded-full bg-gray-200 transition-colors flex-shrink-0" role="switch" aria-checked="false" data-filter-toggle="instantBooking">
          <span class="absolute top-0.5 left-0.5 h-5 w-5 rounded-full bg-white shadow transition-transform"></span>
        </button>
      </div>
    </div>

    <hr class="border-gray-200" />

    <!-- Ideal for -->
    <div>
      <h3 class="text-sm font-bold text-text mb-3">Ideal for</h3>
      <div class="space-y-2.5">
        {idealForOptions.map((item) => (
          <label class="flex items-center gap-2.5 cursor-pointer group">
            <input type="checkbox" class="filter-ideal-for h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" data-filter-value={item} />
            <span class="text-sm text-text group-hover:text-text">{item}</span>
          </label>
        ))}
      </div>
    </div>

    <!-- Equipment -->
    <div>
      <h3 class="text-sm font-bold text-text mb-3">Equipment</h3>
      <div class="space-y-2.5">
        {equipmentOptions.map((item) => (
          <label class="flex items-center gap-2.5 cursor-pointer group">
            <input type="checkbox" class="filter-equipment h-4 w-4 rounded border-gray-300 text-pink focus:ring-pink" data-filter-value={item} />
            <span class="text-sm text-text group-hover:text-text">{item}</span>
          </label>
        ))}
      </div>
    </div>

    <hr class="border-gray-200" />

    <!-- Free cancellation -->
    <div class="flex items-start justify-between gap-3">
      <div>
        <p class="text-sm font-bold text-text">Free cancellation</p>
        <p class="text-xs text-text-muted">Refunds possible up to 24 hours before departure</p>
      </div>
      <button class="filter-toggle relative h-6 w-11 rounded-full bg-gray-200 transition-colors flex-shrink-0" role="switch" aria-checked="false" data-filter-toggle="freeCancel">
        <span class="absolute top-0.5 left-0.5 h-5 w-5 rounded-full bg-white shadow transition-transform"></span>
      </button>
    </div>

    <!-- Best rated -->
    <div class="flex items-start justify-between gap-3">
      <div>
        <p class="text-sm font-bold text-text flex items-center gap-1">
          Best rated
          <svg class="h-3.5 w-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        </p>
        <p class="text-xs text-text-muted">Only display boats with a rating over 4 stars</p>
      </div>
      <button class="filter-toggle relative h-6 w-11 rounded-full bg-gray-200 transition-colors flex-shrink-0" role="switch" aria-checked="false" data-filter-toggle="bestRated">
        <span class="absolute top-0.5 left-0.5 h-5 w-5 rounded-full bg-white shadow transition-transform"></span>
      </button>
    </div>

    <!-- Year of manufacture -->
    <div>
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-bold text-text">Year of manufacture</h3>
        <span class="filter-year-label text-xs text-text-muted">2006 - 2026</span>
      </div>
      <input type="range" min="2006" max="2026" value="2006" class="filter-year w-full accent-pink h-1" />
    </div>

    <!-- Reset filters -->
    <button class="filter-reset w-full py-2.5 rounded-lg border border-gray-200 text-sm font-semibold text-text-muted hover:border-gray-400 hover:text-text transition-colors">
      Reset all filters
    </button>
  </div>
</aside>

<script>
  // Tab switching
  const tabs = document.querySelectorAll(".sidebar-tab");
  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      tabs.forEach((t) => {
        t.classList.remove("border-pink", "bg-white");
        t.classList.add("border-transparent", "bg-gray-50");
        const label = t.querySelector("span:first-child")!;
        label.classList.remove("text-pink");
        label.classList.add("text-text");
      });
      tab.classList.add("border-pink", "bg-white");
      tab.classList.remove("border-transparent", "bg-gray-50");
      const label = tab.querySelector("span:first-child")!;
      label.classList.add("text-pink");
      label.classList.remove("text-text");
    });
  });

  // Toggle switches (visual + dispatch event)
  const toggles = document.querySelectorAll(".filter-toggle");
  toggles.forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const checked = toggle.getAttribute("aria-checked") === "true";
      toggle.setAttribute("aria-checked", String(!checked));
      const knob = toggle.querySelector("span")!;
      if (!checked) {
        toggle.classList.remove("bg-gray-200");
        toggle.classList.add("bg-pink");
        knob.classList.add("translate-x-5");
      } else {
        toggle.classList.add("bg-gray-200");
        toggle.classList.remove("bg-pink");
        knob.classList.remove("translate-x-5");
      }
      document.dispatchEvent(new CustomEvent("filters-changed"));
    });
  });

  // Checkboxes
  document.querySelectorAll(".filter-boat-type, .filter-ideal-for, .filter-equipment").forEach((cb) => {
    cb.addEventListener("change", () => {
      document.dispatchEvent(new CustomEvent("filters-changed"));
    });
  });

  // Location search
  document.querySelectorAll(".filter-location").forEach((input) => {
    input.addEventListener("input", () => {
      document.dispatchEvent(new CustomEvent("filters-changed"));
    });
  });

  // Date inputs
  document.querySelectorAll(".filter-date-start, .filter-date-end").forEach((input) => {
    // Set min to today
    (input as HTMLInputElement).min = new Date().toISOString().split("T")[0];
    input.addEventListener("change", () => {
      document.dispatchEvent(new CustomEvent("filters-changed"));
    });
  });

  // Rental type radios
  document.querySelectorAll(".filter-rental-type").forEach((radio) => {
    radio.addEventListener("change", () => {
      document.dispatchEvent(new CustomEvent("filters-changed"));
    });
  });

  // Price range sliders + inputs
  function syncPriceFilters(sidebar: Element) {
    const minSlider = sidebar.querySelector(".filter-price-min") as HTMLInputElement;
    const maxSlider = sidebar.querySelector(".filter-price-max") as HTMLInputElement;
    const minInput = sidebar.querySelector(".filter-price-min-input") as HTMLInputElement;
    const maxInput = sidebar.querySelector(".filter-price-max-input") as HTMLInputElement;
    const minLabel = sidebar.querySelector(".filter-price-min-label");
    const maxLabel = sidebar.querySelector(".filter-price-max-label");

    if (!minSlider || !maxSlider) return;

    function update() {
      if (minLabel) minLabel.textContent = "\u20AC " + minSlider.value;
      if (maxLabel) maxLabel.textContent = "\u20AC " + maxSlider.value + (parseInt(maxSlider.value) >= 1200 ? "+" : "");
      if (minInput) minInput.value = minSlider.value;
      if (maxInput) maxInput.value = maxSlider.value;
      document.dispatchEvent(new CustomEvent("filters-changed"));
    }

    minSlider.addEventListener("input", update);
    maxSlider.addEventListener("input", update);

    if (minInput) minInput.addEventListener("change", () => {
      minSlider.value = minInput.value;
      update();
    });
    if (maxInput) maxInput.addEventListener("change", () => {
      maxSlider.value = maxInput.value;
      update();
    });
  }

  document.querySelectorAll(".filter-sidebar").forEach(syncPriceFilters);

  // Steppers
  document.querySelectorAll(".stepper-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const name = (btn as HTMLElement).dataset.stepper!;
      const dir = (btn as HTMLElement).dataset.dir!;
      // Find the value display in the same sidebar
      const sidebar = btn.closest(".filter-sidebar")!;
      const valueEl = sidebar.querySelector(`.stepper-value[data-stepper="${name}"]`)!;
      let val = parseInt(valueEl.textContent || "0");
      if (dir === "up") val++;
      else if (dir === "down" && val > 0) val--;
      valueEl.textContent = String(val);
      document.dispatchEvent(new CustomEvent("filters-changed"));
    });
  });

  // Range sliders (length, engine, year)
  document.querySelectorAll(".filter-length").forEach((slider) => {
    slider.addEventListener("input", () => {
      const val = (slider as HTMLInputElement).value;
      const label = slider.closest("div")?.querySelector(".filter-length-label");
      if (label) label.textContent = "0 - " + val + (parseInt(val) >= 15 ? "+" : "") + " m";
      document.dispatchEvent(new CustomEvent("filters-changed"));
    });
  });

  document.querySelectorAll(".filter-engine").forEach((slider) => {
    slider.addEventListener("input", () => {
      const val = (slider as HTMLInputElement).value;
      const label = slider.closest("div")?.querySelector(".filter-engine-label");
      if (label) label.textContent = "0 - " + val + (parseInt(val) >= 400 ? "+" : "") + " hp";
      document.dispatchEvent(new CustomEvent("filters-changed"));
    });
  });

  document.querySelectorAll(".filter-year").forEach((slider) => {
    slider.addEventListener("input", () => {
      const val = (slider as HTMLInputElement).value;
      const label = slider.closest("div")?.querySelector(".filter-year-label");
      if (label) label.textContent = val + " - 2026";
      document.dispatchEvent(new CustomEvent("filters-changed"));
    });
  });

  // Reset buttons
  document.querySelectorAll(".filter-reset").forEach((btn) => {
    btn.addEventListener("click", () => {
      // Reset all checkboxes
      document.querySelectorAll(".filter-boat-type, .filter-ideal-for, .filter-equipment").forEach((cb) => {
        (cb as HTMLInputElement).checked = false;
      });
      // Reset toggles
      document.querySelectorAll(".filter-toggle").forEach((t) => {
        t.setAttribute("aria-checked", "false");
        t.classList.add("bg-gray-200");
        t.classList.remove("bg-pink");
        const knob = t.querySelector("span")!;
        knob.classList.remove("translate-x-5");
      });
      // Reset steppers
      document.querySelectorAll(".stepper-value").forEach((el) => {
        const name = (el as HTMLElement).dataset.stepper;
        el.textContent = name === "people" ? "1" : "0";
      });
      // Reset sliders
      document.querySelectorAll(".filter-price-min").forEach((s) => { (s as HTMLInputElement).value = "0"; });
      document.querySelectorAll(".filter-price-max").forEach((s) => { (s as HTMLInputElement).value = "1200"; });
      document.querySelectorAll(".filter-price-min-input").forEach((s) => { (s as HTMLInputElement).value = "0"; });
      document.querySelectorAll(".filter-price-max-input").forEach((s) => { (s as HTMLInputElement).value = "1200"; });
      document.querySelectorAll(".filter-price-min-label").forEach((l) => { l.textContent = "\u20AC 0"; });
      document.querySelectorAll(".filter-price-max-label").forEach((l) => { l.textContent = "\u20AC 1200+"; });
      document.querySelectorAll(".filter-length").forEach((s) => { (s as HTMLInputElement).value = "15"; });
      document.querySelectorAll(".filter-length-label").forEach((l) => { l.textContent = "0 - 15+ m"; });
      document.querySelectorAll(".filter-engine").forEach((s) => { (s as HTMLInputElement).value = "400"; });
      document.querySelectorAll(".filter-engine-label").forEach((l) => { l.textContent = "0 - 400+ hp"; });
      document.querySelectorAll(".filter-year").forEach((s) => { (s as HTMLInputElement).value = "2006"; });
      document.querySelectorAll(".filter-year-label").forEach((l) => { l.textContent = "2006 - 2026"; });
      // Reset location
      document.querySelectorAll(".filter-location").forEach((s) => { (s as HTMLInputElement).value = ""; });
      // Reset dates
      document.querySelectorAll(".filter-date-start, .filter-date-end").forEach((s) => { (s as HTMLInputElement).value = ""; });
      // Reset rental type
      document.querySelectorAll(".filter-rental-type").forEach((r) => {
        (r as HTMLInputElement).checked = (r as HTMLInputElement).value === "all";
      });

      document.dispatchEvent(new CustomEvent("filters-changed"));
    });
  });
</script>
