---
// Customer testimonials — matches Click&Boat's review cards
const testimonials = [
  {
    name: "Maria S.",
    avatar: "MS",
    rating: 5,
    date: "September 2025",
    boat: "Beneteau Oceanis 45",
    location: "Ibiza, Spain",
    comment: "Absolutely incredible experience! The boat was in perfect condition and the skipper knew all the best hidden coves. We had the most magical sunset sailing experience. Will definitely book again!",
  },
  {
    name: "James W.",
    avatar: "JW",
    rating: 5,
    date: "August 2025",
    boat: "Lagoon 42",
    location: "Santorini, Greece",
    comment: "Best family holiday we've ever had. The catamaran was spacious, clean, and well-equipped. The kids absolutely loved it and the booking process through BoatHaven was seamless.",
  },
  {
    name: "Sophie L.",
    avatar: "SL",
    rating: 5,
    date: "October 2025",
    boat: "Jeanneau Cap Camarat 7.5",
    location: "Saint-Tropez, France",
    comment: "Perfect day on the water! The motorboat was exactly as described and the owner was incredibly helpful with recommendations for where to anchor and eat along the coast.",
  },
  {
    name: "Marco R.",
    avatar: "MR",
    rating: 5,
    date: "July 2025",
    boat: "Bavaria Cruiser 34",
    location: "Amalfi Coast, Italy",
    comment: "We sailed along the Amalfi Coast for 3 days. Unforgettable sunsets, hidden beaches, and the most amazing food in coastal villages. BoatHaven made everything so easy.",
  },
];

function renderStars(count: number): string {
  return Array.from({ length: 5 }, (_, i) =>
    i < count
      ? `<svg class="h-4 w-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>`
      : `<svg class="h-4 w-4 text-gray-200" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>`
  ).join("");
}
---

<section class="py-16 sm:py-20 bg-white" aria-labelledby="testimonials-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-10 gap-4">
      <div>
        <h2 id="testimonials-heading" class="text-2xl sm:text-3xl font-bold text-text">
          Fellow sailors share their amazing experiences
        </h2>
        <p class="mt-2 text-text-muted text-base">
          See what our community has to say about their trips
        </p>
      </div>
      <div class="flex items-center gap-2 flex-shrink-0">
        <div class="flex items-center gap-0.5" set:html={renderStars(5)} />
        <span class="text-sm font-bold text-text">4.9/5</span>
        <span class="text-sm text-text-muted">based on 12,400+ reviews</span>
      </div>
    </div>

    <!-- Testimonial Cards — horizontal scroll on mobile, grid on desktop -->
    <div class="flex gap-5 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide lg:grid lg:grid-cols-4 lg:overflow-visible lg:pb-0">
      {testimonials.map((t) => (
        <article class="flex-shrink-0 snap-start w-[300px] sm:w-[320px] lg:w-auto bg-surface rounded-2xl p-6 border border-gray-100">
          <!-- Header -->
          <div class="flex items-center gap-3 mb-4">
            <div class="h-10 w-10 rounded-full bg-primary/10 text-primary flex items-center justify-center text-sm font-bold">
              {t.avatar}
            </div>
            <div>
              <p class="font-semibold text-sm text-text">{t.name}</p>
              <p class="text-xs text-text-muted">{t.date}</p>
            </div>
          </div>

          <!-- Stars -->
          <div class="flex items-center gap-0.5 mb-3" set:html={renderStars(t.rating)} />

          <!-- Comment -->
          <p class="text-sm text-text-muted leading-relaxed mb-4 line-clamp-4">
            "{t.comment}"
          </p>

          <!-- Boat info -->
          <div class="pt-3 border-t border-gray-100">
            <p class="text-xs font-semibold text-text">{t.boat}</p>
            <p class="text-xs text-text-muted">{t.location}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
