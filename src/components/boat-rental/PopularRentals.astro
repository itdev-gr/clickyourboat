---
import { localizeHref } from "../../lib/i18n-utils";

interface Props {
  lang?: string;
}

// Popular rentals by country — link grid organized by region like Click&Boat
const regions = [
  {
    name: "Greece",
    flag: "🇬🇷",
    locations: [
      { name: "Athens", href: "/boat-rental/greece/athens" },
      { name: "Santorini", href: "/boat-rental/greece/santorini" },
      { name: "Mykonos", href: "/boat-rental/greece/mykonos" },
      { name: "Corfu", href: "/boat-rental/greece/corfu" },
      { name: "Rhodes", href: "/boat-rental/greece/rhodes" },
      { name: "Lefkada", href: "/boat-rental/greece/lefkada" },
    ],
  },
  {
    name: "Croatia",
    flag: "🇭🇷",
    locations: [
      { name: "Split", href: "/boat-rental/croatia/split" },
      { name: "Dubrovnik", href: "/boat-rental/croatia/dubrovnik" },
      { name: "Zadar", href: "/boat-rental/croatia/zadar" },
      { name: "Hvar", href: "/boat-rental/croatia/hvar" },
      { name: "Trogir", href: "/boat-rental/croatia/trogir" },
    ],
  },
  {
    name: "Spain",
    flag: "🇪🇸",
    locations: [
      { name: "Ibiza", href: "/boat-rental/spain/ibiza" },
      { name: "Mallorca", href: "/boat-rental/spain/mallorca" },
      { name: "Barcelona", href: "/boat-rental/spain/barcelona" },
      { name: "Menorca", href: "/boat-rental/spain/menorca" },
      { name: "Marbella", href: "/boat-rental/spain/marbella" },
      { name: "Tenerife", href: "/boat-rental/spain/tenerife" },
    ],
  },
  {
    name: "Italy",
    flag: "🇮🇹",
    locations: [
      { name: "Amalfi Coast", href: "/boat-rental/italy/amalfi" },
      { name: "Sardinia", href: "/boat-rental/italy/sardinia" },
      { name: "Naples", href: "/boat-rental/italy/naples" },
      { name: "Sicily", href: "/boat-rental/italy/sicily" },
      { name: "Lake Como", href: "/boat-rental/italy/lake-como" },
      { name: "Portofino", href: "/boat-rental/italy/portofino" },
    ],
  },
  {
    name: "France",
    flag: "🇫🇷",
    locations: [
      { name: "Saint-Tropez", href: "/boat-rental/france/saint-tropez" },
      { name: "Nice", href: "/boat-rental/france/nice" },
      { name: "Cannes", href: "/boat-rental/france/cannes" },
      { name: "Corsica", href: "/boat-rental/france/corsica" },
      { name: "Marseille", href: "/boat-rental/france/marseille" },
    ],
  },
  {
    name: "Turkey",
    flag: "🇹🇷",
    locations: [
      { name: "Bodrum", href: "/boat-rental/turkey/bodrum" },
      { name: "Fethiye", href: "/boat-rental/turkey/fethiye" },
      { name: "Göcek", href: "/boat-rental/turkey/gocek" },
      { name: "Marmaris", href: "/boat-rental/turkey/marmaris" },
      { name: "Antalya", href: "/boat-rental/turkey/antalya" },
    ],
  },
];

const { lang = "en" } = Astro.props;
const l = (href: string) => localizeHref(href, lang);
---

<section class="py-16 sm:py-20 bg-white" aria-labelledby="popular-rentals-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-10">
      <h2 id="popular-rentals-heading" class="text-2xl sm:text-3xl font-bold text-text">
        Popular boat rentals by destination
      </h2>
      <p class="mt-2 text-text-muted text-base">
        Find boats in the most popular sailing locations around the world
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-8">
      {regions.map((region) => (
        <div>
          <h3 class="font-bold text-text text-sm mb-3 flex items-center gap-1.5">
            <span class="text-base">{region.flag}</span>
            {region.name}
          </h3>
          <ul class="space-y-2">
            {region.locations.map((loc) => (
              <li>
                <a
                  href={loc.href}
                  class="text-sm text-text-muted hover:text-primary transition-colors"
                >
                  {loc.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-10 text-center">
      <a
        href={l("/destinations")}
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-gray-200 text-sm font-semibold text-text hover:border-primary hover:text-primary transition-colors"
      >
        View all destinations
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </a>
    </div>
  </div>
</section>
