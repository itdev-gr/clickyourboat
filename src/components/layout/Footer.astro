---
import { localizeHref } from "../../lib/i18n-utils";

interface Props {
  lang?: string;
}

const { lang = "en" } = Astro.props;
const l = (href: string) => localizeHref(href, lang);
const currentYear = new Date().getFullYear();

const columns = [
  {
    title: "Explore",
    i18n: "footer.explore",
    links: [
      { label: "Boat Rental", href: "/boat-rental", i18n: "footer.boat_rental" },
      { label: "Boat Types", href: "/boat-types", i18n: "footer.boat_types" },
      { label: "Charter Types", href: "/charter-types", i18n: "footer.charter_types" },
      { label: "Destinations", href: "/destinations", i18n: "footer.destinations" },
      { label: "Blog", href: "/blog", i18n: "footer.blog" },
    ],
  },
  {
    title: "For Owners",
    i18n: "footer.for_owners",
    links: [
      { label: "List Your Boat", href: "/list-your-boat", i18n: "footer.list_your_boat" },
      { label: "Dashboard", href: "/dashboard", i18n: "footer.dashboard" },
      { label: "My Offers", href: "/my-offers", i18n: "footer.my_offers" },
    ],
  },
  {
    title: "My Account",
    i18n: "footer.my_account",
    links: [
      { label: "My Bookings", href: "/bookings", i18n: "footer.my_bookings" },
{ label: "Favorites", href: "/favorites", i18n: "footer.favorites" },
      { label: "Account Settings", href: "/account", i18n: "footer.account_settings" },
    ],
  },
  {
    title: "Company",
    i18n: "footer.company",
    links: [
      { label: "Contact Us", href: "/contact", i18n: "footer.contact_us" },
      { label: "Terms of Service", href: "/terms", i18n: "footer.terms" },
      { label: "Privacy Policy", href: "/privacy", i18n: "footer.privacy" },
    ],
  },
];
---

<footer class="bg-text text-white" role="contentinfo">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-8 lg:gap-12">
      <!-- Brand + Newsletter -->
      <div class="col-span-2 md:col-span-4 lg:col-span-1">
        <a href={l("/")} class="flex items-center gap-2 text-white font-bold text-xl mb-4">
          <img src="/logo-white.svg" alt="TapYourBoat" class="h-8" />
        </a>
        <p class="text-sm text-slate-400 mb-6" data-i18n="footer.tagline">
          Find your perfect boat experience. Thousands of boats worldwide, ready for your next adventure.
        </p>

        <!-- Newsletter -->
        <form id="newsletter-form" class="space-y-3">
          <label for="newsletter-email" class="text-sm font-medium" data-i18n="footer.stay_updated">Stay updated</label>
          <div class="flex gap-2">
            <input
              type="email"
              id="newsletter-email"
              name="email"
              required
              placeholder="your@email.com"
              data-i18n-placeholder="footer.email_placeholder"
              class="flex-1 rounded-lg bg-white/10 border border-white/20 px-3 py-2 text-sm text-white placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-primary-light"
            />
            <button
              type="submit"
              class="px-4 py-2 rounded-lg bg-primary text-white text-sm font-semibold hover:bg-primary-light transition-colors focus:outline-none focus:ring-2 focus:ring-primary-light"
              data-i18n="footer.subscribe"
            >
              Subscribe
            </button>
          </div>
          <p id="newsletter-msg" class="text-xs text-slate-400 hidden"></p>
        </form>
      </div>

      <!-- Link Columns -->
      {columns.map((col) => (
        <div>
          <h3 class="text-sm font-semibold text-white mb-4" data-i18n={col.i18n}>{col.title}</h3>
          <ul class="space-y-3">
            {col.links.map((link) => (
              <li>
                <a
                  href={l(link.href)}
                  class="text-sm text-slate-400 hover:text-white transition-colors"
                  data-i18n={link.i18n}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-slate-500" data-i18n="footer.rights">
        &copy; {currentYear} TapYourBoat. All rights reserved.
      </p>
      <p class="text-sm text-slate-500">
        Powered by <a href="https://www.itdev.gr" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors">IT DEV</a>
      </p>
    </div>
  </div>
</footer>

<script>
  import { subscribeNewsletter } from "../../lib/api";

  const form = document.getElementById("newsletter-form") as HTMLFormElement;
  const msg = document.getElementById("newsletter-msg") as HTMLParagraphElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const email = formData.get("email") as string;

    // Client-side email validation
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      const t = (window as any).__i18n;
      msg.textContent = t ? t.translations["footer.email_error"]?.[t.getLang()] : "Please enter a valid email address.";
      msg.classList.remove("hidden", "text-green-400");
      msg.classList.add("text-red-400");
      return;
    }

    try {
      await subscribeNewsletter(email);
      const t2 = (window as any).__i18n;
      msg.textContent = t2 ? t2.translations["footer.email_success"]?.[t2.getLang()] : "Thanks for subscribing!";
      msg.classList.remove("hidden", "text-red-400");
      msg.classList.add("text-green-400");
      form.reset();
    } catch {
      const t3 = (window as any).__i18n;
      msg.textContent = t3 ? t3.translations["footer.email_fail"]?.[t3.getLang()] : "Something went wrong. Please try again.";
      msg.classList.remove("hidden", "text-green-400");
      msg.classList.add("text-red-400");
    }
  });
</script>
