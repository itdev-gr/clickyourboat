---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import { getLangFromParam, getAlternateLang } from "../lib/i18n-utils";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  fullHeight?: boolean;
  hideFooter?: boolean;
  lang?: string;
}

const {
  title = "TapYourBoat — Find Your Perfect Boat Experience",
  description = "Choose from thousands of boats worldwide. Sailing, motor, catamaran, and yacht rentals with or without skipper.",
  image = "/og-image.jpg",
  fullHeight = false,
  hideFooter = false,
  lang,
} = Astro.props;

const resolvedLang = getLangFromParam(lang);
const altLang = getAlternateLang(lang);
const pathname = Astro.url.pathname;
// Strip the current lang prefix to get the base path
const basePath = lang === "gr"
  ? pathname.replace(/^\/gr/, "") || "/"
  : pathname;
// Alternate URL: English↔Greek
const altHref = lang === "gr"
  ? `${basePath}${Astro.url.search}`
  : `/gr${basePath}${Astro.url.search}`;
const canonicalUrl = new URL(`${pathname}${Astro.url.search}`, Astro.site ?? "https://tapyourboat.com");
const enHref = new URL(`${basePath}${Astro.url.search}`, Astro.site ?? "https://tapyourboat.com");
const elHref = new URL(`/gr${basePath}${Astro.url.search}`, Astro.site ?? "https://tapyourboat.com");
---

<!doctype html>
<html lang={resolvedLang} data-lang-prefix={lang || ""}>
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2VK9VDFRY9"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-2VK9VDFRY9');
      gtag('config', 'AW-18045292626');
    </script>

    <script is:inline>
      (function() {
        var script = document.createElement('script');
        script.src = 'https://cbl.link/b/semTkLV.js';
        script.async = true;
        document.head.appendChild(script);
      })();
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="el" href={elHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="TapYourBoat" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <slot name="head" />

    <!-- i18n Engine -->
    <script>
      import { translations } from "../lib/i18n";
      type Lang = "en" | "el";

      function getLang(): Lang {
        return (document.documentElement.lang as Lang) || "en";
      }

      function applyTranslations(lang: Lang) {
        // Text content
        document.querySelectorAll("[data-i18n]").forEach((el) => {
          const key = el.getAttribute("data-i18n")!;
          const t = translations[key];
          if (t && t[lang]) el.textContent = t[lang];
        });
        // Force select elements to re-render after option text changes
        document.querySelectorAll("select").forEach((sel) => {
          const idx = (sel as HTMLSelectElement).selectedIndex;
          (sel as HTMLSelectElement).selectedIndex = idx;
        });
        // innerHTML (for strings with nested HTML)
        document.querySelectorAll("[data-i18n-html]").forEach((el) => {
          const key = el.getAttribute("data-i18n-html")!;
          const t = translations[key];
          if (t && t[lang]) el.innerHTML = t[lang];
        });
        // Placeholders
        document.querySelectorAll("[data-i18n-placeholder]").forEach((el) => {
          const key = el.getAttribute("data-i18n-placeholder")!;
          const t = translations[key];
          if (t && t[lang]) (el as HTMLInputElement).placeholder = t[lang];
        });
        // Aria labels
        document.querySelectorAll("[data-i18n-aria]").forEach((el) => {
          const key = el.getAttribute("data-i18n-aria")!;
          const t = translations[key];
          if (t && t[lang]) el.setAttribute("aria-label", t[lang]);
        });
      }

      // Apply on page load
      document.addEventListener("DOMContentLoaded", () => {
        const lang = getLang();
        applyTranslations(lang);
      });

      // Also apply immediately for fast rendering
      applyTranslations(getLang());

      // Re-apply after dynamic content loads
      document.addEventListener("boats-loaded", () => {
        applyTranslations(getLang());
      });

      // Expose for other scripts
      (window as any).__i18n = { getLang, applyTranslations, translations };
    </script>

    <!-- Preserve query params on language toggle links (static build has no access to URL params) -->
    <script>
      const search = window.location.search;
      if (search) {
        document.querySelectorAll<HTMLAnchorElement>("[data-lang-toggle]").forEach((a) => {
          const url = new URL(a.href, window.location.origin);
          // Replace the search portion with the current page's query string
          url.search = search;
          a.href = url.pathname + url.search;
        });
      }
    </script>
  </head>
  <body class:list={["flex flex-col", fullHeight ? "h-screen overflow-hidden" : "min-h-screen"]}>
    <Header lang={lang} />
    <main class:list={["flex-1", fullHeight && "min-h-0 overflow-hidden"]}>
      <slot />
    </main>
    {!hideFooter && <div class="flex-shrink-0"><Footer lang={lang} /></div>}

    <!-- Make the third-party WhatsApp widget draggable -->
    <script is:inline>
      (function () {
        const STORAGE_KEY = "tyb_whatsapp_pos";
        const DRAG_THRESHOLD = 5;
        const EDGE_PAD = 16;

        function readSaved() {
          try {
            const raw = localStorage.getItem(STORAGE_KEY);
            if (!raw) return null;
            const v = JSON.parse(raw);
            if (typeof v?.left === "number" && typeof v?.top === "number") return v;
          } catch (_) {}
          return null;
        }

        function writeSaved(pos) {
          try { localStorage.setItem(STORAGE_KEY, JSON.stringify(pos)); } catch (_) {}
        }

        function clamp(pos, w, h) {
          const maxL = Math.max(0, window.innerWidth - w);
          const maxT = Math.max(0, window.innerHeight - h);
          return {
            left: Math.min(maxL, Math.max(0, pos.left)),
            top: Math.min(maxT, Math.max(0, pos.top)),
          };
        }

        function attach(host) {
          const root = host.shadowRoot;
          if (!root) return false;
          const container = root.querySelector('[id^="button-tool-widget-"]');
          const button = container && container.querySelector("button");
          if (!container || !button) return false;

          const rect = container.getBoundingClientRect();
          const w = rect.width;
          const h = rect.height;

          const initial = readSaved() ?? {
            left: window.innerWidth - w - EDGE_PAD,
            top: window.innerHeight - h - EDGE_PAD,
          };
          const start = clamp(initial, w, h);
          container.style.right = "auto";
          container.style.bottom = "auto";
          container.style.left = start.left + "px";
          container.style.top = start.top + "px";

          button.style.touchAction = "none";

          let state = null;
          let suppressNextClick = false;

          button.addEventListener("click", (e) => {
            if (suppressNextClick) {
              e.preventDefault();
              e.stopPropagation();
              suppressNextClick = false;
            }
          }, true);

          button.addEventListener("pointerdown", (e) => {
            const r = container.getBoundingClientRect();
            state = {
              startX: e.clientX,
              startY: e.clientY,
              originLeft: r.left,
              originTop: r.top,
              pointerId: e.pointerId,
              dragging: false,
            };
            try { button.setPointerCapture(e.pointerId); } catch (_) {}
          });

          button.addEventListener("pointermove", (e) => {
            if (!state || e.pointerId !== state.pointerId) return;
            const dx = e.clientX - state.startX;
            const dy = e.clientY - state.startY;
            if (!state.dragging && Math.hypot(dx, dy) > DRAG_THRESHOLD) {
              state.dragging = true;
            }
            if (state.dragging) {
              e.preventDefault();
              const next = clamp(
                { left: state.originLeft + dx, top: state.originTop + dy },
                w, h
              );
              container.style.left = next.left + "px";
              container.style.top = next.top + "px";
            }
          });

          function end(e) {
            if (!state || e.pointerId !== state.pointerId) return;
            try { button.releasePointerCapture(state.pointerId); } catch (_) {}
            if (state.dragging) {
              suppressNextClick = true;
              const r = container.getBoundingClientRect();
              writeSaved({ left: r.left, top: r.top });
            }
            state = null;
          }
          button.addEventListener("pointerup", end);
          button.addEventListener("pointercancel", end);

          let resizeRaf = 0;
          window.addEventListener("resize", () => {
            if (resizeRaf) return;
            resizeRaf = requestAnimationFrame(() => {
              resizeRaf = 0;
              const r = container.getBoundingClientRect();
              const next = clamp({ left: r.left, top: r.top }, r.width, r.height);
              container.style.left = next.left + "px";
              container.style.top = next.top + "px";
            });
          });

          return true;
        }

        function tryAttach() {
          const host = document.querySelector("button-tool-widget");
          if (!host) return false;
          // Shadow root may not be populated yet — retry on next frame if attach fails.
          if (attach(host)) return true;
          requestAnimationFrame(() => attach(host));
          return true;
        }

        function init() {
          if (tryAttach()) return;
          const obs = new MutationObserver(() => {
            if (tryAttach()) obs.disconnect();
          });
          obs.observe(document.body, { childList: true, subtree: true });
        }

        if (window.customElements && customElements.whenDefined) {
          customElements.whenDefined("button-tool-widget").then(init).catch(() => init());
        } else {
          init();
        }
      })();
    </script>
  </body>
</html>
