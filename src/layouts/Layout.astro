---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  fullHeight?: boolean;
  hideFooter?: boolean;
}

const {
  title = "BoatHaven — Find Your Perfect Boat Experience",
  description = "Choose from thousands of boats worldwide. Sailing, motor, catamaran, and yacht rentals with or without skipper.",
  image = "/og-image.jpg",
  fullHeight = false,
  hideFooter = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "https://boathaven.com");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="BoatHaven" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <slot name="head" />

    <!-- i18n Engine -->
    <script>
      import { translations } from "../lib/i18n";
      type Lang = "en" | "el";

      function getLang(): Lang {
        return (localStorage.getItem("lang") as Lang) || "en";
      }

      function setLang(lang: Lang) {
        localStorage.setItem("lang", lang);
        document.documentElement.lang = lang;
        applyTranslations(lang);
        // Update toggle buttons
        document.querySelectorAll("[data-lang-toggle]").forEach((btn) => {
          btn.textContent = lang === "en" ? "EN" : "GR";
        });
      }

      function applyTranslations(lang: Lang) {
        // Text content
        document.querySelectorAll("[data-i18n]").forEach((el) => {
          const key = el.getAttribute("data-i18n")!;
          const t = translations[key];
          if (t && t[lang]) el.textContent = t[lang];
        });
        // innerHTML (for strings with nested HTML)
        document.querySelectorAll("[data-i18n-html]").forEach((el) => {
          const key = el.getAttribute("data-i18n-html")!;
          const t = translations[key];
          if (t && t[lang]) el.innerHTML = t[lang];
        });
        // Placeholders
        document.querySelectorAll("[data-i18n-placeholder]").forEach((el) => {
          const key = el.getAttribute("data-i18n-placeholder")!;
          const t = translations[key];
          if (t && t[lang]) (el as HTMLInputElement).placeholder = t[lang];
        });
        // Aria labels
        document.querySelectorAll("[data-i18n-aria]").forEach((el) => {
          const key = el.getAttribute("data-i18n-aria")!;
          const t = translations[key];
          if (t && t[lang]) el.setAttribute("aria-label", t[lang]);
        });
      }

      // Apply on page load
      document.addEventListener("DOMContentLoaded", () => {
        const lang = getLang();
        document.documentElement.lang = lang;
        applyTranslations(lang);
        document.querySelectorAll("[data-lang-toggle]").forEach((btn) => {
          btn.textContent = lang === "en" ? "EN" : "GR";
        });
      });

      // Also apply immediately for fast rendering
      const currentLang = getLang();
      document.documentElement.lang = currentLang;

      // Toggle handler
      document.addEventListener("click", (e) => {
        const btn = (e.target as Element).closest("[data-lang-toggle]");
        if (!btn) return;
        const current = getLang();
        const next: Lang = current === "en" ? "el" : "en";
        setLang(next);
      });

      // Re-apply after dynamic content loads
      document.addEventListener("boats-loaded", () => {
        applyTranslations(getLang());
      });

      // Expose for other scripts
      (window as any).__i18n = { getLang, setLang, applyTranslations, translations };
    </script>
  </head>
  <body class:list={["flex flex-col", fullHeight ? "h-screen overflow-hidden" : "min-h-screen"]}>
    <Header />
    <main class:list={["flex-1", fullHeight && "min-h-0 overflow-hidden"]}>
      <slot />
    </main>
    {!hideFooter && <div class="flex-shrink-0"><Footer /></div>}
  </body>
</html>
